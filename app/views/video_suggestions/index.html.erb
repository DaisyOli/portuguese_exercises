<% content_for :head do %>
  <title>Sugestões de Vídeo · Practice-BR</title>
  <style>
    .suggestion-card { transition: box-shadow 0.15s; }
    .suggestion-card:hover { box-shadow: 0 8px 28px rgba(15,56,38,0.13); }
    .pb-input:focus { border-color:#1A6B4A !important; box-shadow:0 0 0 3px rgba(26,107,74,0.1) !important; outline:none !important; }
    details[open] summary .chevron { transform: rotate(180deg); }
    .chevron { transition: transform 0.2s; display:inline-block; }
  </style>
<% end %>

<div style="max-width:860px; margin:1.5rem auto 3rem; padding:0 1.5rem;">

  <%# Cabeçalho %>
  <div style="display:flex; align-items:center; justify-content:space-between; gap:12px; margin-bottom:1.5rem; flex-wrap:wrap;">
    <div style="display:flex; align-items:center; gap:12px;">
      <%= link_to teachers_dashboard_path,
            style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:600; color:#5C5853; padding:7px 14px; border:1.5px solid #DDD9D2; border-radius:8px; text-decoration:none; background:#fff; white-space:nowrap;" do %>
        ← Dashboard
      <% end %>
      <span style="font-family:'Raleway',sans-serif; font-size:1.2rem; font-weight:700; color:#1C1917;">
        🎬 Sugestões de Vídeo
      </span>
    </div>
    <%= button_to generate_now_video_suggestions_path, method: :post,
          style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:700; color:#fff; background:#0F3826; padding:8px 18px; border-radius:10px; border:none; cursor:pointer; white-space:nowrap;" do %>
      ✨ Gerar novas sugestões
    <% end %>
  </div>

  <% if flash[:notice] %>
    <div style="background:#E8F5EE; border:1.5px solid #2A9B6F; border-radius:10px; padding:12px 16px; margin-bottom:18px; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; color:#0F3826;">
      <%= flash[:notice] %>
    </div>
  <% end %>
  <% if flash[:alert] %>
    <div style="background:#FEF2F2; border:1.5px solid #FCA5A5; border-radius:10px; padding:12px 16px; margin-bottom:18px; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; color:#991B1B;">
      <%= flash[:alert] %>
    </div>
  <% end %>

  <% if @suggestions.empty? %>
    <div style="background:#FAFAF9; border:1.5px dashed #DDD9D2; border-radius:16px; padding:48px 32px; text-align:center;">
      <div style="font-size:2.5rem; margin-bottom:12px;">🎬</div>
      <div style="font-family:'Raleway',sans-serif; font-size:1rem; font-weight:700; color:#1C1917; margin-bottom:6px;">
        Nenhuma sugestão pendente
      </div>
      <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; color:#9C9892; margin-bottom:20px; line-height:1.5;">
        Clique em "Gerar novas sugestões" para que a IA pesquise 3 vídeos para você.<br>
        O Heroku Scheduler também faz isso automaticamente todo dia às 7h.
      </div>
      <%= button_to generate_now_video_suggestions_path, method: :post,
            style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; font-weight:700; color:#fff; background:#1A6B4A; padding:12px 28px; border-radius:12px; border:none; cursor:pointer;" do %>
        ✨ Gerar agora
      <% end %>
    </div>

  <% else %>
    <div style="display:flex; flex-direction:column; gap:16px;">
      <% @suggestions.each do |s| %>
        <%= render 'video_suggestions/suggestion_card', suggestion: s %>
      <% end %>
    </div>
  <% end %>

</div>
