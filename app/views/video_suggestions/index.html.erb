<% content_for :head do %>
  <title>Sugestões de Vídeo · Practice-BR</title>
  <style>
    .suggestion-card { transition: box-shadow 0.15s; }
    .suggestion-card:hover { box-shadow: 0 6px 24px rgba(15,56,38,0.11); }
    .pb-input:focus { border-color:var(--brand) !important; box-shadow:0 0 0 3px var(--brand-veil-2) !important; outline:none !important; }
  </style>
<% end %>

<div style="max-width:860px; margin:1.5rem auto 3rem; padding:0 1.5rem;">

  <%# Cabeçalho %>
  <div style="display:flex; align-items:center; justify-content:space-between; gap:12px; margin-bottom:1.5rem; flex-wrap:wrap;">
    <div style="display:flex; align-items:center; gap:12px;">
      <%= link_to teacher_dashboard_path,
            style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:600; color:var(--ink-soft); padding:7px 14px; border:1.5px solid var(--line); border-radius:8px; text-decoration:none; background:var(--surface); white-space:nowrap;" do %>
        ← Dashboard
      <% end %>
      <span style="font-family:'Raleway',sans-serif; font-size:1.2rem; font-weight:700; color:var(--ink);">
        🎬 Sugestões de Vídeo
      </span>
    </div>
    <%= button_to generate_now_video_suggestions_path, method: :post,
          style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700; color:var(--surface); background:var(--brand-deep); padding:9px 20px; border-radius:10px; border:none; cursor:pointer; white-space:nowrap; display:inline-flex; align-items:center; gap:7px;" do %>
      ✨ Gerar novas sugestões
    <% end %>
  </div>

  <% if flash[:notice] %>
    <div style="background:var(--brand-tint); border:1.5px solid var(--brand-bright); border-radius:10px; padding:12px 16px; margin-bottom:18px; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; color:var(--brand-deep);">
      <%= flash[:notice] %>
    </div>
  <% end %>
  <% if flash[:alert] %>
    <div style="background:var(--error-tint); border:1.5px solid var(--error-border); border-radius:10px; padding:12px 16px; margin-bottom:18px; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; color:var(--error-deep);">
      <%= flash[:alert] %>
    </div>
  <% end %>

  <% if @suggestions.empty? %>
    <%# Estado vazio %>
    <div style="background:var(--surface); border:1px solid var(--line); border-radius:20px; padding:56px 32px; text-align:center;">
      <div style="width:64px; height:64px; background:var(--line-soft); border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 16px; font-size:1.8rem;">🎬</div>
      <div style="font-family:'Raleway',sans-serif; font-size:1.05rem; font-weight:700; color:var(--ink); margin-bottom:8px;">
        Nenhuma sugestão pendente
      </div>
      <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; color:var(--ink-faint); margin-bottom:24px; line-height:1.6; max-width:380px; margin-left:auto; margin-right:auto;">
        Clique em "Gerar novas sugestões" e a IA vai pesquisar 3 temas de vídeo para você praticar com seus alunos.
      </div>
      <%= button_to generate_now_video_suggestions_path, method: :post,
            style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; font-weight:700; color:var(--surface); background:var(--brand); padding:13px 32px; border-radius:12px; border:none; cursor:pointer;" do %>
        ✨ Gerar agora
      <% end %>
    </div>

  <% else %>
    <div style="display:flex; flex-direction:column; gap:14px;">
      <% @suggestions.each do |s| %>
        <%= render 'video_suggestions/suggestion_card', suggestion: s %>
      <% end %>
    </div>
  <% end %>

</div>
