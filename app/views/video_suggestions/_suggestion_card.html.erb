<div class="suggestion-card" style="background:#fff; border:1px solid #DDD9D2; border-radius:16px; overflow:hidden;">

  <%# Cabeçalho do card %>
  <div style="display:flex; gap:16px; padding:18px 20px; align-items:flex-start;">

    <%# Thumbnail %>
    <div style="flex-shrink:0; width:120px; height:68px; border-radius:8px; overflow:hidden; background:#F0EDE8;">
      <% if suggestion.thumbnail_url.present? %>
        <img src="<%= suggestion.thumbnail_url %>" alt="" style="width:100%; height:100%; object-fit:cover;">
      <% else %>
        <div style="width:100%; height:100%; display:flex; align-items:center; justify-content:center; font-size:1.8rem;">🎬</div>
      <% end %>
    </div>

    <%# Informações do vídeo %>
    <div style="flex:1; min-width:0;">
      <div style="display:flex; align-items:center; gap:8px; margin-bottom:5px; flex-wrap:wrap;">
        <% if suggestion.level_hint.present? %>
          <span style="font-family:'DM Mono',monospace; font-size:0.7rem; font-weight:700; background:#E8F5EE; color:#0F3826; border:1.5px solid #2A9B6F; border-radius:20px; padding:2px 10px;">
            <%= suggestion.level_hint %>
          </span>
        <% end %>
        <% if suggestion.channel_name.present? %>
          <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.72rem; color:#9C9892;">
            <%= suggestion.channel_name %>
          </span>
        <% end %>
      </div>

      <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.88rem; font-weight:600; color:#1C1917; line-height:1.4; margin-bottom:4px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
        <%= suggestion.title.present? ? suggestion.title : suggestion.topic %>
      </div>

      <% if suggestion.topic.present? %>
        <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; color:#5C5853; line-height:1.4;">
          Tema: <em><%= suggestion.topic %></em>
        </div>
      <% end %>
    </div>

    <%# Botão rejeitar (X) %>
    <%= button_to reject_video_suggestion_path(suggestion), method: :post,
          style: "flex-shrink:0; width:28px; height:28px; border-radius:50%; border:1.5px solid #FECACA; background:#FEF2F2; color:#B91C1C; font-size:0.8rem; font-weight:700; cursor:pointer; display:flex; align-items:center; justify-content:center; padding:0;",
          title: "Descartar" do %>
      ✕
    <% end %>
  </div>

  <%# Link pro YouTube %>
  <% if suggestion.youtube_url.present? %>
    <div style="padding:0 20px 12px;">
      <%= link_to suggestion.youtube_url, target: "_blank", rel: "noopener",
            style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; font-weight:600; color:#C9952A; display:inline-flex; align-items:center; gap:5px; text-decoration:none;" do %>
        <i class="bi bi-youtube"></i> Abrir no YouTube para copiar a transcrição ↗
      <% end %>
    </div>
  <% end %>

  <%# Formulário de transcrição + aprovar %>
  <details style="border-top:1px solid #F0EDE8;">
    <summary style="display:flex; align-items:center; gap:8px; padding:12px 20px; cursor:pointer; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.83rem; font-weight:600; color:#1A6B4A; list-style:none; user-select:none; background:#F7FDF9;">
      <i class="bi bi-clipboard-plus"></i>
      Cole a transcrição e gere a atividade
      <span class="chevron" style="margin-left:auto; font-size:0.75rem; color:#9C9892;">▼</span>
    </summary>
    <div style="padding:16px 20px 20px; background:#FAFAF9;">
      <%= form_with url: approve_video_suggestion_path(suggestion), method: :post, local: true do |f| %>
        <label style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:600; color:#44403C; display:block; margin-bottom:6px;">
          Transcrição do vídeo
          <span style="font-weight:400; color:#9C9892;">— YouTube: ⋮ → Abrir transcrição → selecionar tudo → copiar</span>
        </label>
        <%= text_area_tag :transcript, nil,
              class: "pb-input",
              rows: 8,
              placeholder: "Cole aqui a transcrição do vídeo...",
              spellcheck: "false",
              style: "width:100%; padding:12px 14px; border:1.5px solid #DDD9D2; border-radius:10px; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; color:#1C1917; background:#fff; resize:vertical; min-height:140px; box-sizing:border-box; line-height:1.6;" %>
        <div style="margin-top:10px; text-align:right;">
          <button type="submit"
                  style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; font-weight:700; color:#fff; background:#1A6B4A; padding:11px 28px; border-radius:10px; border:none; cursor:pointer; display:inline-flex; align-items:center; gap:8px;">
            ✨ Gerar atividade
          </button>
        </div>
      <% end %>
    </div>
  </details>

</div>
