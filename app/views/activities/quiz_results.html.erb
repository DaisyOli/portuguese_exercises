<% content_for :head do %>
  <title><%= @activity.title %> - Resultados - Practice PT</title>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Kalam:wght@400;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <%= render 'quiz_shared_styles' %>
  <style>
    .question-header {
      padding: 1rem 1.5rem;
      border-bottom: 1px solid rgba(0,0,0,0.08);
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-weight: 600;
    }

    .question-header.correct {
      background: linear-gradient(135deg, #e8f5e8, #f1f8e9);
      color: var(--verde-destaque);
      border-left: 4px solid var(--verde-destaque);
    }

    .question-header.incorrect {
      background: linear-gradient(135deg, #ffebee, #fce4ec);
      color: #c62828;
      border-left: 4px solid #ef5350;
    }

    .question-text {
      font-weight: 600;
    }

    .question-type {
      font-size: 0.85rem;
      color: #666;
      background: #f5f5f5;
      padding: 0.25rem 0.5rem;
      border-radius: 4px;
      display: inline-block;
      margin-bottom: 1rem;
    }

    .answer-section {
      margin-top: 1rem;
    }

    .answer-item {
      margin-bottom: 0.75rem;
      padding: 0.75rem;
      border-radius: 8px;
      font-weight: 500;
    }

    .your-answer {
      background: rgba(244, 67, 54, 0.1);
      border-left: 3px solid #f44336;
    }

    .your-answer.correct {
      background: rgba(76, 175, 80, 0.1);
      border-left: 3px solid #4caf50;
    }

    .correct-answer {
      background: rgba(76, 175, 80, 0.1);
      border-left: 3px solid #4caf50;
    }

    .answer-label {
      font-size: 0.85rem;
      font-weight: 600;
      color: #666;
      margin-bottom: 0.25rem;
    }

    .action-buttons {
      text-align: center;
      margin-top: 2rem;
      padding-top: 2rem;
      border-top: 1px solid #e0e0e0;
    }

    .btn-quiz-primary,
    .btn-quiz-secondary {
      margin: 0.5rem;
    }

    @media (max-width: 768px) {
      .score-cards { grid-template-columns: 1fr; }
      .btn-quiz-primary, .btn-quiz-secondary { margin: 0.5rem 0; }
    }
  </style>
<% end %>

  <div class="results-container">
    <!-- Header elegante -->
    <div class="results-header">
      <h1 class="results-title">
        <i class="fas fa-chart-line"></i>
        <%= t('quiz.results') %>
      </h1>
    </div>

    <!-- Folha principal -->
    <div class="results-paper">
      <!-- Seção de Score -->
      <div class="score-section">
        <h3 class="score-title">
          <i class="fas fa-trophy"></i>
          <%= t('quiz.final_score') %>
        </h3>
        
        <div class="score-cards">
          <div class="score-card">
            <div class="score-number" style="color: var(--azul-acao);"><%= @quiz_results["score"] %>%</div>
            <div class="score-label"><%= t('quiz.score') %></div>
          </div>
          <div class="score-card">
            <div class="score-number" style="color: var(--verde-destaque);"><%= @quiz_results["total_correct"] %></div>
            <div class="score-label"><%= t('activities.correct_answers') %></div>
          </div>
          <div class="score-card">
            <div class="score-number" style="color: var(--roxo-acao);"><%= @quiz_results["total_questions"] %></div>
            <div class="score-label"><%= t('activities.total_questions') %></div>
          </div>
        </div>
      </div>

      <!-- Questões detalhadas -->
      <% @quiz_results["results"].each_with_index do |(question_id, result), index| %>
        <div class="question-card">
          <div class="question-header <%= result["is_correct"] ? 'correct' : 'incorrect' %>">
            <i class="fas <%= result["is_correct"] ? 'fa-check-circle' : 'fa-times-circle' %>"></i>
            <span><%= t('questions.title') %> <%= index + 1 %></span>
          </div>

          <div class="question-body">
            <% if result["exercise_type"] == "column_matching" %>
              <div class="question-text">
                <i class="fas fa-columns" style="color: var(--verde-destaque); margin-right: 0.4rem;"></i>
                <%= t('column_matchings.result_label') %>
              </div>
              <div class="question-type"><%= result["title"] %></div>
              <div class="answer-section">
                <div class="answer-item your-answer <%= result["is_correct"] ? 'correct' : '' %>">
                  <div class="answer-label">
                    <i class="fas <%= result["is_correct"] ? 'fa-check' : 'fa-times' %>"></i>
                    <%= result["is_correct"] ? t('column_matchings.correct') : t('column_matchings.incorrect') %>
                  </div>
                </div>
                <% if !result["is_correct"] && result["correct_pairs"].present? %>
                  <div class="answer-item correct-answer">
                    <div class="answer-label">
                      <i class="fas fa-check"></i>
                      <%= t('quiz.correct_answer') %>:
                    </div>
                    <div style="margin-top: 0.5rem;">
                      <% result["correct_pairs"].each do |pair| %>
                        <div style="font-size: 0.9rem; margin-bottom: 0.25rem;">
                          <strong><%= pair[0] %></strong> ↔ <%= pair[1] %>
                        </div>
                      <% end %>
                    </div>
                  </div>
                <% end %>
              </div>
            <% elsif result["exercise_type"] == "sentence_ordering" || result["exercise_type"] == "paragraph_ordering" %>
              <% exercise_key = result["exercise_type"] %>
              <% icon = exercise_key == "sentence_ordering" ? "fa-sort-alpha-down" : "fa-list-ol" %>
              <div class="question-text">
                <i class="fas <%= icon %>" style="color: var(--verde-destaque); margin-right: 0.4rem;"></i>
                <%= t("#{exercise_key.pluralize}.result_label") %>
              </div>
              <div class="question-type">
                <%= result["sentence"] || result["title"] %>
              </div>
              <div class="answer-section">
                <div class="answer-item your-answer <%= result["is_correct"] ? 'correct' : '' %>">
                  <div class="answer-label">
                    <i class="fas <%= result["is_correct"] ? 'fa-check' : 'fa-times' %>"></i>
                    <%= result["is_correct"] ? t("#{exercise_key.pluralize}.correct") : t("#{exercise_key.pluralize}.incorrect") %>
                  </div>
                </div>
                <% if !result["is_correct"] && result["correct_order"].present? %>
                  <div class="answer-item correct-answer">
                    <div class="answer-label">
                      <i class="fas fa-check"></i>
                      <%= t('quiz.correct_answer') %>:
                    </div>
                    <ol style="margin: 0.5rem 0 0 1rem; padding: 0;">
                      <% result["correct_order"].each do |sentence| %>
                        <li style="margin-bottom: 0.3rem; font-size: 0.9rem;"><%= sentence %></li>
                      <% end %>
                    </ol>
                  </div>
                <% end %>
              </div>
            <% else %>
              <div class="question-text">
                <%= result["question_text"].present? ? result["question_text"] : "N/A" %>
              </div>

              <div class="question-type">
                <%= result["question_type"].present? ? t("questions.types.#{result["question_type"]}") : "N/A" %>
              </div>

              <div class="answer-section">
                <div class="answer-item your-answer <%= result["is_correct"] ? 'correct' : '' %>">
                  <div class="answer-label">
                    <i class="fas fa-user"></i>
                    <%= t('quiz.your_answer') %>:
                  </div>
                  <%= !result["given_answer"].present? || result["given_answer"] == t('quiz.not_answered') || result["given_answer"] == "Não respondida" ? t('quiz.not_answered') : result["given_answer"] %>
                </div>

                <% unless result["is_correct"] %>
                  <div class="answer-item correct-answer">
                    <div class="answer-label">
                      <i class="fas fa-check"></i>
                      <%= t('quiz.correct_answer') %>:
                    </div>
                    <%= result["correct_answer"].present? ? result["correct_answer"] : "N/A" %>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <!-- Botões de ação -->
      <div class="action-buttons">
        <%= link_to solve_activity_path(@activity), class: "btn-quiz-primary" do %>
          <i class="fas fa-refresh"></i>
          <%= t('quiz.try_again') %>
        <% end %>
        
        <% if current_user.teacher? %>
          <%= link_to teacher_dashboard_path, class: "btn-quiz-secondary" do %>
            <i class="fas fa-arrow-left"></i>
            <%= t('activities.back_to_dashboard') %>
          <% end %>
        <% else %>
          <%= link_to student_dashboard_path, class: "btn-quiz-secondary" do %>
            <i class="fas fa-graduation-cap"></i>
            Voltar ao Meu Painel
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

