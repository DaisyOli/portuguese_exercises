<% content_for :head do %>
  <title><%= @activity.title %> - <%= t('quiz.results') %> - Practice PT</title>
<% end %>

<% grading_pending = @quiz_attempt&.ai_grading_pending? %>
<div class="results-container"
     <% if grading_pending %>
       data-controller="grading-status"
       data-grading-status-url-value="<%= grading_status_activity_path(@activity) %>"
     <% end %>>
  <div class="results-header">
    <h1 class="results-title">
      <i class="bi bi-bar-chart-line"></i> <%= t('quiz.results') %>
    </h1>
    <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; color:rgba(255,255,255,0.7);">
      <%= @activity.title %>
    </span>
  </div>

  <div class="results-paper">
    <%# Score summary %>
    <div class="score-section">
      <h3 class="score-title">
        <i class="bi bi-trophy"></i>
        <%= t('quiz.final_score') %>
      </h3>

      <div class="score-cards">
        <div class="score-card">
          <div class="score-number" style="color:var(--info);"><%= @quiz_results["score"] %>%</div>
          <div class="score-label"><%= t('quiz.score') %></div>
        </div>
        <div class="score-card">
          <div class="score-number" style="color:var(--brand);"><%= @quiz_results["total_correct"] %></div>
          <div class="score-label"><%= t('activities.correct_answers') %></div>
        </div>
        <div class="score-card">
          <div class="score-number" style="color:var(--action);"><%= @quiz_results["total_questions"] %></div>
          <div class="score-label"><%= t('activities.total_questions') %></div>
        </div>
      </div>

      <% if grading_pending %>
        <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; color:var(--action); margin:10px 0 0; display:flex; align-items:center; gap:6px;">
          <i class="bi bi-stars"></i> <%= t('quiz.ai_grading_note') %>
        </p>
      <% end %>
    </div>

    <%# Detailed results per exercise %>
    <% @quiz_results["results"].each_with_index do |(question_id, result), index| %>
      <div class="question-card">
        <% if result["ai_pending"] %>
          <div class="question-header" style="background:var(--warning-tint); color:var(--action);">
            <i class="bi bi-hourglass-split"></i>
            <span><%= t('questions.title') %> <%= index + 1 %></span>
          </div>
        <% else %>
          <div class="question-header <%= result["is_correct"] ? 'correct' : 'incorrect' %>">
            <i class="bi bi-<%= result["is_correct"] ? 'check-circle' : 'x-circle' %>"></i>
            <span><%= t('questions.title') %> <%= index + 1 %></span>
          </div>
        <% end %>

        <div class="question-body">
          <% if result["exercise_type"] == "column_matching" %>
            <div class="question-text">
              <i class="bi bi-arrow-left-right" style="color:var(--brand); margin-right:6px;"></i>
              <%= t('column_matchings.result_label') %>
            </div>
            <% if result["title"].present? %>
              <span class="question-type-badge"><%= result["title"] %></span>
            <% end %>
            <div class="answer-section">
              <div class="answer-item your-answer <%= result["is_correct"] ? 'correct' : '' %>">
                <div class="answer-label">
                  <i class="bi bi-<%= result["is_correct"] ? 'check' : 'x' %>"></i>
                  <%= result["is_correct"] ? t('column_matchings.correct') : t('column_matchings.incorrect') %>
                </div>
              </div>
              <% if !result["is_correct"] && result["correct_pairs"].present? %>
                <div class="answer-item correct-answer">
                  <div class="answer-label">
                    <i class="bi bi-check"></i> <%= t('quiz.correct_answer') %>:
                  </div>
                  <div style="margin-top:6px;">
                    <% result["correct_pairs"].each do |pair| %>
                      <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.88rem; margin-bottom:3px;">
                        <strong><%= pair[0] %></strong> ↔ <%= pair[1] %>
                      </div>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>

          <% elsif result["exercise_type"] == "sentence_ordering" || result["exercise_type"] == "paragraph_ordering" %>
            <% exercise_key = result["exercise_type"] %>
            <% icon = exercise_key == "sentence_ordering" ? "sort-alpha-down" : "list-ol" %>
            <div class="question-text">
              <i class="bi bi-<%= icon %>" style="color:var(--brand); margin-right:6px;"></i>
              <%= t("#{exercise_key.pluralize}.result_label") %>
            </div>
            <% if (result["sentence"] || result["title"]).present? %>
              <span class="question-type-badge"><%= result["sentence"] || result["title"] %></span>
            <% end %>
            <div class="answer-section">
              <div class="answer-item your-answer <%= result["is_correct"] ? 'correct' : '' %>">
                <div class="answer-label">
                  <i class="bi bi-<%= result["is_correct"] ? 'check' : 'x' %>"></i>
                  <%= result["is_correct"] ? t("#{exercise_key.pluralize}.correct") : t("#{exercise_key.pluralize}.incorrect") %>
                </div>
              </div>
              <% if !result["is_correct"] && result["correct_order"].present? %>
                <div class="answer-item correct-answer">
                  <div class="answer-label">
                    <i class="bi bi-check"></i> <%= t('quiz.correct_answer') %>:
                  </div>
                  <ol style="margin:6px 0 0 1rem; padding:0;">
                    <% result["correct_order"].each do |sentence| %>
                      <li style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.88rem; margin-bottom:3px;"><%= sentence %></li>
                    <% end %>
                  </ol>
                </div>
              <% end %>
            </div>

          <% elsif result["question_type"] == "open_ended" %>
            <div class="question-text">
              <%= sanitize((result["question_text"].presence || "N/A").to_s, tags: %w[p br strong em u], attributes: []) %>
            </div>
            <span class="question-type-badge" style="color:var(--action); border-color:var(--warning-border); background:var(--warning-tint);">
              ✨ <%= t('questions.types.open_ended') %>
            </span>
            <div class="answer-section" style="margin-top:10px;">
              <div class="answer-item your-answer" style="background:var(--surface-2);">
                <div class="answer-label">
                  <i class="bi bi-person"></i> <%= t('quiz.your_answer') %>:
                </div>
                <%= result["given_answer"].presence || t('quiz.not_answered') %>
              </div>

              <% if result["ai_pending"] %>
                <div style="background:var(--warning-tint); border:1.5px dashed var(--warning-border); border-radius:10px; padding:14px 16px; margin-top:8px;">
                  <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; color:var(--action); margin:0; display:flex; align-items:center; gap:8px;">
                    <span class="loading loading-spinner" style="width:0.9rem; height:0.9rem;" aria-hidden="true"></span>
                    ✨ <%= t('quiz.ai_grading_pending') %>
                  </p>
                </div>
              <% elsif result["ai_unavailable"] %>
                <div style="background:var(--paper); border:1.5px solid var(--line); border-radius:10px; padding:14px 16px; margin-top:8px;">
                  <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; color:var(--ink-soft); margin:0; display:flex; align-items:center; gap:6px;">
                    <i class="bi bi-exclamation-circle" style="color:var(--action);"></i>
                    <%= result["ai_feedback"].presence || t('ai.errors.generic') %>
                  </p>
                </div>
              <% else %>
                <% ai_score = result["ai_score"].to_i %>
                <% score_color = ai_score >= 70 ? 'var(--brand)' : (ai_score >= 40 ? 'var(--action)' : 'var(--error)') %>
                <div style="background:var(--warning-tint); border:1.5px solid var(--warning-border); border-radius:10px; padding:14px 16px; margin-top:8px;">
                  <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:8px;">
                    <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; font-weight:700; color:var(--action); display:flex; align-items:center; gap:5px;">
                      ✨ <%= t('quiz.ai_feedback') %>
                    </span>
                    <span style="font-family:'DM Mono',monospace; font-size:0.9rem; font-weight:700; color:<%= score_color %>;">
                      <%= ai_score %>/100
                    </span>
                  </div>
                  <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.88rem; color:var(--ink); margin:0; line-height:1.55;">
                    <%= result["ai_feedback"].presence || t('ai.errors.generic') %>
                  </p>
                </div>
              <% end %>
            </div>

          <% elsif result["question_type"] == "fill_in_blank" && result["blank_results"].present? %>
            <%# fill_in_blank com múltiplas lacunas %>
            <div class="question-text">
              <%= sanitize((result["question_text"].presence || "N/A").to_s, tags: %w[p br strong em u], attributes: []) %>
            </div>
            <span class="question-type-badge"><%= t("questions.types.fill_in_blank") %></span>
            <div class="answer-section" style="margin-top:8px;">
              <% result["blank_results"].each_with_index do |br, i| %>
                <% ok = br["ok"] %>
                <div style="border:1px solid <%= ok ? 'var(--brand-bright)' : 'var(--error-border)' %>; border-radius:8px; padding:10px 14px; margin-bottom:8px; background:<%= ok ? 'var(--brand-mist)' : 'var(--error-tint)' %>;">
                  <div style="font-family:'DM Mono',monospace; font-size:0.65rem; color:<%= ok ? 'var(--brand)' : 'var(--error)' %>; letter-spacing:0.06em; text-transform:uppercase; margin-bottom:6px;">
                    <i class="bi bi-<%= ok ? 'check-circle' : 'x-circle' %>"></i>
                    Lacuna <%= i + 1 %>
                  </div>
                  <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.88rem; color:var(--ink); margin-bottom:<%= ok ? '0' : '4px' %>;">
                    <span style="color:var(--ink-faint); font-size:0.78rem;">Sua resposta: </span><strong><%= br["given"] %></strong>
                  </div>
                  <% unless ok %>
                    <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; color:var(--brand);">
                      <span style="color:var(--ink-faint); font-size:0.78rem;">Resposta correta: </span><strong><%= br["correct"] %></strong>
                    </div>
                  <% end %>
                </div>
              <% end %>
            </div>

          <% else %>
            <div class="question-text">
              <%= sanitize((result["question_text"].presence || "N/A").to_s, tags: %w[p br strong em u], attributes: []) %>
            </div>
            <% if result["question_type"].present? %>
              <span class="question-type-badge"><%= t("questions.types.#{result["question_type"]}", default: result["question_type"].humanize) %></span>
            <% end %>
            <%
              not_answered_values = I18n.available_locales.map { |l| I18n.t('quiz.not_answered', locale: l) }
              given = result["given_answer"]
              answered = given.present? && not_answered_values.exclude?(given)
            %>
            <div class="answer-section">
              <div class="answer-item your-answer <%= result["is_correct"] ? 'correct' : '' %>">
                <div class="answer-label">
                  <i class="bi bi-person"></i> <%= t('quiz.your_answer') %>:
                </div>
                <%= answered ? given : t('quiz.not_answered') %>
              </div>
              <% unless result["is_correct"] %>
                <div class="answer-item correct-answer">
                  <div class="answer-label">
                    <i class="bi bi-check"></i> <%= t('quiz.correct_answer') %>:
                  </div>
                  <%= result["correct_answer"].presence || "N/A" %>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# Action buttons %>
    <div style="margin-top:28px; padding-top:24px; border-top:1px solid var(--line);">
      <%= link_to solve_activity_path(@activity), class: "btn-quiz-primary" do %>
        <i class="bi bi-arrow-clockwise"></i> <%= t('quiz.try_again') %>
      <% end %>

      <% if current_user.teacher? %>
        <%= link_to teacher_dashboard_path, class: "btn-quiz-secondary" do %>
          <i class="bi bi-arrow-left"></i> <%= t('activities.back_to_dashboard') %>
        <% end %>
      <% else %>
        <% if current_user&.student? %>
          <button type="button"
                  onclick="(function(){ var o=document.getElementById('rating-modal-overlay'); if(o){ o.style.display='flex'; } else { window.location.href='<%= student_dashboard_path %>'; } })()"
                  class="btn-quiz-secondary" style="cursor:pointer;">
            <i class="bi bi-grid"></i> Voltar ao Meu Painel
          </button>
        <% else %>
          <%= link_to student_dashboard_path, class: "btn-quiz-secondary" do %>
            <i class="bi bi-grid"></i> Voltar ao Meu Painel
          <% end %>
        <% end %>
      <% end %>
    </div>
  </div>
</div>

<%# ── Modal de avaliação ── %>
<% if current_user&.student? %>
<div id="rating-modal-overlay"
     onclick="if(event.target===this) dismissRating()"
     style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.55); z-index:9999;
            align-items:center; justify-content:center; padding:16px;">
  <div style="background:var(--surface); border-radius:20px; padding:36px 32px; max-width:460px; width:100%;
              box-shadow:0 24px 60px rgba(0,0,0,0.22); position:relative;">

    <%# Sucesso (oculto inicialmente) %>
    <div id="rating-success" style="display:none; text-align:center; padding:16px 0;">
      <div style="font-size:3rem; margin-bottom:12px;">⭐</div>
      <div style="font-family:'Raleway',sans-serif; font-size:1.15rem; font-weight:700; color:var(--brand-deep); margin-bottom:6px;">
        Obrigada pela sua avaliação!
      </div>
      <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.88rem; color:var(--ink-soft);">
        Redirecionando para o painel…
      </div>
    </div>

    <%# Formulário de avaliação %>
    <div id="rating-modal-content">
      <div style="display:flex; align-items:flex-start; justify-content:space-between; margin-bottom:20px; gap:8px;">
        <div>
          <div style="font-family:'Raleway',sans-serif; font-size:1.1rem; font-weight:700; color:var(--ink); margin-bottom:4px;">
            ⭐ O que achou desta atividade?
          </div>
          <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; color:var(--ink-faint);">
            <em><%= @activity.title %></em>
          </div>
        </div>
        <button type="button" onclick="dismissRating()"
                title="Pular"
                style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.75rem; color:var(--ink-faint);
                       background:transparent; border:none; cursor:pointer; padding:4px; flex-shrink:0; margin-top:2px;">
          Pular
        </button>
      </div>

      <div id="modal-stars-container" style="display:flex; gap:8px; margin-bottom:20px; justify-content:center;">
        <% 5.times do |i| %>
          <i class="bi bi-<%= @existing_rating && i < @existing_rating.stars ? 'star-fill' : 'star' %>"
             data-value="<%= i + 1 %>"
             style="font-size:2.4rem; color:<%= @existing_rating && i < @existing_rating.stars ? 'var(--action)' : 'var(--line)' %>; cursor:pointer; transition:color 0.1s;"
             onmouseover="hoverStars(<%= i + 1 %>)"
             onmouseout="resetStars()"
             onclick="selectStar(<%= i + 1 %>)"></i>
        <% end %>
      </div>

      <textarea id="modal-rating-comment"
                maxlength="500"
                rows="3"
                placeholder="Comentário opcional (max. 500 caracteres)..."
                style="width:100%; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem;
                       padding:10px 13px; border:1.5px solid var(--line); border-radius:10px;
                       color:var(--ink); background:var(--surface-2); box-sizing:border-box; resize:vertical; margin-bottom:8px;"></textarea>

      <div id="modal-rating-feedback" style="display:none; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; color:var(--error); margin-bottom:10px;"></div>

      <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
        <button id="modal-submit-btn"
                type="button"
                onclick="submitRating('<%= @existing_rating ? activity_activity_rating_path(@activity, @existing_rating) : activity_activity_ratings_path(@activity) %>', '<%= @existing_rating ? 'PATCH' : 'POST' %>')"
                disabled
                style="flex:1; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; font-weight:700;
                       background:var(--brand); color:var(--surface); border:none; border-radius:10px;
                       padding:12px 20px; cursor:pointer; opacity:0.4; min-width:160px;">
          <%= @existing_rating ? "Atualizar avaliação" : "Enviar avaliação" %>
        </button>
        <button type="button" onclick="dismissRating()"
                style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; color:var(--ink-faint);
                       background:transparent; border:1.5px solid var(--line); border-radius:10px;
                       padding:11px 18px; cursor:pointer;">
          Pular →
        </button>
      </div>
    </div>

  </div>
</div>
<% end %>

<script>
  var selectedStars = <%= @existing_rating&.stars || 0 %>;
  var dashboardUrl  = '<%= student_dashboard_path %>';

  function openRatingModal() {
    var overlay = document.getElementById('rating-modal-overlay');
    if (overlay) { overlay.style.display = 'flex'; }
    else { window.location.href = dashboardUrl; }
  }

  function dismissRating() {
    window.location.href = dashboardUrl;
  }

  function hoverStars(n) {
    document.querySelectorAll('#modal-stars-container .bi').forEach(function(el, i) {
      el.className = 'bi bi-' + (i < n ? 'star-fill' : 'star');
      el.style.color = i < n ? 'var(--action)' : 'var(--line)';
    });
  }

  function resetStars() {
    document.querySelectorAll('#modal-stars-container .bi').forEach(function(el, i) {
      el.className = 'bi bi-' + (i < selectedStars ? 'star-fill' : 'star');
      el.style.color = i < selectedStars ? 'var(--action)' : 'var(--line)';
    });
  }

  function selectStar(n) {
    selectedStars = n;
    resetStars();
    var btn = document.getElementById('modal-submit-btn');
    btn.disabled = false;
    btn.style.opacity = '1';
  }

  function submitRating(url, method) {
    if (!selectedStars || selectedStars < 1) {
      var fb = document.getElementById('modal-rating-feedback');
      fb.textContent = 'Selecione pelo menos 1 estrela.';
      fb.style.display = 'block';
      return;
    }

    var btn = document.getElementById('modal-submit-btn');
    btn.disabled = true;
    btn.textContent = 'Enviando…';

    var comment = document.getElementById('modal-rating-comment').value;
    var tokenEl = document.querySelector('meta[name="csrf-token"]');
    var token   = tokenEl ? tokenEl.content : '';

    var fallback = setTimeout(function() { window.location.href = dashboardUrl; }, 8000);

    fetch(url, {
      method: method,
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': token },
      body: JSON.stringify({ activity_rating: { stars: selectedStars, comment: comment } })
    })
    .then(function(r) {
      clearTimeout(fallback);
      if (!r.ok) { window.location.href = dashboardUrl; return null; }
      return r.json();
    })
    .then(function(data) {
      if (!data) return;
      if (data.status === 'success') {
        document.getElementById('rating-modal-content').style.display = 'none';
        document.getElementById('rating-success').style.display = 'block';
        setTimeout(function() { window.location.href = dashboardUrl; }, 1600);
      } else {
        clearTimeout(fallback);
        window.location.href = dashboardUrl;
      }
    })
    .catch(function() {
      clearTimeout(fallback);
      window.location.href = dashboardUrl;
    });
  }

  <% if @existing_rating %>
    document.getElementById('modal-rating-comment').value = <%= @existing_rating.comment.to_json %>;
    document.getElementById('modal-submit-btn').disabled = false;
    document.getElementById('modal-submit-btn').style.opacity = '1';
  <% end %>
</script>
