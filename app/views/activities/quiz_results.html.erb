<div class="container d-flex justify-content-center align-items-center py-5">
  <div class="card shadow-lg p-4 w-100" style="max-width: 900px;">
    <div class="card-body">
      <h1 class="text-center mb-4"><%= t('quiz.results') %></h1>
      
      <!-- Script inline para garantir exibição dos resultados mesmo sem jQuery -->
      <script>
        console.log('Página de resultados do quiz carregada diretamente');
        // Verifica se temos os resultados
        <% if @quiz_results && @quiz_results["results"] %>
          console.log('Resultados disponíveis: <%= @quiz_results["total_correct"] %> de <%= @quiz_results["total_questions"] %>');
          
          // Debug adicional: mostrar resultados individuais
          <% @quiz_results["results"].each do |question_id, result| %>
            console.log('Questão <%= question_id %>:',
                        'Texto: <%= result["question_text"].to_s.gsub(/"/, '\"').truncate(30) if result["question_text"] %>',
                        'Tipo: <%= result["question_type"] %>',
                        'Resposta dada: <%= result["given_answer"].to_s.gsub(/"/, '\"').truncate(30) if result["given_answer"] %>',
                        'Resposta correta: <%= result["correct_answer"].to_s.gsub(/"/, '\"').truncate(30) if result["correct_answer"] %>',
                        'Correto: <%= result["is_correct"] %>');
            
            <% if result["question_type"] == "order_sentences" %>
              console.log('DIAGNÓSTICO ORDEM - Questão <%= question_id %>:',
                        'Texto completo da resposta: "<%= result["given_answer"] %>"',
                        'Contém separador |: <%= result["given_answer"].to_s.include?("|") %>',
                        'Começa com "Não respondida": <%= result["given_answer"].to_s.start_with?("Não respondida") %>');
            <% end %>
          <% end %>
        <% else %>
          console.error('Resultados não disponíveis ou formato incorreto');
        <% end %>
      </script>
      
      <div class="alert alert-info mb-4">
        <h4 class="alert-heading"><%= t('quiz.final_score') %></h4>
        <p class="mb-0"><%= t('quiz.correct_answers', correct: @quiz_results["total_correct"], total: @quiz_results["total_questions"], score: @quiz_results["score"]) %></p>
        <% if params[:raw_display] == "true" %>
          <div class="mt-2"><small><em>Exibindo dados brutos sem correções</em> - <a href="<%= quiz_results_activity_path(@activity) %>">Voltar ao modo normal</a></small></div>
        <% else %>
          <div class="mt-2"><small><a href="<%= quiz_results_activity_path(@activity, raw_display: true) %>">Visualizar dados originais</a></small></div>
        <% end %>
      </div>

      <% @quiz_results["results"].each do |question_id, result| %>
        <div class="card mb-4">
          <div class="card-header <%= result["is_correct"] ? 'bg-success text-white' : 'bg-danger text-white' %>">
            <h5 class="mb-0"><%= t('questions.title') %></h5>
          </div>
          <div class="card-body">
            <% if result["question_type"] != "order_sentences" %>
              <p class="card-text mb-3"><strong><%= t('questions.content') %>:</strong> <%= result["question_text"].present? ? result["question_text"] : "N/A" %></p>
            <% end %>
            <p class="card-text mb-3"><strong><%= t('questions.type') %>:</strong> <%= result["question_type"].present? ? t("questions.types.#{result["question_type"]}") : "N/A" %></p>
            
            <div class="mb-2">
              <strong><%= t('quiz.your_answer') %>:</strong>
              <span class="<%= result["is_correct"] ? 'text-success' : 'text-danger' %>">
                <%= !result["given_answer"].present? || result["given_answer"] == t('quiz.not_answered') || result["given_answer"] == "Não respondida" ? t('quiz.not_answered') : result["given_answer"] %>
              </span>
            </div>
            
            <% unless result["is_correct"] %>
              <div class="mt-2">
                <strong><%= t('quiz.correct_answer') %>:</strong>
                <span class="text-success"><%= result["correct_answer"].present? ? result["correct_answer"] : "N/A" %></span>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <div class="d-grid gap-2">
        <%= link_to t('quiz.try_again'), resolve_quiz_activity_path(@activity), class: "btn btn-primary" %>
        <% if current_user.teacher? %>
          <%= link_to t('activities.back_to_dashboard'), teacher_dashboard_path, class: "btn btn-secondary" %>
        <% else %>
          <%= link_to t('activities.back_to_activities'), activities_path, class: "btn btn-secondary" %>
        <% end %>
      </div>
    </div>
  </div>
</div>

<script>
  // Inicializar página sem tentar carregar jQuery novamente
  document.addEventListener('DOMContentLoaded', function() {
    console.log('Página de resultados inicializada');
    
    // Verifica se temos resultados
    <% if @debug_results_json.present? %>
      try {
        var resultsData = <%= raw @debug_results_json %>;
        console.log('Total de questões:', resultsData.total_questions);
        console.log('Acertos:', resultsData.total_correct);
        
        if (resultsData && resultsData.results) {
          console.log('Número de resultados:', Object.keys(resultsData.results).length);
          
          // Verificar detalhes de cada resultado
          Object.keys(resultsData.results).forEach(function(key) {
            var result = resultsData.results[key];
            console.log('Questão ' + key + ':', result.is_correct ? 'Correta' : 'Incorreta');
          });
        }
      } catch (e) {
        console.error('Erro ao processar dados:', e);
      }
    <% end %>
  });
</script>
