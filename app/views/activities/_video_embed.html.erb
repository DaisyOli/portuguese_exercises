<%# Renderiza player para YouTube, Vimeo ou arquivo de vídeo direto (.mp4/.webm/.ogg) %>
<%# Uso: render 'activities/video_embed', url: activity.video_url, link_label: "Assistir no YouTube" %>

<% embed_type = if url.match?(/youtube\.com|youtu\.be/) then :youtube
                elsif url.match?(/vimeo\.com/) then :vimeo
                elsif url.match?(/\.(mp4|webm|ogg)(\?.*)?$/i) then :direct
                end %>

<% if embed_type == :youtube %>
  <% yt_id = url.match(/(?:youtube\.com\/(?:[^\/]+\/.+\/|(?:v|e(?:mbed)?)\/|.*[?&]v=)|youtu\.be\/)([^"&?\/\s]{11})/)&.[](1) %>
  <% if yt_id %>
    <div style="position:relative; padding-bottom:56.25%; height:0; overflow:hidden; border-radius:10px;">
      <iframe src="https://www.youtube.com/embed/<%= yt_id %>"
              style="position:absolute; top:0; left:0; width:100%; height:100%; border:0;"
              allowfullscreen
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture">
      </iframe>
    </div>
    <% if defined?(link_label) && link_label.present? %>
      <div style="margin-top:8px; text-align:right;">
        <%= link_to url, target: "_blank", rel: "noopener noreferrer",
              style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; color:var(--action); text-decoration:none; display:inline-flex; align-items:center; gap:4px;" do %>
          <i class="bi bi-box-arrow-up-right"></i> <%= link_label %>
        <% end %>
      </div>
    <% end %>
  <% end %>

<% elsif embed_type == :vimeo %>
  <% vimeo_id = url.match(/vimeo\.com\/(?:video\/)?(\d+)/)&.[](1) %>
  <% if vimeo_id %>
    <div style="position:relative; padding-bottom:56.25%; height:0; overflow:hidden; border-radius:10px;">
      <iframe src="https://player.vimeo.com/video/<%= vimeo_id %>"
              style="position:absolute; top:0; left:0; width:100%; height:100%; border:0;"
              allowfullscreen
              allow="autoplay; fullscreen; picture-in-picture">
      </iframe>
    </div>
    <% if defined?(link_label) && link_label.present? %>
      <div style="margin-top:8px; text-align:right;">
        <%= link_to url, target: "_blank", rel: "noopener noreferrer",
              style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; color:var(--action); text-decoration:none; display:inline-flex; align-items:center; gap:4px;" do %>
          <i class="bi bi-box-arrow-up-right"></i> <%= link_label %>
        <% end %>
      </div>
    <% end %>
  <% end %>

<% elsif embed_type == :direct %>
  <video controls style="width:100%; max-height:320px; border-radius:10px; display:block;">
    <source src="<%= url %>">
  </video>

<% else %>
  <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.88rem; color:var(--ink-faint);">
    <%= t('activities.invalid_video_url') %>
  </p>
<% end %>
