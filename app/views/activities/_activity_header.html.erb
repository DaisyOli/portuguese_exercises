<%
  level_styles = {
    'A1' => { bg:'var(--brand-tint)', text:'var(--brand-deep)', border:'var(--brand-bright)' },
    'A2' => { bg:'var(--info-tint)', text:'var(--info-deep)', border:'var(--info)' },
    'B1' => { bg:'var(--violet-tint)', text:'var(--violet-deep)', border:'var(--violet)' },
    'B2' => { bg:'var(--warning-tint)', text:'var(--warning-ink)', border:'var(--warning)' },
    'C1' => { bg:'var(--neutral-tint)', text:'var(--ink)', border:'var(--neutral-ink)' },
  }
  ls = level_styles[activity.level] || { bg:'var(--neutral-tint)', text:'var(--ink)', border:'var(--ink-faint)' }
%>

<div style="border:1px solid var(--brand); border-radius:18px; margin-bottom:20px; overflow:hidden;">

  <%# Faixa verde escura — navegação + nível + ações %>
  <div style="background:var(--brand-deep); padding:14px 24px; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:10px;">

    <div style="display:flex; align-items:center; gap:12px;">
      <% if current_user.teacher? %>
        <%= link_to activities_path,
              style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.8rem; font-weight:600; color:rgba(255,255,255,0.65); text-decoration:none;" do %>
          ← Atividades
        <% end %>
      <% else %>
        <%= link_to student_dashboard_path,
              style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.8rem; font-weight:600; color:rgba(255,255,255,0.65); text-decoration:none;" do %>
          ← Voltar
        <% end %>
      <% end %>
      <span style="color:rgba(255,255,255,0.2);">|</span>
      <span style="font-family:'DM Mono',monospace; font-size:0.75rem; font-weight:700; padding:4px 12px; border-radius:20px; background:<%= ls[:bg] %>; color:<%= ls[:text] %>; border:1.5px solid <%= ls[:border] %>; white-space:nowrap;">
        <%= activity.level %>
      </span>
    </div>

    <% if current_user.teacher? && activity.teacher == current_user %>
      <div style="display:flex; gap:8px;">
        <%= link_to edit_activity_path(activity),
              style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; font-weight:600; color:rgba(255,255,255,0.85); padding:6px 12px; border:1.5px solid rgba(255,255,255,0.25); border-radius:7px; text-decoration:none; background:rgba(255,255,255,0.1);" do %>
          Editar
        <% end %>
        <%= link_to activity_path(activity),
              data: { turbo_method: :delete, turbo_confirm: t('activities.confirm_delete') },
              style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; font-weight:600; color:var(--error-border); padding:6px 12px; border:1.5px solid rgba(252,165,165,0.35); border-radius:7px; text-decoration:none; background:rgba(185,28,28,0.2);" do %>
          Excluir
        <% end %>
      </div>
    <% end %>
  </div>

  <%# Corpo branco — título + descrição + stats %>
  <div style="background:var(--surface); padding:22px 26px;">
    <div style="display:flex; align-items:flex-start; justify-content:space-between; gap:10px; margin-bottom:8px;">
      <h1 style="font-family:'Raleway',sans-serif; font-size:1.4rem; font-weight:700; color:var(--ink); margin:0; line-height:1.3;">
        <%= activity.title %>
      </h1>
      <% if current_user.teacher? && activity.ai_generated? %>
        <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.72rem; font-weight:600; background:var(--warning-tint); color:var(--action-ink); border:1.5px solid var(--action); border-radius:20px; padding:4px 10px; white-space:nowrap; flex-shrink:0;">
          ✨ Gerada com IA
        </span>
      <% end %>
    </div>
    <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; color:var(--ink-soft); margin:0; line-height:1.65;">
      <%= activity.description %>
    </p>

    <% q_count = activity.questions.count %>
    <% total_exercises = activity.sentence_orderings.count + activity.paragraph_orderings.count + activity.column_matchings.count %>
    <% if q_count > 0 || total_exercises > 0 %>
      <div style="display:flex; gap:18px; flex-wrap:wrap; margin-top:14px; padding-top:14px; border-top:1px solid var(--line-soft);">
        <% if q_count > 0 %>
          <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; color:var(--ink-faint); display:flex; align-items:center; gap:5px;">
            <i class="bi bi-check2-square"></i> <%= q_count %> <%= q_count == 1 ? 'questão' : 'questões' %>
          </span>
        <% end %>
        <% if total_exercises > 0 %>
          <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; color:var(--ink-faint); display:flex; align-items:center; gap:5px;">
            <i class="bi bi-puzzle"></i> <%= total_exercises %> <%= total_exercises == 1 ? 'exercício' : 'exercícios' %>
          </span>
        <% end %>
      </div>
    <% end %>
  </div>

</div>
