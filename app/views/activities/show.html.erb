<% content_for :head do %>
  <title><%= @activity.title %> · Practice-BR</title>
<% end %>

<div id="activity-show-root" data-user-id="<%= current_user.id %>" style="max-width:900px; margin:1.5rem auto 3rem; padding:0 1.5rem;">

  <% if @activity.ai_generated? && @activity.draft? && current_user.teacher? %>
    <div style="background:linear-gradient(135deg,var(--warning-tint) 0%,var(--action-tint) 100%); border:2px solid var(--action); border-radius:16px; padding:18px 22px; margin-bottom:20px; display:flex; align-items:center; justify-content:space-between; gap:16px; flex-wrap:wrap;">
      <div>
        <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.88rem; font-weight:700; color:var(--action-ink); margin-bottom:3px;">
          ✨ Rascunho gerado por IA — não visível para os alunos ainda
        </div>
        <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.8rem; color:var(--action-ink);">
          Adicione ou ajuste os exercícios abaixo, depois publique.
        </div>
      </div>
      <div style="display:flex; gap:10px; flex-shrink:0;">
        <%= link_to review_draft_activity_path(@activity),
              style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:600; color:var(--ink-soft); padding:8px 16px; border:1.5px solid var(--line); border-radius:10px; text-decoration:none; background:var(--surface); white-space:nowrap;" do %>
          Pré-visualizar
        <% end %>
        <%= button_to "✓ Publicar atividade", publish_draft_activity_path(@activity),
              method: :post,
              style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.88rem; font-weight:700; color:var(--surface); background:var(--brand); padding:8px 20px; border-radius:10px; border:none; cursor:pointer; white-space:nowrap;" %>
      </div>
    </div>
  <% end %>

  <%= render 'activity_header', activity: @activity %>

  <% if @activity.statement.present? %>
    <%= render 'text_content_section',
          activity:       @activity,
          section_id:     'statement',
          title:          t('activities.statement_label'),
          content:        @activity.statement,
          delete_path:    clear_content_activity_path(@activity, content: "statement"),
          delete_method:  :patch,
          delete_confirm: t('activities.confirm_delete_statement'),
          field_name:     :statement,
          field_label:    t('activities.statement_label') %>
  <% end %>

  <% if @activity.media_url.present? || @activity.video_url.present? || @activity.image_file.attached? || @activity.video_file.attached? %>
    <%= render 'media_section', activity: @activity %>
  <% end %>

  <% if @activity.audio_file.attached? %>
    <%= render 'audio_section', activity: @activity %>
  <% end %>

  <% if @activity.explanation_text.present? %>
    <%= render 'text_content_section',
          activity:               @activity,
          section_id:             'explanation',
          title:                  t('activities.explanation_text_label'),
          content:                @activity.explanation_text,
          delete_path:            clear_content_activity_path(@activity, content: "explanation"),
          delete_method:          :patch,
          delete_confirm:         t('activities.confirm_delete_explanation'),
          field_name:             :explanation_text,
          field_label:            t('activities.explanation_text_label'),
          show_transcript_toggle: true %>
  <% end %>

  <% if current_user.teacher? %>
    <%= render 'questions_list', activity: @activity %>
    <%= render 'sentence_orderings_list', activity: @activity %>
    <%= render 'paragraph_orderings_list', activity: @activity %>
    <%= render 'column_matchings_list', activity: @activity %>
    <% oe_questions = @activity.questions.where(question_type: 'open_ended').order(:created_at) %>
    <% if oe_questions.any? %>
      <div style="background:var(--action-tint); border:1px solid var(--action-soft); border-left:4px solid var(--action); border-radius:14px; margin-bottom:14px; overflow:hidden;">
        <div style="display:flex; align-items:center; padding:12px 18px; border-bottom:1px solid var(--action-soft); background:rgba(201,149,42,0.06);">
          <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.06em; color:var(--action-ink); display:flex; align-items:center; gap:6px;">
            ✨ Expressão escrita (<%= oe_questions.count %>)
          </span>
        </div>
        <div style="padding:14px 16px; display:flex; flex-direction:column; gap:10px;">
          <% oe_questions.each_with_index do |question, index| %>
            <%= render 'question_card', question: question, activity: @activity, index: index %>
          <% end %>
        </div>
      </div>
    <% end %>
    <%= render 'suggestions_list', activity: @activity %>
    <%= render 'add_content_section', activity: @activity %>
  <% end %>

  <%# ── Avaliações dos alunos (visível apenas para o professor dono) ── %>
  <% if current_user.teacher? && @activity.teacher == current_user %>
    <% ratings = @activity.activity_ratings.includes(:user).order(created_at: :desc) %>
    <% if ratings.any? %>
      <div style="background:var(--surface); border:1px solid var(--line); border-radius:16px; padding:24px 28px; margin-top:2rem;">
        <div style="display:flex; align-items:center; gap:12px; margin-bottom:1.25rem;">
          <h2 style="font-family:'Raleway',sans-serif; font-size:1rem; font-weight:700; color:var(--ink); margin:0;">
            Avaliações dos alunos
          </h2>
          <span style="font-family:'DM Mono',monospace; font-size:0.88rem; font-weight:800; color:var(--action);">
            ⭐ <%= @activity.average_rating %>
          </span>
          <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; color:var(--ink-faint);">
            <%= pluralize(ratings.size, 'avaliação', 'avaliações') %>
          </span>
        </div>

        <div style="display:flex; flex-direction:column; gap:10px;">
          <% ratings.each do |rating| %>
            <div style="border:1px solid var(--line-soft); border-radius:10px; padding:14px 16px;">
              <div style="display:flex; align-items:center; gap:10px; margin-bottom:<%= rating.comment.present? ? '8px' : '0' %>; flex-wrap:wrap;">
                <div style="width:28px; height:28px; border-radius:50%; background:var(--brand); display:flex; align-items:center; justify-content:center;
                            font-family:'Raleway',sans-serif; font-size:0.72rem; font-weight:800; color:var(--surface); flex-shrink:0;">
                  <%= rating.user.display_name[0].upcase %>
                </div>
                <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:600; color:var(--ink);">
                  <%= rating.user.display_name %>
                </span>
                <span style="font-size:0.9rem; letter-spacing:1px;">
                  <% 5.times do |i| %>
                    <i class="bi bi-star<%= i < rating.stars ? '-fill' : '' %>" style="color:var(--action); font-size:0.85rem;"></i>
                  <% end %>
                </span>
                <span style="font-family:'DM Mono',monospace; font-size:0.72rem; color:var(--ink-faint); margin-left:auto;">
                  <%= rating.created_at.strftime("%d/%m/%Y") %>
                </span>
              </div>
              <% if rating.comment.present? %>
                <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; color:var(--ink-soft); line-height:1.55; padding-left:38px;">
                  "<%= rating.comment %>"
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  <% end %>

  <div style="text-align:center; margin-top:2.5rem; padding-bottom:1rem;">
    <%= link_to solve_activity_path(@activity),
          id: "tour-resolve-quiz",
          style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:1rem; font-weight:700; color:var(--surface); background:var(--brand); padding:14px 40px; border-radius:14px; text-decoration:none; display:inline-block;" do %>
      <%= t('activities.solve_quiz') %> →
    <% end %>
  </div>

</div>

<script>
  (function() {
    var targetId = null;
    <% if params[:ultimo_id].present? %>
      targetId = 'question-<%= params[:ultimo_id] %>';
    <% elsif params[:ultimo_conteudo].present? %>
      <% if params[:ultimo_conteudo] == 'suggestion' %>
        targetId = '__suggestion_last__';
      <% else %>
        targetId = '<%= params[:ultimo_conteudo] %>';
      <% end %>
    <% end %>

    if (!targetId) return;

    function highlight(el) {
      el.style.transition = 'box-shadow 0.3s';
      el.style.boxShadow  = '0 0 0 3px rgba(201,149,42,0.35)';
      setTimeout(function() { el.style.boxShadow = ''; }, 2000);
    }

    function scrollOnce() {
      var el = targetId === '__suggestion_last__'
        ? document.querySelector('#suggestions-section .card:last-child')
        : document.getElementById(targetId);
      if (!el) return;
      el.scrollIntoView({ behavior: 'smooth', block: 'center' });
      highlight(el);
    }

    // Espera o layout estabilizar (Quill e outros scripts do card terminarem)
    setTimeout(scrollOnce, 300);
  })();
</script>
