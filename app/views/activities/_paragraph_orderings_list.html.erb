<% if activity.paragraph_orderings.any? %>
  <div class="sentence-orderings-section">
    <h4 class="section-heading">
      <i class="fas fa-list-ol"></i>
      <%= t('paragraph_orderings.title') %> (<%= activity.paragraph_orderings.count %>)
    </h4>

    <% activity.paragraph_orderings.order(:display_order, :created_at).each do |ordering| %>
      <div class="sentence-ordering-card" id="paragraph-ordering-<%= ordering.id %>">
        <div class="sentence-ordering-header">
          <span class="sentence-preview">
            <i class="fas fa-list-ol"></i>
            <%= ordering.title.presence || t('paragraph_orderings.title') %>
          </span>
          <span class="word-count"><%= ordering.paragraph_sentences_count %> <%= t('paragraph_orderings.sentence_label').downcase %>s</span>
        </div>

        <% if ordering.instruction.present? %>
          <p class="ordering-instruction"><em><%= ordering.instruction %></em></p>
        <% end %>

        <!-- Lista de frases existentes -->
        <% if ordering.paragraph_sentences.any? %>
          <ol class="sentences-preview-list">
            <% ordering.paragraph_sentences.order(:correct_position).each do |ps| %>
              <li>
                <%= ps.sentence %>
                <%= button_to activity_paragraph_ordering_paragraph_sentence_path(activity, ordering, ps),
                      method: :delete,
                      class: "btn-delete-small",
                      data: { turbo_confirm: "Remover esta frase?" } do %>
                  <i class="fas fa-times"></i>
                <% end %>
              </li>
            <% end %>
          </ol>
        <% else %>
          <p class="text-muted" style="font-size:0.85rem;"><%= t('paragraph_orderings.no_sentences') %></p>
        <% end %>

        <!-- Formulário para adicionar frase -->
        <div class="add-sentence-form mt-2">
          <%= form_with(model: [activity, ordering, ParagraphSentence.new], local: true) do |f| %>
            <div class="input-group input-group-sm">
              <%= f.text_field :sentence, class: "form-control",
                  placeholder: t('paragraph_orderings.sentence_placeholder') %>
              <%= f.submit t('paragraph_orderings.add_sentence'), class: "btn btn-outline-success btn-sm" %>
            </div>
          <% end %>
        </div>

        <div class="sentence-ordering-actions mt-2">
          <button type="button" class="btn-edit-small"
                  data-bs-toggle="collapse"
                  data-bs-target="#edit-paragraph-<%= ordering.id %>">
            <i class="fas fa-edit"></i> <%= t('common.edit') %>
          </button>

          <%= button_to activity_paragraph_ordering_path(activity, ordering),
                method: :delete,
                class: "btn-delete-small",
                data: { turbo_confirm: "Remover este exercício e todas as frases?" } do %>
            <i class="fas fa-trash"></i> <%= t('common.delete') %>
          <% end %>
        </div>

        <div class="collapse" id="edit-paragraph-<%= ordering.id %>">
          <div class="edit-form-body">
            <%= form_with(model: [activity, ordering], local: true) do |f| %>
              <div class="mb-2">
                <%= f.label :title, "Título (opcional)", class: "form-label" %>
                <%= f.text_field :title, class: "form-control form-control-sm" %>
              </div>
              <div class="mb-2">
                <%= f.label :instruction, "Instrução para o aluno (opcional)", class: "form-label" %>
                <%= f.text_field :instruction, class: "form-control form-control-sm" %>
              </div>
              <%= f.submit t('common.save'), class: "btn btn-primary btn-sm" %>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
