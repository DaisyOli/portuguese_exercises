<% if activity.media_url.present? %>
  <div id="media" style="background:var(--action-tint); border:1px solid var(--action-border); border-left:4px solid var(--action); border-radius:14px; margin-bottom:14px; overflow:hidden;">

    <div style="display:flex; align-items:center; justify-content:space-between; padding:12px 18px; border-bottom:1px solid var(--action-border); background:var(--action-veil);">
      <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.06em; color:var(--action);">
        <i class="bi bi-image" style="margin-right:5px;"></i><%= t('activities.image_label') %>
      </span>
      <% if current_user.teacher? && activity.teacher == current_user %>
        <div style="display:flex; gap:6px;">
          <button type="button"
                  data-controller="collapse" data-collapse-target-value="#edit-image-form" data-action="collapse#toggle"
                  style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.75rem; font-weight:600; color:var(--ink-soft); padding:5px 10px; border:1.5px solid var(--line); border-radius:7px; background:var(--surface); cursor:pointer;">
            Editar
          </button>
          <%= button_to clear_content_activity_path(activity, content: "media"),
              method: :post,
              data: { turbo_confirm: t('activities.confirm_delete_media') },
              style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.75rem; font-weight:600; color:var(--error); padding:5px 10px; border:1.5px solid var(--error-border); border-radius:7px; background:var(--error-tint); cursor:pointer;" do %>
            Remover
          <% end %>
        </div>
      <% end %>
    </div>

    <div style="padding:18px 20px; background:rgba(255,255,255,0.6);">
      <% if activity.media_url.match?(/youtube\.com|youtu\.be|vimeo\.com|\.(mp4|webm|ogg)(\?.*)?$/i) %>
        <%= render 'activities/video_embed', url: activity.media_url, link_label: t('activities.watch_link') %>
      <% else %>
        <img src="<%= activity.media_url %>"
             alt="<%= t('activities.image_label') %>"
             style="max-width:100%; border-radius:10px; display:block; margin:0 auto;">
      <% end %>
    </div>

    <% if current_user.teacher? && activity.teacher == current_user %>
      <div class="hidden" id="edit-image-form">
        <div style="padding:20px; border-top:1px solid var(--action-border); background:var(--surface-2);">
          <%= form_with(model: activity, local: true) do |f| %>
            <div class="mb-3">
              <%= f.label :media_url, t('activities.image_url_label'), class: "form-label" %>
              <%= f.text_field :media_url, class: "form-input", placeholder: t('activities.image_url_placeholder') %>
            </div>
            <div class="d-grid">
              <%= f.submit t('common.save'), class: "btn btn-primary" %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

  </div>
<% end %>

<% if activity.image_file.attached? %>
  <div id="image_file" style="background:var(--action-tint); border:1px solid var(--action-border); border-left:4px solid var(--action); border-radius:14px; margin-bottom:14px; overflow:hidden;">

    <div style="display:flex; align-items:center; justify-content:space-between; padding:12px 18px; border-bottom:1px solid var(--action-border); background:var(--action-veil);">
      <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.06em; color:var(--action);">
        <i class="bi bi-image" style="margin-right:5px;"></i><%= t('activities.image_label') %>
      </span>
      <% if current_user.teacher? && activity.teacher == current_user %>
        <div style="display:flex; gap:6px;">
          <button type="button"
                  data-controller="collapse" data-collapse-target-value="#edit-image-file-form" data-action="collapse#toggle"
                  style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.75rem; font-weight:600; color:var(--ink-soft); padding:5px 10px; border:1.5px solid var(--line); border-radius:7px; background:var(--surface); cursor:pointer;">
            <%= t('common.edit') %>
          </button>
          <%= button_to clear_content_activity_path(activity, content: "image_file"),
              method: :post,
              data: { turbo_confirm: t('activities.confirm_delete_image_file') },
              style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.75rem; font-weight:600; color:var(--error); padding:5px 10px; border:1.5px solid var(--error-border); border-radius:7px; background:var(--error-tint); cursor:pointer;" do %>
            <%= t('common.remove') %>
          <% end %>
        </div>
      <% end %>
    </div>

    <div style="padding:18px 20px; background:rgba(255,255,255,0.6); text-align:center;">
      <img src="<%= rails_blob_path(activity.image_file, disposition: 'inline') %>"
           alt="<%= t('activities.image_label') %>"
           style="width:100%; max-height:360px; border-radius:10px; display:block; object-fit:contain;">
    </div>

    <% if current_user.teacher? && activity.teacher == current_user %>
      <div class="hidden" id="edit-image-file-form">
        <div style="padding:16px 20px; border-top:1px solid var(--action-border); background:var(--surface-2);">

          <%# Mini-tab: URL | Do computador %>
          <div style="display:flex; gap:6px; margin-bottom:14px;">
            <button type="button" id="edit-img-tab-url"
                    onclick="document.getElementById('edit-img-section-url').style.display='block';
                             document.getElementById('edit-img-section-file').style.display='none';
                             this.style.background='var(--brand-deep)'; this.style.color='var(--surface)'; this.style.borderColor='var(--brand-deep)';
                             document.getElementById('edit-img-tab-file').style.background='var(--surface)';
                             document.getElementById('edit-img-tab-file').style.color='var(--ink-soft)'; document.getElementById('edit-img-tab-file').style.borderColor='var(--line)';"
                    style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; font-weight:600;
                           padding:5px 14px; border-radius:8px; border:1.5px solid var(--brand-deep);
                           background:var(--brand-deep); color:var(--surface); cursor:pointer;">
              <i class="bi bi-link-45deg"></i> URL
            </button>
            <button type="button" id="edit-img-tab-file"
                    onclick="document.getElementById('edit-img-section-url').style.display='none';
                             document.getElementById('edit-img-section-file').style.display='block';
                             this.style.background='var(--brand-deep)'; this.style.color='var(--surface)'; this.style.borderColor='var(--brand-deep)';
                             document.getElementById('edit-img-tab-url').style.background='var(--surface)';
                             document.getElementById('edit-img-tab-url').style.color='var(--ink-soft)'; document.getElementById('edit-img-tab-url').style.borderColor='var(--line)';"
                    style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; font-weight:600;
                           padding:5px 14px; border-radius:8px; border:1.5px solid var(--line);
                           background:var(--surface); color:var(--ink-soft); cursor:pointer;">
              <i class="bi bi-upload"></i> <%= t('activities.upload_from_computer') %>
            </button>
          </div>

          <%# Seção URL (visível por padrão) %>
          <div id="edit-img-section-url">
            <%= form_with(model: activity, local: true) do |f| %>
              <div style="margin-bottom:12px;">
                <%= f.label :media_url, t('activities.image_url_label'),
                      style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:600; color:var(--ink-soft); display:block; margin-bottom:6px;" %>
                <%= f.text_field :media_url,
                      placeholder: t('activities.image_url_placeholder'),
                      style: "display:block; width:100%; font-size:0.88rem; padding:9px 12px; border:1.5px solid var(--line); border-radius:8px; font-family:'Plus Jakarta Sans',sans-serif;" %>
              </div>
              <%= f.submit t('common.save'),
                    style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700; background:var(--brand); color:var(--surface); padding:9px 22px; border-radius:10px; border:none; cursor:pointer; width:100%;" %>
            <% end %>
          </div>

          <%# Seção Upload (oculta por padrão) %>
          <div id="edit-img-section-file" style="display:none;">
            <%= form_with(model: activity, local: true, multipart: true) do |f| %>
              <div style="margin-bottom:12px;">
                <%= f.label :image_file, t('activities.image_file_label'),
                      style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:600; color:var(--ink-soft); display:block; margin-bottom:6px;" %>
                <div style="display:flex; align-items:center; gap:10px;">
                  <%= f.file_field :image_file, accept: "image/*",
                        id: "img-file-input-edit",
                        style: "position:absolute; opacity:0; width:0.1px; height:0.1px;",
                        onchange: "document.getElementById('img-file-name-edit').textContent = this.files[0]?.name || #{t('activities.no_file_chosen').to_json}" %>
                  <label for="img-file-input-edit"
                         style="display:inline-flex; align-items:center; gap:6px; padding:8px 14px;
                                border:1.5px solid var(--line); border-radius:8px; cursor:pointer;
                                background:var(--surface); font-family:'Plus Jakarta Sans',sans-serif;
                                font-size:0.83rem; font-weight:600; color:var(--ink-soft); white-space:nowrap;">
                    <i class="bi bi-paperclip"></i> <%= t('activities.choose_file') %>
                  </label>
                  <span id="img-file-name-edit"
                        style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; color:var(--ink-faint); overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                    <%= t('activities.no_file_chosen') %>
                  </span>
                </div>
                <small style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; color:var(--ink-faint); margin-top:4px; display:block;">
                  <%= t('activities.image_file_hint') %>
                </small>
              </div>
              <%= f.submit t('common.save'),
                    style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700; background:var(--brand); color:var(--surface); padding:9px 22px; border-radius:10px; border:none; cursor:pointer; width:100%;" %>
            <% end %>
          </div>

        </div>
      </div>
    <% end %>

  </div>
<% end %>

<% if activity.video_url.present? %>
  <div id="video" style="background:var(--action-tint); border:1px solid var(--action-border); border-left:4px solid var(--action); border-radius:14px; margin-bottom:14px; overflow:hidden;">

    <div style="display:flex; align-items:center; justify-content:space-between; padding:12px 18px; border-bottom:1px solid var(--action-border); background:var(--action-veil);">
