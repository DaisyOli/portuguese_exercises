<% if activity.media_url.present? %>
  <div class="content-section" id="media">
    <div class="content-header">
      <span><i class="fas fa-image"></i> <%= t('activities.image_label') %></span>
      <% if current_user.teacher? && activity.teacher == current_user %>
        <div class="btn-group-custom">
          <button type="button" class="btn-icon edit"
                  data-bs-toggle="collapse"
                  data-bs-target="#edit-image-form">
            <i class="fas fa-edit"></i>
          </button>
          <%= button_to clear_media_activity_path(activity),
              method: :post,
              data: { turbo_confirm: t('activities.confirm_delete_media') },
              class: "btn-icon delete" do %>
            <i class="fas fa-trash"></i>
          <% end %>
        </div>
      <% end %>
    </div>

    <div class="content-body">
      <div class="media-container">
        <% if activity.media_url.include?('youtube.com') || activity.media_url.include?('youtu.be') %>
          <%# Backwards-compat: YouTube links stored in media_url still render as video %>
          <% youtube_id = activity.media_url.match(/(?:youtube\.com\/(?:[^\/]+\/.+\/|(?:v|e(?:mbed)?)\/|.*[?&]v=)|youtu\.be\/)([^"&?\/\s]{11})/) %>
          <% if youtube_id && youtube_id[1] %>
            <div class="ratio ratio-16x9 mb-3">
              <iframe
                src="https://www.youtube.com/embed/<%= youtube_id[1] %>"
                allowfullscreen
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture">
              </iframe>
            </div>
          <% end %>
        <% else %>
          <img src="<%= activity.media_url %>" alt="<%= t('activities.image_label') %>" class="img-fluid mb-3" style="border-radius: 8px;">
        <% end %>
      </div>
    </div>

    <% if current_user.teacher? && activity.teacher == current_user %>
      <div class="collapse form-collapse" id="edit-image-form">
        <div class="card-body">
          <%= form_with(model: activity, local: true) do |f| %>
            <div class="mb-3">
              <%= f.label :media_url, t('activities.image_url_label'), class: "form-label" %>
              <%= f.text_field :media_url, class: "form-control",
                  placeholder: t('activities.image_url_placeholder') %>
            </div>
            <div class="d-grid">
              <%= f.submit t('common.save'), class: "btn btn-primary" %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% end %>

<% if activity.video_url.present? %>
  <div class="content-section" id="video">
    <div class="content-header">
      <span><i class="fab fa-youtube"></i> <%= t('activities.video_label') %></span>
      <% if current_user.teacher? && activity.teacher == current_user %>
        <div class="btn-group-custom">
          <button type="button" class="btn-icon edit"
                  data-bs-toggle="collapse"
                  data-bs-target="#edit-video-form">
            <i class="fas fa-edit"></i>
          </button>
          <%= button_to clear_video_activity_path(activity),
              method: :post,
              data: { turbo_confirm: t('activities.confirm_delete_video') },
              class: "btn-icon delete" do %>
            <i class="fas fa-trash"></i>
          <% end %>
        </div>
      <% end %>
    </div>

    <div class="content-body">
      <% youtube_id = activity.video_url.match(/(?:youtube\.com\/(?:[^\/]+\/.+\/|(?:v|e(?:mbed)?)\/|.*[?&]v=)|youtu\.be\/)([^"&?\/\s]{11})/) %>
      <% if youtube_id && youtube_id[1] %>
        <div class="ratio ratio-16x9">
          <iframe
            src="https://www.youtube.com/embed/<%= youtube_id[1] %>"
            allowfullscreen
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture">
          </iframe>
        </div>
      <% else %>
        <p class="text-muted"><%= t('activities.invalid_video_url') %></p>
      <% end %>
    </div>

    <% if current_user.teacher? && activity.teacher == current_user %>
      <div class="collapse form-collapse" id="edit-video-form">
        <div class="card-body">
          <%= form_with(model: activity, local: true) do |f| %>
            <div class="mb-3">
              <%= f.label :video_url, t('activities.video_url_label'), class: "form-label" %>
              <%= f.text_field :video_url, class: "form-control",
                  placeholder: t('activities.video_url_placeholder') %>
            </div>
            <div class="d-grid">
              <%= f.submit t('common.save'), class: "btn btn-primary" %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
