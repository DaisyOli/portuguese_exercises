<% content_for :head do %>
  <title><%= @activity.title %> - Practice PT</title>
  <style>
    input[type="radio"].mc-radio:focus,
    input[type="radio"].mc-radio:focus-visible,
    input[type="radio"].mc-radio:active {
      outline: none !important;
      box-shadow: none !important;
    }
  </style>
<% end %>

<%
  regular_questions    = @questions.reject(&:open_ended?)
  open_ended_questions = @questions.select(&:open_ended?)

  total_exercises = @questions.size +
                    @activity.sentence_orderings.size +
                    @activity.paragraph_orderings.size +
                    @activity.column_matchings.size

  has_material = @activity.statement.present? ||
                 @activity.media_url.present? ||
                 @activity.video_url.present? ||
                 @activity.explanation_text.present? ||
                 @activity.audio_file.attached? ||
                 @activity.image_file.attached? ||
                 @activity.video_file.attached?
%>

<div class="quiz-outer<%= ' quiz-outer--results' if @show_score %>">

  <div class="quiz-page-header">
    <h1 class="quiz-title"><%= @activity.title %></h1>
    <% if @activity.level.present? %>
      <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.75rem; font-weight:700; background:var(--brand-tint); color:var(--brand); padding:3px 12px; border-radius:20px; letter-spacing:0.05em;">
        <%= @activity.level %>
      </span>
    <% end %>
  </div>

  <% if @show_score %>
    <%
      score_pct = @score.to_i
      score_msg = if score_pct >= 80
        t('quiz.score_excellent', default: 'Excelente trabalho! 🌟')
      elsif score_pct >= 60
        t('quiz.score_good', default: 'Muito bem! Continue praticando.')
      else
        t('quiz.score_keep_going', default: 'Continue assim — cada tentativa é um aprendizado!')
      end
    %>
    <style>.btn-completion-gold:hover{background:var(--brand) !important;}</style>
    <div style="width:100%; display:flex; justify-content:center; padding:2rem 1rem 1rem;">
      <div style="width:100%; max-width:440px; border-radius:20px; overflow:hidden; box-shadow:0 8px 32px rgba(15,56,38,0.16);">

        <div style="background:var(--brand-deep); padding:28px 24px 22px; text-align:center;">
          <div style="display:inline-flex; align-items:center; justify-content:center; width:52px; height:52px; background:rgba(201,149,42,0.18); border-radius:50%; margin-bottom:12px;">
            <i class="bi bi-trophy-fill" style="font-size:1.5rem; color:var(--action);"></i>
          </div>
          <h3 style="font-family:'Raleway',sans-serif; font-size:1.35rem; font-weight:800; color:var(--surface); margin:0 0 6px; letter-spacing:-0.01em;">
            <%= t('quiz.completed') %>
          </h3>
          <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; color:rgba(255,255,255,0.55); margin:0; letter-spacing:0.02em;">
            <%= @activity.title %>
          </p>
        </div>

        <div style="background:var(--surface); padding:28px 24px 24px; text-align:center;">

          <div style="display:inline-flex; flex-direction:column; align-items:center; justify-content:center; width:130px; height:130px; border-radius:50%; background:var(--paper); border:4px solid var(--action); margin-bottom:8px;">
            <span style="font-family:'Raleway',sans-serif; font-size:2.2rem; font-weight:800; color:var(--brand-deep); line-height:1;"><%= @score %>%</span>
            <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.58rem; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:var(--ink-faint); margin-top:3px;"><%= t('quiz.score') %></span>
          </div>

          <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; color:var(--ink-soft); margin:12px 0 20px; line-height:1.5;">
            <%= score_msg %>
          </p>

          <div style="background:var(--line); border-radius:999px; height:7px; margin-bottom:20px; overflow:hidden;">
            <div style="background:linear-gradient(90deg,var(--brand),var(--brand-bright)); height:100%; width:<%= score_pct %>%; border-radius:999px;"></div>
          </div>

          <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-bottom:24px;">
            <div style="background:var(--brand-mist); border:1px solid var(--success-border); border-radius:12px; padding:16px 8px;">
              <div style="font-family:'DM Mono',monospace; font-size:1.6rem; font-weight:700; color:var(--brand); line-height:1;"><%= @total_correct %></div>
              <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.62rem; font-weight:700; text-transform:uppercase; letter-spacing:0.06em; color:var(--brand); margin-top:5px; opacity:0.75;"><%= t('activities.correct_answers') %></div>
            </div>
            <div style="background:var(--paper); border:1px solid var(--line); border-radius:12px; padding:16px 8px;">
              <div style="font-family:'DM Mono',monospace; font-size:1.6rem; font-weight:700; color:var(--ink-soft); line-height:1;"><%= @total_questions %></div>
              <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.62rem; font-weight:700; text-transform:uppercase; letter-spacing:0.06em; color:var(--ink-faint); margin-top:5px;"><%= t('activities.total_questions') %></div>
            </div>
          </div>

          <%= link_to results_activity_path(@activity), class: "btn-quiz-primary btn-completion-gold", style: "background:var(--brand-bright);" do %>
            <i class="bi bi-clipboard-check"></i> <%= t('quiz.see_detailed_results') %>
          <% end %>
          <%= link_to solve_activity_path(@activity), class: "btn-quiz-secondary" do %>
            <i class="bi bi-arrow-clockwise"></i> <%= t('quiz.try_again') %>
          <% end %>

        </div>
      </div>
    </div>

  <% else %>

    <%# Capture the form so it can be placed in either layout (two-col or single-col) %>
    <% exercise_index = 0 %>
    <% form_html = capture do %>
      <%= form_with(url: submit_activity_path(@activity), method: :post,
          class: "quiz-exercise-form",
          data: {
            turbo: false,
            controller: "quiz-loading toast",
            action: "submit->quiz-loading#submit"
          }) do |f| %>

        <%= hidden_field_tag :started_at, '', id: 'started_at_field' %>

        <%# Progress: counter + thin bar — wrapped para sticky no mobile %>
        <div class="quiz-progress-header">
          <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:6px;">
            <span style="font-family:'DM Mono',monospace; font-weight:700; font-size:0.72rem; color:var(--ink-faint);"
                  data-quiz-progress-target="counter">1 de <%= total_exercises %></span>
          </div>
          <div class="quiz-progress-bar-track" style="margin-bottom:0;">
            <div class="quiz-progress-bar-fill"
                 data-quiz-progress-target="bar"
                 style="width:<%= total_exercises > 0 ? (100.0 / total_exercises).round : 100 %>%;"></div>
          </div>
        </div>

        <%# All exercise cards stacked — height fixed to tallest card (no layout shift) %>
        <div class="quiz-questions-stack">

        <%# Questions (multiple choice + fill in blank) — open_ended rendered after all other types %>
        <% regular_questions.each_with_index do |question, index| %>
          <div data-quiz-progress-target="question"
               style="<%= exercise_index == 0 ? '' : 'display:none;' %>">
              <% cache [question, index, I18n.locale] do %>
                <div class="question-card">
                  <div class="question-header">
                    <span style="font-family:'DM Mono',monospace; font-weight:700; font-size:0.75rem; color:var(--ink-faint);"><%= "%02d" % (index + 1) %></span>
                    <% if question.fill_in_blank? %>
                      <span style="font-size:0.72rem; font-weight:600; color:var(--ink-faint); font-family:'Plus Jakarta Sans',sans-serif;">
                        <i class="bi bi-input-cursor-text"></i> <%= t('questions.types.fill_in_blank') %>
                      </span>
                    <% elsif question.multiple_choice? %>
                      <span style="font-size:0.72rem; font-weight:600; color:var(--ink-faint); font-family:'Plus Jakarta Sans',sans-serif;">
                        <i class="bi bi-list-ul"></i> <%= t('questions.types.multiple_choice') %>
                      </span>
                    <% end %>
                  </div>
                  <div class="question-body">
                    <div class="question-text">
                      <% if question.fill_in_blank? %>
                        <% safe_c = sanitize(question.content.to_s, tags: %w[p br strong em u], attributes: []) %>
                        <% fib_idx = 0 %>
                        <%= safe_c.gsub('_____') {
                              field = text_field_tag("answers[#{question.id}][#{fib_idx}]", nil,
                                class: "fib-input",
                                style: "display:inline-block; width:105px; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; padding:2px 8px; border:1.5px solid var(--brand-bright); border-radius:7px; color:var(--ink); background:var(--brand-mist); box-shadow:0 1px 6px var(--brand-glow); margin:1px 3px; vertical-align:middle; outline:none; line-height:1.4;",
                                autocomplete: "off",
                                autocapitalize: "none",
                                autocorrect: "off",
                                spellcheck: "false",
                                inputmode: "text")
                              fib_idx += 1
                              field
                            }.html_safe %>
                      <% else %>
                        <%= sanitize(question.content.to_s, tags: %w[p br strong em u], attributes: []) %>
                      <% end %>
                    </div>

                    <% if question.multiple_choice? && question.options.any? %>
                      <div style="display:flex; flex-direction:column; gap:8px; margin-top:4px;">
                        <% question.options.each do |option| %>
                          <label class="mc-option-label" style="display:flex; align-items:center; gap:10px; padding:10px 14px; border:1.5px solid var(--line); border-radius:8px; cursor:pointer; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.92rem; color:var(--ink); transition:border-color 0.15s, background 0.15s;">
                            <%= radio_button_tag "answers[#{question.id}]", option, false,
                                  class: "mc-radio",
                                  style: "width:20px; height:20px; accent-color:var(--brand); flex-shrink:0; cursor:pointer; outline:none;" %>
                            <%= option %>
                          </label>
                        <% end %>
                      </div>
                    <% end %>
                  </div>
                </div>
              <% end %>
          </div>
          <% exercise_index += 1 %>
        <% end %>

        <%# Sentence ordering exercises %>
        <% @activity.sentence_orderings.order(:display_order, :created_at).each_with_index do |ordering, index| %>
          <div data-quiz-progress-target="question"
               style="<%= exercise_index == 0 ? '' : 'display:none;' %>">
            <div class="question-card sentence-ordering-exercise" data-controller="sentence-ordering">
              <div class="question-header">
                <span style="font-family:'DM Mono',monospace; font-weight:700; font-size:0.75rem; color:var(--ink-faint);"><%= "%02d" % (index + 1) %></span>
                <span style="font-size:0.72rem; font-weight:600; color:var(--ink-faint); font-family:'Plus Jakarta Sans',sans-serif;">
                  <i class="bi bi-sort-alpha-down"></i> <%= t('sentence_orderings.title') %>
                </span>
              </div>
              <div class="question-body">
                <p class="ordering-instruction-text">
                  <%= ordering.instruction.present? ? ordering.instruction : t('sentence_orderings.instruction_default') %>
                </p>
                <div class="word-zones-container">
                  <% ordering.shuffled_words.each_with_index do |word, i| %>
                    <div class="word-drop-zone" data-sentence-ordering-target="zone">
                      <span class="slot-number"><%= i + 1 %></span>
                      <span class="draggable-word"
                            data-sentence-ordering-target="word"
                            data-word-id="<%= word.id %>">
                        <%= word.word %>
                      </span>
                    </div>
                  <% end %>
                </div>
                <input type="hidden"
                       name="sentence_ordering_answers[<%= ordering.id %>]"
                       data-sentence-ordering-target="input"
                       value="<%= ordering.shuffled_words.map(&:id).join(',') %>">
              </div>
            </div>
          </div>
          <% exercise_index += 1 %>
        <% end %>

        <%# Paragraph ordering exercises %>
        <% @activity.paragraph_orderings.order(:display_order, :created_at).each_with_index do |ordering, index| %>
          <div data-quiz-progress-target="question"
               style="<%= exercise_index == 0 ? '' : 'display:none;' %>">
            <div class="question-card" data-controller="paragraph-ordering">
              <div class="question-header">
                <span style="font-family:'DM Mono',monospace; font-weight:700; font-size:0.75rem; color:var(--ink-faint);"><%= "%02d" % (index + 1) %></span>
                <span style="font-size:0.72rem; font-weight:600; color:var(--ink-faint); font-family:'Plus Jakarta Sans',sans-serif;">
                  <i class="bi bi-list-ol"></i> <%= t('paragraph_orderings.title') %>
                </span>
                <% if ordering.title.present? %>
                  <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; font-weight:400; color:var(--ink-faint);">— <%= ordering.title %></span>
                <% end %>
              </div>
              <div class="question-body">
                <p class="ordering-instruction-text">
                  <%= ordering.instruction.present? ? ordering.instruction : t('paragraph_orderings.instruction_default') %>
                </p>
                <div class="sentence-zones-container">
                  <% ordering.shuffled_sentences.each_with_index do |ps, i| %>
                    <div class="sentence-drop-zone" data-paragraph-ordering-target="zone">
                      <span class="slot-number"><%= i + 1 %></span>
                      <div class="draggable-sentence"
                           data-paragraph-ordering-target="sentence"
                           data-sentence-id="<%= ps.id %>">
                        <%= ps.sentence %>
                      </div>
                    </div>
                  <% end %>
                </div>
                <input type="hidden"
                       name="paragraph_ordering_answers[<%= ordering.id %>]"
                       data-paragraph-ordering-target="input"
                       value="<%= ordering.shuffled_sentences.map(&:id).join(',') %>">
              </div>
            </div>
          </div>
          <% exercise_index += 1 %>
        <% end %>

        <%# Column matching exercises %>
        <% @activity.column_matchings.order(:display_order, :created_at).each_with_index do |matching, index| %>
          <div data-quiz-progress-target="question"
               style="<%= exercise_index == 0 ? '' : 'display:none;' %>">
            <div class="question-card column-matching-exercise" data-controller="column-matching">
              <div class="question-header">
                <span style="font-family:'DM Mono',monospace; font-weight:700; font-size:0.75rem; color:var(--ink-faint);"><%= "%02d" % (index + 1) %></span>
                <span style="font-size:0.72rem; font-weight:600; color:var(--ink-faint); font-family:'Plus Jakarta Sans',sans-serif;">
                  <i class="bi bi-arrow-left-right"></i> <%= t('column_matchings.title') %>
                </span>
                <% if matching.title.present? %>
                  <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; font-weight:400; color:var(--ink-faint);">— <%= matching.title %></span>
                <% end %>
              </div>
              <div class="question-body">
                <p class="ordering-instruction-text">
                  <%= t('column_matchings.instruction_default') %>
                </p>
                <div class="matching-grid">
                  <div class="matching-column">
                    <% matching.matching_pairs.order(:position).each do |pair| %>
                      <div class="matching-item left-item"
                           data-column-matching-target="leftItem"
                           data-pair-id="<%= pair.id %>"
                           data-action="click->column-matching#selectLeft">
                        <%= pair.left_item %>
                      </div>
                    <% end %>
                  </div>
                  <div class="matching-column">
                    <% matching.shuffled_pairs.each do |pair| %>
                      <div class="matching-item right-item"
                           data-column-matching-target="rightItem"
                           data-pair-id="<%= pair.id %>"
                           data-action="click->column-matching#selectRight">
                        <%= pair.right_item %>
                      </div>
                    <% end %>
                  </div>
                </div>

                <input type="hidden"
                       name="column_matching_answers[<%= matching.id %>]"
                       data-column-matching-target="input"
                       value="">
              </div>
            </div>
          </div>
          <% exercise_index += 1 %>
        <% end %>

        <%# Open-ended writing exercises — always rendered last %>
        <% open_ended_questions.each_with_index do |question, index| %>
          <div data-quiz-progress-target="question"
               style="<%= exercise_index == 0 ? '' : 'display:none;' %>">
            <div class="question-card">
              <div class="question-header">
                <span style="font-family:'DM Mono',monospace; font-weight:700; font-size:0.75rem; color:var(--ink-faint);"><%= "%02d" % (index + 1) %></span>
                <span style="font-size:0.72rem; font-weight:600; color:var(--action); font-family:'Plus Jakarta Sans',sans-serif;">
                  ✨ <%= t('questions.types.open_ended') %>
                </span>
              </div>
              <div class="question-body">
                <div class="question-text">
                  <%= sanitize(question.content.to_s, tags: %w[p br strong em u], attributes: []) %>
                </div>

                <%# Textarea de resposta %>
                <%= text_area_tag "answers[#{question.id}]", nil,
                      id: "open-answer-#{question.id}",
                      rows: 5,
                      placeholder: t('quiz.open_answer_placeholder'),
                      style: "width:100%; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.92rem; padding:10px 12px; border:2px solid var(--line); border-radius:8px; color:var(--ink); background:var(--surface); resize:vertical; box-sizing:border-box; margin-top:8px;",
                      autocorrect: "off",
                      spellcheck: "false" %>

                <%# Botão de gravação de áudio %>
                <div id="audio-recorder-<%= question.id %>" style="margin-top:10px;">
                  <button type="button"
                          onclick="startRecording('<%= question.id %>', '<%= transcribe_activity_path(@activity, locale: I18n.locale) %>')"
                          id="btn-record-<%= question.id %>"
                          style="display:inline-flex; align-items:center; gap:7px; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:600; color:var(--brand); background:var(--brand-tint); border:1.5px solid var(--brand-bright); border-radius:9px; padding:8px 16px; cursor:pointer;">
                    🎙️ Responder por áudio
                  </button>
                  <button type="button"
                          onclick="stopRecording('<%= question.id %>')"
                          id="btn-stop-<%= question.id %>"
                          style="display:none; align-items:center; gap:7px; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:600; color:var(--surface); background:var(--error); border:none; border-radius:9px; padding:8px 16px; cursor:pointer;">
                    ⏹ Parar gravação
                  </button>
                  <span id="rec-timer-<%= question.id %>"
                        style="display:none; font-family:'DM Mono',monospace; font-size:0.78rem; color:var(--error); margin-left:8px; vertical-align:middle;">
                    ● 0:00
                  </span>

                  <%# Estado: transcrevendo %>
                  <div id="rec-loading-<%= question.id %>" style="display:none; margin-top:10px; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; color:var(--ink-soft);">
                    <span style="display:inline-flex; align-items:center; gap:6px;">
                      <span style="width:14px; height:14px; border:2px solid var(--line); border-top-color:var(--brand); border-radius:50%; display:inline-block; animation:spin 0.8s linear infinite;"></span>
                      Transcrevendo seu áudio...
                    </span>
                  </div>

                  <%# Preview da transcrição %>
                  <div id="rec-preview-<%= question.id %>" style="display:none; margin-top:10px; background:var(--success-tint); border:1.5px solid var(--success-border); border-radius:10px; padding:12px 14px;">
                    <div style="font-family:'DM Mono',monospace; font-size:0.65rem; color:var(--success); text-transform:uppercase; letter-spacing:0.06em; margin-bottom:6px;">Você disse:</div>
                    <div id="rec-text-<%= question.id %>" style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.88rem; color:var(--ink); line-height:1.5;"></div>
                    <div style="display:flex; gap:8px; margin-top:10px;">
                      <button type="button"
                              onclick="acceptTranscription('<%= question.id %>')"
                              style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.8rem; font-weight:700; color:var(--surface); background:var(--brand); border:none; border-radius:8px; padding:7px 16px; cursor:pointer;">
                        ✓ Usar esta resposta
                      </button>
                      <button type="button"
                              onclick="reRecord('<%= question.id %>')"
                              style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.8rem; font-weight:600; color:var(--ink-soft); background:var(--line-soft); border:none; border-radius:8px; padding:7px 14px; cursor:pointer;">
                        🔄 Regravar
                      </button>
                    </div>
                  </div>

                  <%# Erro %>
                  <div id="rec-error-<%= question.id %>" style="display:none; margin-top:8px; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.8rem; color:var(--error);"></div>
                </div>

                <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.75rem; color:var(--action); margin-top:8px;">
                  ✨ <%= t('quiz.evaluated_by_ai') %>
                </p>
              </div>
            </div>
          </div>
          <% exercise_index += 1 %>
        <% end %>

        </div><%# /quiz-questions-stack %>

        <%# Loading indicator %>
        <div class="loading-section" style="display:none;" data-quiz-loading-target="indicator">
          <div class="loading-spinner"></div>
          <span>Avaliando suas respostas...</span>
        </div>

        <%# Navigation: Voltar (1ª questão) / Anterior / Próxima / Enviar %>
        <div class="quiz-nav-row">
          <%# Back link — shown only on first exercise %>
          <% back_path = current_user.teacher? ? activities_path : student_dashboard_path %>
          <%= link_to back_path,
                data: { "quiz-progress-target": "backBtn" },
                style: "flex:1; display:flex; align-items:center; justify-content:center; gap:5px; padding:7px 12px; background:var(--surface); border:1.5px solid var(--line); border-radius:9px; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.8rem; font-weight:600; color:var(--ink-soft); text-decoration:none;" do %>
            <i class="bi bi-arrow-left"></i> <%= t('quiz.back') %>
          <% end %>

          <%# Previous button — shown from 2nd exercise onward %>
          <button type="button"
                  data-quiz-progress-target="prevBtn"
                  data-action="click->quiz-progress#previous"
                  style="flex:1; display:none; align-items:center; justify-content:center; gap:5px; padding:7px 12px; background:var(--surface); border:1.5px solid var(--line); border-radius:9px; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.8rem; font-weight:600; color:var(--ink-soft); cursor:pointer;">
            <i class="bi bi-arrow-left"></i> <%= t('quiz.previous') %>
          </button>

          <%# Next button — hidden on last exercise %>
          <button type="button"
                  data-quiz-progress-target="nextBtn"
                  data-action="click->quiz-progress#next"
                  style="flex:2; display:<%= total_exercises > 1 ? 'flex' : 'none' %>; align-items:center; justify-content:center; gap:5px; padding:7px 12px; background:var(--brand); border:none; border-radius:9px; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.8rem; font-weight:700; color:var(--surface); cursor:pointer;">
            <%= t('quiz.next') %> <i class="bi bi-arrow-right"></i>
          </button>

          <%# Submit button — shown only on last exercise, replaces Próxima %>
          <%= f.submit t('quiz.submit'),
                data: {
                  "quiz-progress-target": "submitBtn",
                  "quiz-loading-target": "submit",
                  disable_with: t('quiz.submitting')
                },
                style: "flex:2; display:#{total_exercises <= 1 ? 'block' : 'none'}; text-align:center; padding:7px 12px; background:var(--brand); border:none; border-radius:9px; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.8rem; font-weight:700; color:var(--surface); cursor:pointer;" %>
        </div>

      <% end %>
    <% end %>

    <%# quiz-progress controller wraps material panel + form so it can reach all targets %>
    <div data-controller="quiz-progress"
         data-quiz-progress-total-value="<%= total_exercises %>"
         style="flex:1; min-height:0; display:flex; flex-direction:column; width:100%; max-width:1100px; overflow:hidden;">

      <% if has_material %>
        <button type="button"
                class="quiz-mobile-toggle"
                data-quiz-progress-target="materialToggle"
                data-action="click->quiz-progress#toggleMaterial"
                data-text-show="<%= t('quiz.see_material') %>"
                data-text-hide="<%= t('quiz.hide_material', default: 'Ocultar material de apoio') %>">
          <i class="bi bi-book"></i> <%= t('quiz.see_material') %>
          <i class="bi bi-chevron-down" style="margin-left:auto;"></i>
        </button>

        <div class="quiz-two-col">

          <%# Left column: material (sticky) %>
          <div class="quiz-material-col" data-quiz-progress-target="materialPanel">
            <% cache [@activity, @activity.suggestions.cache_key_with_version, "quiz_material", I18n.locale] do %>

              <% if @activity.statement.present? %>
                <div class="quiz-statement-block">
                  <%= simple_format(@activity.statement) %>
                </div>
              <% end %>

              <% if @activity.media_url.present? %>
                <% if @activity.media_url.match?(/youtube\.com|youtu\.be|vimeo\.com|\.(mp4|webm|ogg)(\?.*)?$/i) %>
                  <%= render 'activities/video_embed', url: @activity.media_url %>
                <% else %>
                  <div style="text-align:center;">
                    <img src="<%= @activity.media_url %>" alt="<%= t('activities.image_label') %>"
                         style="max-width:100%; border-radius:8px; display:inline-block;">
                  </div>
                <% end %>
              <% end %>

              <% if @activity.image_file.attached? %>
                <div style="text-align:center; margin-bottom:1rem;">
                  <img src="<%= rails_blob_path(@activity.image_file, disposition: 'inline') %>"
                       alt="<%= t('activities.image_label') %>"
                       style="width:100%; max-height:320px; border-radius:8px; display:block; object-fit:contain;">
                </div>
              <% end %>

              <% if @activity.video_file.attached? %>
                <div style="margin-bottom:1rem;">
                  <video controls style="width:100%; max-height:280px; border-radius:8px; display:block;">
                    <source src="<%= rails_blob_path(@activity.video_file, disposition: 'inline') %>">
                  </video>
                </div>
              <% end %>

              <% if @activity.video_url.present? %>
                <%= render 'activities/video_embed', url: @activity.video_url %>
              <% end %>

              <% if @activity.explanation_text.present? %>
                <% explanation_html = @activity.explanation_text.include?('<') ? sanitize(@activity.explanation_text, tags: %w[p br strong em u ol ul li], attributes: []) : simple_format(@activity.explanation_text) %>
                <% if @activity.explanation_is_transcript? %>
                  <details style="border:1px solid var(--line); border-radius:10px; overflow:hidden; margin-bottom:4px;">
                    <summary style="display:flex; align-items:center; gap:8px; padding:10px 14px; cursor:pointer; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:600; color:var(--ink-soft); background:var(--surface-2); list-style:none; user-select:none;">
                      <span style="font-size:1rem;">📄</span>
                      <%= t('quiz.see_transcript', default: 'Ver transcrição') %>
                      <span style="margin-left:auto; font-size:0.75rem; color:var(--ink-faint);">▼</span>
                    </summary>
                    <div class="quiz-statement-block" style="border-top:1px solid var(--line); border-radius:0;">
                      <%= explanation_html %>
                    </div>
                  </details>
                <% else %>
                  <div class="quiz-statement-block">
                    <%= explanation_html %>
                  </div>
                <% end %>
              <% end %>

              <% if @activity.audio_file.attached? %>
                <div style="margin-bottom:1rem;">
                  <div style="font-family:'DM Mono',monospace; font-size:0.7rem; font-weight:700;
                              text-transform:uppercase; letter-spacing:0.06em; color:var(--action); margin-bottom:8px;">
                    <i class="bi bi-music-note-beamed"></i> <%= t('activities.audio_label') %>
                  </div>
                  <audio controls style="width:100%;">
                    <source src="<%= rails_blob_path(@activity.audio_file, disposition: 'inline') %>">
                  </audio>
                </div>
              <% end %>

              <% @activity.suggestions.each do |suggestion| %>
                <div class="quiz-suggestion-block">
                  <span class="dica-label"><i class="bi bi-lightbulb-fill"></i> <%= t('quiz.tip') %></span>
                  <% if suggestion.content.to_s.strip.start_with?('<') %>
                    <%= sanitize(suggestion.content, tags: %w[p br strong em u], attributes: []) %>
                  <% else %>
                    <%= simple_format(suggestion.content) %>
                  <% end %>
                </div>
              <% end %>

            <% end %>
          </div>

          <%# Right column: exercises %>
          <div class="quiz-exercise-col">
            <%= form_html %>
          </div>

        </div>

      <% else %>
        <%# No material: single-column layout %>
        <div class="quiz-paper" style="max-width:720px; display:flex; flex-direction:column; flex:1; min-height:0;">
          <%= form_html %>
        </div>
      <% end %>

    </div>

  <% end %>

<script>
(function() {
  function stampStart() {
    var f = document.getElementById('started_at_field');
    if (f && !f.value) f.value = new Date().toISOString();
  }
  document.addEventListener('DOMContentLoaded', stampStart);
  document.addEventListener('turbo:load', stampStart);
})();

// ── Gravação de áudio para questões abertas ──
var _mediaRecorder = null;
var _audioChunks   = [];
var _timerInterval = null;
var _timerSeconds  = 0;

function startRecording(qId, transcribeUrl) {
  if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
    showRecError(qId, 'Seu navegador não suporta gravação de áudio.');
    return;
  }
  navigator.mediaDevices.getUserMedia({ audio: true }).then(function(stream) {
    _audioChunks = [];
    _timerSeconds = 0;

    var mimeType = MediaRecorder.isTypeSupported('audio/webm') ? 'audio/webm' : 'audio/mp4';
    _mediaRecorder = new MediaRecorder(stream, { mimeType: mimeType });

    _mediaRecorder.ondataavailable = function(e) {
      if (e.data.size > 0) _audioChunks.push(e.data);
    };

    _mediaRecorder.onstop = function() {
      stream.getTracks().forEach(function(t) { t.stop(); });
      var blob = new Blob(_audioChunks, { type: mimeType });
      sendAudio(qId, blob, transcribeUrl, mimeType);
    };

    _mediaRecorder.start();

    // UI: mostra botão parar + timer
    document.getElementById('btn-record-' + qId).style.display = 'none';
    var stopBtn = document.getElementById('btn-stop-' + qId);
    stopBtn.style.display = 'inline-flex';
    var timer = document.getElementById('rec-timer-' + qId);
    timer.style.display = 'inline';
    hideRecPreview(qId);
    hideRecError(qId);

    _timerInterval = setInterval(function() {
      _timerSeconds++;
      var m = Math.floor(_timerSeconds / 60);
      var s = _timerSeconds % 60;
      timer.textContent = '● ' + m + ':' + (s < 10 ? '0' : '') + s;
      if (_timerSeconds >= 120) stopRecording(qId); // limite de 2 min
    }, 1000);

  }).catch(function(err) {
    showRecError(qId, 'Não foi possível acessar o microfone. Verifique as permissões do navegador.');
  });
}

function stopRecording(qId) {
  clearInterval(_timerInterval);
  document.getElementById('btn-stop-' + qId).style.display = 'none';
  document.getElementById('rec-timer-' + qId).style.display = 'none';
  document.getElementById('btn-record-' + qId).style.display = 'none';
  document.getElementById('rec-loading-' + qId).style.display = 'block';
  if (_mediaRecorder && _mediaRecorder.state !== 'inactive') _mediaRecorder.stop();
}

function sendAudio(qId, blob, url, mimeType) {
  var ext  = mimeType.includes('webm') ? 'webm' : 'm4a';
  var form = new FormData();
  form.append('audio', blob, 'recording.' + ext);
  form.append('authenticity_token', document.querySelector('meta[name="csrf-token"]').content);

  fetch(url, { method: 'POST', body: form })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      document.getElementById('rec-loading-' + qId).style.display = 'none';
      if (data.text) {
        document.getElementById('rec-text-' + qId).textContent = data.text;
        document.getElementById('rec-preview-' + qId).style.display = 'block';
      } else {
        showRecError(qId, data.error || 'Erro ao transcrever.');
        document.getElementById('btn-record-' + qId).style.display = 'inline-flex';
      }
    })
    .catch(function() {
      document.getElementById('rec-loading-' + qId).style.display = 'none';
      showRecError(qId, 'Erro de conexão. Tente digitar sua resposta.');
      document.getElementById('btn-record-' + qId).style.display = 'inline-flex';
    });
}

function acceptTranscription(qId) {
  var text = document.getElementById('rec-text-' + qId).textContent;
  document.getElementById('open-answer-' + qId).value = text;
  hideRecPreview(qId);
  document.getElementById('btn-record-' + qId).style.display = 'inline-flex';
}

function reRecord(qId) {
  hideRecPreview(qId);
  document.getElementById('btn-record-' + qId).style.display = 'inline-flex';
}

function hideRecPreview(qId) {
  document.getElementById('rec-preview-' + qId).style.display = 'none';
}

function showRecError(qId, msg) {
  var el = document.getElementById('rec-error-' + qId);
  el.textContent = msg;
  el.style.display = 'block';
}

function hideRecError(qId) {
  document.getElementById('rec-error-' + qId).style.display = 'none';
}
</script>

</div>
