<div class="container d-flex justify-content-center align-items-center flex-column" style="min-height: 100vh;">
  <% if params[:use_alternative] == "true" %>
  <div class="alert alert-info w-100 text-center" role="alert" style="max-width: 900px; margin-bottom: 20px;">
    <strong>MODO DE TESTE:</strong> Usando implementação alternativa com select boxes
    <a href="<%= resolve_quiz_activity_path(@activity, locale: params[:locale]) %>" class="btn btn-sm btn-outline-primary ms-3">Voltar para versão padrão</a>
  </div>
  <% end %>
  <div class="card shadow-lg p-4 w-100" style="max-width: 900px;">
    <div class="card-body">
      <h1 class="text-center mb-4"><%= t('quiz.title') %> <%= @activity.title %></h1>
      
      <% cache [@activity, "header", I18n.locale] do %>
        <div class="mb-4">
          <p><strong><%= t('activities.description') %>:</strong> <%= @activity.description %></p>
          <p><strong><%= t('activities.level') %>:</strong> <span class="badge bg-info"><%= @activity.level %></span></p>
          
          <% if @activity.statement.present? %>
            <div class="card bg-light mb-3">
              <div class="card-body">
                <%= simple_format(@activity.statement) %>
              </div>
            </div>
          <% end %>
        </div>
        
        <!-- Exibição da mídia -->
        <% if @activity.media_url.present? %>
          <div class="mb-4">
            <% if @activity.media_url.include?('youtube.com') || @activity.media_url.include?('youtu.be') %>
              <% youtube_id = @activity.media_url.match(/(?:youtube\.com\/(?:[^\/]+\/.+\/|(?:v|e(?:mbed)?)\/|.*[?&]v=)|youtu\.be\/)([^"&?\/\s]{11})/) %>
              <% if youtube_id && youtube_id[1] %>
                <div style="max-width: 560px; margin: 0 auto;">
                  <div class="ratio ratio-16x9 mb-3">
                    <iframe 
                      src="https://www.youtube.com/embed/<%= youtube_id[1] %>" 
                      allowfullscreen
                      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture">
                    </iframe>
                  </div>
                </div>
              <% end %>
            <% else %>
              <img src="<%= @activity.media_url %>" alt="Imagem da atividade" class="img-fluid mb-3">
            <% end %>
          </div>
        <% end %>

        <!-- Exibição do texto explicativo -->
        <% if @activity.explanation_text.present? %>
          <div class="mb-4">
            <div class="card">
              <div class="card-body">
                <%= simple_format(@activity.explanation_text) %>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
      
      <%= form_with(url: submit_quiz_activity_path(@activity), method: :post, data: { turbo: false }) do |f| %>
        <% @questions.each_with_index do |question, index| %>
          <% cache [question, index, I18n.locale] do %>
            <div class="card mb-3">
              <div class="card-body py-3">
                <h6 class="card-subtitle text-muted mb-2"><%= t('questions.title') %> <%= index + 1 %></h6>
                <p class="card-text mb-3 fs-5">
                  <% if question.fill_in_blank? %>
                    <%= question.content.gsub('_____', text_field_tag("answers[#{question.id}]", nil, class: 'form-control d-inline-block', style: 'width: 150px;')).html_safe %>
                  <% else %>
                    <%= question.content %>
                  <% end %>
                </p>

                <% if question.multiple_choice? && question.options.any? %>
                  <div class="options-list">
                    <div class="ps-2">
                      <% question.options.each do |option| %>
                        <div class="form-check mb-2">
                          <%= radio_button_tag "answers[#{question.id}]", option, false, class: 'form-check-input' %>
                          <%= label_tag "answers_#{question.id}_#{option.parameterize}", option, class: 'form-check-label' %>
                        </div>
                      <% end %>
                    </div>
                  </div>
                <% end %>

                <% if question.order_sentences? && question.options.any? %>
                  <div class="order-sentences-container mb-4">
                    <p class="mb-3 text-muted"><i class="fas fa-info-circle me-2"></i><%= t('questions.order_sentences_instruction', default: 'Selecione a ordem correta das frases:') %></p>
                    
                    <%= hidden_field_tag "answers[#{question.id}]", '', class: 'order-sentences-answer', id: "order_sentences_answer_#{question.id}" %>
                    
                    <div class="list-group">
                      <% question.options.each_with_index do |sentence, i| %>
                        <div class="list-group-item border-0 shadow-sm mb-2 bg-white">
                          <div class="d-flex align-items-center">
                            <div class="me-3">
                              <select class="form-select order-select" 
                                      data-sentence="<%= sentence %>" 
                                      data-question-id="<%= question.id %>"
                                      style="width: 70px;">
                                <% question.options.size.times do |j| %>
                                  <option value="<%= j+1 %>"><%= j+1 %></option>
                                <% end %>
                              </select>
                            </div>
                            <div class="flex-grow-1"><%= sentence %></div>
                          </div>
                        </div>
                      <% end %>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        <% end %>

        <div class="d-grid gap-2">
          <%= f.submit t('quiz.submit'), class: "btn btn-primary btn-lg mb-3", data: { disable_with: t('quiz.submitting') } %>
          <%= link_to t('activities.back_to_activities'), activities_path, class: "btn btn-secondary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- Script para implementação com select boxes -->
<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Função para atualizar o input escondido quando os selects mudam
    function updateOrderInput(questionId) {
      const selects = document.querySelectorAll(`.order-select[data-question-id="${questionId}"]`);
      const input = document.getElementById(`order_sentences_answer_${questionId}`);
      
      if (!input || selects.length === 0) return;
      
      // Criar array para armazenar frases na ordem selecionada
      const orderedSentences = new Array(selects.length);
      
      // Preencher o array baseado na ordem selecionada
      selects.forEach(select => {
        const position = parseInt(select.value) - 1;
        const sentence = select.dataset.sentence;
        orderedSentences[position] = sentence;
      });
      
      // Remover possíveis undefined (caso haja duplicatas na ordem)
      const cleanedSentences = orderedSentences.filter(s => s !== undefined);
      
      // Atualizar o campo escondido
      input.value = cleanedSentences.join('|');
      
      // Debug
      console.log(`Ordem atualizada para questão ${questionId}:`, input.value);
      
      return cleanedSentences.length === selects.length; // Retorna true se não houver duplicatas
    }
    
    // Inicializar os selects com valores diferentes e evitar duplicatas
    const questionsIds = [...new Set([...document.querySelectorAll('.order-select')].map(s => s.dataset.questionId))];
    
    questionsIds.forEach(qId => {
      const selects = document.querySelectorAll(`.order-select[data-question-id="${qId}"]`);
      
      // Atribuir valores iniciais diferentes para cada select
      selects.forEach((select, index) => {
        select.value = index + 1;
        
        // Adicionar evento de mudança
        select.addEventListener('change', function() {
          // Detectar duplicatas e corrigir
          const allSelects = [...document.querySelectorAll(`.order-select[data-question-id="${qId}"]`)];
          const selectedValues = allSelects.map(s => s.value);
          
          // Verificar se há outro select com o mesmo valor
          const duplicates = allSelects.filter(s => s !== this && s.value === this.value);
          
          if (duplicates.length > 0) {
            // Trocar o valor do outro select para o valor que este tinha antes
            const oldPositions = allSelects.map((s, i) => ({ select: s, oldPos: i + 1 }));
            const myOldPos = oldPositions.find(item => item.select === this)?.oldPos;
            
            if (myOldPos) {
              duplicates[0].value = myOldPos;
            }
          }
          
          // Atualizar o input escondido
          updateOrderInput(qId);
        });
      });
      
      // Atualizar o input inicial
      updateOrderInput(qId);
    });
    
    // Adicionar evento ao formulário para garantir que os dados estão atualizados e validar antes de submeter
    const form = document.querySelector('form');
    if (form) {
      form.addEventListener('submit', function(event) {
        let isValid = true;
        
        // Atualizar e verificar todos os inputs de ordenação
        questionsIds.forEach(qId => {
          const selects = document.querySelectorAll(`.order-select[data-question-id="${qId}"]`);
          if (selects.length > 0) {
            const result = updateOrderInput(qId);
            const input = document.getElementById(`order_sentences_answer_${qId}`);
            
            // Verificar se o input tem conteúdo válido
            if (!input.value || input.value.split('|').length !== selects.length) {
              isValid = false;
              
              // Destacar selects com problema
              selects.forEach(select => {
                select.classList.add('is-invalid');
              });
              
              // Se ainda não existe uma mensagem de erro, criar uma
              const errorMsgId = `error-msg-${qId}`;
              if (!document.getElementById(errorMsgId)) {
                const errorDiv = document.createElement('div');
                errorDiv.id = errorMsgId;
                errorDiv.className = 'alert alert-danger mt-2';
                errorDiv.textContent = 'Por favor, defina uma ordem única para cada frase.';
                
                const container = selects[0].closest('.order-sentences-container');
                if (container) {
                  container.appendChild(errorDiv);
                }
              }
            } else {
              // Remover destaque de erro se existir
              selects.forEach(select => {
                select.classList.remove('is-invalid');
              });
              
              // Remover mensagem de erro se existir
              const errorMsg = document.getElementById(`error-msg-${qId}`);
              if (errorMsg) errorMsg.remove();
            }
          }
        });
        
        if (!isValid) {
          event.preventDefault();
          // Rolar até o primeiro erro
          const firstInvalid = document.querySelector('.is-invalid');
          if (firstInvalid) {
            firstInvalid.scrollIntoView({ behavior: 'smooth', block: 'center' });
          }
        }
      });
    }
  });
</script>

<!-- Estilo para os elementos de ordenação -->
<style>
  .list-group-item {
    margin-bottom: 0.5rem;
    border-radius: 8px !important;
  }
  
  .order-sentences-container {
    max-width: 800px;
    margin: 0 auto;
  }
  
  .order-sentences-container .list-group {
    margin-top: 1rem;
  }
  
  .order-select:focus {
    border-color: #0d6efd;
    box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
  }
  
  .order-select.is-invalid {
    border-color: #dc3545;
    background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 12 12' width='12' height='12' fill='none' stroke='%23dc3545'%3e%3ccircle cx='6' cy='6' r='4.5'/%3e%3cpath stroke-linejoin='round' d='M5.8 3.6h.4L6 6.5z'/%3e%3ccircle cx='6' cy='8.2' r='.6' fill='%23dc3545' stroke='none'/%3e%3c/svg%3e");
    background-repeat: no-repeat;
    background-position: right calc(0.375em + 0.1875rem) center;
    background-size: calc(0.75em + 0.375rem) calc(0.75em + 0.375rem);
  }
  
  .order-select.is-invalid:focus {
    box-shadow: 0 0 0 0.25rem rgba(220, 53, 69, 0.25);
  }
</style>
