<% content_for :head do %>
  <title>Editar Atividade · Practice-BR</title>
  <style>
    .pb-input:focus { border-color:#1A6B4A !important; box-shadow:0 0 0 3px rgba(26,107,74,0.1) !important; outline:none !important; }
  </style>
<% end %>

<div style="max-width:680px; margin:1.5rem auto 3rem; padding:0 1.5rem;">

  <%# Cabeçalho %>
  <div style="display:flex; align-items:center; gap:12px; margin-bottom:1.25rem; flex-wrap:wrap;">
    <%= link_to activity_path(@activity),
          style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:600; color:#5C5853; padding:7px 14px; border:1.5px solid #DDD9D2; border-radius:8px; text-decoration:none; background:#fff; white-space:nowrap;" do %>
      ← Voltar
    <% end %>
    <span style="font-family:'Raleway',sans-serif; font-size:1.2rem; font-weight:700; color:#1C1917;">
      Editar — <span style="font-weight:500; color:#5C5853;"><%= @activity.title %></span>
    </span>
  </div>

  <div style="background:#fff; border:1px solid #DDD9D2; border-radius:20px; padding:32px 36px;">

    <%= form_with model: @activity, local: true do |f| %>

      <%# Erros %>
      <% if @activity.errors.any? %>
        <div style="background:#FEF2F2; border:1.5px solid #FCA5A5; border-radius:10px; padding:14px 16px; margin-bottom:24px;">
          <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:600; color:#991B1B; margin-bottom:6px;">Corrija os erros abaixo:</div>
          <ul style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; color:#B91C1C; margin:0; padding-left:18px;">
            <% @activity.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%# Título %>
      <div style="margin-bottom:22px;">
        <%= f.label :title, style: "display:block; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:600; color:#1C1917; margin-bottom:6px;" do %>
          Título <span style="color:#EA580C;">*</span>
        <% end %>
        <%= f.text_field :title,
              class: "pb-input",
              style: "width:100%; padding:11px 14px; border:1.5px solid #DDD9D2; border-radius:10px; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; color:#1C1917; background:#fff; box-sizing:border-box;" %>
      </div>

      <%# Descrição %>
      <div style="margin-bottom:22px;">
        <%= f.label :description, style: "display:block; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:600; color:#1C1917; margin-bottom:6px;" do %>
          Descrição <span style="color:#EA580C;">*</span>
        <% end %>
        <%= f.text_area :description,
              class: "pb-input",
              rows: 3,
              style: "width:100%; padding:11px 14px; border:1.5px solid #DDD9D2; border-radius:10px; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; color:#1C1917; background:#fff; resize:vertical; min-height:90px; box-sizing:border-box;" %>
      </div>

      <%# Nível CEFR %>
      <%
        cefr_opts = {
          'A1' => { bg:'#E8F5EE', text:'#0F3826', border:'#2A9B6F', ring:'rgba(42,155,111,0.15)' },
          'A2' => { bg:'#EBF2FC', text:'#1A4A8A', border:'#2563EB', ring:'rgba(37,99,235,0.12)' },
          'B1' => { bg:'#F5F3FF', text:'#4C1D95', border:'#7C3AED', ring:'rgba(124,58,237,0.12)' },
          'B2' => { bg:'#FFF7ED', text:'#7C2D12', border:'#EA580C', ring:'rgba(234,88,12,0.12)' },
          'C1' => { bg:'#F3F4F6', text:'#1C1917', border:'#374151', ring:'rgba(55,65,81,0.12)' },
        }
      %>
      <div style="margin-bottom:0;">
        <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:600; color:#1C1917; margin-bottom:8px;">
          Nível CEFR <span style="color:#EA580C;">*</span>
        </div>
        <div data-controller="level-picker" style="display:flex; gap:8px; flex-wrap:wrap;">
          <% cefr_opts.each do |lvl, c| %>
            <label class="level-pill"
                   data-level-picker-target="pill"
                   data-action="click->level-picker#select"
                   data-border="<%= c[:border] %>"
                   data-ring="<%= c[:ring] %>"
                   style="display:inline-block; cursor:pointer; font-family:'DM Mono',monospace; font-size:0.8rem; font-weight:700; padding:7px 18px; border-radius:20px; background:<%= c[:bg] %>; color:<%= c[:text] %>; border:1.5px solid #DDD9D2; transition:all 0.12s;">
              <%= f.radio_button :level, lvl,
                    class: "level-radio",
                    data: { "level-picker-target": "radio" },
                    style: "display:none;" %>
              <%= lvl %>
            </label>
          <% end %>
        </div>
      </div>

      <hr style="border:none; border-top:1px solid #F0EDE8; margin:28px 0;">

      <div style="display:flex; align-items:center; justify-content:space-between;">
        <%= link_to "Cancelar", activity_path(@activity),
              style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; color:#9C9892; text-decoration:none; padding:8px 4px;" %>
        <%= f.submit "Salvar Alterações →",
              style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; font-weight:700; color:#fff; background:#C9952A; padding:12px 32px; border-radius:12px; border:none; cursor:pointer;" %>
      </div>

    <% end %>
  </div>

  <% if @activity.ai_generated? && @activity.draft? %>
    <div style="margin-top:16px; background:linear-gradient(135deg,#F0F7F4 0%,#E8F5EE 100%); border:1.5px solid #2A9B6F; border-radius:16px; padding:20px 24px; display:flex; align-items:center; justify-content:space-between; gap:16px; flex-wrap:wrap;">
      <div>
        <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.88rem; font-weight:700; color:#0F3826; margin-bottom:3px;">
          Atividade pronta? Publique agora.
        </div>
        <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.8rem; color:#2A6B4A;">
          Salve as alterações acima antes de publicar.
        </div>
      </div>
      <%= button_to "✓ Publicar atividade", publish_draft_activity_path(@activity),
            method: :post,
            style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; font-weight:700; color:#fff; background:#1A6B4A; padding:10px 24px; border-radius:10px; border:none; cursor:pointer; white-space:nowrap; flex-shrink:0;" %>
    </div>
  <% end %>

</div>
