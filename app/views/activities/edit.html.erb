<!DOCTYPE html>
<html>
<head>
  <title><%= t('activities.edit') %> - Practice PT</title>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Kalam:wght@400;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  
  <style>
    /* 🎨 Estilos específicos da página de edição */
    body {
      background: linear-gradient(135deg, var(--fundo-neutro) 0%, #e3f2fd 100%);
      min-height: 100vh;
      font-family: var(--font-primary);
      color: var(--texto-escuro);
      line-height: 1.6;
    }
  </style>
</head>

<body>
  <!-- ✅ Container usando nosso sistema -->
  <div class="form-container">
    
    <!-- ✅ Header usando componente .header-atividade -->
    <div class="header-atividade form">
      <h1><i class="fas fa-edit"></i> <%= t('activities.edit') %></h1>
      <p>Atualize as informações da sua atividade</p>
    </div>

    <!-- ✅ Card principal usando .form-card -->
    <div class="form-card">
      
      <!-- ✅ Título do formulário -->
      <h2 class="form-title">
        <i class="fas fa-clipboard-list"></i>
        Informações da Atividade
      </h2>

      <%= simple_form_for(@activity) do |f| %>
        
        <!-- ✅ Seção do formulário -->
        <div class="form-section">
          <h3 class="section-title">
            <i class="fas fa-info-circle"></i>
            Dados Básicos
          </h3>
          
          <!-- ✅ Campo Título usando .form-group -->
          <div class="form-group animate">
            <%= f.label :title, t('forms.title'), class: "form-label" %>
            <span class="required">*</span>
            <%= f.input_field :title, 
                            class: "form-input #{'error' if @activity.errors[:title].any?}",
                            placeholder: t('activities.title_placeholder') %>
            <% if @activity.errors[:title].any? %>
              <div class="form-error">
                <i class="fas fa-exclamation-circle"></i>
                <%= @activity.errors[:title].first %>
              </div>
            <% end %>
          </div>

          <!-- ✅ Campo Descrição usando .form-textarea -->
          <div class="form-group animate">
            <%= f.label :description, t('forms.description'), class: "form-label" %>
            <span class="optional">(opcional)</span>
            <%= f.input_field :description, 
                            as: :text,
                            class: "form-textarea #{'error' if @activity.errors[:description].any?}",
                            placeholder: t('activities.description_placeholder'),
                            rows: 4 %>
            <div class="form-help">
              <i class="fas fa-lightbulb"></i>
              Descreva brevemente o objetivo da atividade
            </div>
            <% if @activity.errors[:description].any? %>
              <div class="form-error">
                <i class="fas fa-exclamation-circle"></i>
                <%= @activity.errors[:description].first %>
              </div>
            <% end %>
          </div>

          <!-- ✅ Campo Nível usando .form-select -->
          <div class="form-group animate">
            <%= f.label :level, t('forms.level'), class: "form-label" %>
            <span class="required">*</span>
            <%= f.input_field :level,
                            collection: [['A1', 'A1'], ['A2', 'A2'], ['B1', 'B1'], ['B2', 'B2'], ['C1', 'C1']],
                            class: "form-select #{'error' if @activity.errors[:level].any?}",
                            prompt: "Selecione o nível..." %>
            <div class="form-help">
              <i class="fas fa-graduation-cap"></i>
              Escolha o nível de dificuldade apropriado
            </div>
            <% if @activity.errors[:level].any? %>
              <div class="form-error">
                <i class="fas fa-exclamation-circle"></i>
                <%= @activity.errors[:level].first %>
              </div>
            <% end %>
          </div>
        </div>

        <!-- ✅ Ações do formulário usando .form-actions -->
        <div class="form-actions">
          <%= link_to activity_path(@activity), class: "btn-form secondary" do %>
            <i class="fas fa-arrow-left"></i>
            <%= t('activities.back_to_activities') %>
          <% end %>
          
          <%= f.button :submit, class: "btn-form primary" do %>
            <i class="fas fa-save"></i>
            <%= t('forms.update_activity') %>
          <% end %>
        </div>

      <% end %>
    </div>
  </div>

  <!-- ✅ Script para animações dos form-groups -->
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      // Ativa animações dos grupos de formulário
      const formGroups = document.querySelectorAll('.form-group.animate');
      
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.style.opacity = '1';
            entry.target.style.transform = 'translateY(0)';
          }
        });
      });
      
      formGroups.forEach(group => {
        observer.observe(group);
      });
      
      // Melhora o focus dos inputs
      const inputs = document.querySelectorAll('.form-input, .form-textarea, .form-select');
      inputs.forEach(input => {
        input.addEventListener('focus', function() {
          this.parentElement.classList.add('focused');
        });
        
        input.addEventListener('blur', function() {
          this.parentElement.classList.remove('focused');
        });
      });
    });
  </script>
</body>
</html>
