            <span style="color:#9C9892; font-size:0.9rem; flex-shrink:0;">↔</span>
            <input type="text" name="pairs[1][right]" style="flex:5; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; padding:7px 10px; border:1.5px solid #DDD9D2; border-radius:8px; color:#1C1917; background:#fff;"
                   placeholder="<%= t('column_matchings.item_b_placeholder') %>">
            <span style="width:28px;"></span>
          </div>
          <div data-field style="display:flex; align-items:center; gap:6px; margin-bottom:8px;">
            <input type="text" name="pairs[2][left]" style="flex:5; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; padding:7px 10px; border:1.5px solid #DDD9D2; border-radius:8px; color:#1C1917; background:#fff;"
                   placeholder="<%= t('column_matchings.item_a_placeholder') %>">
            <span style="color:#9C9892; font-size:0.9rem; flex-shrink:0;">↔</span>
            <input type="text" name="pairs[2][right]" style="flex:5; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; padding:7px 10px; border:1.5px solid #DDD9D2; border-radius:8px; color:#1C1917; background:#fff;"
                   placeholder="<%= t('column_matchings.item_b_placeholder') %>">
            <span style="width:28px;"></span>
          </div>
        </div>

        <template data-dynamic-fields-target="template">
          <div data-field style="display:flex; align-items:center; gap:6px; margin-bottom:8px;">
            <input type="text" name="pairs[FIELD_INDEX][left]" style="flex:5; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; padding:7px 10px; border:1.5px solid #DDD9D2; border-radius:8px; color:#1C1917; background:#fff;"
                   placeholder="<%= t('column_matchings.item_a_placeholder') %>">
            <span style="color:#9C9892; font-size:0.9rem; flex-shrink:0;">↔</span>
