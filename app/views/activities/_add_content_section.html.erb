<div class="collapse form-collapse" id="new-question-form" data-content-form-target="form">
  <div style="<%= wrap_s %>">
    <div data-controller="question-form">
      <%= render partial: "questions/form", locals: { question: activity.questions.build, activity: activity } %>
    </div>
  </div>
</div>

<div class="collapse form-collapse" id="new-sentence-ordering-form" data-content-form-target="form">
  <div style="<%= wrap_s %>">
    <%= form_with(model: [activity, SentenceOrdering.new], local: true) do |f| %>
      <div style="<%= field_s %>">
        <%= f.label :sentence, "Frase completa", style: label_s %>
        <%= f.text_area :sentence, style: input_s, rows: 2,
            placeholder: "Ex: O gato bebe leite fresco todos os dias" %>
        <small style="<%= hint_s %>">As palavras serão embaralhadas automaticamente para o aluno.</small>
      </div>
      <div style="<%= field_s %>">
        <%= f.label :instruction, "Instrução para o aluno (opcional)", style: label_s %>
        <%= f.text_field :instruction, style: input_s,
            placeholder: "Ex: Coloque as palavras na ordem correta para formar a frase." %>
      </div>
      <%= f.submit "Criar exercício", style: submit_exercise %>
    <% end %>
  </div>
</div>

<div class="collapse form-collapse" id="new-paragraph-ordering-form" data-content-form-target="form">
  <div style="<%= wrap_s %>">
    <%= form_with(model: [activity, ParagraphOrdering.new], local: true,
          data: { controller: "dynamic-fields" }) do |f| %>
      <div style="<%= field_s %>">
        <%= f.label :title, "Título (opcional)", style: label_s %>
        <%= f.text_field :title, style: input_s,
            placeholder: "Ex: Coloque o diálogo em ordem" %>
      </div>
      <div style="<%= field_s %>">
        <%= f.label :instruction, "Instrução para o aluno (opcional)", style: label_s %>
        <%= f.text_field :instruction, style: input_s,
            placeholder: t('paragraph_orderings.instruction_default') %>
      </div>

      <div style="<%= field_s %>">
        <span style="<%= label_s %>">Frases (na ordem correta)</span>
        <small style="<%= hint_s %> margin-top:0; margin-bottom:10px;">Escreva cada frase na ordem correta — o aluno vai tentar reordenar.</small>

        <div data-dynamic-fields-target="list">
          <div data-field style="display:flex; align-items:center; gap:6px; margin-bottom:8px;">
            <span style="font-family:'DM Mono',monospace; font-size:0.8rem; font-weight:700; color:#9C9892; min-width:20px;">1</span>
            <input type="text" name="sentences[1]" style="<%= input_s %>"
                   placeholder="Primeira frase...">
          </div>
          <div data-field style="display:flex; align-items:center; gap:6px; margin-bottom:8px;">
            <span style="font-family:'DM Mono',monospace; font-size:0.8rem; font-weight:700; color:#9C9892; min-width:20px;">2</span>
            <input type="text" name="sentences[2]" style="<%= input_s %>"
                   placeholder="Segunda frase...">
          </div>
        </div>

        <template data-dynamic-fields-target="template">
          <div data-field style="display:flex; align-items:center; gap:6px; margin-bottom:8px;">
            <span style="font-family:'DM Mono',monospace; font-size:0.8rem; font-weight:700; color:#9C9892; min-width:20px;">+</span>
            <input type="text" name="sentences[FIELD_INDEX]" style="<%= input_s %>"
                   placeholder="<%= t('paragraph_orderings.sentence_placeholder') %>">
            <button type="button" style="<%= btn_rm %>"
                    data-action="dynamic-fields#removeField">✕</button>
          </div>
        </template>

        <button type="button" style="<%= btn_add %>" data-action="dynamic-fields#addField">
          <i class="bi bi-plus"></i> <%= t('paragraph_orderings.add_sentence') %>
        </button>
      </div>

      <%= f.submit "Criar exercício", style: submit_exercise %>
    <% end %>
  </div>
</div>

<div class="collapse form-collapse" id="new-column-matching-form" data-content-form-target="form">
  <div style="<%= wrap_s %>">
    <%= form_with(model: [activity, ColumnMatching.new], local: true,
          data: { controller: "dynamic-fields" }) do |f| %>
      <div style="<%= field_s %>">
        <%= f.label :title, t('column_matchings.title_label'), style: label_s %>
        <%= f.text_field :title, style: input_s,
            placeholder: t('column_matchings.title_placeholder') %>
      </div>
      <div style="<%= field_s %>">
        <%= f.label :instruction, t('column_matchings.instruction_label'), style: label_s %>
        <%= f.text_field :instruction, style: input_s,
            placeholder: t('column_matchings.instruction_default') %>
      </div>

      <div style="<%= field_s %>">
        <span style="<%= label_s %>"><%= t('column_matchings.pairs_label') %></span>
        <small style="<%= hint_s %> margin-top:0; margin-bottom:10px;"><%= t('column_matchings.pairs_hint') %></small>

        <div style="display:flex; gap:8px; margin-bottom:6px; padding:0 2px;">
          <span style="flex:5; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.72rem; font-weight:700; color:#9C9892; text-transform:uppercase; letter-spacing:0.05em;"><%= t('column_matchings.column_a') %></span>
          <span style="width:24px; text-align:center; font-size:0.8rem; color:#9C9892;">↔</span>
          <span style="flex:5; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.72rem; font-weight:700; color:#9C9892; text-transform:uppercase; letter-spacing:0.05em;"><%= t('column_matchings.column_b') %></span>
          <span style="width:28px;"></span>
        </div>

        <div data-dynamic-fields-target="list">
          <div data-field style="display:flex; align-items:center; gap:6px; margin-bottom:8px;">
            <input type="text" name="pairs[1][left]" style="flex:5; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; padding:7px 10px; border:1.5px solid #DDD9D2; border-radius:8px; color:#1C1917; background:#fff;"
