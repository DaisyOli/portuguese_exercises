<% unless @quill_loaded %>
  <% @quill_loaded = true %>
  <% content_for :head do %>
    <link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet">
    <script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>
    <style>
      .ql-toolbar.ql-snow { border-radius: 8px 8px 0 0; border-color: #DDD9D2; font-family: 'Plus Jakarta Sans', sans-serif; padding: 3px 8px; }
      .ql-toolbar.ql-snow button { padding: 2px; width: 22px; height: 20px; }
      .ql-toolbar.ql-snow .ql-formats { margin-right: 8px; line-height: 1; }
      .ql-container.ql-snow { border-radius: 0 0 8px 8px; border-color: #DDD9D2; font-family: 'Plus Jakarta Sans', sans-serif; font-size: 0.9rem; }
      .ql-editor { min-height: 80px; padding: 6px 10px 4px; line-height: 1.65; color: #1C1917; }
      .quill-tall .ql-editor { min-height: 140px; padding: 12px 15px 6px; }
      .ql-editor.ql-blank::before { color: #9C9892; font-style: normal; }
    </style>
  <% end %>
<% end %>

<%
  pill = "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.8rem; font-weight:600; padding:6px 13px; border-radius:20px; border:1.5px solid; cursor:pointer; white-space:nowrap; display:inline-flex; align-items:center; gap:5px;"
  neutral  = pill + "background:#F0EDE8; color:#5C5853; border-color:#DDD9D2;"
  questao  = pill + "background:#EBF2FC; color:#1A4A8A; border-color:#BFDBFE;"
  palavras = pill + "background:#E8F5EE; color:#0F3826; border-color:#BBF7D0;"
  paras    = pill + "background:#ECFDF5; color:#065F46; border-color:#A7F3D0;"
  colunas  = pill + "background:#FFF7ED; color:#7C2D12; border-color:#FED7AA;"

  label_s  = "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:600; color:#5C5853; display:block; margin-bottom:6px;"
  input_s  = "width:100%; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.88rem; padding:9px 12px; border:1.5px solid #DDD9D2; border-radius:8px; color:#1C1917; background:#fff; box-sizing:border-box;"
  hint_s   = "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; color:#9C9892; margin-top:5px; display:block;"
  field_s  = "margin-bottom:16px;"
  wrap_s   = "padding:20px 22px; background:#fff; border:1px solid #DDD9D2; border-radius:14px; margin-bottom:14px;"
  submit_content  = "background:#C9952A; color:#fff; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.88rem; font-weight:700; border:none; border-radius:10px; padding:10px 24px; cursor:pointer; width:100%; margin-top:4px;"
  submit_exercise = "background:#1A6B4A; color:#fff; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.88rem; font-weight:700; border:none; border-radius:10px; padding:10px 24px; cursor:pointer; width:100%; margin-top:4px;"
  btn_add  = "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.8rem; font-weight:600; color:#0F3826; padding:6px 12px; border:1.5px solid #BBF7D0; border-radius:20px; background:#E8F5EE; cursor:pointer; display:inline-flex; align-items:center; gap:5px;"
  btn_rm   = "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.72rem; font-weight:600; color:#B91C1C; padding:4px 8px; border:1.5px solid #FECACA; border-radius:6px; background:#FEF2F2; cursor:pointer;"
%>

<div data-controller="content-form" style="background:#fff; border:1px solid #DDD9D2; border-radius:16px; padding:20px 24px; margin-bottom:16px;">
  <div style="font-family:'DM Mono',monospace; font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:#5C5853; margin-bottom:12px;">
    + <%= t('activities.add_content') %>
  </div>

  <%# Grupo: Material de estudo %>
  <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.67rem; font-weight:700; text-transform:uppercase; letter-spacing:0.07em; color:#C9952A; margin-bottom:6px;">
    Material de estudo
  </div>
  <div style="display:flex; gap:7px; flex-wrap:wrap; margin-bottom:14px;">
    <button type="button" style="<%= neutral %>"
            data-action="content-form#toggle"
            data-bs-toggle="collapse"
            data-bs-target="#new-statement-form">
      <i class="bi bi-file-text"></i> <%= t('activities.add_statement') %>
    </button>
    <button type="button" style="<%= neutral %>"
            data-action="content-form#toggle"
            data-bs-toggle="collapse"
            data-bs-target="#new-image-form">
      <i class="bi bi-image"></i> <%= t('activities.add_image') %>
    </button>
    <button type="button" style="<%= neutral %>"
            data-action="content-form#toggle"
            data-bs-toggle="collapse"
            data-bs-target="#new-video-form">
      <i class="bi bi-play-circle"></i> <%= t('activities.add_video') %>
    </button>
    <button type="button" style="<%= neutral %>"
            data-action="content-form#toggle"
            data-bs-toggle="collapse"
            data-bs-target="#new-text-form">
      <i class="bi bi-align-left"></i> <%= t('activities.add_text') %>
    </button>
    <button type="button" style="<%= neutral %>"
            data-action="content-form#toggle"
            data-bs-toggle="collapse"
            data-bs-target="#new-suggestion-form">
      <i class="bi bi-lightbulb"></i> <%= t('activities.add_suggestion') %>
    </button>
  </div>

  <%# Grupo: Exercícios %>
  <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.67rem; font-weight:700; text-transform:uppercase; letter-spacing:0.07em; color:#1A6B4A; margin-bottom:6px;">
    Exercícios
  </div>
  <div style="display:flex; gap:7px; flex-wrap:wrap;">
    <button type="button" style="<%= questao %>"
            data-action="content-form#toggle"
            data-bs-toggle="collapse"
            data-bs-target="#new-question-form">
      <i class="bi bi-check2-square"></i> <%= t('activities.add_question') %>
    </button>
    <button type="button" style="<%= palavras %>"
            data-action="content-form#toggle"
            data-bs-toggle="collapse"
            data-bs-target="#new-sentence-ordering-form">
      <i class="bi bi-sort-alpha-down"></i> <%= t('sentence_orderings.title') %>
    </button>
    <button type="button" style="<%= paras %>"
            data-action="content-form#toggle"
            data-bs-toggle="collapse"
            data-bs-target="#new-paragraph-ordering-form">
      <i class="bi bi-list-ol"></i> <%= t('paragraph_orderings.title') %>
    </button>
    <button type="button" style="<%= colunas %>"
            data-action="content-form#toggle"
            data-bs-toggle="collapse"
            data-bs-target="#new-column-matching-form">
      <i class="bi bi-arrow-left-right"></i> <%= t('column_matchings.title') %>
    </button>
  </div>
</div>

<div class="collapse form-collapse" id="new-statement-form" data-content-form-target="form">
  <div style="<%= wrap_s %>">
    <%= form_with(model: activity, local: true) do |f| %>
      <div style="<%= field_s %>">
        <%= f.label :statement, t('activities.statement_label'), style: label_s %>
        <div id="quill-editor-statement"></div>
        <%= f.hidden_field :statement, id: "quill-input-statement", value: activity.statement %>
      </div>
      <%= f.submit t('activities.save_statement'), style: submit_content %>
    <% end %>
  </div>
</div>

<script>
  (function() {
    function initStatementQuill() {
      var editorEl = document.getElementById('quill-editor-statement');
      if (!editorEl || editorEl.dataset.quillInit) return;
      editorEl.dataset.quillInit = '1';

      var quill = new Quill(editorEl, {
        theme: 'snow',
        modules: { toolbar: [['bold', 'italic', 'underline']] },
        placeholder: '<%= j(t("activities.statement_placeholder")) %>'
      });

      var existing = <%= raw json_escape((activity.statement || '').to_json) %>;
      if (existing && existing.trim().length > 0) {
        quill.clipboard.dangerouslyPasteHTML(
          existing.charAt(0) === '<' ? existing : existing.replace(/\n/g, '<br>')
        );
      }

      var hiddenInput = document.getElementById('quill-input-statement');
      quill.on('text-change', function() { hiddenInput.value = quill.root.innerHTML; });

      var form = document.querySelector('#new-statement-form form');
      if (form) form.addEventListener('submit', function() { hiddenInput.value = quill.root.innerHTML; });
    }

    var collapseEl = document.getElementById('new-statement-form');
    if (collapseEl) {
      new MutationObserver(function() {
        if (collapseEl.classList.contains('show')) initStatementQuill();
      }).observe(collapseEl, { attributes: true, attributeFilter: ['class'] });
    }
  })();
</script>

