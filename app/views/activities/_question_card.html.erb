<%
  type_styles = {
    'multiple_choice' => { bg:'#EBF2FC', text:'#1A4A8A', border:'#BFDBFE' },
    'fill_in_blank'   => { bg:'#F5F3FF', text:'#4C1D95', border:'#DDD6FE' },
  }
  ts = type_styles[question.question_type] || { bg:'#F3F4F6', text:'#1C1917', border:'#DDD9D2' }
%>

<div id="question-<%= question.id %>" style="border:1px solid #D1EAD9; border-radius:10px; overflow:hidden; background:#fff;">

  <%# Question header %>
  <div style="display:flex; align-items:center; justify-content:space-between; padding:9px 14px; background:#E8F5EE; border-bottom:1px solid #D1EAD9;">
    <div style="display:flex; align-items:center; gap:8px;">
      <span style="font-family:'DM Mono',monospace; font-size:0.7rem; font-weight:700; color:#1A6B4A;">
        <%= "%02d" % (index + 1) %>
      </span>
      <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.7rem; font-weight:700; padding:3px 9px; border:1px solid <%= ts[:border] %>; border-radius:6px; background:<%= ts[:bg] %>; color:<%= ts[:text] %>;">
        <%= t("questions.types.#{question.question_type}") %>
      </span>
    </div>
    <% if activity.teacher == current_user %>
      <div style="display:flex; gap:6px;">
        <button type="button"
                data-bs-toggle="collapse"
                data-bs-target="#edit-question-form-<%= question.id %>"
                style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.72rem; font-weight:600; color:#5C5853; padding:4px 9px; border:1.5px solid #DDD9D2; border-radius:6px; background:#fff; cursor:pointer;">
          Editar
        </button>
        <%= button_to activity_question_path(activity, question),
            method: :delete,
            data: { confirm: t('questions.confirm_delete') },
            style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.72rem; font-weight:600; color:#B91C1C; padding:4px 9px; border:1.5px solid #FECACA; border-radius:6px; background:#FEF2F2; cursor:pointer;" do %>
          Remover
        <% end %>
      </div>
    <% end %>
  </div>

  <%# Question content %>
  <div style="padding:14px;">
    <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.92rem; color:#1C1917; margin:0 0 12px 0; line-height:1.55;">
      <% if question.fill_in_blank? %>
        <%= question.content.gsub('_____', '<span style="display:inline-block; width:80px; border-bottom:2px solid #4C1D95;">&nbsp;</span>').html_safe %>
      <% else %>
        <%= question.content %>
      <% end %>
    </p>

    <% if question.multiple_choice? && question.options.any? %>
      <ul style="list-style:none; margin:0 0 10px 0; padding:0; display:flex; flex-direction:column; gap:5px;">
        <% question.options.each do |option| %>
          <% is_correct = question.correct_answer == option %>
          <li style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; padding:7px 12px; border-radius:8px; border:1px solid <%= is_correct ? '#2A9B6F' : '#DDD9D2' %>; background:<%= is_correct ? '#E8F5EE' : '#fff' %>; color:<%= is_correct ? '#0F3826' : '#1C1917' %>; font-weight:<%= is_correct ? '600' : '400' %>;">
            <%= option %>
          </li>
        <% end %>
      </ul>
    <% end %>

    <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; font-weight:600; color:#1A6B4A;">
      ✓ <%= t('questions.correct_answer') %>: <%= question.correct_answer %>
    </div>
  </div>

</div>

<% if activity.teacher == current_user %>
  <div class="collapse" id="edit-question-form-<%= question.id %>">
    <div style="padding:20px; border:1px solid #D1EAD9; border-top:none; border-radius:0 0 10px 10px; background:#FAFAF9; margin-top:-1px;">
      <div data-controller="question-selector">
        <%= form_with model: [question.activity, question], html: { id: "edit-form-#{question.id}" } do |form| %>
          <div class="row mb-3">
            <div class="col-md-12">
              <%= form.label :question_type, t('questions.form.question_type') %>
              <%= form.select :question_type,
                  Question::QUESTION_TYPES.map { |type| [t("questions.types.#{type}"), type] },
                  { selected: question.question_type || 'multiple_choice' },
                  { class: "form-control",
                    data: { question_selector_target: "selector",
                            action: "change->question-selector#change" } } %>
            </div>
          </div>

          <div class="row mb-3">
            <div class="col-md-12">
              <%= form.label :content, t('questions.form.question_content') %>
              <%= form.text_area :content, class: "form-control", rows: 3 %>
            </div>
          </div>

          <div class="row mb-3 fill-in-blank-help" data-question-selector-target="fillInBlank"
               style="display: <%= question.fill_in_blank? ? 'block' : 'none' %>;">
            <div class="col-md-12">
              <div class="alert alert-info">
                <%= t('questions.form.fill_in_blank_help_html') %>
              </div>
            </div>
          </div>

          <div class="row mb-3 multiple-choice-fields" data-question-selector-target="multipleChoice"
               style="display: <%= question.multiple_choice? ? 'block' : 'none' %>;">
            <div class="col-md-12">
              <%= form.label :options, t('questions.form.options') %>
              <%= form.text_area :options_text, value: question.options&.join(','), class: "form-control", rows: 3 %>
              <small class="form-text text-muted"><%= t('questions.form.options_help') %></small>
            </div>
          </div>

          <div class="row mb-3" data-question-selector-target="correctAnswer">
            <div class="col-md-12">
              <%= form.label :correct_answer, t('questions.form.correct_answer') %>
              <%= form.text_field :correct_answer, class: "form-control" %>
            </div>
          </div>

          <div class="row">
            <div class="col-md-12">
              <%= form.submit t('common.save'), class: "btn btn-primary" %>
              <% if question.persisted? %>
                <%= link_to t('common.delete'),
                    activity_question_path(activity, question),
                    data: { turbo_method: :delete, turbo_confirm: t('common.confirm_delete') },
                    class: "btn btn-outline-danger ms-2" %>
              <% end %>
            </div>
          </div>

          <script>
            document.addEventListener('DOMContentLoaded', function() {
              const form = document.getElementById('edit-form-<%= question.id %>');
              if (!form) return;
              const select = form.querySelector('select[name="question[question_type]"]');
              if (!select) return;

              function updateEditFields() {
                const type = select.value;
                const multipleChoiceFields = form.querySelector('.multiple-choice-fields');
                const fillInBlankHelp = form.querySelector('.fill-in-blank-help');
                const correctAnswerField = form.querySelector('[data-question-selector-target="correctAnswer"]');
                if (multipleChoiceFields) multipleChoiceFields.style.display = 'none';
                if (fillInBlankHelp) fillInBlankHelp.style.display = 'none';
                if (correctAnswerField) correctAnswerField.style.display = 'block';
                switch (type) {
                  case 'multiple_choice':
                    if (multipleChoiceFields) multipleChoiceFields.style.display = 'block';
                    break;
                  case 'fill_in_blank':
                    if (fillInBlankHelp) fillInBlankHelp.style.display = 'block';
                    break;
                }
              }
              select.addEventListener('change', updateEditFields);
              const collapse = document.getElementById('edit-question-form-<%= question.id %>');
              if (collapse) { collapse.addEventListener('shown.bs.collapse', updateEditFields); }
              updateEditFields();
            });
          </script>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
