<%
  type_styles = {
    'multiple_choice' => { bg:'#EBF2FC', text:'#1A4A8A', border:'#BFDBFE' },
    'fill_in_blank'   => { bg:'#F5F3FF', text:'#4C1D95', border:'#DDD6FE' },
  }
  ts = type_styles[question.question_type] || { bg:'#F3F4F6', text:'#1C1917', border:'#DDD9D2' }
%>

<% unless @quill_loaded %>
  <% @quill_loaded = true %>
  <% content_for :head do %>
    <link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet">
    <script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>
    <style>
      .ql-toolbar.ql-snow { border-radius: 8px 8px 0 0; border-color: #DDD9D2; font-family: 'Plus Jakarta Sans', sans-serif; padding: 3px 8px; }
      .ql-toolbar.ql-snow button { padding: 2px; width: 22px; height: 20px; }
      .ql-toolbar.ql-snow .ql-formats { margin-right: 8px; line-height: 1; }
      .ql-container.ql-snow { border-radius: 0 0 8px 8px; border-color: #DDD9D2; font-family: 'Plus Jakarta Sans', sans-serif; font-size: 0.9rem; }
      .ql-editor { min-height: 80px; padding: 6px 10px 4px; line-height: 1.65; color: #1C1917; }
      .quill-tall .ql-editor { min-height: 140px; padding: 12px 15px 6px; }
      .ql-editor.ql-blank::before { color: #9C9892; font-style: normal; }
    </style>
  <% end %>
<% end %>

<div id="question-<%= question.id %>" style="border:1px solid #D1EAD9; border-radius:10px; overflow:hidden; background:#fff;">

  <%# Question header %>
  <div style="display:flex; align-items:center; justify-content:space-between; padding:9px 14px; background:#E8F5EE; border-bottom:1px solid #D1EAD9;">
    <div style="display:flex; align-items:center; gap:8px;">
      <span style="font-family:'DM Mono',monospace; font-size:0.7rem; font-weight:700; color:#1A6B4A;">
        <%= "%02d" % (index + 1) %>
      </span>
      <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.7rem; font-weight:700; padding:3px 9px; border:1px solid <%= ts[:border] %>; border-radius:6px; background:<%= ts[:bg] %>; color:<%= ts[:text] %>;">
        <%= t("questions.types.#{question.question_type}") %>
      </span>
    </div>
    <% if activity.teacher == current_user %>
      <div style="display:flex; gap:6px;">
        <button type="button"
                data-bs-toggle="collapse"
                data-bs-target="#edit-question-form-<%= question.id %>"
                style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.72rem; font-weight:600; color:#5C5853; padding:4px 9px; border:1.5px solid #DDD9D2; border-radius:6px; background:#fff; cursor:pointer;">
          Editar
        </button>
        <%= button_to activity_question_path(activity, question),
            method: :delete,
            data: { confirm: t('questions.confirm_delete') },
            style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.72rem; font-weight:600; color:#B91C1C; padding:4px 9px; border:1.5px solid #FECACA; border-radius:6px; background:#FEF2F2; cursor:pointer;" do %>
          Remover
        <% end %>
      </div>
    <% end %>
  </div>

  <%# Question content %>
  <div style="padding:14px;">
    <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.92rem; color:#1C1917; margin:0 0 12px 0; line-height:1.55;">
      <% if question.fill_in_blank? %>
        <% safe_c = sanitize(question.content.to_s, tags: %w[p br strong em u], attributes: []) %>
        <%= safe_c.gsub('_____', '<span style="display:inline-block; width:140px; border-bottom:2px solid #4C1D95;">&nbsp;</span>').html_safe %>
      <% else %>
        <%= sanitize(question.content.to_s, tags: %w[p br strong em u], attributes: []) %>
      <% end %>
    </p>

    <% if question.multiple_choice? && question.options.any? %>
      <ul style="list-style:none; margin:0 0 10px 0; padding:0; display:flex; flex-direction:column; gap:5px;">
        <% question.options.each do |option| %>
          <% is_correct = question.correct_answer == option %>
          <li style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; padding:7px 12px; border-radius:8px; border:1px solid <%= is_correct ? '#2A9B6F' : '#DDD9D2' %>; background:<%= is_correct ? '#E8F5EE' : '#fff' %>; color:<%= is_correct ? '#0F3826' : '#1C1917' %>; font-weight:<%= is_correct ? '600' : '400' %>;">
            <%= option %>
          </li>
        <% end %>
      </ul>
    <% end %>

    <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; font-weight:600; color:#1A6B4A;">
      <% all_answers = question.fill_in_blank? ? question.all_correct_answers.reject(&:blank?) : [] %>
      <% if all_answers.length > 1 %>
        <% all_answers.each_with_index do |ans, i| %>
          ✓ Lacuna <%= i + 1 %>: <%= ans %><% unless i == all_answers.length - 1 %> &nbsp;·&nbsp;<% end %>
        <% end %>
      <% else %>
        ✓ <%= t('questions.correct_answer') %>: <%= question.correct_answer %>
      <% end %>
    </div>
  </div>

</div>

<% if activity.teacher == current_user %>
  <div class="collapse" id="edit-question-form-<%= question.id %>">
    <div style="padding:20px; border:1px solid #D1EAD9; border-top:none; border-radius:0 0 10px 10px; background:#FAFAF9; margin-top:-1px;">
      <div data-controller="question-selector">
        <%= form_with model: [question.activity, question], html: { id: "edit-form-#{question.id}" } do |form| %>
          <div class="row mb-3">
            <div class="col-md-12">
              <%= form.label :question_type, t('questions.form.question_type') %>
              <%= form.select :question_type,
                  Question::QUESTION_TYPES.map { |type| [t("questions.types.#{type}"), type] },
                  { selected: question.question_type || 'multiple_choice' },
                  { class: "form-control",
                    data: { question_selector_target: "selector",
                            action: "change->question-selector#change" } } %>
            </div>
          </div>

          <div class="row mb-3">
            <div class="col-md-12">
              <%= form.label :content, t('questions.form.question_content') %>
              <div id="quill-editor-edit-<%= question.id %>"></div>
              <%= form.hidden_field :content, id: "quill-content-edit-#{question.id}", value: question.content %>
            </div>
          </div>

          <div class="row mb-3 fill-in-blank-help" data-question-selector-target="fillInBlank"
               style="display: <%= question.fill_in_blank? ? 'block' : 'none' %>;">
            <div class="col-md-12">
              <div class="alert alert-info">
                <%= t('questions.form.fill_in_blank_help_html') %>
              </div>
            </div>
          </div>

          <div class="row mb-3 multiple-choice-fields" data-question-selector-target="multipleChoice"
               style="display: <%= question.multiple_choice? ? 'block' : 'none' %>;">
            <div class="col-md-12">
              <%= form.label :options, t('questions.form.options') %>
              <%= form.text_area :options_text, value: question.options&.join(','), class: "form-control", rows: 3 %>
              <small class="form-text text-muted"><%= t('questions.form.options_help') %></small>
            </div>
          </div>

          <%# Resposta única — multiple_choice %>
          <div class="row mb-3" data-question-selector-target="correctAnswer"
               style="display:<%= question.fill_in_blank? ? 'none' : 'block' %>;">
            <div class="col-md-12">
              <%= form.label :correct_answer, t('questions.form.correct_answer') %>
              <%= form.text_field :correct_answer, class: "form-control" %>
            </div>
          </div>

          <%# Respostas múltiplas — fill_in_blank %>
          <% fib_answers = question.fill_in_blank? ? question.all_correct_answers.reject(&:blank?) : [] %>
          <% fib_count   = [fib_answers.length, 1].max %>
          <div class="row mb-3 fill-in-blank-answers" data-question-selector-target="fillInBlankAnswers"
               style="display:<%= question.fill_in_blank? ? 'block' : 'none' %>;">
            <div class="col-md-12">
              <label class="form-label">Respostas</label>
              <% 4.times do |i| %>
                <div class="fib-answer-field" data-blank-index="<%= i %>"
                     style="margin-bottom:8px; display:<%= i < fib_count ? 'flex' : 'none' %>; align-items:center; gap:10px;">
                  <span style="font-family:'DM Mono',monospace; font-size:0.72rem; font-weight:700; color:#1A6B4A; background:#E8F5EE; border:1px solid #2A9B6F; border-radius:6px; padding:3px 8px; flex-shrink:0; min-width:62px; text-align:center;">
                    Lacuna <%= i + 1 %>
                  </span>
                  <input type="text"
                         name="question[correct_answers][]"
                         value="<%= fib_answers[i] %>"
                         class="form-control"
                         style="margin-bottom:0; flex:1;"
                         placeholder="Resposta correta <%= i + 1 %>">
                </div>
              <% end %>
            </div>
          </div>

          <div class="row">
            <div class="col-md-12" style="display:flex; align-items:center; gap:10px; flex-wrap:wrap;">
              <%= form.submit t('common.save'),
                    style: "background:#1A4A8A; color:#fff; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.88rem; font-weight:700; border:none; border-radius:12px; padding:9px 24px; cursor:pointer;" %>
              <% if question.persisted? %>
                <%= link_to t('common.delete'),
                    activity_question_path(activity, question),
                    data: { turbo_method: :delete, turbo_confirm: t('common.confirm_delete') },
                    style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:600; color:#B91C1C; padding:8px 14px; border:1.5px solid #FECACA; border-radius:10px; background:#FEF2F2; cursor:pointer; text-decoration:none;" %>
              <% end %>
            </div>
          </div>

          <script>
            (function() {
              var qid = '<%= question.id %>';

              function initQuillEdit() {
                var editorEl = document.getElementById('quill-editor-edit-' + qid);
                if (!editorEl || editorEl.dataset.quillInit) return;
                editorEl.dataset.quillInit = '1';

                var quill = new Quill(editorEl, {
                  theme: 'snow',
                  modules: { toolbar: [['bold', 'italic', 'underline']] }
                });

                var existing = <%= raw json_escape((question.content || '').to_json) %>;
                if (existing && existing.trim()) {
                  quill.clipboard.dangerouslyPasteHTML(
                    existing.charAt(0) === '<' ? existing : existing.replace(/\n/g, '<br>')
                  );
                }

                var hiddenInput = document.getElementById('quill-content-edit-' + qid);
                quill.on('text-change', function() {
                  hiddenInput.value = quill.root.innerHTML;
                });

                var formEl = document.getElementById('edit-form-' + qid);
                if (formEl) {
                  formEl.addEventListener('submit', function() {
                    hiddenInput.value = quill.root.innerHTML;
                  });
                }
              }

              function updateEditFields() {
                const form = document.getElementById('edit-form-' + qid);
                if (!form) return;
                const select = form.querySelector('select[name="question[question_type]"]');
                if (!select) return;
                const type = select.value;
                const multipleChoiceFields = form.querySelector('.multiple-choice-fields');
                const fillInBlankHelp = form.querySelector('.fill-in-blank-help');
                const correctAnswerField = form.querySelector('[data-question-selector-target="correctAnswer"]');
                if (multipleChoiceFields) multipleChoiceFields.style.display = 'none';
                if (fillInBlankHelp) fillInBlankHelp.style.display = 'none';
                if (correctAnswerField) correctAnswerField.style.display = 'block';
                switch (type) {
                  case 'multiple_choice':
                    if (multipleChoiceFields) multipleChoiceFields.style.display = 'block';
                    break;
                  case 'fill_in_blank':
                    if (fillInBlankHelp) fillInBlankHelp.style.display = 'block';
                    break;
                }
              }

              function init() {
                const form = document.getElementById('edit-form-' + qid);
                if (!form) return;
                const select = form.querySelector('select[name="question[question_type]"]');
                if (select) select.addEventListener('change', updateEditFields);
                const collapse = document.getElementById('edit-question-form-' + qid);
                if (collapse) {
                  collapse.addEventListener('shown.bs.collapse', function() {
                    updateEditFields();
                    initQuillEdit();
                  });
                }
                updateEditFields();
              }

              if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', init);
              } else {
                init();
              }
            })();
          </script>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
