<% content_for :head do %>
  <title><%= t('ai_generation.wait_title') %> - Practice PT</title>
  <style>
    @keyframes ai-spin {
      to { transform: rotate(360deg); }
    }
    @keyframes ai-pulse {
      0%, 100% { transform: scale(1); opacity: 1; }
      50%       { transform: scale(0.88); opacity: 0.75; }
    }
  </style>
<% end %>

<% if @generation.failed? %>
  <div class="container mx-auto flex justify-center" style="padding-top:12vh;">
    <div style="max-width:520px; width:100%; background:var(--surface); border:1px solid var(--line); border-radius:16px; padding:36px 32px; text-align:center;">
      <div style="font-size:2.2rem; margin-bottom:10px;">😕</div>
      <h1 style="font-family:'Raleway',sans-serif; font-size:1.15rem; font-weight:700; color:var(--ink); margin:0 0 8px;">
        <%= t('ai_generation.failed_title') %>
      </h1>
      <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; color:var(--ink-soft); margin:0 0 20px;">
        <%= @generation.error_message.presence || t('ai.errors.generic') %>
      </p>
      <%= link_to t('ai_generation.try_again'),
            (@generation.kind == "video" ? generate_from_video_activities_path : generate_with_ai_activities_path),
            style: "display:inline-block; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.88rem; font-weight:700; color:var(--surface); background:var(--brand); padding:10px 24px; border-radius:12px; text-decoration:none;" %>
    </div>
  </div>

<% else %>
  <%# Mesma cara do modal do formulário: a professora nem percebe a troca de página. %>
  <% fun_phrases = t(@generation.kind == "video" ? 'ai_generation.fun_phrases_video' : 'ai_generation.fun_phrases_prompt') %>
  <div data-controller="generation-status"
       data-generation-status-url-value="<%= generation_status_activities_path(id: @generation.id) %>"
       data-generation-status-phrases-value="<%= fun_phrases.to_json %>"
       style="position:fixed; inset:0; z-index:9999;
              background:rgba(15, 56, 38, 0.55);
              backdrop-filter:blur(6px);
              display:flex; align-items:center; justify-content:center;">

    <%# Sem animação de entrada de propósito: esta tela substitui o modal do
        formulário via Turbo e deve parecer que ele nunca saiu de cena. %>
    <div style="background:var(--surface); border-radius:24px; padding:48px 40px;
                max-width:380px; width:90%; text-align:center;
                box-shadow:0 32px 80px rgba(0,0,0,0.22);">

      <h1 class="sr-only"><%= t('ai_generation.wait_title') %></h1>

      <%# Spinner com logo %>
      <div style="position:relative; width:96px; height:96px; margin:0 auto 28px;">
        <div style="position:absolute; inset:0; border-radius:50%;
                    border:3px solid var(--brand-tint);
                    border-top-color:var(--brand);
                    border-right-color:var(--brand-bright);
                    animation:ai-spin 1.1s linear infinite;">
        </div>
        <div style="position:absolute; inset:8px; border-radius:50%;
                    border:2px solid transparent;
                    border-bottom-color:var(--action);
                    animation:ai-spin 1.8s linear infinite reverse;">
        </div>
        <div style="position:absolute; inset:0; display:flex; align-items:center; justify-content:center;">
          <img src="/icons/logo-mark-transparent-64x64.png"
               style="width:44px; height:44px; animation:ai-pulse 2.2s ease-in-out infinite;"
               alt="">
        </div>
      </div>

      <%# Frasesinha rotativa — o Stimulus preenche já com a frase herdada do
          modal do formulário (sessionStorage), sem trocar na frente da professora. %>
      <p data-generation-status-target="message"
         style="font-family:'Raleway',sans-serif; font-size:1.02rem; font-weight:700;
                color:var(--brand-deep); margin:0 0 10px; min-height:2.2em; line-height:1.4;
                transition:opacity 0.35s ease;"></p>

      <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.8rem; color:var(--ink-faint); margin:0;">
        <%= @generation.kind == "video" ? t('ai_generation.wait_hint_video') : t('ai_generation.wait_hint_prompt') %>
      </p>
    </div>
  </div>
<% end %>
