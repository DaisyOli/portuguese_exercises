<div id="<%= section_id %>" style="background:#FBF3E0; border:1px solid #E8C97A; border-left:4px solid #C9952A; border-radius:14px; margin-bottom:14px; overflow:hidden;">

  <%# Section header %>
  <div style="display:flex; align-items:center; justify-content:space-between; padding:12px 18px; border-bottom:1px solid #E8C97A; background:rgba(201,149,42,0.07);">
    <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.06em; color:#C9952A;">
      <%= title %>
    </span>
    <% if current_user.teacher? && activity.teacher == current_user %>
      <div style="display:flex; gap:6px;">
        <button type="button"
                data-bs-toggle="collapse"
                data-bs-target="#edit-<%= section_id %>-form"
                style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.75rem; font-weight:600; color:#5C5853; padding:5px 10px; border:1.5px solid #DDD9D2; border-radius:7px; background:#fff; cursor:pointer;">
          Editar
        </button>
        <%= button_to delete_path,
            method: delete_method,
            data: { turbo_confirm: delete_confirm },
            style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.75rem; font-weight:600; color:#B91C1C; padding:5px 10px; border:1.5px solid #FECACA; border-radius:7px; background:#FEF2F2; cursor:pointer;" do %>
          Remover
        <% end %>
      </div>
    <% end %>
  </div>

  <%# Content body %>
  <div style="padding:16px 18px; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; color:#1C1917; line-height:1.65; background:rgba(255,255,255,0.6);">
    <%= simple_format(content) %>
  </div>

  <%# Inline edit form (Bootstrap collapse) %>
  <% if current_user.teacher? && activity.teacher == current_user %>
    <div class="collapse" id="edit-<%= section_id %>-form">
      <div style="padding:20px; border-top:1px solid #E8C97A; background:#FAFAF9;">
        <%= form_with(model: activity, local: true) do |f| %>
          <div class="mb-3">
            <%= f.label field_name, field_label, class: "form-label" %>
            <%= f.text_area field_name, class: "form-control", rows: 5 %>
          </div>
          <div class="d-grid">
            <%= f.submit t('common.save'), class: "btn btn-primary" %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

</div>
