<% unless @quill_loaded %>
  <% @quill_loaded = true %>
  <% content_for :head do %>
    <link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet">
    <script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>
    <style>
      .ql-toolbar.ql-snow { border-radius: 8px 8px 0 0; border-color: #DDD9D2; font-family: 'Plus Jakarta Sans', sans-serif; padding: 3px 8px; }
      .ql-toolbar.ql-snow button { padding: 2px; width: 22px; height: 20px; }
      .ql-toolbar.ql-snow .ql-formats { margin-right: 8px; line-height: 1; }
      .ql-container.ql-snow { border-radius: 0 0 8px 8px; border-color: #DDD9D2; font-family: 'Plus Jakarta Sans', sans-serif; font-size: 0.9rem; }
      .ql-editor { min-height: 80px; padding: 6px 10px 4px; line-height: 1.65; color: #1C1917; }
      .quill-tall .ql-editor { min-height: 140px; padding: 12px 15px 6px; }
      .ql-editor.ql-blank::before { color: #9C9892; font-style: normal; }
    </style>
  <% end %>
<% end %>

<div id="<%= section_id %>" style="background:#FBF3E0; border:1px solid #E8C97A; border-left:4px solid #C9952A; border-radius:14px; margin-bottom:14px; overflow:hidden;">

  <%# Section header %>
  <div style="display:flex; align-items:center; justify-content:space-between; padding:12px 18px; border-bottom:1px solid #E8C97A; background:rgba(201,149,42,0.07);">
    <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.06em; color:#C9952A; display:flex; align-items:center; gap:7px;">
      <%= title %>
      <% if local_assigns[:show_transcript_toggle] && activity.explanation_is_transcript? %>
        <span style="font-size:0.68rem; font-weight:600; color:#5C5853; background:#F0EDE8; border:1px solid #DDD9D2; border-radius:5px; padding:1px 7px; text-transform:none; letter-spacing:0; display:inline-flex; align-items:center; gap:3px;">
          📄 Transcrição
        </span>
      <% end %>
    </span>
    <% if current_user.teacher? && activity.teacher == current_user %>
      <div style="display:flex; gap:6px;">
        <button type="button"
                data-bs-toggle="collapse"
                data-bs-target="#edit-<%= section_id %>-form"
                style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.75rem; font-weight:600; color:#5C5853; padding:5px 10px; border:1.5px solid #DDD9D2; border-radius:7px; background:#fff; cursor:pointer;">
          Editar
        </button>
        <%= button_to delete_path,
            method: delete_method,
            data: { turbo_confirm: delete_confirm },
            style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.75rem; font-weight:600; color:#B91C1C; padding:5px 10px; border:1.5px solid #FECACA; border-radius:7px; background:#FEF2F2; cursor:pointer;" do %>
          Remover
        <% end %>
      </div>
    <% end %>
  </div>

  <%# Content body %>
  <div style="padding:16px 18px; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; color:#1C1917; line-height:1.65; background:rgba(255,255,255,0.6);">
    <%= content.include?('<') ? sanitize(content, tags: %w[p br strong em u ol ul li], attributes: []) : simple_format(content) %>
  </div>

  <%# Inline edit form (Bootstrap collapse) %>
  <% if current_user.teacher? && activity.teacher == current_user %>
    <div class="collapse" id="edit-<%= section_id %>-form">
      <div style="padding:20px; border-top:1px solid #E8C97A; background:#FAFAF9;">
        <%= form_with(model: activity, local: true) do |f| %>
          <div style="margin-bottom:12px;">
            <%= f.label field_name, field_label,
                  style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:600; color:#44403C; display:block; margin-bottom:8px;" %>

            <div class="quill-tall">
            <div id="quill-editor-<%= section_id %>"></div>
          </div>
            <%= f.hidden_field field_name, id: "quill-input-#{section_id}", value: content %>
          </div>
          <% if local_assigns[:show_transcript_toggle] %>
            <div style="margin-bottom:14px; padding:12px 14px; background:#F0EDE8; border-radius:10px; display:flex; align-items:center; gap:10px;">
              <%= f.check_box :explanation_is_transcript, style: "width:18px; height:18px; accent-color:#1A6B4A; cursor:pointer; flex-shrink:0;" %>
              <label for="activity_explanation_is_transcript"
                     style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.83rem; color:#44403C; cursor:pointer; margin:0; line-height:1.4;">
                📄 Marcar como <strong>transcrição de vídeo</strong>
                <span style="display:block; font-size:0.72rem; color:#9C9892; font-weight:400; margin-top:2px;">O aluno verá um bloco "Ver transcrição" recolhido na atividade.</span>
              </label>
            </div>
          <% end %>
          <div style="margin-top:8px;">
            <%= f.submit t('common.save'),
                  style: "background:#1A4A8A; color:#fff; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.88rem; font-weight:700; border:none; border-radius:12px; padding:9px 24px; cursor:pointer; width:100%;" %>
          </div>
        <% end %>
      </div>
    </div>

    <script>
      (function() {
        function initQuill() {
          var editorEl = document.getElementById('quill-editor-<%= section_id %>');
          if (!editorEl || editorEl.dataset.quillInit) return;
          editorEl.dataset.quillInit = '1';

          var quill = new Quill(editorEl, {
            theme: 'snow',
            modules: { toolbar: [['bold', 'italic', 'underline']] },
            placeholder: '<%= j(field_label) %>'
          });

          var existing = <%= raw json_escape(content.to_json) %>;
          if (existing && existing.trim().length > 0) {
            quill.clipboard.dangerouslyPasteHTML(
              existing.charAt(0) === '<' ? existing : existing.replace(/\n/g, '<br>')
            );
          }

          var hiddenInput = document.getElementById('quill-input-<%= section_id %>');

          quill.on('text-change', function() {
            hiddenInput.value = quill.root.innerHTML;
          });

          var form = document.querySelector('#edit-<%= section_id %>-form form');
          if (form) {
            form.addEventListener('submit', function() {
              hiddenInput.value = quill.root.innerHTML;
            });
          }
        }

        function init() {
          var collapseEl = document.getElementById('edit-<%= section_id %>-form');
          if (collapseEl) {
            collapseEl.addEventListener('shown.bs.collapse', initQuill);
          }
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', init);
        } else {
          init();
        }
      })();
    </script>
  <% end %>

</div>
