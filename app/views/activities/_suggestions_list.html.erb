<% if activity.suggestions.any? %>
  <div id="suggestions-section" style="background:var(--info-tint); border:1px solid var(--info-border); border-left:4px solid var(--info); border-radius:14px; margin-bottom:14px; overflow:hidden;">

    <div style="display:flex; align-items:center; padding:12px 18px; border-bottom:1px solid var(--info-border); background:rgba(37,99,235,0.06);">
      <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.06em; color:var(--info); display:flex; align-items:center; gap:6px;">
        <i class="bi bi-lightbulb"></i> <%= t('activities.suggestions') %> (<%= activity.suggestions.count %>)
      </span>
    </div>

    <div style="padding:14px 16px; display:flex; flex-direction:column; gap:8px; background:rgba(255,255,255,0.5);">
      <% activity.suggestions.each do |suggestion| %>
        <div id="suggestion-<%= suggestion.id %>" style="display:flex; justify-content:space-between; align-items:flex-start; gap:12px; padding:12px 14px; border:1px solid var(--info-border); border-radius:10px; background:var(--surface);">
          <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; color:var(--ink); line-height:1.6;">
            <% if suggestion.content.to_s.strip.start_with?('<') %>
              <%= sanitize(suggestion.content, tags: %w[p br strong em u], attributes: []) %>
            <% else %>
              <%= simple_format(suggestion.content) %>
            <% end %>
          </div>
          <% if current_user.teacher? && activity.teacher == current_user %>
            <%= button_to activity_suggestion_path(activity, suggestion),
                method: :delete,
                data: { turbo_confirm: t('activities.confirm_delete_suggestion') },
                style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.72rem; font-weight:600; color:var(--error); padding:4px 9px; border:1.5px solid var(--error-border); border-radius:6px; background:var(--error-tint); cursor:pointer; flex-shrink:0;" do %>
              Remover
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>

  </div>
<% end %>
