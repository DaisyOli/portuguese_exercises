<% content_for :head do %>
  <title>Atividades · Practice-BR</title>
<% end %>

<%
  # cefr_colors(level) available from ApplicationHelper::CEFR_COLORS

  type_labels = {
    'multiple_choice'   => 'Múltipla escolha',
    'fill_in_blank'     => 'Completar lacunas',
    'sentence_ordering' => 'Ordenar frases',
    'paragraph_ordering'=> 'Ordenar parágrafos',
    'column_matching'   => 'Associar colunas',
  }

  view_mode = params[:view] == 'grid' ? 'grid' : 'list'
%>

<div style="max-width:1100px; margin:0 auto; padding:2rem 1.5rem;">

  <%# ── Cabeçalho ── %>
  <div style="display:flex; align-items:baseline; justify-content:space-between; margin-bottom:1.5rem;">
    <div>
      <h1 style="font-family:'Raleway',sans-serif; font-size:1.5rem; font-weight:700; color:#1C1917; margin-bottom:4px;">
        Todas as Atividades
      </h1>
      <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; color:#5C5853;">
        <%= @activities.count %> <%= @activities.count == 1 ? 'atividade encontrada' : 'atividades encontradas' %>
      </p>
    </div>
    <% if current_user.teacher? %>
      <%= link_to teacher_dashboard_path,
            style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; color:#9C9892; text-decoration:none;" do %>
        ← Dashboard
      <% end %>
    <% end %>
  </div>

  <%# ── Barra de Filtros ── %>
  <%= form_with url: activities_path, method: :get, local: true do %>
    <div style="background:#fff; border:1px solid #DDD9D2; border-radius:14px; padding:16px 20px; margin-bottom:1.5rem; display:flex; align-items:center; justify-content:space-between; gap:12px; flex-wrap:wrap;">

      <div style="display:flex; align-items:center; gap:10px; flex-wrap:wrap;">

        <select name="level"
                style="padding:8px 12px; border:1.5px solid #DDD9D2; border-radius:8px; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; color:#1C1917; background:#fff; cursor:pointer;">
          <option value="">Todos os níveis</option>
          <% ['A1','A2','B1','B2','C1'].each do |lvl| %>
            <option value="<%= lvl %>" <%= 'selected' if params[:level] == lvl %>><%= lvl %></option>
          <% end %>
        </select>

        <select name="sort"
                style="padding:8px 12px; border:1.5px solid #DDD9D2; border-radius:8px; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; color:#1C1917; background:#fff; cursor:pointer;">
          <option value="recentes" <%= 'selected' if params[:sort].blank? || params[:sort] == 'recentes' %>>Mais recentes</option>
          <option value="antigos"  <%= 'selected' if params[:sort] == 'antigos' %>>Mais antigos</option>
          <option value="titulo"   <%= 'selected' if params[:sort] == 'titulo' %>>Título A–Z</option>
          <option value="tentativas" <%= 'selected' if params[:sort] == 'tentativas' %>>Mais tentativas</option>
        </select>

        <input type="text" name="search" value="<%= params[:search] %>"
               placeholder="Buscar atividades..."
               style="padding:8px 12px; border:1.5px solid #DDD9D2; border-radius:8px; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; color:#1C1917; background:#fff; width:200px;">

        <button type="submit"
                style="background:#0F3826; color:#fff; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:600; padding:8px 16px; border:none; border-radius:8px; cursor:pointer;">
          Buscar
        </button>

        <% if params[:level].present? || params[:search].present? || (params[:sort].present? && params[:sort] != 'recentes') %>
          <%= link_to "✕ Limpar", activities_path,
                style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; color:#9C9892; text-decoration:none;" %>
        <% end %>
      </div>

      <%# Toggle lista / grid %>
      <div style="display:flex; gap:0;">
        <%= link_to activities_path(level: params[:level], sort: params[:sort], search: params[:search], view: 'list'),
              style: "padding:7px 11px; border:1.5px solid #{view_mode == 'list' ? '#0F3826' : '#DDD9D2'}; background:#{view_mode == 'list' ? '#0F3826' : '#fff'}; border-radius:8px 0 0 8px; text-decoration:none; font-size:0.85rem; color:#{view_mode == 'list' ? '#fff' : '#9C9892'};" do %>
          ☰
        <% end %>
        <%= link_to activities_path(level: params[:level], sort: params[:sort], search: params[:search], view: 'grid'),
              style: "padding:7px 11px; border:1.5px solid #{view_mode == 'grid' ? '#0F3826' : '#DDD9D2'}; border-left:none; background:#{view_mode == 'grid' ? '#0F3826' : '#fff'}; border-radius:0 8px 8px 0; text-decoration:none; font-size:0.85rem; color:#{view_mode == 'grid' ? '#fff' : '#9C9892'};" do %>
          ⊞
        <% end %>
      </div>

    </div>
  <% end %>

  <%# ── Conteúdo ── %>
  <% if @activities.any? %>

    <% if view_mode == 'list' %>

      <%# VISTA EM LISTA %>
      <div style="background:#fff; border:1px solid #DDD9D2; border-radius:16px; overflow:hidden; margin-bottom:2rem;">

        <%# Cabeçalho da tabela %>
        <div style="display:grid; grid-template-columns:48px 1fr 100px 80px 120px; gap:16px; align-items:center; padding:10px 20px; background:#F7F5F0; border-bottom:1px solid #DDD9D2;">
          <div style="font-family:'DM Mono',monospace; font-size:0.68rem; color:#9C9892; letter-spacing:0.08em; text-transform:uppercase;">Nível</div>
          <div style="font-family:'DM Mono',monospace; font-size:0.68rem; color:#9C9892; letter-spacing:0.08em; text-transform:uppercase;">Título</div>
          <div style="font-family:'DM Mono',monospace; font-size:0.68rem; color:#9C9892; letter-spacing:0.08em; text-transform:uppercase;">Criada em</div>
          <div style="font-family:'DM Mono',monospace; font-size:0.68rem; color:#9C9892; letter-spacing:0.08em; text-transform:uppercase; text-align:center;">Tent.</div>
          <div></div>
        </div>

        <% @activities.each_with_index do |activity, i| %>
          <% c = cefr_colors(activity.level) %>
          <% last = i == @activities.size - 1 %>
          <div style="display:grid; grid-template-columns:48px 1fr 100px 80px 120px; gap:16px; align-items:center; padding:14px 20px; <%= last ? '' : 'border-bottom:1px solid #F0EDE8;' %> transition:background 0.15s;"
               onmouseover="this.style.background='#FAFAF8'" onmouseout="this.style.background=''">

            <span style="font-family:'DM Mono',monospace; font-size:0.72rem; font-weight:700;
                         background:<%= c[:bg] %>; color:<%= c[:text] %>; border:1.5px solid <%= c[:border] %>;
                         padding:3px 8px; border-radius:20px; text-align:center; display:inline-block;">
              <%= activity.level %>
            </span>

            <div style="min-width:0;">
              <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; font-weight:600; color:#1C1917; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                <%= activity.title %>
              </div>
              <% if activity.content_type.present? %>
                <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.75rem; color:#9C9892; margin-top:2px;">
                  <%= type_labels[activity.content_type] || activity.content_type.humanize %>
                </div>
              <% end %>
            </div>

            <div style="font-family:'DM Mono',monospace; font-size:0.75rem; color:#5C5853; white-space:nowrap;">
              <%= activity.created_at.strftime("%d/%m/%Y") %>
            </div>

            <div style="font-family:'DM Mono',monospace; font-size:0.85rem; font-weight:600; color:#5C5853; text-align:center;">
              <%= @attempt_stats[:counts][activity.id] || 0 %>
            </div>

            <div style="display:flex; gap:6px; justify-content:flex-end;">
              <%= link_to "Ver", activity_path(activity),
                    style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; font-weight:600; color:#2563EB; padding:5px 12px; border:1.5px solid #BFDBFE; border-radius:8px; text-decoration:none; background:#EBF2FC; white-space:nowrap;" %>
              <% if current_user.teacher? %>
                <%= link_to "Editar", edit_activity_path(activity),
                      style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; font-weight:500; color:#5C5853; padding:5px 12px; border:1.5px solid #DDD9D2; border-radius:8px; text-decoration:none; white-space:nowrap;" %>
              <% end %>
            </div>

          </div>
        <% end %>
      </div>

    <% else %>

      <%# VISTA EM GRID %>
      <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:1rem; margin-bottom:2rem;">
        <% @activities.each do |activity| %>
          <% c = cefr_colors(activity.level) %>
          <div style="background:#fff; border:1px solid #DDD9D2; border-radius:14px; padding:20px;">

            <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:12px;">
              <span style="font-family:'DM Mono',monospace; font-size:0.72rem; font-weight:700;
                           background:<%= c[:bg] %>; color:<%= c[:text] %>; border:1.5px solid <%= c[:border] %>;
                           padding:3px 10px; border-radius:20px;">
                <%= activity.level %>
              </span>
              <span style="font-family:'DM Mono',monospace; font-size:0.7rem; color:#9C9892;">
                <%= activity.created_at.strftime("%d/%m/%Y") %>
              </span>
            </div>

            <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; font-weight:600; color:#1C1917; margin-bottom:4px; line-height:1.35;">
              <%= activity.title %>
            </div>
            <% if activity.content_type.present? %>
              <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.75rem; color:#9C9892; margin-bottom:14px;">
                <%= type_labels[activity.content_type] || activity.content_type.humanize %>
              </div>
            <% else %>
              <div style="margin-bottom:14px;"></div>
            <% end %>

            <div style="display:flex; gap:16px; margin-bottom:16px;">
              <div>
                <div style="font-family:'DM Mono',monospace; font-size:1rem; font-weight:700; color:#2563EB; line-height:1;">
                  <%= @attempt_stats[:counts][activity.id] || 0 %>
                </div>
                <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.68rem; color:#9C9892; margin-top:2px;">tentativas</div>
              </div>
              <div>
                <div style="font-family:'DM Mono',monospace; font-size:1rem; font-weight:700; color:#2A9B6F; line-height:1;">
                  <%= @attempt_stats[:unique_users][activity.id] || 0 %>
                </div>
                <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.68rem; color:#9C9892; margin-top:2px;">estudantes</div>
              </div>
            </div>

            <div style="display:flex; gap:6px;">
              <%= link_to "Ver", activity_path(activity),
                    style: "flex:1; text-align:center; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; font-weight:600; color:#2563EB; padding:7px; border:1.5px solid #BFDBFE; border-radius:8px; text-decoration:none; background:#EBF2FC;" %>
              <% if current_user.teacher? %>
                <%= link_to "Editar", edit_activity_path(activity),
                      style: "flex:1; text-align:center; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; font-weight:500; color:#5C5853; padding:7px; border:1.5px solid #DDD9D2; border-radius:8px; text-decoration:none;" %>
              <% end %>
            </div>

          </div>
        <% end %>
      </div>

    <% end %>

  <% else %>

    <%# ESTADO VAZIO %>
    <div style="background:#fff; border:1px solid #DDD9D2; border-radius:16px; padding:48px; text-align:center;">
      <div style="font-size:2.5rem; margin-bottom:14px;">📝</div>
      <div style="font-family:'Raleway',sans-serif; font-size:1.1rem; font-weight:700; color:#1C1917; margin-bottom:8px;">
        <% if params[:search].present? || params[:level].present? %>
          Nenhuma atividade encontrada
        <% else %>
          Nenhuma atividade ainda
        <% end %>
      </div>
      <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; color:#5C5853; margin-bottom:20px;">
        <% if params[:search].present? || params[:level].present? %>
          Tente outros filtros ou <%= link_to "limpe a busca", activities_path, style: "color:#2563EB; text-decoration:none; font-weight:600;" %>.
        <% else %>
          Comece criando sua primeira atividade.
        <% end %>
      </div>
      <% if current_user.teacher? && params[:search].blank? && params[:level].blank? %>
        <%= link_to new_activity_path,
              style: "background:#C9952A; color:#fff; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700; padding:10px 24px; border-radius:10px; text-decoration:none; display:inline-block;" do %>
          + Nova Atividade
        <% end %>
      <% end %>
    </div>

  <% end %>

  <%# ── Rodapé: paginação + voltar ── %>
  <div style="display:flex; align-items:center; justify-content:center; flex-wrap:wrap; gap:12px; margin-bottom:2rem;">

    <%# Voltar %>
    <% dashboard_path = current_user.teacher? ? teacher_dashboard_path : student_dashboard_path %>
    <%= link_to dashboard_path,
          style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:600; color:#fff; background:#1A6B4A; padding:8px 18px; border:none; border-radius:8px; text-decoration:none; display:inline-block;" do %>
      ← Voltar
    <% end %>

    <%# Paginação %>
    <% if @activities.total_pages > 1 %>
      <div style="display:flex; align-items:center; gap:6px;">
        <% if @activities.prev_page %>
          <%= link_to activities_path(params.permit(:level, :sort, :search, :view).merge(page: @activities.prev_page)),
                style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:600; color:#fff; background:#0F3826; padding:8px 16px; border-radius:8px; text-decoration:none; display:inline-block;" do %>
            ← Anterior
          <% end %>
        <% else %>
          <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:600; color:#9C9892; background:#F0EDE8; padding:8px 16px; border-radius:8px; cursor:default; display:inline-block;">← Anterior</span>
        <% end %>

        <span style="font-family:'DM Mono',monospace; font-size:0.78rem; color:#5C5853; background:#F7F5F0; padding:8px 14px; border-radius:8px;">
          <%= @activities.current_page %>&nbsp;/&nbsp;<%= @activities.total_pages %>
        </span>

        <% if @activities.next_page %>
          <%= link_to activities_path(params.permit(:level, :sort, :search, :view).merge(page: @activities.next_page)),
                style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:600; color:#fff; background:#0F3826; padding:8px 16px; border-radius:8px; text-decoration:none; display:inline-block;" do %>
            Próxima →
          <% end %>
        <% else %>
          <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:600; color:#9C9892; background:#F0EDE8; padding:8px 16px; border-radius:8px; cursor:default; display:inline-block;">Próxima →</span>
        <% end %>
      </div>
    <% end %>

  </div>

</div>
