<% content_for :head do %>
  <title>Revisar Rascunho · <%= @activity.title %> · Practice-BR</title>
<% end %>

<div style="max-width:900px; margin:1.5rem auto 3rem; padding:0 1.5rem;">

  <%# Banner de rascunho %>
  <div style="background:linear-gradient(135deg,#FFF7ED 0%,#FFFBF0 100%); border:2px solid #C9952A; border-radius:16px; padding:20px 24px; margin-bottom:24px; display:flex; align-items:center; justify-content:space-between; gap:16px; flex-wrap:wrap;">
    <div>
      <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.92rem; font-weight:700; color:#7C4A00; margin-bottom:4px;">
        ✨ Rascunho gerado por IA — aguardando sua aprovação
      </div>
      <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; color:#A06000; line-height:1.5;">
        Revise o conteúdo abaixo. Esta atividade <strong>não está visível para os alunos</strong> até você publicar.
        Você pode editá-la normalmente depois de publicar.
      </div>
    </div>
    <div style="display:flex; gap:10px; flex-shrink:0;">
      <%= link_to edit_activity_path(@activity),
            style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:600; color:#5C5853; padding:9px 18px; border:1.5px solid #DDD9D2; border-radius:10px; text-decoration:none; background:#fff; white-space:nowrap;" do %>
        Editar
      <% end %>
      <%= button_to "✓ Publicar atividade", publish_draft_activity_path(@activity),
            method: :post,
            style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; font-weight:700; color:#fff; background:#1A6B4A; padding:9px 22px; border-radius:10px; border:none; cursor:pointer; white-space:nowrap;" %>
    </div>
  </div>

  <%# Header da atividade %>
  <%= render 'activity_header', activity: @activity %>

  <%# Exercícios gerados %>
  <%
    total_exercises = @questions.count + @sentence_orderings.count + @paragraph_orderings.count + @column_matchings.count
    exercise_index = 0
  %>
  <% if total_exercises > 0 %>
    <div style="background:#fff; border:1px solid #DDD9D2; border-radius:16px; padding:24px 28px; margin-top:24px;">
      <div style="font-family:'Raleway',sans-serif; font-size:1rem; font-weight:700; color:#1C1917; margin-bottom:18px; display:flex; align-items:center; gap:8px;">
        Exercícios gerados
        <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; font-weight:600; background:#E8F5EE; color:#1A6B4A; border:1.5px solid #2A9B6F; border-radius:20px; padding:3px 10px;">
          <%= total_exercises %> <%= total_exercises == 1 ? 'exercício' : 'exercícios' %>
        </span>
      </div>

      <div style="display:flex; flex-direction:column; gap:16px;">

        <%# Questões (multiple_choice + fill_in_blank) %>
        <% @questions.each do |q| %>
          <% exercise_index += 1 %>
          <div style="background:#FAFAF9; border:1px solid #F0EDE8; border-radius:12px; padding:18px 20px;">
            <div style="display:flex; align-items:flex-start; gap:12px;">
              <span style="font-family:'DM Mono',monospace; font-size:0.72rem; font-weight:700; background:#F0EDE8; color:#5C5853; border-radius:6px; padding:3px 8px; flex-shrink:0; margin-top:2px;">#<%= exercise_index %></span>
              <div style="flex:1;">
                <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.72rem; font-weight:600; color:#5C5853; background:#F0EDE8; border-radius:20px; padding:2px 9px; display:inline-block; margin-bottom:8px;">
                  <%= q.question_type == 'multiple_choice' ? 'Múltipla escolha' : 'Preencher lacuna' %>
                </span>
                <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; color:#1C1917; margin:0 0 10px 0; line-height:1.55; font-weight:500;"><%= q.content %></p>
                <% if q.multiple_choice? && q.options.present? %>
                  <div style="display:flex; flex-direction:column; gap:5px;">
                    <% q.options.each do |opt| %>
                      <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.83rem; padding:7px 12px; border-radius:8px; <%= opt == q.correct_answer ? "background:#E8F5EE; border:1.5px solid #2A9B6F; color:#0F3826; font-weight:600;" : "background:#fff; border:1px solid #F0EDE8; color:#5C5853;" %>">
                        <%= opt == q.correct_answer ? "✓ #{opt}" : opt %>
                      </div>
                    <% end %>
                  </div>
                <% elsif q.fill_in_blank? %>
                  <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.83rem; color:#1A6B4A; background:#E8F5EE; border:1.5px solid #2A9B6F; border-radius:8px; padding:7px 12px; display:inline-block;">
                    ✓ Resposta: <strong><%= q.correct_answer %></strong>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>

        <%# Ordenar palavras %>
        <% @sentence_orderings.each do |so| %>
          <% exercise_index += 1 %>
          <div style="background:#FAFAF9; border:1px solid #F0EDE8; border-radius:12px; padding:18px 20px;">
            <div style="display:flex; align-items:flex-start; gap:12px;">
              <span style="font-family:'DM Mono',monospace; font-size:0.72rem; font-weight:700; background:#F0EDE8; color:#5C5853; border-radius:6px; padding:3px 8px; flex-shrink:0; margin-top:2px;">#<%= exercise_index %></span>
              <div style="flex:1;">
                <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.72rem; font-weight:600; color:#5C5853; background:#F0EDE8; border-radius:20px; padding:2px 9px; display:inline-block; margin-bottom:8px;">Ordenar palavras</span>
                <% if so.instruction.present? %>
                  <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; color:#5C5853; margin:0 0 8px 0;"><em><%= so.instruction %></em></p>
                <% end %>
                <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.83rem; color:#1A6B4A; background:#E8F5EE; border:1.5px solid #2A9B6F; border-radius:8px; padding:7px 12px;">
                  ✓ <strong><%= so.sentence %></strong>
                </div>
              </div>
            </div>
          </div>
        <% end %>

        <%# Ordenar parágrafos %>
        <% @paragraph_orderings.each do |po| %>
          <% exercise_index += 1 %>
          <div style="background:#FAFAF9; border:1px solid #F0EDE8; border-radius:12px; padding:18px 20px;">
            <div style="display:flex; align-items:flex-start; gap:12px;">
              <span style="font-family:'DM Mono',monospace; font-size:0.72rem; font-weight:700; background:#F0EDE8; color:#5C5853; border-radius:6px; padding:3px 8px; flex-shrink:0; margin-top:2px;">#<%= exercise_index %></span>
              <div style="flex:1;">
                <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.72rem; font-weight:600; color:#5C5853; background:#F0EDE8; border-radius:20px; padding:2px 9px; display:inline-block; margin-bottom:8px;">Ordenar frases</span>
                <% if po.instruction.present? %>
                  <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; color:#5C5853; margin:0 0 8px 0;"><em><%= po.instruction %></em></p>
                <% end %>
                <div style="display:flex; flex-direction:column; gap:4px;">
                  <% po.paragraph_sentences.sort_by(&:correct_position).each_with_index do |s, idx| %>
                    <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.83rem; padding:6px 12px; border-radius:8px; background:#E8F5EE; border:1px solid #2A9B6F; color:#0F3826; display:flex; gap:8px;">
                      <span style="font-weight:700; flex-shrink:0;"><%= idx + 1 %>.</span> <%= s.sentence %>
                    </div>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        <% end %>

        <%# Associar colunas %>
        <% @column_matchings.each do |cm| %>
          <% exercise_index += 1 %>
          <div style="background:#FAFAF9; border:1px solid #F0EDE8; border-radius:12px; padding:18px 20px;">
            <div style="display:flex; align-items:flex-start; gap:12px;">
              <span style="font-family:'DM Mono',monospace; font-size:0.72rem; font-weight:700; background:#F0EDE8; color:#5C5853; border-radius:6px; padding:3px 8px; flex-shrink:0; margin-top:2px;">#<%= exercise_index %></span>
              <div style="flex:1;">
                <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.72rem; font-weight:600; color:#5C5853; background:#F0EDE8; border-radius:20px; padding:2px 9px; display:inline-block; margin-bottom:8px;">Associar colunas</span>
                <% if cm.instruction.present? %>
                  <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; color:#5C5853; margin:0 0 8px 0;"><em><%= cm.instruction %></em></p>
                <% end %>
                <div style="display:flex; flex-direction:column; gap:4px;">
                  <% cm.matching_pairs.sort_by(&:position).each do |pair| %>
                    <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.83rem; padding:6px 12px; border-radius:8px; background:#E8F5EE; border:1px solid #2A9B6F; color:#0F3826; display:flex; align-items:center; gap:10px;">
                      <span style="font-weight:600; flex:1;"><%= pair.left_item %></span>
                      <span style="color:#2A9B6F; flex-shrink:0;">→</span>
                      <span style="flex:1;"><%= pair.right_item %></span>
                    </div>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        <% end %>

      </div>
    </div>
  <% end %>

  <%# Botão publicar (rodapé) %>
  <div style="margin-top:28px; padding:24px 0; border-top:1px solid #F0EDE8; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px;">
    <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.83rem; color:#9C9892;">
      Quer ajustar algo? <%= link_to "Edite a atividade", edit_activity_path(@activity), style: "color:#1A6B4A; font-weight:600;" %> antes de publicar.
    </div>
    <%= button_to "✓ Publicar atividade para os alunos", publish_draft_activity_path(@activity),
          method: :post,
          style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; font-weight:700; color:#fff; background:#1A6B4A; padding:12px 28px; border-radius:12px; border:none; cursor:pointer;" %>
  </div>

</div>
