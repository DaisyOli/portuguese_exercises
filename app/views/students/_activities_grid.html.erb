<% activities.each do |activity| %>
  <% completed = session[:completed_quizzes]&.include?(activity.id) %>
  <% m = cefr_colors(activity.level) %>
  <% question_count = activity.questions_count.to_i %>
  <% cover = activity_cover(activity) %>
  <% act_comps = activity_competencies(activity, @open_ended_activity_ids || Set.new, @av_activity_ids || Set.new) %>

  <div class="activity-card">

    <%# Capa %>
    <div class="activity-card-cover" style="position:relative;">
      <% if cover[:type] == :image %>
        <img src="<%= cover[:url] %>" alt="" style="width:100%; height:100%; object-fit:cover; display:block;">
        <% if cover[:credit] %>
          <span style="position:absolute; bottom:3px; right:5px; font-size:0.55rem; color:rgba(255,255,255,0.6); line-height:1; pointer-events:none;"><%= cover[:credit] %></span>
        <% end %>
      <% else %>
        <div style="width:100%; height:100%; background:linear-gradient(135deg, <%= m[:bg] %> 0%, <%= m[:border] %>33 100%); display:flex; align-items:center; justify-content:center;">
          <i class="bi <%= cover[:icon] %>" style="font-size:2.8rem; color:<%= m[:border] %>; opacity:0.55;"></i>
        </div>
      <% end %>
    </div>

    <%# Conteúdo %>
    <div style="padding:16px 18px; flex:1; display:flex; flex-direction:column;">

      <div style="display:flex; align-items:center; justify-content:space-between; gap:8px; margin-bottom:8px;">
        <div style="display:flex; align-items:center; gap:6px;">
          <span style="font-family:'DM Mono',monospace; font-size:0.72rem; font-weight:700; background:<%= m[:bg] %>; color:<%= m[:text] %>; border:1.5px solid <%= m[:border] %>; padding:3px 9px; border-radius:20px;">
            <%= activity.level %>
          </span>
          <% act_comps.each do |comp| %>
            <% cm = ApplicationHelper::COMPETENCY_META[comp] %>
            <span style="font-family:'DM Mono',monospace; font-size:0.68rem; font-weight:800; background:<%= cm[:bg] %>; color:<%= cm[:color] %>; border:1.5px solid <%= cm[:color] %>55; padding:3px 8px; border-radius:20px; display:inline-flex; align-items:center; gap:3px; letter-spacing:0.03em;">
              <%= cm[:icon] %> <%= cm[:abbr] %>
            </span>
          <% end %>
        </div>
        <% if completed %>
          <span style="font-size:0.7rem; background:var(--brand-tint); color:var(--brand); border:1px solid var(--brand-bright); border-radius:99px; padding:2px 8px; font-family:'Plus Jakarta Sans',sans-serif; font-weight:700;">
            ✓ Feita
          </span>
        <% end %>
      </div>

      <h3 style="font-family:'Raleway',sans-serif; font-size:1rem; font-weight:700; color:var(--ink); margin:0 0 6px 0; line-height:1.35;">
        <%= activity.title %>
      </h3>

      <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.83rem; color:var(--ink-soft); margin:0 0 12px 0; line-height:1.5; flex:1;">
        <%= truncate(activity.description.presence || "Pratique português com exercícios interativos.", length: 80) %>
      </p>

      <div style="display:flex; gap:12px; flex-wrap:wrap; margin-bottom:14px;">
        <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.77rem; color:var(--ink-faint); display:flex; align-items:center; gap:4px;">
          <i class="bi bi-patch-question" style="color:<%= m[:border] %>;"></i>
          <%= question_count %> <%= question_count == 1 ? 'questão' : 'questões' %>
        </span>
        <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.77rem; color:var(--ink-faint); display:flex; align-items:center; gap:4px;">
          <i class="bi bi-clock" style="color:<%= m[:border] %>;"></i>
          ~<%= [1, (question_count * 1.5).round].max %> min
        </span>
        <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.77rem; color:var(--ink-faint); display:flex; align-items:center; gap:4px;">
          <i class="bi bi-bar-chart-line" style="color:<%= m[:border] %>;"></i>
          <%= m[:label] %>
        </span>
        <% rc = activity.ratings_count; avg = activity.average_rating %>
        <% if rc > 0 %>
          <span style="font-family:'DM Mono',monospace; font-size:0.77rem; font-weight:700; color:var(--action); display:flex; align-items:center; gap:3px;">
            <i class="bi bi-star-fill" style="font-size:0.68rem;"></i> <%= avg %>
          </span>
        <% end %>
      </div>

      <div style="display:flex; align-items:center; justify-content:space-between; gap:10px; padding-top:12px; border-top:1px solid var(--line-soft);">
        <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.77rem; color:var(--ink-faint); display:flex; align-items:center; gap:4px; min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
          <i class="bi bi-person" style="flex-shrink:0;"></i> Prof. <%= activity.teacher&.display_name %>
        </span>
        <%= link_to solve_activity_path(activity),
              style: "flex-shrink:0; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700; padding:9px 20px; border-radius:10px; text-decoration:none; display:inline-flex; align-items:center; gap:6px; #{completed ? 'background:var(--paper); color:var(--ink-soft); border:1.5px solid var(--line);' : "background:#{m[:border]}; color:var(--surface);"}" do %>
          <% if completed %>
            <i class="bi bi-arrow-clockwise"></i> <%= t('student_dashboard.actions.retry_quiz') %>
          <% else %>
            <i class="bi bi-play-fill"></i> <%= t('activities.solve_quiz') %>
          <% end %>
        <% end %>
      </div>

    </div>
  </div>
<% end %>
