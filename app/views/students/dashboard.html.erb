<% content_for :head do %>
  <title>Dashboard · Practice-BR</title>
<% end %>

<%
  completed_ids   = session[:completed_quizzes] || []
  current_streak  = session[:current_streak].to_i
  last_score      = session[:last_quiz_score]
  total_count     = @activities.count
  completed_count = completed_ids.length
  progress_pct    = total_count > 0 ? ((completed_count.to_f / total_count) * 100).round : 0

  cefr_colors = {
    'A1' => { bg:'#E8F5EE', text:'#0F3826', border:'#2A9B6F', bar:'#2A9B6F', label:'Iniciante' },
    'A2' => { bg:'#EBF2FC', text:'#1A4A8A', border:'#2563EB', bar:'#2563EB', label:'Básico' },
    'B1' => { bg:'#F5F3FF', text:'#4C1D95', border:'#7C3AED', bar:'#7C3AED', label:'Intermediário' },
    'B2' => { bg:'#FFF7ED', text:'#7C2D12', border:'#EA580C', bar:'#EA580C', label:'Avançado' },
    'C1' => { bg:'#F3F4F6', text:'#1C1917', border:'#374151', bar:'#374151', label:'Fluente' },
  }
%>

<div style="max-width:1000px; margin:0 auto; padding:2rem 1.5rem;">

<% if params[:level].present? %>

  <%# ══════════════════════════════════════════════ %>
  <%# VISTA DE NÍVEL ESPECÍFICO                      %>
  <%# ══════════════════════════════════════════════ %>

  <%# — Breadcrumb / back — %>
  <div style="display:flex; align-items:center; gap:10px; margin-bottom:1.5rem;">
    <%= link_to student_dashboard_path,
          style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; color:#5C5853; text-decoration:none; display:flex; align-items:center; gap:4px;" do %>
      ← Todos os níveis
    <% end %>
    <% if @current_level %>
      <% c = cefr_colors[@current_level] || cefr_colors['A1'] %>
      <span style="font-family:'DM Mono',monospace; font-size:0.72rem; font-weight:700;
                   background:<%= c[:bg] %>; color:<%= c[:text] %>; border:1.5px solid <%= c[:border] %>;
                   padding:3px 10px; border-radius:20px;">
        <%= @current_level %>
      </span>
    <% end %>
  </div>

  <% if @current_level.present? %>

    <% if @pending_activities.any? %>
      <h2 style="font-family:'Raleway',sans-serif; font-size:1.1rem; font-weight:700; color:#1C1917; margin-bottom:1rem;">
        Atividades disponíveis
      </h2>
      <div class="activities-grid" id="activities-container">
        <%= render 'activities_grid', activities: @pending_activities %>
      </div>

      <% if @total_pending > 3 %>
        <div class="text-center mt-4">
          <button class="btn-giz secondary load-more-btn"
                  data-level="<%= @current_level %>"
                  data-offset="3"
                  data-total="<%= @total_pending %>">
            + Carregar mais (<%= [@total_pending - 3, 0].max %> restantes)
          </button>
          <div class="loading-spinner d-none">Carregando...</div>
        </div>
      <% end %>

      <% if @completed_activities.any? %>
        <div class="mt-4">
          <button style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:600;
                         color:#5C5853; background:transparent; border:1.5px solid #DDD9D2;
                         padding:8px 18px; border-radius:10px; cursor:pointer;"
                  data-bs-toggle="collapse" data-bs-target="#completed-activities">
            ✓ Ver atividades concluídas (<%= @completed_activities.count %>)
          </button>
          <div class="collapse mt-3" id="completed-activities">
            <div class="activities-grid">
              <%= render 'activities_grid', activities: @completed_activities %>
            </div>
          </div>
        </div>
      <% end %>

    <% else %>
      <%# Nível completado %>
      <div style="background:#E8F5EE; border:1.5px solid #2A9B6F; border-radius:16px; padding:32px; text-align:center; margin-bottom:1.5rem;">
        <div style="font-size:2.5rem; margin-bottom:12px;">🏆</div>
        <h2 style="font-family:'Raleway',sans-serif; font-size:1.2rem; font-weight:700; color:#0F3826; margin-bottom:8px;">
          Nível <%= @current_level %> completo!
        </h2>
        <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; color:#1A6B4A;">
          Você concluiu todas as atividades deste nível. Parabéns!
        </p>

        <% if @completed_activities.any? %>
          <button style="margin-top:16px; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem;
                         font-weight:600; color:#0F3826; background:transparent; border:1.5px solid #2A9B6F;
                         padding:8px 20px; border-radius:10px; cursor:pointer;"
                  data-bs-toggle="collapse" data-bs-target="#completed-activities">
            Revisar atividades →
          </button>
          <div class="collapse mt-3" id="completed-activities">
            <div class="activities-grid">
              <%= render 'activities_grid', activities: @completed_activities %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

  <% else %>
    <%# Nível sem atividades %>
    <div style="background:#fff; border:1px solid #DDD9D2; border-radius:16px; padding:32px; text-align:center;">
      <div style="font-size:2rem; margin-bottom:12px;">🔍</div>
      <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; color:#5C5853; margin-bottom:16px;">
        Nenhuma atividade disponível neste nível ainda.
      </p>
      <%= link_to "← Explorar outros níveis", student_dashboard_path,
            style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:600;
                    color:#2563EB; text-decoration:none;" %>
    </div>
  <% end %>

<% else %>

  <%# ══════════════════════════════════════════════ %>
  <%# VISTA PRINCIPAL — seletor de níveis            %>
  <%# ══════════════════════════════════════════════ %>

  <%# — Saudação — %>
  <div style="margin-bottom:2rem;">
    <h1 style="font-family:'Raleway',sans-serif; font-size:1.75rem; font-weight:700; color:#1C1917; margin-bottom:4px;">
      Olá<% if current_user.greeting_name %>, <%= current_user.greeting_name %><% end %>! 👋
    </h1>
    <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.95rem; color:#5C5853;">
      Continue praticando — você está no caminho certo.
    </p>
  </div>

  <%# — 4 Cards de Métricas — %>
  <div style="display:grid; grid-template-columns:repeat(4,1fr); gap:1rem; margin-bottom:2rem;">

    <div style="background:#fff; border:1px solid #DDD9D2; border-radius:14px; padding:20px 22px;">
      <div style="font-family:'DM Mono',monospace; font-size:0.68rem; color:#9C9892; letter-spacing:0.08em; text-transform:uppercase; margin-bottom:8px;">Concluídas</div>
      <div style="font-family:'Raleway',sans-serif; font-size:2rem; font-weight:800; color:#2A9B6F; line-height:1;"><%= completed_count %></div>
      <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; color:#5C5853; margin-top:6px;">atividades feitas</div>
    </div>

    <div style="background:#FBF3E0; border:1px solid #E8C97A; border-radius:14px; padding:20px 22px;">
      <div style="font-family:'DM Mono',monospace; font-size:0.68rem; color:#9C7A30; letter-spacing:0.08em; text-transform:uppercase; margin-bottom:8px;">Sequência</div>
      <div style="display:flex; align-items:baseline; gap:6px;">
        <div style="font-family:'Raleway',sans-serif; font-size:2rem; font-weight:800; color:#C9952A; line-height:1;"><%= current_streak %></div>
        <div style="font-size:1.1rem;">🔥</div>
      </div>
      <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; color:#8B6914; margin-top:6px;">dias seguidos</div>
    </div>

    <div style="background:#fff; border:1px solid #DDD9D2; border-radius:14px; padding:20px 22px;">
      <div style="font-family:'DM Mono',monospace; font-size:0.68rem; color:#9C9892; letter-spacing:0.08em; text-transform:uppercase; margin-bottom:8px;">Progresso</div>
      <div style="font-family:'Raleway',sans-serif; font-size:2rem; font-weight:800; color:#2563EB; line-height:1;"><%= progress_pct %>%</div>
      <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; color:#5C5853; margin-top:6px;">do total de atividades</div>
    </div>

    <div style="background:#fff; border:1px solid #DDD9D2; border-radius:14px; padding:20px 22px;">
      <div style="font-family:'DM Mono',monospace; font-size:0.68rem; color:#9C9892; letter-spacing:0.08em; text-transform:uppercase; margin-bottom:8px;">Última nota</div>
      <div style="font-family:'Raleway',sans-serif; font-size:2rem; font-weight:800; color:#7C3AED; line-height:1;"><%= last_score || '--' %></div>
      <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; color:#5C5853; margin-top:6px;">no último exercício</div>
    </div>

  </div>

  <%# — Cabeçalho do grid de níveis — %>
  <div style="display:flex; align-items:baseline; justify-content:space-between; margin-bottom:0.75rem;">
    <h2 style="font-family:'Raleway',sans-serif; font-size:1.1rem; font-weight:700; color:#1C1917;">Escolha um Nível</h2>
    <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; color:#9C9892;">
      <%= completed_count %>/<%= total_count %> atividades concluídas
    </span>
  </div>

  <%# — Grid de Níveis — %>
  <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:1rem; margin-bottom:2rem;">
    <% Activity.levels.keys.each do |level| %>
      <% level_activities   = @activities_by_level[level] || [] %>
      <% completed_in_level = completed_ids & level_activities.map(&:id) %>
      <% level_count        = level_activities.count %>
      <% level_done         = completed_in_level.length %>
      <% level_pct          = level_count > 0 ? ((level_done.to_f / level_count) * 100).round : 0 %>
      <% c = cefr_colors[level] %>
      <% empty = level_activities.empty? %>

      <div style="background:#fff; border:1px solid #DDD9D2; border-radius:16px; padding:24px; opacity:<%= empty ? '0.55' : '1' %>;">

        <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:14px;">
          <span style="font-family:'DM Mono',monospace; font-size:0.75rem; font-weight:700;
                       background:<%= c[:bg] %>; color:<%= c[:text] %>; border:1.5px solid <%= c[:border] %>;
                       padding:4px 12px; border-radius:20px;">
            <%= level %>
          </span>
          <span style="font-family:'DM Mono',monospace; font-size:0.72rem; color:<%= empty ? '#9C9892' : (level_done > 0 ? c[:bar] : '#9C9892') %>; font-weight:600;">
            <% if empty %>em breve<% else %><%= level_done %>/<%= level_count %> ✓<% end %>
          </span>
        </div>

        <div style="font-family:'Raleway',sans-serif; font-size:1rem; font-weight:700; color:#1C1917; margin-bottom:4px;">
          <%= c[:label] %>
        </div>
        <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.8rem; color:#5C5853; margin-bottom:16px; line-height:1.45;">
          <%= case level
              when 'A1' then t('student_dashboard.level_descriptions.a1')
              when 'A2' then t('student_dashboard.level_descriptions.a2')
              when 'B1' then t('student_dashboard.level_descriptions.b1')
              when 'B2' then t('student_dashboard.level_descriptions.b2')
              when 'C1' then t('student_dashboard.level_descriptions.c1')
              end %>
        </div>

        <div style="background:#F0EDE8; border-radius:99px; height:6px; overflow:hidden; margin-bottom:6px;">
          <div style="width:<%= level_pct %>%; height:100%; border-radius:99px; background:<%= c[:bar] %>;"></div>
        </div>
        <div style="font-family:'DM Mono',monospace; font-size:0.7rem; color:#9C9892; margin-bottom:16px;">
          <%= level_pct %>% completo
        </div>

        <% if empty %>
          <div style="display:block; text-align:center; background:#DDD9D2; color:#9C9892;
                      font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:700;
                      padding:9px; border-radius:10px; cursor:not-allowed;">
            Em breve
          </div>
        <% else %>
          <%= link_to student_dashboard_path(level: level),
                style: "display:block; text-align:center; background:#0F3826; color:#fff;
                        font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:700;
                        padding:9px; border-radius:10px; text-decoration:none;" do %>
            <%= level_done > 0 ? 'Continuar →' : 'Explorar →' %>
          <% end %>
        <% end %>

      </div>
    <% end %>
  </div>

  <%# — Conquistas (só se tiver badges) — %>
  <% achieved_badges = get_all_achieved_badges(current_streak) %>
  <% if achieved_badges.any? %>
    <div style="background:#fff; border:1px solid #DDD9D2; border-radius:16px; padding:24px; margin-bottom:2rem;">
      <h2 style="font-family:'Raleway',sans-serif; font-size:1.1rem; font-weight:700; color:#1C1917; margin-bottom:16px;">
        🏆 Conquistas
      </h2>
      <div style="display:flex; gap:12px; flex-wrap:wrap;">
        <% achieved_badges.each do |badge| %>
          <div style="background:#FBF3E0; border:1.5px solid #E8C97A; border-radius:12px; padding:14px 18px; text-align:center; min-width:110px;">
            <div style="font-size:1.8rem; margin-bottom:6px;"><%= badge[:icon] %></div>
            <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.8rem; font-weight:700; color:#1C1917; margin-bottom:2px;"><%= badge[:name] %></div>
            <div style="font-family:'DM Mono',monospace; font-size:0.68rem; color:#9C7A30;"><%= badge[:days] %> dias</div>
          </div>
        <% end %>

        <% next_badge = get_next_badge(current_streak) %>
        <% if next_badge %>
          <% days_left = get_days_to_next_badge(current_streak) %>
          <div style="background:#F7F5F0; border:1.5px dashed #DDD9D2; border-radius:12px; padding:14px 18px; text-align:center; min-width:110px; opacity:0.5;">
            <div style="font-size:1.8rem; margin-bottom:6px;"><%= next_badge[:icon] %></div>
            <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.8rem; font-weight:700; color:#1C1917; margin-bottom:2px;"><%= next_badge[:name] %></div>
            <div style="font-family:'DM Mono',monospace; font-size:0.68rem; color:#9C9892;"><%= days_left %> dias restantes</div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

<% end %>

  <%# ── CTA Footer ── %>
  <% if params[:level].blank? %>
    <div style="display:flex; justify-content:center; padding-bottom:2rem;">
      <%= link_to activities_path,
            style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; font-weight:700;
                    background:#1A6B4A; color:#fff; padding:13px 32px; border-radius:12px;
                    text-decoration:none; display:inline-flex; align-items:center; gap:8px;" do %>
        Ver Todas as Atividades →
      <% end %>
    </div>
  <% end %>

</div>
