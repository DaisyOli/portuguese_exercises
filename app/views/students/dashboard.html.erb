<% content_for :head do %>
  <title><%= t('student_dashboard.welcome') %> - Practice PT</title>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Kalam:wght@400;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  
  <style>
    /* 🎨 BACKGROUND MIGRADO PARA _student_components.scss */

    /* 📐 GRIDS MIGRADOS PARA _student_components.scss */

    /* 🏆 LEVEL BADGES MIGRADOS PARA _student_components.scss */

    /* ✨ ANIMAÇÕES MIGRADAS PARA _student_components.scss */

    /* 🚨 CORREÇÕES DE CONTAINER E ALERTAS MIGRADAS PARA _student_components.scss */

    /* ANIMAÇÕES E INDICADOR MIGRADOS PARA _student_components.scss */

    /* 🇧🇷 SISTEMA DE STREAKS BRASILEIRO MIGRADO PARA _student_components.scss */

    /* ⚡ CARREGAMENTO PROGRESSIVO E ATIVIDADES COMPLETADAS MIGRADOS PARA _student_components.scss */
    
    /* post-it.verde h3 MIGRADO PARA _student_components.scss */
    
     /* ANIMAÇÕES DUPLICADAS REMOVIDAS */

     /* Smooth scroll behavior - mais agressivo */
     html {
       scroll-behavior: smooth;
     }
     
     * {
       scroll-behavior: smooth;
     }

     #activities,
     #levels {
       scroll-margin-top: 20px; /* Offset para não ficar grudado no topo */
     }
    /* BADGES BRASILEIROS ADICIONAIS MIGRADOS PARA _student_components.scss */

    /* Animação sutil para o ícone do badge atual */
    .streak-card .metrica-icon {
      animation: gentlePulse 3s ease-in-out infinite;
    }

         @keyframes gentlePulse {
       0%, 100% { transform: scale(1); }
       50% { transform: scale(1.05); }
     }

     /* 🎖️ GALERIA DE CONQUISTAS */
     .badges-gallery {
       display: grid;
       grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
       gap: var(--spacing-md);
       margin: var(--spacing-lg) 0;
     }

     .achievement-badge {
       background: rgba(255,255,255,0.9);
       border-radius: var(--border-radius-md);
       padding: var(--spacing-sm);
       border: 2px solid #ddd;
       transition: all 0.3s ease;
       text-align: center;
     }

     .achievement-badge:hover {
       transform: translateY(-2px);
       box-shadow: 0 4px 15px rgba(0,0,0,0.1);
     }

     .badge-icon {
       font-size: 2rem;
       margin-bottom: var(--spacing-xs);
     }

     .badge-title {
       font-weight: 600;
       font-size: 0.9rem;
       color: var(--texto-escuro);
       margin-bottom: 2px;
     }

     .badge-days {
       font-size: 0.8rem;
       color: #666;
       margin-bottom: var(--spacing-xs);
     }

     .badge-quote {
       font-size: 0.75rem;
       font-style: italic;
       color: #888;
       line-height: 1.3;
     }

     .next-challenge {
       margin-top: var(--spacing-md);
       padding: var(--spacing-sm);
       background: rgba(255,255,255,0.5);
       border-radius: var(--border-radius-sm);
       border: 1px dashed #ccc;
     }

     .streak-motivation {
       color: #666;
       font-weight: 500;
       background: rgba(255,255,255,0.3);
       padding: var(--spacing-xs);
       border-radius: var(--border-radius-sm);
       margin-top: var(--spacing-sm);
     }

    /* @keyframes pulse MIGRADO PARA _student_components.scss */

    /* Barra de progresso personalizada */
    .progress-bar-custom {
      background: #e0e0e0;
      height: 8px;
      border-radius: 4px;
      overflow: hidden;
      margin-top: var(--spacing-sm);
    }

    .progress-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--verde-destaque), #4caf50);
      border-radius: 4px;
      transition: width 1s ease;
    }
  </style>
<% end %>
  <div class="student-dashboard-page">
    <div class="student-container">
    
    <!-- ✅ Header personalizado para estudante -->
    <div class="header-custom azul">
      <div class="professor-info text-center">
        <h1><i class="fas fa-graduation-cap"></i> 
          <% if current_user.greeting_name %>
            <%= t('student_dashboard.welcome_with_name', name: current_user.greeting_name) %>
          <% else %>
            <%= t('student_dashboard.welcome') %>
          <% end %>
        </h1>
        <p>
          <% if current_user.greeting_name %>
            <%= t('student_dashboard.welcome_back_with_name', name: current_user.greeting_name) %>
          <% else %>
            <%= t('student_dashboard.welcome_back') %>
          <% end %>
          🚀
        </p>
      </div>
    </div>

    <!-- ✅ Métricas pessoais do estudante -->
    <div class="metrics-grid">
      
      <!-- Atividades Concluídas -->
      <div class="card-metrica hover-scale">
        <div class="metrica-icon">
          <i class="fas fa-check-circle"></i>
        </div>
        <div class="metrica-numero">
          <%= session[:completed_quizzes]&.length || 0 %>
        </div>
        <div class="metrica-label"><%= t('student_dashboard.metrics.completed_activities') %></div>
      </div>
      
      <!-- Sistema de Streaks Brasileiro -->
      <% current_streak = session[:current_streak] || 0 %>
      <% current_badge = get_current_badge(current_streak) %>
      <% next_badge = get_next_badge(current_streak) %>
      <% days_to_next = get_days_to_next_badge(current_streak) %>
      
      <div class="card-metrica hover-scale streak-card <%= current_badge[:class] %>">
        <div class="metrica-icon">
          <%= current_badge[:icon] %>
        </div>
        <div class="metrica-numero">
          <%= current_streak %>
        </div>
        <div class="metrica-label"><%= t('student_dashboard.metrics.streak_days') %></div>
        
        <!-- Badge Atual -->
        <% if current_streak > 0 %>
          <div class="current-badge">
            <span class="badge-name"><%= current_badge[:name] %></span>
            <span class="badge-phrase">"<%= current_badge[:phrase] %>"</span>
          </div>
        <% end %>
        
        <!-- Próximo Marco -->
        <% if next_badge && days_to_next %>
          <div class="next-milestone">
            <div class="next-badge-info">
              <%= next_badge[:icon] %> <%= next_badge[:name] %>
            </div>
                         <div class="days-remaining">
               <%= days_to_next == 1 ? t('student_dashboard.messages.tomorrow') : "#{t('student_dashboard.messages.in_days')} #{days_to_next} #{t('student_dashboard.messages.days')}" %>
             </div>
            
            <!-- Barra de progresso entre marcos -->
            <div class="milestone-progress">
              <div class="milestone-progress-bar" style="width: <%= get_streak_progress_percentage(current_streak) %>%"></div>
            </div>
          </div>
        <% end %>
      </div>
      
      <!-- Progresso Geral -->
      <div class="card-metrica hover-scale">
        <div class="metrica-icon">
          <i class="fas fa-chart-line"></i>
        </div>
        <div class="metrica-numero">
          <%= session[:completed_quizzes]&.length.to_i > 0 && @activities.count > 0 ? ((session[:completed_quizzes].length.to_f / @activities.count) * 100).round : 0 %>%
        </div>
        <div class="metrica-label"><%= t('student_dashboard.metrics.total_progress') %></div>
      </div>
      
      <!-- Última Pontuação -->
      <div class="card-metrica hover-scale">
        <div class="metrica-icon">
          <i class="fas fa-star"></i>
        </div>
        <div class="metrica-numero">
          <%= session[:last_quiz_score] || '--' %>
        </div>
        <div class="metrica-label"><%= t('student_dashboard.metrics.last_score') %></div>
      </div>
      
    </div>

    <% if params[:level].present? %>
      <!-- ✅ Vista de nível específico -->
      <div class="post-it azul-gelo" id="activities">
        <h2>
          <i class="fas fa-layer-group"></i>
          Nível <%= @current_level %>
          <span class="level-badge <%= @current_level %>"><%= @current_level %></span>
        </h2>
        <p>Explore todas as atividades deste nível e domine o português!</p>
        <div class="text-center mt-3">
          <%= link_to student_dashboard_path + "#levels", class: "btn-mini ver back-to-levels-btn" do %>
            <i class="fas fa-arrow-left"></i> <%= t('activities.back_to_all') %>
          <% end %>
        </div>
      </div>

      <!-- ✅ Atividades do nível específico com carregamento progressivo -->
      <% if @current_level.present? %>
        <!-- Seção de atividades pendentes -->
        <% if @pending_activities.any? %>
          <div class="activities-section">
            <div class="activities-grid" id="activities-container">
              <%= render 'activities_grid', activities: @pending_activities %>
            </div>
            
            <!-- Botão "Carregar Mais" -->
            <% if @total_pending > 3 %>
              <div class="load-more-section text-center mt-4">
                <button class="btn-giz secondary load-more-btn" 
                        data-level="<%= @current_level %>" 
                        data-offset="3"
                        data-total="<%= @total_pending %>">
                  <i class="fas fa-plus"></i>
                  <%= t('student_dashboard.actions.load_more') %> 
                  (<%= [@total_pending - 3, 0].max %> <%= t('student_dashboard.messages.remaining') %>)
                </button>
                <div class="loading-spinner d-none">
                  <i class="fas fa-spinner fa-spin"></i>
                  <%= t('student_dashboard.messages.loading') %>...
                </div>
              </div>
            <% end %>
          </div>
          
          <!-- Seção de atividades completadas (colapsável) -->
          <% if @completed_activities.any? %>
            <div class="completed-activities-section mt-4">
              <button class="btn-toggle-completed btn-giz secondary" data-bs-toggle="collapse" data-bs-target="#completed-activities">
                <i class="fas fa-check-circle"></i>
                <%= t('student_dashboard.actions.show_completed') %> (<%= @completed_activities.count %>)
                <i class="fas fa-chevron-down toggle-icon"></i>
              </button>
              
              <div class="collapse mt-3" id="completed-activities">
                <div class="activities-grid">
                  <%= render 'activities_grid', activities: @completed_activities %>
                </div>
              </div>
            </div>
          <% end %>
        <% else %>
          <!-- Todas as atividades deste nível foram completadas -->
          <div class="post-it verde text-center">
            <h3><i class="fas fa-trophy"></i> <%= t('student_dashboard.messages.level_completed') %></h3>
            <p><%= t('student_dashboard.messages.level_completed_desc', level: @current_level) %></p>
            <% if @completed_activities.any? %>
              <button class="btn-giz mt-2" data-bs-toggle="collapse" data-bs-target="#completed-activities">
                <i class="fas fa-redo"></i>
                <%= t('student_dashboard.actions.review_activities') %>
              </button>
              
              <div class="collapse mt-3" id="completed-activities">
                <div class="activities-grid">
                  <%= render 'activities_grid', activities: @completed_activities %>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      <% elsif @activities.any? %>
        <!-- Vista geral (manter compatibilidade) -->
        <div class="activities-grid">
          <%= render 'activities_grid', activities: @activities %>
        </div>
      <% else %>
        <!-- Nenhuma atividade neste nível -->
        <div class="post-it pessego text-center">
          <h3><i class="fas fa-info-circle"></i> Oops!</h3>
          <p><%= t('student_dashboard.messages.no_activities_level') %> <%= @current_level %>.</p>
          <p><%= t('student_dashboard.messages.try_other_levels') %></p>
                     <%= link_to student_dashboard_path + "#levels", class: "btn-giz mt-2 back-to-levels-btn" do %>
             <i class="fas fa-search"></i> <%= t('student_dashboard.actions.explore_levels') %>
           <% end %>
        </div>
      <% end %>

    <% else %>
      <!-- ✅ Vista geral - escolha de níveis -->
      <div class="post-it menta" id="levels">
        <h2><i class="fas fa-rocket"></i> <%= t('student_dashboard.choose_level') %></h2>
        <p><%= t('student_dashboard.choose_level_description') %></p>
        
        <!-- Barra de progresso geral -->
        <div class="progress-bar-custom mt-3">
          <div class="progress-fill" style="width: <%= session[:completed_quizzes]&.length.to_i > 0 && @activities.count > 0 ? ((session[:completed_quizzes].length.to_f / @activities.count) * 100).round : 0 %>%"></div>
        </div>
                           <div class="text-center mt-2 text-small">
            <%= t('student_dashboard.messages.general_progress') %>: <%= session[:completed_quizzes]&.length || 0 %>/<%= @activities.count %> <%= t('student_dashboard.messages.activities_text') %>
          </div>
         <div class="text-center mt-2 text-small streak-motivation">
           <%= get_motivational_message(session[:current_streak] || 0) %>
         </div>
      </div>

      <div class="levels-grid">
        <% Activity.levels.keys.each do |level| %>
          <% level_activities = @activities_by_level[level] || [] %>
          <% completed_in_level = (session[:completed_quizzes] || []) & level_activities.map(&:id) %>
          
          <div class="card-atividade hover-lift">
            <div class="card-header text-center">
              <span class="level-badge <%= level %>"><%= level %></span>
                             <h3 class="card-title mt-2">
                 <%= case level
                     when 'A1' then t('student_dashboard.levels.beginner')
                     when 'A2' then t('student_dashboard.levels.basic')
                     when 'B1' then t('student_dashboard.levels.intermediate') 
                     when 'B2' then t('student_dashboard.levels.advanced')
                     when 'C1' then t('student_dashboard.levels.expert')
                     end %>
               </h3>
            </div>
            
            <div class="card-content text-center">
                             <p class="card-description">
                 <%= case level
                     when 'A1' then t('student_dashboard.level_descriptions.a1')
                     when 'A2' then t('student_dashboard.level_descriptions.a2')
                     when 'B1' then t('student_dashboard.level_descriptions.b1')
                     when 'B2' then t('student_dashboard.level_descriptions.b2')
                     when 'C1' then t('student_dashboard.level_descriptions.c1')
                     end %>
               </p>
              
              <div class="card-meta">
                <span class="meta-item">
                  <i class="fas fa-clipboard-list"></i>
                  <%= level_activities.count %> atividades
                </span>
                <span class="meta-item">
                  <i class="fas fa-check-circle text-verde"></i>
                  <%= completed_in_level.length %> concluídas
                </span>
              </div>
              
              <!-- Progress bar do nível -->
              <div class="progress-bar-custom mt-3">
                <div class="progress-fill" 
                     style="width: <%= level_activities.count > 0 ? ((completed_in_level.length.to_f / level_activities.count) * 100).round : 0 %>%">
                </div>
              </div>
              <div class="text-small mt-1">
                <%= level_activities.count > 0 ? ((completed_in_level.length.to_f / level_activities.count) * 100).round : 0 %>% completo
              </div>
            </div>
            
            <div class="card-actions">
              <%= link_to student_dashboard_path(level: level) + "#activities", 
                    class: "btn-giz #{level_activities.empty? ? 'secondary' : ''} level-link", 
                    data: { level: level } do %>
                <% if level_activities.empty? %>
                  <i class="fas fa-clock"></i>
                  Em Breve
                <% else %>
                  <i class="fas fa-arrow-right"></i>
                  <%= t('activities.view_level') %>
                <% end %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <!-- ✅ Galeria de Conquistas Brasileiras -->
    <% current_streak = session[:current_streak] || 0 %>
    <% achieved_badges = get_all_achieved_badges(current_streak) %>
    
    <% if achieved_badges.any? %>
             <div class="post-it menta text-center mt-4">
         <h3><i class="fas fa-trophy"></i> <%= t('student_dashboard.achievements') %></h3>
         <p><%= t('student_dashboard.achievements_description') %></p>
        
        <div class="badges-gallery">
          <% achieved_badges.each do |badge| %>
            <div class="achievement-badge <%= badge[:class] %>">
              <div class="badge-icon"><%= badge[:icon] %></div>
              <div class="badge-details">
                <div class="badge-title"><%= badge[:name] %></div>
                <div class="badge-days"><%= badge[:days] %> dias</div>
                <div class="badge-quote">"<%= badge[:phrase] %>"</div>
              </div>
            </div>
          <% end %>
        </div>
        
        <% next_badge = get_next_badge(current_streak) %>
        <% if next_badge %>
                     <div class="next-challenge">
             <p><strong><%= t('student_dashboard.messages.next_challenge') %>:</strong> <%= next_badge[:icon] %> <%= next_badge[:name] %> <%= t('student_dashboard.messages.in_days') %> <%= get_days_to_next_badge(current_streak) %> <%= t('student_dashboard.messages.days') %>!</p>
           </div>
        <% end %>
      </div>
    <% end %>



    <!-- ✅ Ações do estudante -->
    <div class="post-it lavanda text-center mt-4">
      <h3><i class="fas fa-user-graduate"></i> <%= t('student_dashboard.your_profile') %></h3>
      <p><%= t('student_dashboard.connected_as') %>: <strong><%= current_user.display_name %></strong></p>
      
      <div class="d-flex justify-center gap-2 mt-3">
        <%= button_to destroy_user_session_path, method: :delete, 
              class: "btn-form secondary", 
              data: { turbo: false } do %>
          <i class="fas fa-sign-out-alt"></i>
          <%= t('auth.sign_out') %>
        <% end %>
      </div>
    </div>
  </div>
</div>

  <!-- ✅ Scripts para melhorar a experiência -->
  <script>
    function initializeStudentDashboard() {
      // Animação das barras de progresso
      const progressBars = document.querySelectorAll('.progress-fill');
      progressBars.forEach(bar => {
        const width = bar.style.width;
        bar.style.width = '0%';
        setTimeout(() => {
          bar.style.width = width;
        }, 500);
      });

      // Efeito hover nos cards de métricas
      const metricCards = document.querySelectorAll('.card-metrica');
      metricCards.forEach(card => {
        card.addEventListener('mouseenter', function() {
          this.style.transform = 'scale(1.05) translateY(-5px)';
        });
        
        card.addEventListener('mouseleave', function() {
          this.style.transform = 'scale(1) translateY(0)';
        });
      });

      // Celebration para atividades concluídas
      const completedCards = document.querySelectorAll('.completed-indicator');
      completedCards.forEach(indicator => {
        indicator.addEventListener('click', function() {
          // Pequena animação de celebração
          this.style.transform = 'scale(1.3)';
          setTimeout(() => {
            this.style.transform = 'scale(1)';
          }, 200);
        });
      });

      // ✅ SCROLL AUTOMÁTICO BASEADO EM ÂNCORA (Simples e Eficaz)
      function handleAnchorScroll() {
        const hash = window.location.hash;
        console.log('Hash detected:', hash);
        
        if (hash) {
          setTimeout(() => {
            const target = document.querySelector(hash);
            if (target) {
              console.log('Scrolling to target:', hash);
              target.scrollIntoView({
                behavior: 'smooth',
                block: 'start'
              });
            } else {
              console.log('Target not found:', hash);
            }
          }, 300); // Delay maior para garantir renderização
        }
      }

      // ✅ Executar após DOM carregar
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', handleAnchorScroll);
      } else {
        handleAnchorScroll();
      }
      
      // ✅ Também executar no evento hashchange
      window.addEventListener('hashchange', handleAnchorScroll);

      // ✅ Progressive Loading para atividades
      const loadMoreBtn = document.querySelector('.load-more-btn');
      if (loadMoreBtn) {
        console.log('✅ Botão load-more encontrado:', loadMoreBtn);
        
        loadMoreBtn.addEventListener('click', function() {
          console.log('🔥 Botão clicado!');
          
          const level = this.dataset.level;
          const offset = parseInt(this.dataset.offset);
          const button = this;
          const spinner = document.querySelector('.loading-spinner');
          
          console.log('📊 Dados:', { level, offset });
          console.log('🎯 Container:', document.getElementById('activities-container'));
          
          // Show loading state
          button.style.display = 'none';
          spinner.classList.remove('d-none');
          
          const url = `/students/load_more?level=${level}&offset=${offset}&locale=<%= I18n.locale %>`;
          console.log('🌐 URL requisição:', url);
          
          fetch(url)
            .then(response => {
              console.log('📥 Response status:', response.status);
              return response.json();
            })
            .then(data => {
              console.log('📦 Dados recebidos:', data);
              
              // Add new activities
              const container = document.getElementById('activities-container');
              if (container) {
                container.insertAdjacentHTML('beforeend', data.html);
                console.log('✅ HTML inserido');
              } else {
                console.error('❌ Container não encontrado!');
              }
              
              // Add animations to new cards
              const newCards = document.querySelectorAll('.card-atividade:not(.animated)');
              newCards.forEach((card, index) => {
                card.classList.add('animated', 'slideInUp');
                card.style.animationDelay = `${index * 0.1}s`;
              });
              
              // Update button state
              spinner.classList.add('d-none');
              if (data.has_more) {
                button.dataset.offset = data.next_offset;
                button.innerHTML = `<i class="fas fa-plus"></i> <%= t('student_dashboard.actions.load_more') %> (${data.remaining} <%= t('student_dashboard.messages.remaining') %>)`;
                button.style.display = 'inline-block';
              } else {
                button.style.display = 'none';
              }
            })
            .catch(error => {
              console.error('💥 Erro:', error);
              spinner.classList.add('d-none');
              button.style.display = 'inline-block';
            });
        });
      } else {
        console.error('❌ Botão load-more NÃO encontrado!');
      }
      
      // Toggle completed activities section
      const toggleBtn = document.querySelector('.btn-toggle-completed');
      if (toggleBtn) {
        toggleBtn.addEventListener('click', function() {
          const icon = this.querySelector('.toggle-icon');
          const target = document.querySelector(this.dataset.bsTarget);
          
          setTimeout(() => {
            if (target && target.classList.contains('show')) {
              icon.style.transform = 'rotate(180deg)';
            } else {
              icon.style.transform = 'rotate(0deg)';
            }
          }, 100);
                 });
       }
     }

     // Executar quando DOM estiver pronto
     if (document.readyState === 'loading') {
       document.addEventListener('DOMContentLoaded', initializeStudentDashboard);
     } else {
       initializeStudentDashboard();
     }
     
     // Também executar após Turbo navegação
     document.addEventListener('turbo:load', initializeStudentDashboard);
     
     // E garantir que execute após um pequeno delay
     setTimeout(initializeStudentDashboard, 100);
   </script>
