<script>
(function() {
  var lang = (navigator.language || navigator.userLanguage || 'pt').toLowerCase().substring(0, 2);
  var t = {
    fr: {
      btn:  "Résilier mon abonnement",
      confirm: "Voulez-vous vraiment résilier ? Votre accès restera actif jusqu'à la fin de la période en cours.",
      canceled: "Votre abonnement a été résilié. Accès jusqu'au"
    },
    pt: {
      btn:  "Cancelar inscrição",
      confirm: "Tem certeza? Seu acesso permanece ativo até o fim do período pago.",
      canceled: "Assinatura cancelada. Acesso até"
    },
    en: {
      btn:  "Cancel subscription",
      confirm: "Are you sure? Your access remains active until the end of the current billing period.",
      canceled: "Subscription canceled. Access until"
    }
  };
  var d = t[lang] || t['en'];
  window._cancelConfirm = d.confirm;
  var btn = document.querySelector('.cancel-sub-btn');
  if (btn) btn.textContent = d.btn;
  var msg = document.querySelector('.cancel-msg');
  if (msg) {
    var dateMatch = msg.textContent.match(/\d{2}\/\d{2}\/\d{4}/);
    if (dateMatch) msg.textContent = d.canceled + ' ' + dateMatch[0] + '.';
  }
})();
</script>

