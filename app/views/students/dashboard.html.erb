<div id="daily-limit-modal" style="
  display: flex;
  position: fixed; inset: 0; z-index: 9999;
  background: rgba(15, 56, 38, 0.6);
  backdrop-filter: blur(7px);
  align-items: center; justify-content: center;
  padding: 1.5rem;">

  <div style="
    background: #fff; border-radius: 24px; padding: 44px 36px 36px;
    max-width: 370px; width: 100%; text-align: center;
    box-shadow: 0 32px 80px rgba(0,0,0,0.24);">

    <div style="margin: 0 auto 24px; width: 72px; height: 72px; background: #E8F5EE; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
      <img src="/icons/logo-mark-transparent-64x64.png" style="width: 44px; height: 44px;" alt="">
    </div>

    <p id="dlm-title" style="font-family:'Raleway',sans-serif; font-size: 1.1rem; font-weight: 800; color: #0F3826; margin: 0 0 6px; line-height: 1.3;"></p>
    <p id="dlm-title-pt" style="font-family:'Raleway',sans-serif; font-size: 0.82rem; font-weight: 600; color: #9C9892; margin: 0 0 22px; font-style: italic;"></p>

    <div id="dlm-tip-box" style="background: #F7F5F0; border-radius: 12px; padding: 14px 16px; margin-bottom: 24px; text-align: left;">
      <p id="dlm-tip-label" style="font-family:'Plus Jakarta Sans',sans-serif; font-size: 0.67rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #C9952A; margin: 0 0 8px;"></p>
      <p id="dlm-tip" style="font-family:'Plus Jakarta Sans',sans-serif; font-size: 0.88rem; color: #1C1917; margin: 0 0 8px; line-height: 1.5;"></p>
      <p id="dlm-tip-pt" style="font-family:'Plus Jakarta Sans',sans-serif; font-size: 0.82rem; color: #5C5853; margin: 0; line-height: 1.5; font-style: italic;"></p>
    </div>

    <button onclick="document.getElementById('daily-limit-modal').style.display='none';"
            style="width: 100%; background: #1A6B4A; color: #fff; font-family:'Plus Jakarta Sans',sans-serif; font-size: 0.95rem; font-weight: 700; border: none; border-radius: 12px; padding: 13px 24px; cursor: pointer;">
      <span id="dlm-btn"></span>
    </button>
  </div>
</div>

<script>
