<% content_for :head do %>
  <title>Dashboard · Practice-BR</title>
  <style>
    .level-card-link { text-decoration:none; display:block; }
    .level-card-link:hover .level-card-inner { border-color:#2A9B6F; transform:translateY(-2px); transition:all .15s ease; }
    .level-card-inner { transition:all .15s ease; }
  </style>
<% end %>

<%
  completed_ids   = session[:completed_quizzes] || []
  current_streak  = session[:current_streak].to_i
  last_score      = session[:last_quiz_score]

  cefr_levels = User::CEFR_LEVELS

  # per-level stats
  levels_data = cefr_levels.map do |lvl|
    acts  = @activities_by_level[lvl] || [] rescue []
    done  = (completed_ids & acts.map(&:id)).length
    total = acts.count
    pct   = total > 0 ? ((done.to_f / total) * 100).round : 0
    { level: lvl, acts: acts, done: done, total: total, pct: pct, empty: acts.empty? }
  end

  total_acts      = levels_data.sum { |d| d[:total] }
  total_completed = levels_data.sum { |d| d[:done] }
  overall_pct     = total_acts > 0 ? ((total_completed.to_f / total_acts) * 100).round : 0

  # current level = first non-empty level that isn't 100% complete, or last non-empty
  current_level_data = levels_data.find { |d| !d[:empty] && d[:pct] < 100 } ||
                       levels_data.reverse.find { |d| !d[:empty] }

  # levels the student can access, ordered: own level first, then descending (B1 → A2 → A1)
  accessible_levels = current_user.accessible_levels
  priority_levels   = accessible_levels.reverse

  # first pending activity for "continue studying" — only needed on the main dashboard (no level filter)
  all_pending = priority_levels.flat_map do |lvl|
    (levels_data.find { |d| d[:level] == lvl } || { acts: [] })[:acts]
      .reject { |a| completed_ids.include?(a.id) }
  end

  # Helper: classify activity by support type using a pre-loaded set of attached names
  suporte_type = ->(act, attached_names) {
    names = attached_names[act.id] || []
    if names.include?('image_file') || (act.media_url.present? && !act.media_url.match?(/youtube\.com|youtu\.be/))
      :imagem
    elsif names.include?('video_file') || act.video_url.present?
      :video
    elsif names.include?('audio_file')
      :audio
    else
      :texto
    end
  }

  # Determine last completed activity's suporte (one query for the attempt + one batch for attachments)
  last_suporte = nil
  last_attempt = completed_ids.any? && params[:level].blank? ?
    QuizAttempt.where(user: current_user).order(submitted_at: :desc).first : nil

  if last_attempt&.activity_id
    last_attached = ActiveStorage::Attachment
      .where(record_type: 'Activity', record_id: last_attempt.activity_id,
             name: %w[audio_file video_file image_file])
      .pluck(:name)
    la = last_attempt.activity
    last_suporte = suporte_type.call(la, { la.id => last_attached })
  end

  # Batch-load attachment names for all pending activities (single query)
  pending_ids = all_pending.map(&:id)
  pending_attached = pending_ids.any? ? ActiveStorage::Attachment
    .where(record_type: 'Activity', record_id: pending_ids, name: %w[audio_file video_file image_file])
    .group_by(&:record_id)
    .transform_values { |recs| recs.map(&:name) } : {}

  # Pick first pending with a different suporte; fall back to first pending
  best_candidate = if last_suporte && all_pending.any?
    all_pending.find { |a| suporte_type.call(a, pending_attached) != last_suporte } || all_pending.first
  else
    all_pending.first
  end

  continue_activity = if best_candidate && params[:level].blank?
    Activity.with_attached_image_file.with_attached_video_file.with_attached_audio_file
            .includes(:teacher).find(best_candidate.id)
  end

  # last completed activity (for when nothing is pending)
  last_completed_activity = if continue_activity.nil? && params[:level].blank? && last_attempt&.activity
    Activity.with_attached_image_file.with_attached_video_file.with_attached_audio_file
            .includes(:teacher).find(last_attempt.activity.id)
  end

  level_descriptions = {
    'A1' => t('student_dashboard.level_descriptions.a1'),
    'A2' => t('student_dashboard.level_descriptions.a2'),
    'B1' => t('student_dashboard.level_descriptions.b1'),
    'B2' => t('student_dashboard.level_descriptions.b2'),
    'C1' => t('student_dashboard.level_descriptions.c1'),
  }
%>

<div class="dash-outer" style="max-width:1000px; margin:0 auto;" data-user-id="<%= current_user.id %>" id="student-dashboard-root">

<% unless current_user.level_assigned? %>
  <div style="background:#FEF2F2; border:1px solid #FECACA; border-radius:14px; padding:24px 28px; margin-bottom:1.5rem; text-align:center;">
    <div style="font-size:2rem; margin-bottom:10px;">🔒</div>
    <div style="font-family:'Raleway',sans-serif; font-size:1.05rem; font-weight:700; color:#B91C1C; margin-bottom:6px;">
      Aguardando seu nível de acesso
    </div>
    <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.88rem; color:#7F1D1D; line-height:1.6;">
      Seu professor ainda não definiu seu nível. Assim que ele fizer isso, as atividades disponíveis para você aparecerão aqui.
    </div>
  </div>
<% end %>

<% if params[:level].present? %>

  <%# ══════════════════════════════════════════════ %>
  <%# VISTA DE NÍVEL ESPECÍFICO                      %>
  <%# ══════════════════════════════════════════════ %>

  <% lvl_meta = cefr_colors(@current_level) %>

  <div style="display:flex; align-items:center; gap:10px; margin-bottom:1.5rem;">
    <%= link_to student_dashboard_path,
          style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; color:#5C5853; text-decoration:none; display:flex; align-items:center; gap:4px;" do %>
      ← Todos os níveis
    <% end %>
    <% if @current_level %>
      <span style="font-family:'DM Mono',monospace; font-size:0.72rem; font-weight:700;
                   background:<%= lvl_meta[:bg] %>; color:<%= lvl_meta[:text] %>; border:1.5px solid <%= lvl_meta[:border] %>;
                   padding:3px 10px; border-radius:20px;">
        <%= @current_level %>
      </span>
    <% end %>
  </div>

  <% if @current_level.present? %>
    <% if @pending_activities.any? %>
      <h2 style="font-family:'Raleway',sans-serif; font-size:1.1rem; font-weight:700; color:#1C1917; margin-bottom:1rem;">
        Atividades disponíveis
      </h2>
      <div class="activities-grid" id="activities-container">
        <%= render 'activities_grid', activities: @pending_activities %>
      </div>

      <% if @total_pending > 3 %>
        <div class="text-center mt-4">
          <button class="btn-giz secondary load-more-btn"
                  data-level="<%= @current_level %>"
                  data-offset="3"
                  data-total="<%= @total_pending %>">
            + Carregar mais (<%= [@total_pending - 3, 0].max %> restantes)
          </button>
          <div class="loading-spinner d-none">Carregando...</div>
        </div>
      <% end %>

      <% if @completed_activities.any? %>
        <div class="mt-4">
          <button style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:600;
                         color:#5C5853; background:transparent; border:1.5px solid #DDD9D2;
                         padding:8px 18px; border-radius:10px; cursor:pointer;"
                  data-bs-toggle="collapse" data-bs-target="#completed-activities">
            ✓ Ver atividades concluídas (<%= @completed_activities.length %>)
          </button>
          <div class="collapse mt-3" id="completed-activities">
            <div class="activities-grid">
              <%= render 'activities_grid', activities: @completed_activities %>
            </div>
          </div>
        </div>
      <% end %>

    <% else %>
      <div style="background:#E8F5EE; border:1.5px solid #2A9B6F; border-radius:16px; padding:32px; text-align:center; margin-bottom:1.5rem;">
        <div style="font-size:2.5rem; margin-bottom:12px;">🏆</div>
        <h2 style="font-family:'Raleway',sans-serif; font-size:1.2rem; font-weight:700; color:#0F3826; margin-bottom:8px;">
          Nível <%= @current_level %> completo!
        </h2>
        <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; color:#1A6B4A;">
          Você concluiu todas as atividades deste nível. Parabéns!
        </p>
        <% if @completed_activities.any? %>
          <button style="margin-top:16px; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem;
                         font-weight:600; color:#0F3826; background:transparent; border:1.5px solid #2A9B6F;
                         padding:8px 20px; border-radius:10px; cursor:pointer;"
                  data-bs-toggle="collapse" data-bs-target="#completed-activities">
            Revisar atividades →
          </button>
          <div class="collapse mt-3" id="completed-activities">
            <div class="activities-grid">
              <%= render 'activities_grid', activities: @completed_activities %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

  <% else %>
    <div style="background:#fff; border:1px solid #DDD9D2; border-radius:16px; padding:32px; text-align:center;">
      <div style="font-size:2rem; margin-bottom:12px;">🔍</div>
      <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; color:#5C5853; margin-bottom:16px;">
        Nenhuma atividade disponível neste nível ainda.
      </p>
      <%= link_to "← Explorar outros níveis", student_dashboard_path,
            style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:600;
                    color:#2563EB; text-decoration:none;" %>
    </div>
  <% end %>

<% else %>

  <%# ══════════════════════════════════════════════ %>
  <%# VISTA PRINCIPAL                                %>
  <%# ══════════════════════════════════════════════ %>

  <%# — Saudação — %>
  <div style="margin-bottom:1.75rem;">
    <h1 style="font-family:'Raleway',sans-serif; font-size:1.75rem; font-weight:800; color:#0F3826; margin-bottom:4px;">
      Olá<% if current_user.greeting_name %>, <%= current_user.greeting_name %><% end %>! 👋
    </h1>
    <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.95rem; color:#5C5853; margin:0 0 8px 0;">
      Que bom ter você aqui! Continue firme no seu aprendizado.
    </p>
    <% if current_user.professional_type.present? %>
      <% pc = ApplicationHelper::PROFESSIONAL_COLORS[current_user.professional_type] || { bg: '#F3F4F6', text: '#374151', border: '#D1D5DB' } %>
      <div style="display:inline-flex; align-items:center; gap:8px; background:<%= pc[:bg] %>; border:1.5px solid <%= pc[:border] %>; border-radius:20px; padding:4px 12px 4px 8px;">
        <span style="font-family:'DM Mono',monospace; font-size:0.7rem; font-weight:800; color:<%= pc[:text] %>; letter-spacing:0.04em;">
          <%= current_user.professional_type %>
        </span>
        <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; color:<%= pc[:text] %>; opacity:0.85;">
          Percurso profissional reconhecido
        </span>
      </div>
    <% end %>
  </div>

  <%# — 4 Cards de Métricas — %>
  <div class="dash-metrics-grid" id="tour-metrics" style="margin-bottom:1.5rem;">

    <div style="background:#fff; border:1px solid #DDD9D2; border-radius:14px; padding:18px 20px;">
      <div style="font-family:'DM Mono',monospace; font-size:0.67rem; color:#9C9892; letter-spacing:0.08em; text-transform:uppercase; margin-bottom:10px;">Sequência</div>
      <div style="display:flex; align-items:baseline; gap:5px;">
        <span style="font-family:'Raleway',sans-serif; font-size:2rem; font-weight:800; color:#C9952A; line-height:1;"><%= current_streak %></span>
        <span style="font-size:1.1rem; line-height:1;">🔥</span>
      </div>
      <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; color:#5C5853; margin-top:6px;">dias seguidos</div>
    </div>

    <div style="background:#fff; border:1px solid #DDD9D2; border-radius:14px; padding:18px 20px;">
      <div style="font-family:'DM Mono',monospace; font-size:0.67rem; color:#9C9892; letter-spacing:0.08em; text-transform:uppercase; margin-bottom:10px;">Concluídas</div>
      <div style="font-family:'Raleway',sans-serif; font-size:2rem; font-weight:800; color:#1A6B4A; line-height:1;"><%= total_completed %></div>
      <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; color:#5C5853; margin-top:6px;">atividades feitas</div>
    </div>

    <div style="background:#fff; border:1px solid #DDD9D2; border-radius:14px; padding:18px 20px;">
      <div style="font-family:'DM Mono',monospace; font-size:0.67rem; color:#9C9892; letter-spacing:0.08em; text-transform:uppercase; margin-bottom:10px;">Progresso geral</div>
      <div style="font-family:'Raleway',sans-serif; font-size:2rem; font-weight:800; color:#2563EB; line-height:1;"><%= overall_pct %>%</div>
      <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; color:#5C5853; margin-top:6px;">do total</div>
    </div>

    <div style="background:#fff; border:1px solid #DDD9D2; border-radius:14px; padding:18px 20px;">
      <div style="font-family:'DM Mono',monospace; font-size:0.67rem; color:#9C9892; letter-spacing:0.08em; text-transform:uppercase; margin-bottom:10px;">Última nota</div>
      <div style="font-family:'Raleway',sans-serif; font-size:2rem; font-weight:800; color:#7C3AED; line-height:1;"><%= last_score || '--' %></div>
      <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; color:#5C5853; margin-top:6px;">no último exercício</div>
    </div>

  </div>

  <%# — Dois cards médios: Continue estudando + Progresso geral — %>
  <div class="dash-mid-grid" style="margin-bottom:1.5rem;">

    <%# Continue estudando %>
    <div style="background:#fff; border:1px solid #DDD9D2; border-radius:16px; padding:22px;">
      <h2 style="font-family:'Raleway',sans-serif; font-size:1rem; font-weight:700; color:#1C1917; margin:0 0 16px 0;">
        Continue estudando
      </h2>

      <% if continue_activity %>
        <% cont_meta  = cefr_colors(continue_activity.level) %>
        <% cont_cover = activity_cover(continue_activity) %>
        <% cont_badge = activity_media_badge(continue_activity) %>
        <% cont_q     = continue_activity.try(:questions_count).to_i %>
        <% cont_started = QuizAttempt.where(user: current_user, activity: continue_activity).exists? %>

        <div class="continue-card" id="tour-continue">

          <%# Capa lateral %>
          <div class="continue-card-image">
            <% if cont_cover[:type] == :image %>
              <img src="<%= cont_cover[:url] %>" alt="" style="width:100%; height:100%; object-fit:cover; display:block; position:absolute; inset:0;">
              <% if cont_cover[:credit] %>
                <span style="position:absolute; bottom:3px; right:5px; font-size:0.55rem; color:rgba(255,255,255,0.6); line-height:1; pointer-events:none;"><%= cont_cover[:credit] %></span>
              <% end %>
            <% else %>
              <div style="width:100%; height:100%; position:absolute; inset:0; background:linear-gradient(135deg, <%= cont_meta[:bg] %> 0%, <%= cont_meta[:border] %>33 100%); display:flex; align-items:center; justify-content:center;">
                <i class="bi <%= cont_cover[:icon] %>" style="font-size:2.8rem; color:<%= cont_meta[:border] %>; opacity:0.55;"></i>
              </div>
            <% end %>
          </div>

          <%# Conteúdo %>
          <div class="continue-card-body">

            <div style="display:flex; align-items:center; gap:6px; flex-wrap:wrap; margin-bottom:8px;">
              <span style="font-family:'DM Mono',monospace; font-size:0.72rem; font-weight:700; background:<%= cont_meta[:bg] %>; color:<%= cont_meta[:text] %>; border:1.5px solid <%= cont_meta[:border] %>; padding:3px 9px; border-radius:20px;">
                <%= continue_activity.level %>
              </span>
              <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.7rem; font-weight:600; background:#E0F7FA; color:#00838F; border:1.5px solid #00ACC1; padding:3px 8px; border-radius:20px; display:inline-flex; align-items:center; gap:3px;">
                <i class="bi <%= cont_badge[:icon] %>" style="font-size:0.72rem;"></i> <%= cont_badge[:label] %>
              </span>
            </div>

            <div class="continue-card-title">
              <%= continue_activity.title %>
            </div>

            <% if continue_activity.description.present? %>
              <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; color:#5C5853; margin:0 0 10px 0; line-height:1.5; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; flex:1;">
                <%= continue_activity.description %>
              </p>
            <% else %>
              <div style="flex:1;"></div>
            <% end %>

            <% if cont_q > 0 %>
              <div style="display:flex; gap:12px; flex-wrap:wrap; margin-bottom:12px;">
                <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.77rem; color:#9C9892; display:flex; align-items:center; gap:4px;">
                  <i class="bi bi-patch-question" style="color:<%= cont_meta[:border] %>;"></i>
                  <%= cont_q %> <%= cont_q == 1 ? 'questão' : 'questões' %>
                </span>
                <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.77rem; color:#9C9892; display:flex; align-items:center; gap:4px;">
                  <i class="bi bi-clock" style="color:<%= cont_meta[:border] %>;"></i>
                  ~<%= [1, (cont_q * 1.5).round].max %> min
                </span>
              </div>
            <% end %>

            <div class="continue-card-bottom">
              <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.77rem; color:#9C9892; display:flex; align-items:center; gap:4px; min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                <i class="bi bi-person" style="flex-shrink:0;"></i>
                Prof. <%= continue_activity.teacher&.display_name %>
              </span>
              <%= link_to solve_activity_path(continue_activity),
                    style: "flex-shrink:0; background:#0F3826; color:#fff; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700; padding:9px 20px; border-radius:10px; text-decoration:none; white-space:nowrap;" do %>
                <%= cont_started ? 'Continuar →' : 'Iniciar →' %>
              <% end %>
            </div>

          </div>
        </div>

      <% else %>
        <% if last_completed_activity %>
          <% lc_meta  = cefr_colors(last_completed_activity.level) %>
          <% lc_cover = activity_cover(last_completed_activity) %>
          <% lc_badge = activity_media_badge(last_completed_activity) %>

          <div style="background:#E8F5EE; border:1px solid #2A9B6F; border-radius:10px; padding:10px 12px; margin-bottom:14px; display:flex; align-items:center; gap:8px;">
            <span style="font-size:1rem;">🏆</span>
            <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:600; color:#0F3826;">
              Você concluiu todas as atividades disponíveis!
            </span>
          </div>

          <div class="continue-card">
            <div class="continue-card-image">
              <% if lc_cover[:type] == :image %>
                <img src="<%= lc_cover[:url] %>" alt="" style="width:100%; height:100%; object-fit:cover; display:block; position:absolute; inset:0;">
                <% if lc_cover[:credit] %>
                  <span style="position:absolute; bottom:3px; right:5px; font-size:0.55rem; color:rgba(255,255,255,0.6); line-height:1; pointer-events:none;"><%= lc_cover[:credit] %></span>
                <% end %>
              <% else %>
                <div style="width:100%; height:100%; position:absolute; inset:0; background:linear-gradient(135deg, <%= lc_meta[:bg] %> 0%, <%= lc_meta[:border] %>33 100%); display:flex; align-items:center; justify-content:center;">
                  <i class="bi <%= lc_cover[:icon] %>" style="font-size:2.8rem; color:<%= lc_meta[:border] %>; opacity:0.55;"></i>
                </div>
              <% end %>
            </div>
            <div class="continue-card-body">
              <div style="display:flex; align-items:center; gap:6px; flex-wrap:wrap; margin-bottom:8px;">
                <span style="font-family:'DM Mono',monospace; font-size:0.72rem; font-weight:700; background:<%= lc_meta[:bg] %>; color:<%= lc_meta[:text] %>; border:1.5px solid <%= lc_meta[:border] %>; padding:3px 9px; border-radius:20px;">
                  <%= last_completed_activity.level %>
                </span>
                <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.7rem; font-weight:600; background:#E0F7FA; color:#00838F; border:1.5px solid #00ACC1; padding:3px 8px; border-radius:20px; display:inline-flex; align-items:center; gap:3px;">
                  <i class="bi <%= lc_badge[:icon] %>" style="font-size:0.72rem;"></i> <%= lc_badge[:label] %>
                </span>
              </div>
              <div style="font-family:'Raleway',sans-serif; font-size:1rem; font-weight:700; color:#1C1917; margin-bottom:6px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; flex:1;">
                <%= last_completed_activity.title %>
              </div>
              <div style="border-top:1px solid #F0EDE8; padding-top:10px; display:flex; align-items:center; justify-content:space-between; gap:10px;">
                <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.77rem; color:#9C9892; display:flex; align-items:center; gap:4px; min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                  <i class="bi bi-person" style="flex-shrink:0;"></i>
                  Prof. <%= last_completed_activity.teacher&.name %>
                </span>
                <%= link_to solve_activity_path(last_completed_activity),
                      style: "flex-shrink:0; background:#F7F5F0; color:#5C5853; border:1.5px solid #DDD9D2; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700; padding:9px 20px; border-radius:10px; text-decoration:none; white-space:nowrap;" do %>
                  ↺ Refazer
                <% end %>
              </div>
            </div>
          </div>

        <% else %>
          <div style="text-align:center; padding:20px 0;">
            <div style="font-size:2rem; margin-bottom:8px;">📚</div>
            <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.88rem; color:#5C5853;">
              Nenhuma atividade disponível ainda.
            </p>
          </div>
        <% end %>
      <% end %>
    </div>

    <%# Seu progresso %>
    <div style="background:#fff; border:1px solid #DDD9D2; border-radius:16px; padding:22px;">
      <h2 style="font-family:'Raleway',sans-serif; font-size:1rem; font-weight:700; color:#1C1917; margin:0 0 18px 0;">
        Seu progresso
      </h2>

      <%
        s_level      = current_user.level
        s_level_data = levels_data.find { |d| d[:level] == s_level }
        s_done       = s_level_data&.dig(:done) || 0
        s_meta       = s_level.present? ? cefr_colors(s_level) : {}
        s_label      = s_meta[:label]
        s_plural     = s_done == 1 ? '' : 's'
        current_idx  = cefr_levels.index(s_level) || 0

        # Competency stats — derivadas dos dados já carregados (sem N+1)
        oe_ids  = @open_ended_activity_ids || Set.new
        av_ids  = @av_activity_ids || Set.new
        done_set = completed_ids.to_set
        comp_stats = { co: { done: 0, total: 0 }, ce: { done: 0, total: 0 }, ee: { done: 0, total: 0 } }
        accessible_levels.each do |lvl|
          ld = levels_data.find { |d| d[:level] == lvl }
          next unless ld
          ld[:acts].each do |act|
            comps   = activity_competencies(act, oe_ids, av_ids)
            is_done = done_set.include?(act.id)
            comps.each { |c| comp_stats[c][:total] += 1; comp_stats[c][:done] += 1 if is_done }
          end
        end
        comp_defs = ApplicationHelper::COMPETENCY_META.map { |k, v| v.merge(key: k) }
        visible_comps = comp_defs.select { |cd| comp_stats[cd[:key]][:total] > 0 }

        # Competência mais fraca — só ela recebe o nudge
        any_done      = comp_stats.values.sum { |s| s[:done] } > 0
        weakest_key   = visible_comps.min_by { |cd|
          s = comp_stats[cd[:key]]
          s[:total] > 0 ? s[:done].to_f / s[:total] : 1.0
        }&.dig(:key)
      %>

      <%# Zona primária: barras de competência %>
      <% if visible_comps.any? %>
        <div style="display:flex; flex-direction:column; gap:14px; margin-bottom:20px;">
          <% visible_comps.each do |cd| %>
            <%
              key    = cd[:key]
              done   = comp_stats[key][:done]
              total  = comp_stats[key][:total]
              pct    = total > 0 ? (done.to_f / total * 100).round : 0
              nudge  = any_done && key == weakest_key
            %>
            <div>
              <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:5px;">
                <div style="display:flex; align-items:center; gap:7px;">
                  <div style="width:24px; height:24px; border-radius:7px; background:<%= cd[:bg] %>; display:flex; align-items:center; justify-content:center; font-size:0.82rem; flex-shrink:0; line-height:1;"><%= cd[:icon] %></div>
                  <span style="font-family:'DM Mono',monospace; font-size:0.72rem; font-weight:800; color:<%= cd[:color] %>;"><%= cd[:abbr] %></span>
                  <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.8rem; font-weight:600; color:#5C5853;"><%= cd[:label] %></span>
                </div>
                <span style="font-family:'DM Mono',monospace; font-size:0.72rem; font-weight:700; color:<%= cd[:color] %>;"><%= done %> de <%= total %></span>
              </div>
              <div style="height:7px; border-radius:99px; background:#E5E2DE; overflow:hidden; margin-bottom:<%= nudge ? '5px' : '0' %>;">
                <div class="dash-comp-bar" data-pct="<%= pct %>" style="height:100%; border-radius:99px; background:<%= cd[:bar] %>; width:0%; transition:width 0.9s cubic-bezier(0.33,1,0.68,1);"></div>
              </div>
              <% if nudge %>
                <div style="display:flex; align-items:center; gap:5px; background:#FFF7ED; border-radius:8px; padding:5px 9px; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.71rem; font-weight:600; color:#C2410C;">
                  💡 Experimente atividades de <%= cd[:label] %>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
        <div style="border-top:1px dashed #E5E2DE; margin:0 0 18px;"></div>
      <% end %>

      <%# Zona secundária: nível + caminho CEFR %>
      <% if s_level.present? %>
        <div style="display:flex; align-items:center; gap:14px; margin-bottom:14px;">
          <div style="width:60px; height:60px; border-radius:50%; flex-shrink:0; background:<%= s_meta[:bg] %>; border:2px solid <%= s_meta[:border] %>; display:flex; align-items:center; justify-content:center;">
            <span style="font-family:'DM Mono',monospace; font-size:0.95rem; font-weight:800; color:<%= s_meta[:text] %>; letter-spacing:-0.02em;"><%= s_level %></span>
          </div>
          <div>
            <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.67rem; font-weight:700; letter-spacing:0.07em; text-transform:uppercase; color:#9C9892; margin-bottom:3px;"><%= s_label %></div>
            <div style="font-family:'DM Mono',monospace; font-size:1.35rem; font-weight:800; color:<%= s_meta[:text] %>; line-height:1; margin-bottom:2px;"><%= s_done %></div>
            <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.76rem; color:#5C5853;">atividade<%= s_plural %> <%= s_level %> concluída<%= s_plural %></div>
          </div>
        </div>

        <%# Pills CEFR — 3 estados: ativo / acessível / bloqueado %>
        <div style="display:flex; gap:5px; flex-wrap:wrap;">
          <% cefr_levels.each do |lvl| %>
            <% lm = cefr_colors(lvl) %>
            <% if lvl == s_level %>
              <span style="font-family:'DM Mono',monospace; font-size:0.67rem; font-weight:800; padding:3px 9px; border-radius:20px; background:<%= lm[:border] %>; color:#fff;"><%= lvl %> ◉</span>
            <% elsif accessible_levels.include?(lvl) %>
              <span style="font-family:'DM Mono',monospace; font-size:0.67rem; font-weight:700; padding:3px 9px; border-radius:20px; background:<%= lm[:bg] %>; color:<%= lm[:text] %>; border:1.5px solid <%= lm[:border] %>;"><%= lvl %></span>
            <% else %>
              <span style="font-family:'DM Mono',monospace; font-size:0.67rem; font-weight:600; padding:3px 9px; border-radius:20px; background:#F0EDE8; color:#C4BFB8;"><%= lvl %></span>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.88rem; color:#5C5853;">
          Nenhuma atividade disponível ainda.
        </div>
      <% end %>
    </div>

  </div>

  <%# — Seus Níveis (5 cards compactos) — %>
  <div style="background:#fff; border:1px solid #DDD9D2; border-radius:16px; padding:22px; margin-bottom:1.5rem;">
    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:16px;">
      <h2 style="font-family:'Raleway',sans-serif; font-size:1rem; font-weight:700; color:#1C1917; margin:0;">
        Seus níveis
      </h2>
      <%= link_to activities_path,
            style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.8rem; font-weight:600; color:#fff; background:#1A6B4A; padding:7px 16px; border-radius:8px; text-decoration:none; display:inline-flex; align-items:center; gap:6px; flex-shrink:0;" do %>
        <i class="bi bi-search"></i> Todas as atividades
      <% end %>
    </div>
    <div class="dash-levels-grid" id="tour-levels">
      <% levels_data.each do |ld| %>
        <% m = cefr_colors(ld[:level]) %>
        <% is_locked = !accessible_levels.include?(ld[:level]) %>
        <% if is_locked %>
          <div style="text-align:center; border:1.5px solid #E5E1D8; border-radius:12px; padding:12px 8px; opacity:0.4; cursor:not-allowed; position:relative;" title="Nível não liberado pelo seu professor">
            <div style="background:#F0EDE8; color:#9C9892; border:1.5px solid #DDD9D2; font-family:'DM Mono',monospace; font-size:0.85rem; font-weight:800; width:44px; height:44px; border-radius:10px; display:flex; align-items:center; justify-content:center; margin:0 auto 8px;">
              🔒
            </div>
            <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.75rem; font-weight:600; color:#9C9892; margin-bottom:8px;"><%= ld[:level] %></div>
            <div style="background:#F0EDE8; border-radius:99px; height:5px; overflow:hidden; margin-bottom:4px;">
              <div style="width:0%; height:100%; border-radius:99px;"></div>
            </div>
            <div style="font-family:'DM Mono',monospace; font-size:0.65rem; color:#9C9892;">bloqueado</div>
          </div>
        <% elsif ld[:empty] %>
          <div style="text-align:center; border:1.5px solid #F0EDE8; border-radius:12px; padding:12px 8px; opacity:0.45; cursor:not-allowed;">
            <div style="background:<%= m[:bg] %>; color:<%= m[:text] %>; border:1.5px solid <%= m[:border] %>; font-family:'DM Mono',monospace; font-size:0.85rem; font-weight:800; width:44px; height:44px; border-radius:10px; display:flex; align-items:center; justify-content:center; margin:0 auto 8px;">
              <%= ld[:level] %>
            </div>
            <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.75rem; font-weight:600; color:#1C1917; margin-bottom:8px;"><%= m[:label] %></div>
            <div style="background:#F0EDE8; border-radius:99px; height:5px; overflow:hidden; margin-bottom:4px;">
              <div style="width:0%; height:100%; border-radius:99px;"></div>
            </div>
            <div style="font-family:'DM Mono',monospace; font-size:0.65rem; color:#9C9892;">em breve</div>
          </div>
        <% else %>
          <%= link_to student_dashboard_path(level: ld[:level]), class: "level-card-link" do %>
            <div class="level-card-inner" style="text-align:center; border:1.5px solid #F0EDE8; border-radius:12px; padding:12px 8px;">
              <div style="background:<%= m[:bg] %>; color:<%= m[:text] %>; border:1.5px solid <%= m[:border] %>; font-family:'DM Mono',monospace; font-size:0.85rem; font-weight:800; width:44px; height:44px; border-radius:10px; display:flex; align-items:center; justify-content:center; margin:0 auto 8px;">
                <%= ld[:level] %>
              </div>
              <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.75rem; font-weight:600; color:#1C1917; margin-bottom:8px;"><%= m[:label] %></div>
              <div style="background:#F0EDE8; border-radius:99px; height:5px; overflow:hidden; margin-bottom:4px;">
                <div style="width:<%= ld[:pct] %>%; height:100%; border-radius:99px; background:<%= m[:bar] %>;"></div>
              </div>
              <div style="font-family:'DM Mono',monospace; font-size:0.65rem; color:#9C9892;"><%= ld[:pct] %>%</div>
            </div>
          <% end %>
        <% end %>
      <% end %>
    </div>
  </div>

  <%# — Conquistas (só se tiver) — %>
  <% achieved_badges = get_all_achieved_badges(current_streak) %>
  <% if achieved_badges.any? %>
    <div style="background:#fff; border:1px solid #DDD9D2; border-radius:16px; padding:22px; margin-bottom:1.5rem;">
      <h2 style="font-family:'Raleway',sans-serif; font-size:1rem; font-weight:700; color:#1C1917; margin:0 0 16px 0;">
        🏆 Conquistas
      </h2>
      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <% achieved_badges.each do |badge| %>
          <div style="background:#FBF3E0; border:1.5px solid #E8C97A; border-radius:12px; padding:12px 16px; text-align:center; min-width:100px;">
            <div style="font-size:1.6rem; margin-bottom:5px;"><%= badge[:icon] %></div>
            <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; font-weight:700; color:#1C1917; margin-bottom:2px;"><%= badge[:name] %></div>
            <div style="font-family:'DM Mono',monospace; font-size:0.65rem; color:#9C7A30;"><%= badge[:days] %> dias</div>
          </div>
        <% end %>
        <% next_badge = get_next_badge(current_streak) %>
        <% if next_badge %>
          <% days_left = get_days_to_next_badge(current_streak) %>
          <div style="background:#F7F5F0; border:1.5px dashed #DDD9D2; border-radius:12px; padding:12px 16px; text-align:center; min-width:100px; opacity:0.5;">
            <div style="font-size:1.6rem; margin-bottom:5px;"><%= next_badge[:icon] %></div>
            <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; font-weight:700; color:#1C1917; margin-bottom:2px;"><%= next_badge[:name] %></div>
            <div style="font-family:'DM Mono',monospace; font-size:0.65rem; color:#9C9892;"><%= days_left %> dias restantes</div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# — Minhas expressões escritas — %>
  <div id="open-ended-section" style="background:#fff; border:1px solid #DDD9D2; border-radius:16px; padding:22px; margin-bottom:1.5rem;">
    <div class="oe-section-header">
      <h2 style="font-family:'Raleway',sans-serif; font-size:1rem; font-weight:700; color:#1C1917; margin:0;">
        ✍️ Minhas expressões escritas
      </h2>
      <button id="load-open-ended"
              data-url="<%= student_open_ended_attempts_path %>"
              style="width:30px; height:30px; border-radius:50%; border:1.5px solid #DDD9D2;
                     background:#F7F5F0; color:#5C5853; font-size:1.1rem; font-weight:700;
                     cursor:pointer; display:flex; align-items:center; justify-content:center;
                     font-family:'Raleway',sans-serif; flex-shrink:0; line-height:1;">
        +
      </button>
    </div>
    <div id="open-ended-container" style="display:none; flex-direction:column; gap:14px; margin-top:16px;"></div>
  </div>

  <script>
    (function() {
      var toggleBtn = document.getElementById('load-open-ended');
      var section   = document.getElementById('open-ended-section');
      var container = document.getElementById('open-ended-container');
      if (!toggleBtn || !container) return;

      var loaded       = false;
      var sectionShown = false;
      var allExpanded  = false;
      var initialCount = 0;

      function moreButtonStyle(collapsed) {
        return "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:600;" +
          " border-radius:8px; padding:8px 20px; cursor:pointer; border:1px solid;" +
          (collapsed
            ? " color:#0369A1; background:#E0F2FE; border-color:#BAE6FD;"
            : " color:#075985; background:#BAE6FD; border-color:#7DD3FC;");
      }

      function handleMore() {
        var moreBtn = document.getElementById('oe-more-btn');
        if (!moreBtn) return;

        if (allExpanded) {
          // Ver menos — encolher de volta aos iniciais
          while (container.children.length > initialCount + 1) {
            container.removeChild(container.children[initialCount]);
          }
          moreBtn.dataset.offset = String(initialCount);
          moreBtn.textContent    = 'Ver mais';
          moreBtn.style.cssText  = moreButtonStyle(true);
          allExpanded = false;
          section.scrollIntoView({ behavior: 'smooth', block: 'start' });
          return;
        }

        var offset = parseInt(moreBtn.dataset.offset);
        var url    = moreBtn.dataset.url;
        moreBtn.disabled    = true;
        moreBtn.textContent = 'Carregando...';

        fetch(url + '?offset=' + offset, {
          headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          var wrap = document.getElementById('oe-more-wrap');
          var temp = document.createElement('div');
          temp.innerHTML = data.html;
          while (temp.firstChild) container.insertBefore(temp.firstChild, wrap);

          // Scroll para o primeiro card novo
          var firstNew = container.children[offset];
          if (firstNew) firstNew.scrollIntoView({ behavior: 'smooth', block: 'start' });

          moreBtn.dataset.offset = data.next_offset;
          moreBtn.disabled       = false;
          if (data.has_more) {
            moreBtn.textContent   = 'Ver mais';
            moreBtn.style.cssText = moreButtonStyle(true);
          } else {
            moreBtn.textContent   = 'Ver menos';
            moreBtn.style.cssText = moreButtonStyle(false);
            allExpanded = true;
          }
        })
        .catch(function() {
          moreBtn.disabled    = false;
          moreBtn.textContent = 'Ver mais';
        });
      }

      function appendMoreButton(nextOffset, url) {
        var wrap = document.createElement('div');
        wrap.id = 'oe-more-wrap';
        wrap.style.cssText = 'text-align:center; margin-top:6px;';
        var btn = document.createElement('button');
        btn.id              = 'oe-more-btn';
        btn.dataset.offset  = nextOffset;
        btn.dataset.url     = url;
        btn.textContent     = 'Ver mais';
        btn.style.cssText   = moreButtonStyle(true);
        btn.addEventListener('click', handleMore);
        wrap.appendChild(btn);
        container.appendChild(wrap);
      }

      toggleBtn.addEventListener('click', function() {
        if (loaded) {
          sectionShown = !sectionShown;
          container.style.display = sectionShown ? 'flex' : 'none';
          toggleBtn.textContent   = sectionShown ? '−' : '+';
          return;
        }

        toggleBtn.textContent = '…';
        toggleBtn.disabled    = true;

        fetch(toggleBtn.dataset.url + '?offset=0', {
          headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.html && data.html.trim().length > 0) {
            container.innerHTML = data.html;
            if (data.has_more) {
              initialCount = container.children.length;
              appendMoreButton(data.next_offset, toggleBtn.dataset.url);
            }
          } else {
            container.innerHTML = '<p style="font-family:\'Plus Jakarta Sans\',sans-serif; font-size:0.85rem; color:#9C9892; padding:8px 0; margin:0;">Nenhuma expressão escrita ainda.</p>';
          }
          container.style.display = 'flex';
          sectionShown = true;
          loaded       = true;
          toggleBtn.disabled    = false;
          toggleBtn.textContent = '−';
          section.scrollIntoView({ behavior: 'smooth', block: 'start' });
        })
        .catch(function() {
          toggleBtn.disabled    = false;
          toggleBtn.textContent = '+';
        });
      });
    })();
  </script>

<% end %>

