<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <title><%= t('app_name') %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    
    <!-- Analytics e metatags -->
    <%= yield :head %>
    
    <!-- jQuery carregado uma única vez -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js" 
            integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=" 
            crossorigin="anonymous"></script>
    
    <!-- Importmap após jQuery -->
    <%= javascript_importmap_tags %>
    
    <style>
      /* Estilos para o botão de idioma */
      .navbar-toggler .fa-globe {
        color: #17a2b8;
      }
      
      /* Destaque para o botão de idioma em dispositivos móveis */
      @media (max-width: 991.98px) {
        .nav-item.dropdown .btn {
          width: 100%;
          margin-top: 10px;
          padding: 10px;
          font-size: 1.1rem;
        }
        
        .navbar-toggler {
          border-color: #17a2b8;
        }
        
        .navbar-toggler:focus {
          box-shadow: 0 0 0 0.25rem rgba(23, 162, 184, 0.25);
        }
      }
    </style>
    
    <!-- Código para resolver automaticamente problemas de inicialização -->
    <script>
      // Garantir que o jQuery esteja disponível globalmente sem recarregá-lo
      document.addEventListener('DOMContentLoaded', function() {
        if (typeof jQuery === 'undefined') {
          console.error('jQuery não foi carregado!');
          // Não tenta carregar novamente para evitar duplicidade
        } else {
          console.log('jQuery carregado com sucesso!');
          // Garantir que jQuery esteja disponível em ambas as variáveis
          window.$ = window.jQuery = jQuery;
        }
      });
    </script>
  </head>
  
  <body>
    <% if current_user %>
      <!-- Barra de navegação fixa no topo -->
      <nav class="navbar navbar-expand-lg navbar-light bg-light fixed-top">
        <div class="container-fluid">
          <a class="navbar-brand" href="#"><%= t('app_name') %></a>
          
          <!-- Botão de toggle para mobile -->
          <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
            <i class="fas fa-globe fa-lg"></i>
          </button>
          
          <!-- Conteúdo da navbar -->
          <div class="collapse navbar-collapse" id="navbarContent">
            <ul class="navbar-nav ms-auto">
              <li class="nav-item dropdown">
                <button class="btn btn-outline-info dropdown-toggle" type="button" data-bs-toggle="dropdown">
                  <i class="fas fa-globe me-1"></i> <%= current_user.language_name %>
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                  <% User::LANGUAGES.each do |lang| %>
                    <li>
                      <%= form_with(url: update_language_path, method: :patch, data: { turbo: false }) do |f| %>
                        <%= f.hidden_field :language, value: lang %>
                        <button type="submit" class="dropdown-item <%= 'active' if current_user.language == lang %>">
                          <% if lang == 'pt' %>
                            <i class="fas fa-flag me-1 text-success"></i>
                          <% elsif lang == 'fr' %>
                            <i class="fas fa-flag me-1 text-primary"></i>
                          <% else %>
                            <i class="fas fa-flag me-1 text-danger"></i>
                          <% end %>
                          <%= current_user.language_name_for(lang) %>
                        </button>
                      <% end %>
                    </li>
                  <% end %>
                </ul>
              </li>
            </ul>
          </div>
        </div>
      </nav>

      <!-- Espaçamento para compensar a navbar fixa -->
      <div style="margin-top: 70px;">
        <div class="container">
          <% flash.each do |name, msg| %>
            <div class="alert alert-<%= name == 'notice' ? 'success' : 'danger' %> alert-dismissible fade show">
              <%= msg %>
              <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
          <% end %>
        </div>
        
        <%= yield %>
      </div>
    <% else %>
      <div class="container mt-3">
        <% flash.each do |name, msg| %>
          <div class="alert alert-<%= name == 'notice' ? 'success' : 'danger' %> alert-dismissible fade show">
            <%= msg %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
          </div>
        <% end %>
      </div>
      
      <%= yield %>
    <% end %>
    <!-- Toast Notifications Container -->
    <div id="toast-container" 
         class="toast-container position-fixed top-0 end-0 p-3" 
         style="z-index: 1050;"
         data-controller="toast">
    </div>

    <!-- Script para conectar flash messages aos toast notifications -->
    <script>
      document.addEventListener('DOMContentLoaded', function() {
        // Converter flash messages em toast notifications
        <% if flash[:notice] %>
          document.dispatchEvent(new CustomEvent('show-toast', {
            detail: { message: '<%= j(flash[:notice]) %>', type: 'success' }
          }));
        <% end %>
        
        <% if flash[:alert] %>
          document.dispatchEvent(new CustomEvent('show-toast', {
            detail: { message: '<%= j(flash[:alert]) %>', type: 'error' }
          }));
        <% end %>
        
        // Listener para eventos de toast customizados
        document.addEventListener('show-toast', function(event) {
          const toastController = document.querySelector('[data-controller*="toast"]');
          if (toastController && window.Stimulus) {
            const controller = window.Stimulus.getControllerForElementAndIdentifier(toastController, 'toast');
            if (controller) {
              controller.show(event.detail.message, event.detail.type);
            }
          }
        });

        // Listener para eventos de validação de quiz
        document.addEventListener('quiz:validation-error', function(event) {
          document.dispatchEvent(new CustomEvent('show-toast', {
            detail: { message: event.detail.message, type: 'warning' }
          }));
        });
      });
    </script>
  </body>
</html>
