<!DOCTYPE html>
<html lang="<%= I18n.locale %>" data-theme="practice-br">
  <head>
    <title><%= t('app_name') %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <!-- Google Fonts: Raleway + Plus Jakarta Sans + DM Mono -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Raleway:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    
    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/icons/favicon.ico">
    <link rel="icon" type="image/png" sizes="16x16" href="/icons/favicon-16x16.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/icons/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="48x48" href="/icons/favicon-48x48.png">

    <!-- PWA -->
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#0F3826">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="Practice-BR">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <meta name="vapid-public-key" content="<%= ENV['VAPID_PUBLIC_KEY'] %>">
    <script>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js');
      }
    </script>

    <!-- Shepherd.js onboarding tour -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/shepherd.js@11/dist/css/shepherd.css">
    <script src="https://cdn.jsdelivr.net/npm/shepherd.js@11/dist/js/shepherd.min.js"></script>

    <!-- Analytics e metatags -->
    <%= yield :head %>
    
    <!-- jQuery carregado uma única vez -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js" 
            integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=" 
            crossorigin="anonymous"></script>
    
    <!-- Importmap após jQuery -->
    <%= javascript_importmap_tags %>

    <!-- Código para resolver automaticamente problemas de inicialização -->
    <script>
      // Garantir que o jQuery esteja disponível globalmente sem recarregá-lo
      document.addEventListener('DOMContentLoaded', function() {
        if (typeof jQuery === 'undefined') {
          console.error('jQuery não foi carregado!');
        } else {
          // Garantir que jQuery esteja disponível em ambas as variáveis
          window.$ = window.jQuery = jQuery;
        }
      });
    </script>
  </head>
  
  <body>
    <%# Splash animada PWA — aparece uma vez por sessão, apenas em modo standalone (app instalado) %>
    <div id="pwa-splash" aria-hidden="true" style="position:fixed;inset:0;z-index:9999;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;padding-bottom:96px;background:var(--paper);">
      <div id="pwaLogoWrap" style="position:relative;width:160px;height:160px;flex-shrink:0;opacity:0;transform:scale(.88)">
        <%= image_tag "logo-mark-transparent-256x256.png", alt: "", style: "width:160px;height:160px;display:block;" %>
        <svg viewBox="0 0 100 100" style="position:absolute;top:0;left:0;width:160px;height:160px;overflow:visible;" aria-hidden="true">
          <circle id="pwacover" cx="76" cy="27" r="6" fill="var(--paper)"/>
          <circle id="pwadot" cx="35" cy="80" r="0" fill="var(--action)" opacity="0"/>
        </svg>
      </div>
      <span id="pwaName" style="font-family:'Raleway',sans-serif;font-size:1.35rem;font-weight:700;letter-spacing:.04em;color:var(--brand-deep);opacity:0;transform:translateY(8px);">Practice-BR</span>
      <small id="pwaTag" style="font-family:'Raleway',sans-serif;font-size:.72rem;font-weight:400;letter-spacing:.08em;text-transform:uppercase;color:var(--ink-faint);opacity:0;transform:translateY(8px);">APRENDER É UMA AVENTURA</small>
    </div>
    <script>
      (function(){
        var el=document.getElementById('pwa-splash');
        var standalone=window.matchMedia('(display-mode: standalone)').matches||navigator.standalone;
        if(!standalone||sessionStorage.getItem('_pbr_splash')){el.style.display='none';return;}
        sessionStorage.setItem('_pbr_splash','1');
        var wrap=document.getElementById('pwaLogoWrap'),
            dot=document.getElementById('pwadot'),
            cover=document.getElementById('pwacover'),
            nameEl=document.getElementById('pwaName'),
            tagEl=document.getElementById('pwaTag');
        var WP=[{x:35,y:80},{x:50,y:73},{x:55,y:68},{x:46,y:62},{x:32,y:51},
                {x:40,y:46},{x:50,y:40},{x:58,y:36},{x:67,y:34},{x:72,y:33},
                {x:75,y:31},{x:76,y:27}];
        function crPoint(pts,t){
          var n=pts.length-1;
          if(t<=0)return{x:pts[0].x,y:pts[0].y};
          if(t>=1)return{x:pts[n].x,y:pts[n].y};
          var seg=Math.min(Math.floor(t*n),n-1),lt=t*n-seg;
          var p0=pts[Math.max(seg-1,0)],p1=pts[seg],
              p2=pts[Math.min(seg+1,n)],p3=pts[Math.min(seg+2,n)];
          var t2=lt*lt,t3=t2*lt;
          return{
            x:.5*((2*p1.x)+(-p0.x+p2.x)*lt+(2*p0.x-5*p1.x+4*p2.x-p3.x)*t2+(-p0.x+3*p1.x-3*p2.x+p3.x)*t3),
            y:.5*((2*p1.y)+(-p0.y+p2.y)*lt+(2*p0.y-5*p1.y+4*p2.y-p3.y)*t2+(-p0.y+3*p1.y-3*p2.y+p3.y)*t3)
          };
        }
        function ease(t){return t<.5?2*t*t:-1+(4-2*t)*t;}
        function dotR(t){return 1.5+4.0*(0.55*t+0.45*t*t);}
        var rafId=null;
        function cancelAnim(){if(rafId){cancelAnimationFrame(rafId);rafId=null;}}
        function animateDot(dur,onDone){
          cancelAnim();var start=null;
          function frame(ts){
            if(!start)start=ts;
            var raw=Math.min((ts-start)/dur,1),e=ease(raw),p=crPoint(WP,e);
            dot.setAttribute('cx',p.x.toFixed(2));dot.setAttribute('cy',p.y.toFixed(2));
            dot.setAttribute('r',dotR(raw).toFixed(2));
            if(raw<1){rafId=requestAnimationFrame(frame);}else{if(onDone)onDone();}
          }
          rafId=requestAnimationFrame(frame);
        }
        function pulseDot(onDone){
          cancelAnim();var start=null,dur=320;
          function frame(ts){
            if(!start)start=ts;
            var t=Math.min((ts-start)/dur,1),s=t<.5?1+t*.7:1.35-(t-.5)*.7;
            dot.setAttribute('r',(5.5*s).toFixed(2));
            if(t<1){rafId=requestAnimationFrame(frame);}else{dot.setAttribute('r','5.5');if(onDone)onDone();}
          }
          rafId=requestAnimationFrame(frame);
        }
        function fadeInEl(el,dur){
          el.style.transition='opacity '+dur+'ms ease-out,transform '+dur+'ms ease-out';
          el.style.opacity='1';el.style.transform='translateY(0)';
        }
        function dismissSplash(){
          el.style.transition='opacity 400ms ease-in';el.style.opacity='0';
          setTimeout(function(){el.style.display='none';},400);
        }
        function run(){
          wrap.style.transition='opacity 350ms ease-out,transform 350ms cubic-bezier(.22,.68,0,1.15)';
          wrap.style.opacity='1';wrap.style.transform='scale(1)';
          setTimeout(function(){dot.setAttribute('opacity','1');},380);
          setTimeout(function(){
            animateDot(1200,function(){
              pulseDot(function(){
                cover.setAttribute('opacity','0');
                setTimeout(function(){
                  fadeInEl(nameEl,350);
                  setTimeout(function(){
                    fadeInEl(tagEl,300);
                    setTimeout(dismissSplash,900);
                  },460);
                },150);
              });
            });
          },570);
        }
        var img=el.querySelector('img');
        if(img.complete){run();}else{img.onload=run;}
      })();
    </script>

    <% if current_user && !content_for?(:hide_navbar) %>
      <%= render 'shared/navbar' %>
      <div style="height:56px;"></div>
    <% end %>

    <%= yield %>
    <!-- Toast Notifications Container -->
    <div id="toast-container" 
         class="toast-container position-fixed top-0 end-0 p-3" 
         style="z-index: 1050;"
         data-controller="toast">
    </div>

    <!-- Script para conectar flash messages aos toast notifications -->
    <script>
      document.addEventListener('DOMContentLoaded', function() {
        // Converter flash messages em toast notifications
        <% if flash[:notice].present? %>
          document.dispatchEvent(new CustomEvent('show-toast', {
            detail: { message: '<%= j(flash[:notice]) %>', type: 'success' }
          }));
        <% end %>

        <% if flash[:alert].present? %>
          document.dispatchEvent(new CustomEvent('show-toast', {
            detail: { message: '<%= j(flash[:alert]) %>', type: 'error' }
          }));
        <% end %>
        
        // Listener para eventos de toast customizados
        document.addEventListener('show-toast', function(event) {
          const toastController = document.querySelector('[data-controller*="toast"]');
          if (toastController && window.Stimulus) {
            const controller = window.Stimulus.getControllerForElementAndIdentifier(toastController, 'toast');
            if (controller) {
              controller.show(event.detail.message, event.detail.type);
            }
          }
        });

        // Listener para eventos de validação de quiz
        document.addEventListener('quiz:validation-error', function(event) {
          document.dispatchEvent(new CustomEvent('show-toast', {
            detail: { message: event.detail.message, type: 'warning' }
          }));
        });
      });
    </script>
  </body>
</html>
