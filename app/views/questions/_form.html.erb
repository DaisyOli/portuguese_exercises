<div data-controller="question-selector">
  <%= form_with model: [activity, question], html: { 
      class: "question-form",
      id: "question-form-#{question.id || 'new'}"
    } do |form| %>

    <div class="row mb-3">
      <div class="col-md-12">
        <%= form.label :question_type, t('questions.form.question_type') %>
        <%= form.select :question_type, 
            Question::QUESTION_TYPES.map { |type| [t("questions.types.#{type}"), type] }, 
            { selected: question.question_type || 'multiple_choice' }, 
            { 
              class: "form-control question-type-select", 
              data: { 
                question_selector_target: "selector",
                action: "change->question-selector#change"
              }
            } 
        %>
      </div>
    </div>
    
    <div class="row mb-3">
      <div class="col-md-12">
        <%= form.label :content, t('questions.form.question_content') %>
        <%= form.text_area :content, 
            class: "form-control", 
            rows: 3,
            placeholder: (question.fill_in_blank? ? 
                        t('questions.form.fill_in_blank_placeholder') : 
                        (question.multiple_choice? ? 
                          t('questions.form.multiple_choice_placeholder') : 
                          t('questions.form.content_placeholder'))) %>
      </div>
    </div>

    <div class="row mb-3 fill-in-blank-help" style="display: <%= question.fill_in_blank? ? 'block' : 'none' %>;" data-question-selector-target="fillInBlank">
      <div class="col-md-12">
        <div class="alert alert-info">
          <%= t('questions.form.fill_in_blank_help_html') %>
        </div>
      </div>
    </div>
    
    <div class="row mb-3 order-sentences-help" style="display: <%= question.order_sentences? ? 'block' : 'none' %>;" data-question-selector-target="orderSentencesHelp">
      <div class="col-md-12">
        <div class="alert alert-info">
          <%= t('questions.form.order_sentences_help_html') %>
        </div>
      </div>
    </div>
    
    <div class="row mb-3 multiple-choice-fields" style="display: <%= question.multiple_choice? ? 'block' : 'none' %>;" data-question-selector-target="multipleChoice">
      <div class="col-md-12">
        <%= form.label :options_text, t('questions.form.options') %>
        <%= form.text_area :options_text, 
            value: question.options&.join(","), 
            class: "form-control", 
            rows: 3,
            placeholder: t('questions.form.options_placeholder') %>
        <small class="form-text text-muted"><%= t('questions.form.options_help') %></small>
      </div>
    </div>
    
    <div class="row mb-3 order-sentences-fields" style="display: <%= question.order_sentences? ? 'block' : 'none' %>;" data-question-selector-target="orderSentencesFields">
      <div class="col-md-12">
        <%= form.label :sentences_content, t('questions.form.sentences'), class: "form-label required" %>
        <%= form.text_area :sentences_content, 
            class: "form-control", 
            rows: 5,
            required: question.order_sentences?,
            placeholder: t('questions.form.sentences_placeholder'),
            value: (question.order_sentences? && question.correct_answer.present? ? question.correct_answer.gsub('|', "\n") : nil) %>
        <small class="form-text text-muted"><%= t('questions.form.order_sentences_input_help') %></small>
      </div>
    </div>
    
    <div class="row mb-3" style="display: <%= question.order_sentences? ? 'none' : 'block' %>;" data-question-selector-target="correctAnswer">
      <div class="col-md-12">
        <%= form.label :correct_answer, t('questions.form.correct_answer') %>
        <%= form.text_field :correct_answer, 
            class: "form-control",
            placeholder: t('questions.form.correct_answer_placeholder') %>
        <small class="form-text text-muted"><%= t('questions.form.correct_answer_help') %></small>
      </div>
    </div>

    <div class="row">
      <div class="col-md-12">
        <%= form.submit t('common.save'), class: "btn btn-primary" %>
        <% if question.persisted? %>
          <%= link_to t('common.delete'), 
                    activity_question_path(activity, question), 
                    data: { turbo_method: :delete, turbo_confirm: t('common.confirm_delete') },
                    class: "btn btn-outline-danger ms-2" %>
        <% end %>
      </div>
    </div>

    <!-- Script de fallback se o Stimulus falhar -->
    <script>
      document.addEventListener('DOMContentLoaded', function() {
        const form = document.getElementById('question-form-<%= question.id || "new" %>');
        if (!form) return;
        
        const select = form.querySelector('select[name="question[question_type]"]');
        if (!select) return;
        
        function updateFields() {
          const type = select.value;
          console.log("Script fallback: tipo alterado para", type);
          
          // Esconder todos os campos
          const multipleChoiceFields = form.querySelector('.multiple-choice-fields');
          const fillInBlankHelp = form.querySelector('.fill-in-blank-help');
          const orderSentencesHelp = form.querySelector('.order-sentences-help');
          const orderSentencesFields = form.querySelector('.order-sentences-fields');
          const correctAnswerField = form.querySelector('[data-question-selector-target="correctAnswer"]');
          
          if (multipleChoiceFields) multipleChoiceFields.style.display = 'none';
          if (fillInBlankHelp) fillInBlankHelp.style.display = 'none';
          if (orderSentencesHelp) orderSentencesHelp.style.display = 'none';
          if (orderSentencesFields) orderSentencesFields.style.display = 'none';
          if (correctAnswerField) correctAnswerField.style.display = 'block';
          
          // Mostrar campos para o tipo selecionado
          switch (type) {
            case 'multiple_choice':
              if (multipleChoiceFields) multipleChoiceFields.style.display = 'block';
              break;
            case 'fill_in_blank':
              if (fillInBlankHelp) fillInBlankHelp.style.display = 'block';
              break;
            case 'order_sentences':
              if (orderSentencesHelp) orderSentencesHelp.style.display = 'block';
              if (orderSentencesFields) orderSentencesFields.style.display = 'block';
              if (correctAnswerField) correctAnswerField.style.display = 'none';
              break;
          }
        }
        
        // Adicionar listener para o select
        select.addEventListener('change', updateFields);
        
        // Inicializar no carregamento
        updateFields();
      });
    </script>
  <% end %>
</div>

