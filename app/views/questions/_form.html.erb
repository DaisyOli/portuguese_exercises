<%
  preset_type ||= nil
  form_prefix ||= nil
  label_s  = "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:600; color:#5C5853; display:block; margin-bottom:6px;"
  input_s  = "width:100%; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.88rem; padding:9px 12px; border:1.5px solid #DDD9D2; border-radius:8px; color:#1C1917; background:#fff; box-sizing:border-box;"
  hint_s   = "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; color:#9C9892; margin-top:5px; display:block;"
  field_s  = "margin-bottom:16px;"
  alert_s  = "background:#EBF2FC; border:1px solid #BFDBFE; border-radius:8px; padding:12px 14px; font-size:0.85rem; color:#1A4A8A; font-family:'Plus Jakarta Sans',sans-serif;"
  submit_s = "background:#1A4A8A; color:#fff; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.88rem; font-weight:700; border:none; border-radius:12px; padding:9px 24px; cursor:pointer; width:100%; margin-top:4px;"
  delete_s = "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:600; color:#B91C1C; padding:8px 14px; border:1.5px solid #FECACA; border-radius:10px; background:#FEF2F2; cursor:pointer; text-decoration:none; display:inline-block; margin-top:8px; width:100%; text-align:center;"
  form_uid = question.id&.to_s || form_prefix || 'new'
%>

<% unless @quill_loaded %>
  <% @quill_loaded = true %>
  <% content_for :head do %>
    <link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet">
    <script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>
    <style>
      .ql-toolbar.ql-snow { border-radius: 8px 8px 0 0; border-color: #DDD9D2; font-family: 'Plus Jakarta Sans', sans-serif; padding: 3px 8px; }
      .ql-toolbar.ql-snow button { padding: 2px; width: 22px; height: 20px; }
      .ql-toolbar.ql-snow .ql-formats { margin-right: 8px; line-height: 1; }
      .ql-container.ql-snow { border-radius: 0 0 8px 8px; border-color: #DDD9D2; font-family: 'Plus Jakarta Sans', sans-serif; font-size: 0.9rem; }
      .ql-editor { min-height: 80px; padding: 6px 10px 4px; line-height: 1.65; color: #1C1917; }
      .quill-tall .ql-editor { min-height: 140px; padding: 12px 15px 6px; }
      .ql-editor.ql-blank::before { color: #9C9892; font-style: normal; }
    </style>
  <% end %>
<% end %>

<div data-controller="question-selector">
  <%= form_with model: [activity, question], html: {
      class: "question-form",
      id: "question-form-#{form_uid}",
      data: { turbo: false }
    } do |form| %>

    <% if preset_type.blank? %>
    <div style="<%= field_s %>">
      <%= form.label :question_type, t('questions.form.question_type'), style: label_s %>
      <%= form.select :question_type,
          Question::QUESTION_TYPES.map { |type| [t("questions.types.#{type}"), type] },
          { selected: question.question_type || 'multiple_choice' },
          {
            style: input_s,
            class: "question-type-select",
            data: {
              question_selector_target: "selector",
              action: "change->question-selector#change"
            }
          }
      %>
    </div>
    <% else %>
      <%= form.hidden_field :question_type, value: preset_type %>
    <% end %>

    <div style="<%= field_s %>">
      <%= form.label :content, t('questions.form.question_content'), style: label_s %>
      <div id="quill-editor-<%= form_uid %>"></div>
      <%= form.hidden_field :content, id: "quill-content-#{form_uid}", value: question.content %>
    </div>

    <div style="<%= field_s %> display:<%= question.fill_in_blank? ? 'block' : 'none' %>;"
         class="fill-in-blank-help"
         data-question-selector-target="fillInBlank">
      <div style="<%= alert_s %>">
        <%= t('questions.form.fill_in_blank_help_html') %>
      </div>
    </div>

    <div style="<%= field_s %> display:<%= question.multiple_choice? ? 'block' : 'none' %>;"
         class="multiple-choice-fields"
         data-question-selector-target="multipleChoice">
      <%= form.label :options_text, t('questions.form.options'), style: label_s %>
      <%= form.text_area :options_text,
          value: question.options&.join(","),
          style: input_s,
          rows: 3,
          placeholder: t('questions.form.options_placeholder') %>
      <small style="<%= hint_s %>"><%= t('questions.form.options_help') %></small>
    </div>

    <%# open_ended: info note + rubrica field %>
    <div style="<%= field_s %> display:<%= question.open_ended? ? 'block' : 'none' %>;"
         class="open-ended-fields"
         data-question-selector-target="openEnded">
      <div style="background:#FFF7ED; border:1px solid #FED7AA; border-radius:8px; padding:12px 14px; font-size:0.85rem; color:#7C2D12; font-family:'Plus Jakarta Sans',sans-serif; margin-bottom:12px;">
        <strong>✨ <%= t('questions.form.open_ended_info_title') %></strong><br>
        <%= t('questions.form.open_ended_info') %>
      </div>
      <%= form.label :evaluation_prompt, t('questions.form.evaluation_prompt_label'), style: label_s %>
      <%= form.text_area :evaluation_prompt,
          style: input_s,
          rows: 3,
          placeholder: t('questions.form.evaluation_prompt_placeholder') %>
      <small style="<%= hint_s %>"><%= t('questions.form.evaluation_prompt_hint') %></small>

      <div style="<%= field_s %> margin-top:8px; margin-bottom:0;">
        <span style="<%= label_s %>"><%= t('questions.form.weight_label') %></span>
        <div style="display:flex; gap:8px; margin-top:4px;">
          <% [1, 2, 3].each do |w| %>
            <label style="display:flex; align-items:center; gap:6px; padding:7px 14px; border:1.5px solid <%= (question.weight || 1) == w ? '#C9952A' : '#DDD9D2' %>; border-radius:8px; background:<%= (question.weight || 1) == w ? '#FFF7ED' : '#fff' %>; cursor:pointer; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:600; color:<%= (question.weight || 1) == w ? '#7C2D12' : '#5C5853' %>;">
              <%= form.radio_button :weight, w, style: "accent-color:#C9952A;" %>
              ×<%= w %><%= w == 1 ? " (#{t('questions.form.weight_normal')})" : "" %>
            </label>
          <% end %>
        </div>
        <small style="<%= hint_s %>"><%= t('questions.form.weight_hint') %></small>
      </div>
    </div>

    <%# Campo único de resposta — para multiple_choice %>
    <div style="<%= field_s %> display:<%= question.multiple_choice? ? 'block' : 'none' %>;"
         data-question-selector-target="correctAnswer">
      <%= form.label :correct_answer, t('questions.form.correct_answer'), style: label_s %>
      <%= form.text_field :correct_answer,
          style: input_s,
          placeholder: t('questions.form.correct_answer_placeholder') %>
      <small style="<%= hint_s %>"><%= t('questions.form.correct_answer_help') %></small>
    </div>

    <%# Campos de lacunas — para fill_in_blank (até 4) %>
    <% existing_fib_answers = (question.fill_in_blank? ? question.all_correct_answers : []) rescue [] %>
    <% visible_fib_count = [existing_fib_answers.length, 1].max %>
    <div style="<%= field_s %> display:<%= question.fill_in_blank? ? 'block' : 'none' %>;"
         class="fill-in-blank-answers"
         data-question-selector-target="fillInBlankAnswers">
      <label style="<%= label_s %>">Respostas</label>
      <% 4.times do |i| %>
        <div class="fib-answer-field" data-blank-index="<%= i %>"
             style="margin-bottom:8px; display:<%= i < visible_fib_count ? 'flex' : 'none' %>;
                    align-items:center; gap:10px;">
          <span style="font-family:'DM Mono',monospace; font-size:0.72rem; font-weight:700;
                       color:#1A6B4A; background:#E8F5EE; border:1px solid #2A9B6F;
                       border-radius:6px; padding:3px 8px; flex-shrink:0; min-width:62px; text-align:center;">
            Lacuna <%= i + 1 %>
          </span>
          <input type="text"
                 name="question[correct_answers][]"
                 value="<%= existing_fib_answers[i] %>"
                 style="<%= input_s %> margin-bottom:0; flex:1;"
                 placeholder="Resposta correta <%= i + 1 %>">
        </div>
      <% end %>
      <button type="button" id="fib-add-btn-<%= form_uid %>"
              style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.8rem; font-weight:600;
                     color:#0F3826; padding:6px 12px; border:1.5px solid #BBF7D0; border-radius:20px;
                     background:#E8F5EE; cursor:pointer; display:<%= visible_fib_count >= 4 ? 'none' : 'inline-flex' %>;
                     align-items:center; gap:5px; margin-top:4px;">
        <i class="bi bi-plus"></i> Adicionar lacuna
      </button>
    </div>

    <%= form.submit t('common.save'), style: submit_s %>
    <% if question.persisted? %>
      <%= link_to t('common.delete'),
                activity_question_path(activity, question),
                data: { turbo_method: :delete, turbo_confirm: t('common.confirm_delete') },
                style: delete_s %>
    <% end %>

    <script>
      (function() {
        var formId = '<%= form_uid %>';

        function initQuill() {
          var editorEl = document.getElementById('quill-editor-' + formId);
          if (!editorEl || editorEl.dataset.quillInit) return;
          editorEl.dataset.quillInit = '1';

          var quill = new Quill(editorEl, {
            theme: 'snow',
            modules: { toolbar: [['bold', 'italic', 'underline']] },
            placeholder: '<%= j(t("questions.form.multiple_choice_placeholder")) %>'
          });

          var existing = <%= raw json_escape((question.content || '').to_json) %>;
          if (existing && existing.trim()) {
            quill.clipboard.dangerouslyPasteHTML(
              existing.charAt(0) === '<' ? existing : existing.replace(/\n/g, '<br>')
            );
          }

          var hiddenInput = document.getElementById('quill-content-' + formId);
          quill.on('text-change', function() {
            hiddenInput.value = quill.root.innerHTML;
          });

          var formEl = document.getElementById('question-form-' + formId);
          if (formEl) {
            formEl.addEventListener('submit', function() {
              hiddenInput.value = quill.root.innerHTML;
            }, { once: false });
          }
        }

        function updateFields() {
          const form = document.getElementById('question-form-' + formId);
          if (!form) return;
          const select = form.querySelector('select[name="question[question_type]"]');
          if (!select) return;
          const type = select.value;
          const multipleChoiceFields = form.querySelector('.multiple-choice-fields');
          const fillInBlankHelp = form.querySelector('.fill-in-blank-help');
          const fillInBlankAnswers = form.querySelector('.fill-in-blank-answers');
          const openEndedFields = form.querySelector('.open-ended-fields');
          const correctAnswerField = form.querySelector('[data-question-selector-target="correctAnswer"]');
          if (multipleChoiceFields) multipleChoiceFields.style.display = 'none';
          if (fillInBlankHelp) fillInBlankHelp.style.display = 'none';
          if (fillInBlankAnswers) fillInBlankAnswers.style.display = 'none';
          if (openEndedFields) openEndedFields.style.display = 'none';
          if (correctAnswerField) correctAnswerField.style.display = 'none';
          switch (type) {
            case 'multiple_choice':
              if (multipleChoiceFields) multipleChoiceFields.style.display = 'block';
              if (correctAnswerField) correctAnswerField.style.display = 'block';
              break;
            case 'fill_in_blank':
              if (fillInBlankHelp) fillInBlankHelp.style.display = 'block';
              if (fillInBlankAnswers) fillInBlankAnswers.style.display = 'block';
              break;
            case 'open_ended':
              if (openEndedFields) openEndedFields.style.display = 'block';
              break;
          }
        }

        function initFibAddButton() {
          var addBtn = document.getElementById('fib-add-btn-' + formId);
          if (!addBtn) return;
          addBtn.addEventListener('click', function() {
            var form = document.getElementById('question-form-' + formId);
            if (!form) return;
            var fields = Array.from(form.querySelectorAll('.fib-answer-field'));
            var nextHidden = fields.find(function(f) { return f.style.display === 'none'; });
            if (nextHidden) {
              nextHidden.style.display = 'flex';
              nextHidden.querySelector('input').focus();
            }
            var stillHidden = fields.some(function(f) { return f.style.display === 'none'; });
            if (!stillHidden) addBtn.style.display = 'none';
          });
        }

        function init() {
          const form = document.getElementById('question-form-' + formId);
          if (!form) return;
          const select = form.querySelector('select[name="question[question_type]"]');
          if (select) select.addEventListener('change', updateFields);
          updateFields();
          initFibAddButton();

          const parentCollapse = form.closest('.collapse');
          if (parentCollapse) {
            new MutationObserver(function() {
              if (parentCollapse.classList.contains('show')) initQuill();
            }).observe(parentCollapse, { attributes: true, attributeFilter: ['class'] });
          } else {
            initQuill();
          }

          form.addEventListener('submit', function(event) {
            if (!form.action.includes('?')) {
              form.action = form.action + '?destaque=true';
            } else {
              form.action = form.action + '&destaque=true';
            }
          });
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', init);
        } else {
          init();
        }
      })();
    </script>
  <% end %>
</div>
