<% content_for :head do %>
  <title>Attestation de formation · <%= @student.display_name %></title>
  <style>
    @media print {
      .no-print { display: none !important; }
      body { background: #fff !important; }
      .attestation-page { box-shadow: none !important; border: none !important; }
    }
    body { background: #F7F5F0; margin: 0; padding: 0; }
  </style>
<% end %>

<div class="no-print" style="background:#0F3826; padding:12px 24px; display:flex; align-items:center; justify-content:space-between;">
  <%= link_to "← Voltar ao perfil", teacher_student_profile_path(@student),
        style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; color:#6EBD96; text-decoration:none;" %>
  <button onclick="window.print()"
          style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700;
                 background:#1A6B4A; color:#fff; border:none; border-radius:8px;
                 padding:8px 20px; cursor:pointer;">
    🖨️ Imprimir / Salvar PDF
  </button>
</div>

<div style="max-width:800px; margin:2rem auto; padding:0 1rem 3rem;">

  <div class="attestation-page" style="background:#fff; border:1px solid #DDD9D2; border-radius:16px;
              box-shadow:0 4px 24px rgba(0,0,0,0.07); overflow:hidden;">

    <%# ── Cabeçalho ── %>
    <div style="background:#0F3826; padding:28px 36px; display:flex; align-items:center; justify-content:space-between;">
      <div>
        <div style="font-family:'Raleway',sans-serif; font-size:1.4rem; font-weight:900; color:#fff; letter-spacing:-0.01em;">
          Practice<span style="color:#6EBD96;">-BR</span>
        </div>
        <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.72rem; color:#6EBD96; margin-top:3px; letter-spacing:0.04em; text-transform:uppercase;">
          Plateforme de Portugais Brésilien
        </div>
      </div>
      <div style="text-align:right;">
        <div style="font-family:'DM Mono',monospace; font-size:0.72rem; color:#6EBD96; letter-spacing:0.06em; text-transform:uppercase; margin-bottom:3px;">
          Attestation de formation
        </div>
        <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; color:#A7D9C0;">
          Générée le <%= Time.current.strftime("%d/%m/%Y") %>
        </div>
      </div>
    </div>

    <div style="padding:32px 36px;">

      <%# ── Infos aluno + professor ── %>
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:24px; margin-bottom:28px; padding-bottom:24px; border-bottom:1.5px solid #F0EDE8;">
        <div>
          <div style="font-family:'DM Mono',monospace; font-size:0.65rem; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:#9C9892; margin-bottom:10px;">
            Stagiaire
          </div>
          <div style="font-family:'Raleway',sans-serif; font-size:1.1rem; font-weight:800; color:#1C1917; margin-bottom:3px;">
            <%= @student.display_name %>
          </div>
          <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; color:#5C5853; margin-bottom:6px;">
            <%= @student.email %>
          </div>
          <% if @student.professional_type.present? %>
            <% pc = ApplicationHelper::PROFESSIONAL_COLORS[@student.professional_type] || { bg: '#F3F4F6', text: '#374151', border: '#D1D5DB' } %>
            <span style="font-family:'DM Mono',monospace; font-size:0.7rem; font-weight:800;
                         background:<%= pc[:bg] %>; color:<%= pc[:text] %>; border:1.5px solid <%= pc[:border] %>;
                         padding:3px 10px; border-radius:20px; letter-spacing:0.04em;">
              <%= @student.professional_type %>
            </span>
          <% end %>
        </div>
        <div>
          <div style="font-family:'DM Mono',monospace; font-size:0.65rem; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:#9C9892; margin-bottom:10px;">
            Formateur
          </div>
          <div style="font-family:'Raleway',sans-serif; font-size:1.1rem; font-weight:800; color:#1C1917; margin-bottom:3px;">
            <%= @teacher.display_name %>
          </div>
          <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; color:#5C5853;">
            <%= @teacher.email %>
          </div>
        </div>
      </div>

      <%# ── Résumé de la formation ── %>
      <% first_date = @attempts.first&.submitted_at %>
      <% last_date  = @attempts.last&.submitted_at %>
      <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:16px; margin-bottom:28px; padding-bottom:24px; border-bottom:1.5px solid #F0EDE8;">
        <div style="background:#F5F3FF; border:1.5px solid #DDD6FE; border-radius:12px; padding:16px 18px; text-align:center;">
          <div style="font-family:'DM Mono',monospace; font-size:0.65rem; color:#7C3AED; text-transform:uppercase; letter-spacing:0.08em; margin-bottom:6px;">Durée totale</div>
          <div style="font-family:'Raleway',sans-serif; font-size:1.6rem; font-weight:800; color:#7C3AED; line-height:1;">
            <%= format_training_duration(@total_minutes) %>
          </div>
        </div>
        <div style="background:#F0FAF4; border:1.5px solid #A7F3D0; border-radius:12px; padding:16px 18px; text-align:center;">
          <div style="font-family:'DM Mono',monospace; font-size:0.65rem; color:#0F3826; text-transform:uppercase; letter-spacing:0.08em; margin-bottom:6px;">Activités</div>
          <div style="font-family:'Raleway',sans-serif; font-size:1.6rem; font-weight:800; color:#1A6B4A; line-height:1;">
            <%= @attempts.size %>
          </div>
        </div>
        <div style="background:#FFF7ED; border:1.5px solid #FED7AA; border-radius:12px; padding:16px 18px; text-align:center;">
          <div style="font-family:'DM Mono',monospace; font-size:0.65rem; color:#7C2D12; text-transform:uppercase; letter-spacing:0.08em; margin-bottom:6px;">Période</div>
          <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:700; color:#7C2D12; line-height:1.3;">
            <% if first_date && last_date %>
              <%= first_date.strftime("%d/%m/%Y") %><br>→ <%= last_date.strftime("%d/%m/%Y") %>
            <% else %>
              —
            <% end %>
          </div>
        </div>
      </div>

      <%# ── Tableau des activités ── %>
      <h2 style="font-family:'Raleway',sans-serif; font-size:0.95rem; font-weight:700; color:#1C1917; margin:0 0 14px;">
        Détail des activités réalisées
      </h2>

      <table style="width:100%; border-collapse:collapse; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem;">
        <thead>
          <tr style="background:#F7F5F0; border-bottom:2px solid #DDD9D2;">
            <th style="padding:10px 12px; text-align:left; font-family:'DM Mono',monospace; font-size:0.65rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:#9C9892;">Date</th>
            <th style="padding:10px 12px; text-align:left; font-family:'DM Mono',monospace; font-size:0.65rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:#9C9892;">Activité</th>
            <th style="padding:10px 12px; text-align:center; font-family:'DM Mono',monospace; font-size:0.65rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:#9C9892;">Niveau</th>
            <th style="padding:10px 12px; text-align:center; font-family:'DM Mono',monospace; font-size:0.65rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:#9C9892;">Durée</th>
            <th style="padding:10px 12px; text-align:center; font-family:'DM Mono',monospace; font-size:0.65rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:#9C9892;">Score</th>
          </tr>
        </thead>
        <tbody>
          <% @attempts.each_with_index do |attempt, i| %>
            <% mins = [(attempt.submitted_at - attempt.started_at) / 60, 120].min.to_i %>
            <% ac = cefr_colors(attempt.activity.level) %>
            <% sc = attempt.score.round %>
            <% sc_color = sc >= 70 ? '#1A6B4A' : sc >= 40 ? '#C9952A' : '#B91C1C' %>
            <tr style="border-bottom:1px solid #F0EDE8; background:<%= i.even? ? '#fff' : '#FAFAF9' %>;">
              <td style="padding:10px 12px; color:#5C5853;">
                <%= attempt.submitted_at.strftime("%d/%m/%Y") %>
              </td>
              <td style="padding:10px 12px; font-weight:600; color:#1C1917;">
                <%= attempt.activity.title %>
              </td>
              <td style="padding:10px 12px; text-align:center;">
                <span style="font-family:'DM Mono',monospace; font-size:0.68rem; font-weight:700;
                             background:<%= ac[:bg] %>; color:<%= ac[:text] %>; border:1px solid <%= ac[:border] %>;
                             padding:2px 8px; border-radius:20px;">
                  <%= attempt.activity.level %>
                </span>
              </td>
              <td style="padding:10px 12px; text-align:center; font-family:'DM Mono',monospace; font-weight:700; color:#7C3AED;">
                <%= mins %>min
              </td>
              <td style="padding:10px 12px; text-align:center; font-family:'DM Mono',monospace; font-weight:800; color:<%= sc_color %>;">
                <%= sc %>%
              </td>
            </tr>
          <% end %>
          <tr style="background:#F7F5F0; border-top:2px solid #DDD9D2;">
            <td colspan="3" style="padding:10px 12px; font-family:'DM Mono',monospace; font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:#5C5853;">Total</td>
            <td style="padding:10px 12px; text-align:center; font-family:'Raleway',sans-serif; font-weight:800; color:#7C3AED; font-size:0.95rem;">
              <%= format_training_duration(@total_minutes) %>
            </td>
            <td></td>
          </tr>
        </tbody>
      </table>

      <%# ── Rodapé ── %>
      <div style="margin-top:28px; padding-top:20px; border-top:1.5px solid #F0EDE8; text-align:center;">
        <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.75rem; color:#9C9892; line-height:1.6;">
          Cette attestation a été générée automatiquement par la plateforme <strong>Practice-BR</strong>.<br>
          Les durées correspondent au temps enregistré entre l'ouverture et la soumission de chaque activité, avec un maximum de 2h par session.
        </div>
      </div>

    </div>
  </div>
</div>
