<% content_for :hide_navbar, true %>
<% content_for :head do %>
  <title>Attestation - <%= @student.display_name %></title>
  <style>
    @media print {
      .no-print { display: none !important; }
      body { background: var(--surface) !important; }
      .attestation-page { box-shadow: none !important; border: none !important; }
      .attestation-header {
        background: var(--surface) !important;
        border-bottom: 3px solid var(--brand-deep) !important;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
      }
      .attestation-header .logo-img { filter: none !important; }
      .attestation-header .header-subtitle { color: var(--brand) !important; }
      .attestation-header .header-label { color: var(--brand-deep) !important; }
      .attestation-header .header-date { color: var(--ink-soft) !important; }
    }
    body { background: var(--paper); margin: 0; padding: 0; }
  </style>
<% end %>

<div class="no-print" style="background:var(--brand-deep); padding:12px 24px; display:flex; align-items:center; justify-content:space-between;">
  <%= link_to "← Voltar ao perfil", teacher_student_profile_path(@student),
        style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; color:var(--brand-soft); text-decoration:none;" %>
  <button onclick="document.title='Attestation - <%= j @student.display_name %>'; window.print();"
          style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:700;
                 background:var(--brand); color:var(--surface); border:none; border-radius:8px;
                 padding:8px 20px; cursor:pointer;">
    🖨️ Imprimir / Salvar PDF
  </button>
</div>

<div style="max-width:800px; margin:2rem auto; padding:0 1rem 3rem;">

  <div class="attestation-page" style="background:var(--surface); border:1px solid var(--line); border-radius:16px;
              box-shadow:0 4px 24px rgba(0,0,0,0.07); overflow:hidden;">

    <%# ── Cabeçalho ── %>
    <div class="attestation-header" style="background:var(--brand-deep); padding:28px 36px; display:flex; align-items:center; justify-content:space-between;">
      <div>
        <%= image_tag "practice-br-logo-horizontal-color.svg",
              alt: "Practice-BR",
              class: "logo-img",
              style: "height:44px; width:auto; filter:brightness(0) invert(1);" %>
        <div class="header-subtitle" style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.72rem; color:var(--brand-soft); margin-top:4px; letter-spacing:0.04em; text-transform:uppercase;">
          Plateforme de Portugais Brésilien
        </div>
      </div>
      <div style="text-align:right;">
        <div class="header-label" style="font-family:'DM Mono',monospace; font-size:0.72rem; color:var(--brand-soft); letter-spacing:0.06em; text-transform:uppercase; margin-bottom:3px;">
          Attestation de formation
        </div>
        <div class="header-date" style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; color:var(--brand-soft);">
          Générée le <%= Time.current.strftime("%d/%m/%Y") %>
        </div>
      </div>
    </div>

    <div style="padding:32px 36px;">

      <%# ── Infos aluno + professor ── %>
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:24px; margin-bottom:28px; padding-bottom:24px; border-bottom:1.5px solid var(--line-soft);">
        <div>
          <div style="font-family:'DM Mono',monospace; font-size:0.65rem; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:var(--ink-faint); margin-bottom:10px;">
            Stagiaire
          </div>
          <div style="font-family:'Raleway',sans-serif; font-size:1.1rem; font-weight:800; color:var(--ink); margin-bottom:3px;">
            <%= @student.display_name %>
          </div>
          <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; color:var(--ink-soft); margin-bottom:6px;">
            <%= @student.email %>
          </div>
          <% if @student.professional_type.present? %>
            <% pc = ApplicationHelper::PROFESSIONAL_COLORS[@student.professional_type] || { bg: 'var(--neutral-tint)', text: 'var(--neutral-ink)', border: 'var(--line)' } %>
            <span style="font-family:'DM Mono',monospace; font-size:0.7rem; font-weight:800;
                         background:<%= pc[:bg] %>; color:<%= pc[:text] %>; border:1.5px solid <%= pc[:border] %>;
                         padding:3px 10px; border-radius:20px; letter-spacing:0.04em;">
              <%= @student.professional_type %>
            </span>
          <% end %>
        </div>
        <div>
          <div style="font-family:'DM Mono',monospace; font-size:0.65rem; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:var(--ink-faint); margin-bottom:10px;">
            Formateur
          </div>
          <div style="font-family:'Raleway',sans-serif; font-size:1.1rem; font-weight:800; color:var(--ink); margin-bottom:3px;">
            <%= @teacher.display_name %>
          </div>
          <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; color:var(--ink-soft);">
            <%= @teacher.email %>
          </div>
        </div>
      </div>

      <%# ── Résumé de la formation ── %>
      <% first_date = @attempts.first&.submitted_at %>
      <% last_date  = @attempts.last&.submitted_at %>
      <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:16px; margin-bottom:28px; padding-bottom:24px; border-bottom:1.5px solid var(--line-soft);">
        <div style="background:var(--violet-tint); border:1.5px solid var(--violet-border); border-radius:12px; padding:16px 18px; text-align:center;">
          <div style="font-family:'DM Mono',monospace; font-size:0.65rem; color:var(--violet); text-transform:uppercase; letter-spacing:0.08em; margin-bottom:6px;">Durée totale</div>
          <div style="font-family:'Raleway',sans-serif; font-size:1.6rem; font-weight:800; color:var(--violet); line-height:1;">
            <%= format_training_duration(@total_minutes) %>
          </div>
        </div>
        <div style="background:var(--brand-mist); border:1.5px solid var(--success-border); border-radius:12px; padding:16px 18px; text-align:center;">
          <div style="font-family:'DM Mono',monospace; font-size:0.65rem; color:var(--brand-deep); text-transform:uppercase; letter-spacing:0.08em; margin-bottom:6px;">Activités</div>
          <div style="font-family:'Raleway',sans-serif; font-size:1.6rem; font-weight:800; color:var(--brand); line-height:1;">
            <%= @attempts.size %>
          </div>
        </div>
        <div style="background:var(--warning-tint); border:1.5px solid var(--warning-border); border-radius:12px; padding:16px 18px; text-align:center;">
          <div style="font-family:'DM Mono',monospace; font-size:0.65rem; color:var(--warning-ink); text-transform:uppercase; letter-spacing:0.08em; margin-bottom:6px;">Période</div>
          <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:700; color:var(--warning-ink); line-height:1.3;">
            <% if first_date && last_date %>
              <%= first_date.strftime("%d/%m/%Y") %><br>→ <%= last_date.strftime("%d/%m/%Y") %>
            <% else %>
              —
            <% end %>
          </div>
        </div>
      </div>

      <%# ── Tableau des activités ── %>
      <h2 style="font-family:'Raleway',sans-serif; font-size:0.95rem; font-weight:700; color:var(--ink); margin:0 0 14px;">
        Détail des activités réalisées
      </h2>

      <table style="width:100%; border-collapse:collapse; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem;">
        <thead>
          <tr style="background:var(--paper); border-bottom:2px solid var(--line);">
            <th style="padding:10px 12px; text-align:left; font-family:'DM Mono',monospace; font-size:0.65rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:var(--ink-faint);">Date</th>
            <th style="padding:10px 12px; text-align:left; font-family:'DM Mono',monospace; font-size:0.65rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:var(--ink-faint);">Activité</th>
            <th style="padding:10px 12px; text-align:center; font-family:'DM Mono',monospace; font-size:0.65rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:var(--ink-faint);">Niveau</th>
            <th style="padding:10px 12px; text-align:center; font-family:'DM Mono',monospace; font-size:0.65rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:var(--ink-faint);">Durée</th>
            <th style="padding:10px 12px; text-align:center; font-family:'DM Mono',monospace; font-size:0.65rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:var(--ink-faint);">Score</th>
          </tr>
        </thead>
        <tbody>
          <% @attempts.each_with_index do |attempt, i| %>
            <% mins = [(attempt.submitted_at - attempt.started_at) / 60, 120].min.to_i %>
            <% ac = cefr_colors(attempt.activity.level) %>
            <% sc = attempt.score.round %>
            <% sc_color = sc >= 70 ? 'var(--brand)' : sc >= 40 ? 'var(--action)' : 'var(--error)' %>
            <tr style="border-bottom:1px solid var(--line-soft); background:<%= i.even? ? 'var(--surface)' : 'var(--surface-2)' %>;">
              <td style="padding:10px 12px; color:var(--ink-soft);">
                <%= attempt.submitted_at.strftime("%d/%m/%Y") %>
              </td>
              <td style="padding:10px 12px; font-weight:600; color:var(--ink);">
                <%= attempt.activity.title %>
              </td>
              <td style="padding:10px 12px; text-align:center;">
                <span style="font-family:'DM Mono',monospace; font-size:0.68rem; font-weight:700;
                             background:<%= ac[:bg] %>; color:<%= ac[:text] %>; border:1px solid <%= ac[:border] %>;
                             padding:2px 8px; border-radius:20px;">
                  <%= attempt.activity.level %>
                </span>
              </td>
              <td style="padding:10px 12px; text-align:center; font-family:'DM Mono',monospace; font-weight:700; color:var(--violet);">
                <%= mins %>min
              </td>
              <td style="padding:10px 12px; text-align:center; font-family:'DM Mono',monospace; font-weight:800; color:<%= sc_color %>;">
                <%= sc %>%
              </td>
            </tr>
          <% end %>
          <tr style="background:var(--paper); border-top:2px solid var(--line);">
            <td colspan="3" style="padding:10px 12px; font-family:'DM Mono',monospace; font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:var(--ink-soft);">Total</td>
            <td style="padding:10px 12px; text-align:center; font-family:'Raleway',sans-serif; font-weight:800; color:var(--violet); font-size:0.95rem;">
              <%= format_training_duration(@total_minutes) %>
            </td>
            <td></td>
          </tr>
        </tbody>
      </table>

      <%# ── Rodapé ── %>
      <div style="margin-top:28px; padding-top:20px; border-top:1.5px solid var(--line-soft); text-align:center;">
        <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.75rem; color:var(--ink-faint); line-height:1.6;">
          Cette attestation a été générée automatiquement par la plateforme <strong>Practice-BR</strong>.<br>
          Les durées correspondent au temps enregistré entre l'ouverture et la soumission de chaque activité, avec un maximum de 2h par session.
        </div>
      </div>

    </div>
  </div>
</div>
