<% content_for :head do %>
  <title><%= @student.display_name %> · Practice-BR</title>
  <style>
    div[id^="attempt-"]:target {
      border-color: #F5D478 !important;
      background: #FFFBEB;
      box-shadow: 0 0 0 3px rgba(245,212,120,0.4);
    }
  </style>
<% end %>

<%
  score_color = ->(s) {
    s = s.to_i
    s >= 70 ? '#1A6B4A' : s >= 40 ? '#C9952A' : '#B91C1C'
  }
  score_bg = ->(s) {
    s = s.to_i
    s >= 70 ? '#E8F5EE' : s >= 40 ? '#FFF8E7' : '#FEF2F2'
  }
%>

<div style="max-width:900px; margin:0 auto;">

  <%# ── Breadcrumb ── %>
  <div style="display:flex; align-items:center; gap:8px; margin-bottom:1.5rem; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; color:#9C9892;">
    <%= link_to "Dashboard", teacher_dashboard_path, style: "color:#9C9892; text-decoration:none;" %>
    <span>›</span>
    <%= link_to "Meus Alunos", teacher_students_path, style: "color:#9C9892; text-decoration:none;" %>
    <span>›</span>
    <span style="color:#1C1917; font-weight:600;"><%= @student.display_name %></span>
  </div>

  <%# ── Cabeçalho do aluno ── %>
  <div style="background:#fff; border:1px solid #DDD9D2; border-radius:16px; padding:24px 28px; margin-bottom:1.5rem; display:flex; align-items:center; gap:20px; flex-wrap:wrap;">
    <div style="width:56px; height:56px; border-radius:50%; background:#1A6B4A; display:flex; align-items:center; justify-content:center;
                font-family:'Raleway',sans-serif; font-size:1.4rem; font-weight:800; color:#fff; flex-shrink:0;">
      <%= @student.display_name[0].upcase %>
    </div>
    <div style="flex:1; min-width:180px;">
      <div style="display:flex; align-items:center; gap:10px; flex-wrap:wrap; margin-bottom:4px;">
        <h1 style="font-family:'Raleway',sans-serif; font-size:1.3rem; font-weight:700; color:#1C1917; margin:0;">
          <%= @student.display_name %>
        </h1>
        <% if @student.level.present? %>
          <% lc = cefr_colors(@student.level) %>
          <span style="font-family:'DM Mono',monospace; font-size:0.72rem; font-weight:700;
                       background:<%= lc[:bg] %>; color:<%= lc[:text] %>; border:1.5px solid <%= lc[:border] %>;
                       padding:2px 10px; border-radius:20px;">
            <%= @student.level %>
          </span>
        <% else %>
          <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.72rem; font-weight:700;
                       background:#FEF2F2; color:#B91C1C; border:1.5px solid #FECACA;
                       padding:2px 9px; border-radius:20px;">
            ⚠️ Sem nível
          </span>
        <% end %>
        <% if @pending_count > 0 %>
          <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.72rem; font-weight:700;
                       background:#FFF7ED; color:#7C2D12; border:1.5px solid #FED7AA;
                       padding:2px 9px; border-radius:20px;">
            ✍️ <%= @pending_count %> aguardando feedback
          </span>
        <% end %>
      </div>
      <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; color:#9C9892;">
        <%= @student.email %> · aluno desde <%= @student.created_at.strftime("%b %Y") %>
      </div>
    </div>

    <%# ── Seletor de nível ── %>
    <%= form_with url: teacher_student_level_path(@student), method: :patch,
          data: { turbo: false },
          style: "display:flex; align-items:center; gap:8px; flex-shrink:0;" do |f| %>
      <div style="display:flex; gap:6px; flex-wrap:wrap;">
        <% User::CEFR_LEVELS.each do |lvl| %>
          <% lc = cefr_colors(lvl) %>
          <button type="submit" name="level" value="<%= lvl %>"
                  style="font-family:'DM Mono',monospace; font-size:0.72rem; font-weight:700;
                         padding:5px 12px; border-radius:20px; cursor:pointer;
                         border:1.5px solid <%= @student.level == lvl ? lc[:border] : '#DDD9D2' %>;
                         background:<%= @student.level == lvl ? lc[:bg] : '#fff' %>;
                         color:<%= @student.level == lvl ? lc[:text] : '#9C9892' %>;">
            <%= lvl %>
          </button>
        <% end %>
      </div>
      <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.7rem; color:#9C9892; margin-top:2px;">
        Nível do aluno &nbsp;·&nbsp; C1 = acesso total
      </div>
    <% end %>

    <%# ── Remover aluno ── %>
    <%= form_with url: teacher_student_remove_path(@student), method: :delete,
          data: { turbo: false },
          style: "flex-shrink:0;" do |f| %>
      <button type="submit"
              onclick="return confirm('Remover <%= j @student.display_name %> da sua lista? O aluno perde acesso às atividades.');"
              style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; font-weight:600;
                     background:#FEF2F2; color:#B91C1C; border:1.5px solid #FECACA;
                     border-radius:8px; padding:7px 14px; cursor:pointer;">
        🗑 Remover aluno
      </button>
    <% end %>
  </div>

  <%# ── 4 Métricas ── %>
  <div class="dash-metrics-grid" style="margin-bottom:1.5rem;">
    <div style="background:#fff; border:1px solid #DDD9D2; border-radius:14px; padding:20px 22px;">
      <div style="font-family:'DM Mono',monospace; font-size:0.68rem; color:#9C9892; letter-spacing:0.08em; margin-bottom:8px; text-transform:uppercase;">Tentativas</div>
      <div style="font-family:'Raleway',sans-serif; font-size:2rem; font-weight:800; color:#0F3826; line-height:1;"><%= @attempts.size %></div>
      <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; color:#5C5853; margin-top:6px;">nas suas atividades</div>
    </div>
    <div style="background:#fff; border:1px solid #DDD9D2; border-radius:14px; padding:20px 22px;">
      <div style="font-family:'DM Mono',monospace; font-size:0.68rem; color:#9C9892; letter-spacing:0.08em; margin-bottom:8px; text-transform:uppercase;">Média</div>
      <div style="font-family:'Raleway',sans-serif; font-size:2rem; font-weight:800; color:<%= score_color.call(@avg_score) %>; line-height:1;"><%= @avg_score %>%</div>
      <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; color:#5C5853; margin-top:6px;">score médio</div>
    </div>
    <div style="background:#fff; border:1px solid #DDD9D2; border-radius:14px; padding:20px 22px;">
      <div style="font-family:'DM Mono',monospace; font-size:0.68rem; color:#9C9892; letter-spacing:0.08em; margin-bottom:8px; text-transform:uppercase;">Melhor Score</div>
      <div style="font-family:'Raleway',sans-serif; font-size:2rem; font-weight:800; color:#1A6B4A; line-height:1;"><%= @best_score %>%</div>
      <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; color:#5C5853; margin-top:6px;">máximo atingido</div>
    </div>
    <div style="background:#fff; border:1px solid #DDD9D2; border-radius:14px; padding:20px 22px;">
      <div style="font-family:'DM Mono',monospace; font-size:0.68rem; color:#9C9892; letter-spacing:0.08em; margin-bottom:8px; text-transform:uppercase;">Assiduidade</div>
      <div style="font-family:'Raleway',sans-serif; font-size:2rem; font-weight:800; color:#2563EB; line-height:1;"><%= @days_active %></div>
      <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; color:#5C5853; margin-top:6px;">dias ativos (30 dias)</div>
    </div>
  </div>

  <%# ── Histórico de Tentativas ── %>
  <div style="background:#fff; border:1px solid #DDD9D2; border-radius:16px; padding:28px; margin-bottom:2rem;">
    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:1.5rem; flex-wrap:wrap; gap:10px;">
      <h2 style="font-family:'Raleway',sans-serif; font-size:1.1rem; font-weight:700; color:#1C1917; margin:0;">
        Histórico de Tentativas
      </h2>
      <% if @attempts.any? { |a| a.teacher_comments.present? } %>
        <%= form_with url: teacher_student_clear_comments_path(@student), method: :patch,
              data: { turbo: false } do |f| %>
          <button type="submit"
                  onclick="return confirm('Apagar todos os seus feedbacks para <%= j @student.display_name %>?');"
                  style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.75rem; font-weight:600;
                         background:#FFF7ED; color:#7C2D12; border:1.5px solid #FED7AA;
                         border-radius:8px; padding:5px 12px; cursor:pointer;">
            🗑 Limpar todos os feedbacks
          </button>
        <% end %>
      <% end %>
    </div>

    <% if @attempts.empty? %>
      <div style="text-align:center; padding:40px 20px; color:#9C9892;">
        <div style="font-size:2rem; margin-bottom:8px;">📋</div>
        <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.88rem;">Nenhuma tentativa ainda nas suas atividades.</div>
      </div>
    <% else %>
      <% @attempts.each do |attempt| %>
        <% ac = cefr_colors(attempt.activity.level) %>
        <div id="attempt-<%= attempt.id %>" style="border:1px solid #F0EDE8; border-radius:12px; padding:18px 20px; margin-bottom:14px;">

          <%# Linha do título ── %>
          <div style="display:flex; align-items:center; gap:12px; margin-bottom:12px; flex-wrap:wrap;">
            <span style="font-family:'DM Mono',monospace; font-size:0.7rem; font-weight:700;
                         background:<%= ac[:bg] %>; color:<%= ac[:text] %>; border:1.5px solid <%= ac[:border] %>;
                         padding:2px 9px; border-radius:20px; flex-shrink:0;">
              <%= attempt.activity.level %>
            </span>
            <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; font-weight:700; color:#1C1917; flex:1;">
              <%= attempt.activity.title %>
            </span>
            <span style="font-family:'DM Mono',monospace; font-size:1rem; font-weight:800;
                         background:<%= score_bg.call(attempt.score) %>; color:<%= score_color.call(attempt.score) %>;
                         padding:3px 12px; border-radius:20px; flex-shrink:0;">
              <%= attempt.score.round %>%
            </span>
            <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; color:#9C9892; flex-shrink:0;">
              <%= attempt.submitted_at.strftime("%d/%m/%Y") %>
            </span>
          </div>

          <%# Questões abertas desta tentativa ── %>
          <% oe = attempt.open_ended_results %>
          <% if oe.any? %>
            <% oe.each do |q_key, result| %>
              <%
                q_id = q_key.to_s.gsub(/\D/, '')
                ai_score    = result["ai_score"]
                ai_feedback = result["ai_feedback"]
                given_answer = result["given_answer"]
                existing_comment = attempt.teacher_comment_for(q_id)
              %>
              <div style="background:#FAFAF9; border:1px solid #EAE7E2; border-radius:10px; padding:16px; margin-bottom:10px;">
                <div style="font-family:'DM Mono',monospace; font-size:0.68rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:#C9952A; margin-bottom:8px;">
                  ✨ Questão aberta
                </div>

                <%# Pergunta ── %>
                <% if result["question_text"].present? %>
                  <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:600; color:#1C1917; margin-bottom:8px;">
                    <%= result["question_text"].gsub(/<\/?[^>]+>/, '').strip %>
                  </div>
                <% end %>

                <%# Resposta do aluno ── %>
                <div style="background:#fff; border:1px solid #E8E5E0; border-radius:8px; padding:10px 12px; margin-bottom:10px;">
                  <div style="font-family:'DM Mono',monospace; font-size:0.68rem; color:#9C9892; margin-bottom:4px; text-transform:uppercase; letter-spacing:0.06em;">Resposta do aluno</div>
                  <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.88rem; color:#1C1917; line-height:1.55;">
                    <%= given_answer.presence || "(sem resposta)" %>
                  </div>
                </div>

                <%# Feedback da IA ── %>
                <% if ai_score || ai_feedback %>
                  <div style="background:#FFF7ED; border:1px solid #FED7AA; border-radius:8px; padding:10px 12px; margin-bottom:12px;">
                    <div style="display:flex; align-items:center; gap:8px; margin-bottom:4px;">
                      <span style="font-family:'DM Mono',monospace; font-size:0.68rem; text-transform:uppercase; letter-spacing:0.06em; color:#7C2D12;">✨ Avaliação da IA</span>
                      <% if ai_score %>
                        <span style="font-family:'DM Mono',monospace; font-size:0.82rem; font-weight:800; color:<%= score_color.call(ai_score) %>;">
                          <%= ai_score %>/100
                        </span>
                      <% end %>
                    </div>
                    <% if ai_feedback %>
                      <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; color:#7C2D12; line-height:1.55;">
                        <%= ai_feedback %>
                      </div>
                    <% end %>
                  </div>
                <% end %>

                <%# Feedback do professor ── %>
                <% form_id = "feedback-form-#{attempt.id}-#{q_id}" %>
                <% if existing_comment %>
                  <div id="<%= "display-#{form_id}" %>" style="background:#E8F5EE; border:1px solid #BBF7D0; border-radius:8px; padding:10px 12px; margin-bottom:10px;">
                    <div style="display:flex; align-items:flex-start; justify-content:space-between; gap:8px;">
                      <div style="flex:1;">
                        <div style="font-family:'DM Mono',monospace; font-size:0.68rem; text-transform:uppercase; letter-spacing:0.06em; color:#0F3826; margin-bottom:4px;">✍️ Seu feedback</div>
                        <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.88rem; color:#0F3826; line-height:1.55;">
                          <%= existing_comment %>
                        </div>
                      </div>
                      <div style="display:flex; flex-direction:column; gap:4px; flex-shrink:0; margin-top:2px;">
                        <button type="button"
                                onclick="document.getElementById('<%= form_id %>').style.display='block'; document.getElementById('<%= "display-#{form_id}" %>').style.display='none';"
                                title="Editar feedback"
                                style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.72rem; font-weight:600;
                                       background:transparent; color:#1A6B4A; border:1.5px solid #BBF7D0;
                                       border-radius:6px; padding:3px 8px; cursor:pointer;">
                          ✏️
                        </button>
                        <%= form_with url: quiz_attempt_teacher_comment_path(attempt), method: :patch, data: { turbo: false } do |f| %>
                          <%= hidden_field_tag :question_id, q_id %>
                          <%= hidden_field_tag :comment, '' %>
                          <button type="submit"
                                  title="Apagar este feedback"
                                  style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.72rem; font-weight:600;
                                         background:transparent; color:#B91C1C; border:1.5px solid #FECACA;
                                         border-radius:6px; padding:3px 8px; cursor:pointer;">
                            ✕
                          </button>
                        <% end %>
                      </div>
                    </div>
                  </div>
                <% end %>

                <%# Formulário de feedback do professor ── %>
                <div id="<%= form_id %>" style="margin-top:4px;<%= ' display:none;' if existing_comment %>">
                  <%= form_with url: quiz_attempt_teacher_comment_path(attempt),
                                method: :patch,
                                data: { turbo: false } do |f| %>
                    <%= hidden_field_tag :question_id, q_id %>
                    <%= text_area_tag :comment,
                          existing_comment,
                          rows: 2,
                          placeholder: "Deixe seu feedback para este aluno...",
                          style: "width:100%; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem;
                                  padding:8px 11px; border:1.5px solid #DDD9D2; border-radius:8px;
                                  color:#1C1917; background:#fff; box-sizing:border-box; resize:vertical;" %>
                    <div style="display:flex; gap:8px; margin-top:6px;">
                      <button type="submit"
                              style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; font-weight:700;
                                     background:#1A6B4A; color:#fff; border:none; border-radius:8px;
                                     padding:6px 16px; cursor:pointer;">
                        <%= existing_comment ? "Atualizar feedback" : "Salvar feedback" %>
                      </button>
                      <% if existing_comment %>
                        <button type="button"
                                onclick="document.getElementById('<%= form_id %>').style.display='none'; document.getElementById('<%= "display-#{form_id}" %>').style.display='block';"
                                style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; color:#9C9892;
                                       background:transparent; border:1.5px solid #DDD9D2; border-radius:8px;
                                       padding:6px 12px; cursor:pointer;">
                          Cancelar
                        </button>
                      <% end %>
                    </div>
                  <% end %>
                </div>

              </div>
            <% end %>
          <% end %>

        </div>
      <% end %>
    <% end %>
  </div>

</div>
