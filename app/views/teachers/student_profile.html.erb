<% content_for :head do %>
  <title><%= @student.display_name %> · Practice-BR</title>
<% end %>

<div style="max-width:900px; margin:0 auto;">

  <%# ── Breadcrumb ── %>
  <div style="display:flex; align-items:center; gap:8px; margin-bottom:1.5rem; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; color:#9C9892;">
    <%= link_to "Dashboard", teacher_dashboard_path, style: "color:#9C9892; text-decoration:none;" %>
    <span>›</span>
    <%= link_to "Meus Alunos", teacher_students_path, style: "color:#9C9892; text-decoration:none;" %>
    <span>›</span>
    <span style="color:#1C1917; font-weight:600;"><%= @student.display_name %></span>
  </div>

  <%# ── Cabeçalho do aluno ── %>
  <div style="background:#fff; border:1px solid #DDD9D2; border-radius:16px; padding:24px 28px; margin-bottom:1.5rem; display:flex; align-items:center; gap:20px; flex-wrap:wrap;">
    <div style="width:56px; height:56px; border-radius:50%; background:#1A6B4A; display:flex; align-items:center; justify-content:center;
                font-family:'Raleway',sans-serif; font-size:1.4rem; font-weight:800; color:#fff; flex-shrink:0;">
      <%= @student.display_name[0].upcase %>
    </div>
    <div style="flex:1; min-width:180px;">
      <div style="display:flex; align-items:center; gap:10px; flex-wrap:wrap; margin-bottom:4px;">
        <h1 style="font-family:'Raleway',sans-serif; font-size:1.3rem; font-weight:700; color:#1C1917; margin:0;">
          <%= @student.display_name %>
        </h1>
        <%= professional_badge_html(@student) %>
        <% if @student.level.present? %>
          <% lc = cefr_colors(@student.level) %>
          <span style="font-family:'DM Mono',monospace; font-size:0.72rem; font-weight:700;
                       background:<%= lc[:bg] %>; color:<%= lc[:text] %>; border:1.5px solid <%= lc[:border] %>;
                       padding:2px 10px; border-radius:20px;">
            <%= @student.level %>
          </span>
        <% else %>
          <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.72rem; font-weight:700;
                       background:#FEF2F2; color:#B91C1C; border:1.5px solid #FECACA;
                       padding:2px 9px; border-radius:20px;">
            ⚠️ Sem nível
          </span>
        <% end %>
        <% if @pending_count > 0 %>
          <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.72rem; font-weight:700;
                       background:#FFF7ED; color:#7C2D12; border:1.5px solid #FED7AA;
                       padding:2px 9px; border-radius:20px;">
            ✍️ <%= @pending_count %> aguardando feedback
          </span>
        <% end %>
      </div>
      <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; color:#9C9892;">
        <%= @student.email %> · aluno desde <%= @student.created_at.strftime("%b %Y") %>
      </div>
    </div>

    <%# ── Seletor de nível ── %>
    <%= form_with url: teacher_student_level_path(@student), method: :patch,
          data: { turbo: false },
          style: "display:flex; align-items:center; gap:8px; flex-shrink:0;" do |f| %>
      <div style="display:flex; gap:6px; flex-wrap:wrap;">
        <% User::CEFR_LEVELS.each do |lvl| %>
          <% lc = cefr_colors(lvl) %>
          <button type="submit" name="level" value="<%= lvl %>"
                  style="font-family:'DM Mono',monospace; font-size:0.72rem; font-weight:700;
                         padding:5px 12px; border-radius:20px; cursor:pointer;
                         border:1.5px solid <%= @student.level == lvl ? lc[:border] : '#DDD9D2' %>;
                         background:<%= @student.level == lvl ? lc[:bg] : '#fff' %>;
                         color:<%= @student.level == lvl ? lc[:text] : '#9C9892' %>;">
            <%= lvl %>
          </button>
        <% end %>
      </div>
      <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.7rem; color:#9C9892; margin-top:2px;">
        Nível do aluno &nbsp;·&nbsp; C1 = acesso total
      </div>
    <% end %>

    <%# ── Remover aluno ── %>
    <%= form_with url: teacher_student_remove_path(@student), method: :delete,
          data: { turbo: false },
          style: "flex-shrink:0;" do |f| %>
      <button type="submit"
              onclick="return confirm('Remover <%= j @student.display_name %> da sua lista? O aluno perde acesso às atividades.');"
              style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; font-weight:600;
                     background:#FEF2F2; color:#B91C1C; border:1.5px solid #FECACA;
                     border-radius:8px; padding:7px 14px; cursor:pointer;">
        🗑 Remover aluno
      </button>
    <% end %>
  </div>

  <%# ── 4 Métricas ── %>
  <div class="dash-metrics-grid" style="margin-bottom:1.5rem;">
    <div style="background:#fff; border:1px solid #DDD9D2; border-radius:14px; padding:20px 22px;">
      <div style="font-family:'DM Mono',monospace; font-size:0.68rem; color:#9C9892; letter-spacing:0.08em; margin-bottom:8px; text-transform:uppercase;">Atividades</div>
      <div style="font-family:'Raleway',sans-serif; font-size:2rem; font-weight:800; color:#0F3826; line-height:1;"><%= @total_activities %></div>
      <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; color:#5C5853; margin-top:6px;">realizadas</div>
    </div>
    <div style="background:#fff; border:1px solid #DDD9D2; border-radius:14px; padding:20px 22px;">
      <% avg_color = @avg_score >= 70 ? '#1A6B4A' : @avg_score >= 40 ? '#C9952A' : '#B91C1C' %>
      <div style="font-family:'DM Mono',monospace; font-size:0.68rem; color:#9C9892; letter-spacing:0.08em; margin-bottom:8px; text-transform:uppercase;">Média</div>
      <div style="font-family:'Raleway',sans-serif; font-size:2rem; font-weight:800; color:<%= avg_color %>; line-height:1;"><%= @avg_score %>%</div>
      <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; color:#5C5853; margin-top:6px;">score médio</div>
    </div>
    <div style="background:#fff; border:1px solid #DDD9D2; border-radius:14px; padding:20px 22px;">
      <div style="font-family:'DM Mono',monospace; font-size:0.68rem; color:#9C9892; letter-spacing:0.08em; margin-bottom:8px; text-transform:uppercase;">Melhor Score</div>
      <div style="font-family:'Raleway',sans-serif; font-size:2rem; font-weight:800; color:#1A6B4A; line-height:1;"><%= @best_score %>%</div>
      <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; color:#5C5853; margin-top:6px;">máximo atingido</div>
    </div>
    <div style="background:#fff; border:1px solid #DDD9D2; border-radius:14px; padding:20px 22px;">
      <div style="font-family:'DM Mono',monospace; font-size:0.68rem; color:#9C9892; letter-spacing:0.08em; margin-bottom:8px; text-transform:uppercase;">Assiduidade</div>
      <div style="font-family:'Raleway',sans-serif; font-size:2rem; font-weight:800; color:#2563EB; line-height:1;"><%= @days_active %></div>
      <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; color:#5C5853; margin-top:6px;">dias ativos (30 dias)</div>
    </div>
    <div style="background:#fff; border:1px solid #DDD9D2; border-radius:14px; padding:20px 22px;">
      <div style="font-family:'DM Mono',monospace; font-size:0.68rem; color:#9C9892; letter-spacing:0.08em; margin-bottom:8px; text-transform:uppercase;">Formação</div>
      <div style="font-family:'Raleway',sans-serif; font-size:2rem; font-weight:800; color:#7C3AED; line-height:1;"><%= format_training_duration(@training_minutes) %></div>
      <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; color:#5C5853; margin-top:6px;">tempo registado</div>
    </div>
  </div>

  <% if @student.professional_type.present? && @training_minutes > 0 %>
    <div style="margin-bottom:1.5rem; text-align:right;">
      <%= link_to teacher_student_attestation_path(@student), target: '_blank',
            style: "display:inline-flex; align-items:center; gap:6px; font-family:'Plus Jakarta Sans',sans-serif;
                    font-size:0.85rem; font-weight:700; color:#7C3AED; text-decoration:none;
                    background:#F5F3FF; border:1.5px solid #DDD6FE; border-radius:10px; padding:8px 16px;" do %>
        📄 Attestation de formation
      <% end %>
    </div>
  <% end %>

  <%# ── Seção: Atividades realizadas ── %>
  <div style="background:#fff; border:1px solid #DDD9D2; border-radius:16px; overflow:hidden; margin-bottom:1rem;">
    <div onclick="toggleSection('activities')"
         style="display:flex; align-items:center; justify-content:space-between; padding:20px 24px; cursor:pointer; user-select:none;">
      <div style="display:flex; align-items:center; gap:10px;">
        <h2 style="font-family:'Raleway',sans-serif; font-size:1rem; font-weight:700; color:#1C1917; margin:0;">
          Atividades realizadas
        </h2>
        <span style="font-family:'DM Mono',monospace; font-size:0.78rem; font-weight:700;
                     background:#F0FAF4; color:#1A6B4A; border:1.5px solid #A7F3D0;
                     padding:2px 8px; border-radius:20px;">
          <%= @total_activities %>
        </span>
      </div>
      <span id="activities-icon"
            style="font-family:'Raleway',sans-serif; font-size:1.4rem; font-weight:700; color:#1A6B4A; line-height:1; transition:transform 0.15s; display:inline-block;">
        +
      </span>
    </div>

    <div id="activities-body" style="display:none; padding:0 24px 20px;">
      <div id="activities-list"></div>
      <div style="text-align:center; margin-top:8px;">
        <button id="activities-more-btn"
                onclick="loadMoreSection('activities')"
                style="display:none; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:600;
                       background:#F0FAF4; color:#1A6B4A; border:1.5px solid #A7F3D0;
                       border-radius:8px; padding:8px 22px; cursor:pointer;">
          Ver mais
        </button>
      </div>
    </div>
  </div>

  <%# ── Seção: Expressão escrita ── %>
  <div style="background:#fff; border:1px solid #DDD9D2; border-radius:16px; overflow:hidden; margin-bottom:2rem;">
    <div style="display:flex; align-items:center; justify-content:space-between; padding:20px 24px;">
      <div onclick="toggleSection('written')"
           style="display:flex; align-items:center; gap:10px; flex:1; cursor:pointer; user-select:none;">
        <h2 style="font-family:'Raleway',sans-serif; font-size:1rem; font-weight:700; color:#1C1917; margin:0;">
          Expressão escrita
        </h2>
        <span style="font-family:'DM Mono',monospace; font-size:0.78rem; font-weight:700;
                     background:#FFF7ED; color:#7C2D12; border:1.5px solid #FED7AA;
                     padding:2px 8px; border-radius:20px;">
          <%= @total_written %>
        </span>
        <% if @pending_count > 0 %>
          <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.72rem; font-weight:700;
                       background:#FFF7ED; color:#7C2D12; border:1.5px solid #FED7AA;
                       padding:2px 9px; border-radius:20px;">
            ✍️ <%= @pending_count %> aguardando
          </span>
        <% end %>
      </div>
      <div style="display:flex; align-items:center; gap:10px; flex-shrink:0;">
        <% if @has_comments %>
          <%= form_with url: teacher_student_clear_comments_path(@student), method: :patch,
                data: { turbo: false } do |f| %>
            <button type="submit"
                    onclick="event.stopPropagation(); return confirm('Apagar todos os seus feedbacks para <%= j @student.display_name %>?');"
                    style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.75rem; font-weight:600;
                           background:#FFF7ED; color:#7C2D12; border:1.5px solid #FED7AA;
                           border-radius:8px; padding:5px 12px; cursor:pointer;">
              🗑 Limpar feedbacks
            </button>
          <% end %>
        <% end %>
        <span id="written-icon"
              onclick="toggleSection('written')"
              style="font-family:'Raleway',sans-serif; font-size:1.4rem; font-weight:700; color:#C9952A; line-height:1; transition:transform 0.15s; display:inline-block; cursor:pointer;">
          +
        </span>
      </div>
    </div>

    <div id="written-body" style="display:none; padding:0 24px 20px;">
      <div id="written-list"></div>
      <div style="text-align:center; margin-top:8px;">
        <button id="written-more-btn"
                onclick="loadMoreSection('written')"
                style="display:none; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; font-weight:600;
                       background:#FFF7ED; color:#7C2D12; border:1.5px solid #FED7AA;
                       border-radius:8px; padding:8px 22px; cursor:pointer;">
          Ver mais
        </button>
      </div>
    </div>
  </div>

</div>

<script>
(function() {
  var URLS = {
    activities: '<%= teacher_student_activities_path(@student) %>',
    written:    '<%= teacher_student_written_path(@student) %>'
  };
  var opened = { activities: false, written: false };

  window.toggleSection = function(type) {
    var body = document.getElementById(type + '-body');
    var icon = document.getElementById(type + '-icon');
    var isOpen = body.style.display !== 'none';

    if (isOpen) {
      body.style.display = 'none';
      icon.textContent = '+';
      icon.style.transform = '';
    } else {
      body.style.display = 'block';
      icon.textContent = '−';
      if (!opened[type]) {
        opened[type] = true;
        fetchSection(type, 0);
      }
    }
  };

  function fetchSection(type, offset) {
    var list = document.getElementById(type + '-list');
    var btn  = document.getElementById(type + '-more-btn');

    fetch(URLS[type] + '?offset=' + offset, {
      headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      list.insertAdjacentHTML('beforeend', data.html);
      if (data.has_more) {
        btn.dataset.offset = data.next_offset;
        btn.style.display = 'inline-block';
      } else {
        btn.style.display = 'none';
      }
    });
  }

  window.loadMoreSection = function(type) {
    var btn = document.getElementById(type + '-more-btn');
    btn.style.display = 'none';
    fetchSection(type, parseInt(btn.dataset.offset));
  };
})();
</script>
