<% content_for :head do %>
  <title>Dashboard · Practice-BR</title>
<% end %>

<%
  user_activities     = Activity.where(teacher_id: current_user.id)
  activities_by_level = user_activities.group(:level).count
  total_activities    = user_activities.count
  ai_activities       = user_activities.where(ai_generated: true).count
  manual_activities   = total_activities - ai_activities
  unique_students     = QuizAttempt.joins(:activity).where(activities: { teacher_id: current_user.id }).distinct.count('user_id')
  total_attempts      = QuizAttempt.joins(:activity).where(activities: { teacher_id: current_user.id }).count
  recent_activities   = user_activities.includes(:activity_ratings).order(created_at: :desc).limit(5)
  max_count           = activities_by_level.values.max || 1

  # Avaliações recentes com comentário escrito
  recent_ratings = ActivityRating
    .joins(:activity, :user)
    .where(activities: { teacher_id: current_user.id })
    .where.not(comment: [nil, ''])
    .order(created_at: :desc)
    .includes(:user, :activity)
    .limit(3)

  # Meus Alunos — os 3 mais recentemente ativos
  recent_students = current_user.students
    .left_joins(:quiz_attempts)
    .where(
      "quiz_attempts.id IS NULL OR quiz_attempts.activity_id IN (?)",
      user_activities.select(:id)
    )
    .select("users.*, MAX(quiz_attempts.submitted_at) AS last_active, ROUND(AVG(quiz_attempts.score)::numeric,0) AS avg_score")
    .group("users.id")
    .order(Arel.sql("MAX(quiz_attempts.submitted_at) DESC NULLS LAST"))
    .limit(3)

  # Aguardando revisão — tentativas com questão aberta e teacher_comments vazio, apenas de alunos vinculados
  pending_review = QuizAttempt
    .joins(activity: :questions)
    .where(activities: { teacher_id: current_user.id })
    .where(user_id: current_user.students.select(:id))
    .where(questions: { question_type: 'open_ended' })
    .where("quiz_attempts.teacher_comments = '{}' OR quiz_attempts.teacher_comments IS NULL")
    .includes(:activity, :user)
    .distinct
    .order(submitted_at: :desc)
    .limit(5)

  # cefr_colors(level) available from ApplicationHelper::CEFR_COLORS

  type_labels = {
    'multiple_choice'  => 'Múltipla escolha',
    'fill_in_blank'    => 'Completar lacunas',
    'sentence_ordering'=> 'Ordenar frases',
    'paragraph_ordering'=> 'Ordenar parágrafos',
    'column_matching'  => 'Associar colunas',
  }
%>

<div class="dash-outer" id="teacher-dashboard-root" data-user-id="<%= current_user.id %>" style="max-width:1100px; margin:0 auto;">

  <%# ── Saudação ── %>
  <div style="margin-bottom:2rem;">
    <h1 style="font-family:'Raleway',sans-serif; font-size:1.75rem; font-weight:700; color:var(--ink); margin-bottom:4px;">
      Olá, <%= current_user.display_name %> 👋
    </h1>
    <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.95rem; color:var(--ink-soft);">
      Aqui está o resumo das suas atividades.
    </p>
  </div>

  <%# ── 4 Cards de Métricas ── %>
  <div class="dash-metrics-grid" id="tour-teacher-metrics" style="margin-bottom:2rem;">

    <div style="background:var(--surface); border:1px solid var(--line); border-radius:14px; padding:20px 22px;">
      <div style="font-family:'DM Mono',monospace; font-size:0.68rem; color:var(--ink-faint); letter-spacing:0.08em; margin-bottom:8px; text-transform:uppercase;">Atividades</div>
      <div style="font-family:'Raleway',sans-serif; font-size:2rem; font-weight:800; color:var(--brand-deep); line-height:1;"><%= total_activities %></div>
      <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; color:var(--ink-soft); margin-top:6px;">criadas por você</div>
    </div>

    <div style="background:var(--surface); border:1px solid var(--line); border-radius:14px; padding:20px 22px;">
      <div style="font-family:'DM Mono',monospace; font-size:0.68rem; color:var(--ink-faint); letter-spacing:0.08em; margin-bottom:8px; text-transform:uppercase;">Estudantes</div>
      <div style="font-family:'Raleway',sans-serif; font-size:2rem; font-weight:800; color:var(--info); line-height:1;"><%= unique_students %></div>
      <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; color:var(--ink-soft); margin-top:6px;">únicos participantes</div>
    </div>

    <div style="background:var(--surface); border:1px solid var(--line); border-radius:14px; padding:20px 22px;">
      <div style="font-family:'DM Mono',monospace; font-size:0.68rem; color:var(--ink-faint); letter-spacing:0.08em; margin-bottom:8px; text-transform:uppercase;">Tentativas</div>
      <div style="font-family:'Raleway',sans-serif; font-size:2rem; font-weight:800; color:var(--action); line-height:1;"><%= total_attempts %></div>
      <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; color:var(--ink-soft); margin-top:6px;">respostas enviadas</div>
    </div>

    <div style="background:var(--surface); border:1px solid var(--line); border-radius:14px; padding:20px 22px;">
      <div style="font-family:'DM Mono',monospace; font-size:0.68rem; color:var(--ink-faint); letter-spacing:0.08em; margin-bottom:10px; text-transform:uppercase;">Origem</div>
      <div style="display:flex; flex-direction:column; gap:8px;">
        <%= link_to activities_path(origem: 'ia'),
              style: "display:flex; align-items:center; justify-content:space-between; text-decoration:none; padding:6px 10px; background:var(--warning-tint); border:1px solid var(--warning-border); border-radius:8px;" do %>
          <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:600; color:var(--warning-ink);">✨ Geradas por IA</span>
          <span style="font-family:'DM Mono',monospace; font-size:1rem; font-weight:800; color:var(--action);"><%= ai_activities %></span>
        <% end %>
        <%= link_to activities_path(origem: 'manual'),
              style: "display:flex; align-items:center; justify-content:space-between; text-decoration:none; padding:6px 10px; background:var(--brand-tint); border:1px solid var(--success-border); border-radius:8px;" do %>
          <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:600; color:var(--brand-deep);">✏️ Criadas manualmente</span>
          <span style="font-family:'DM Mono',monospace; font-size:1rem; font-weight:800; color:var(--brand);"><%= manual_activities %></span>
        <% end %>
      </div>
    </div>

  </div>

  <%# ── Atividades por Nível e Competência ── %>
  <%
    all_ids = user_activities.pluck(:id)
    comp_oe_ids = all_ids.any? ? Set.new(Question.where(activity_id: all_ids, question_type: 'open_ended').distinct.pluck(:activity_id)) : Set.new
    comp_av_ids = all_ids.any? ? Set.new(
      ActiveStorage::Attachment.where(record_type: 'Activity', record_id: all_ids, name: %w[video_file audio_file]).distinct.pluck(:record_id) +
      user_activities.where.not(video_url: [nil, '']).pluck(:id)
    ) : Set.new
    acts_by_level_full = user_activities.to_a.group_by(&:level)

    # Pré-calcular contagens por nível × competência
    counts_by_level = {}
    ['A1','A2','B1','B2','C1'].each do |lvl|
      lvl_acts = acts_by_level_full[lvl] || []
      tally = { co: 0, ce: 0, ee: 0 }
      lvl_acts.each { |act| activity_competencies(act, comp_oe_ids, comp_av_ids).each { |k| tally[k] += 1 } }
      counts_by_level[lvl] = { total: lvl_acts.size, comps: tally }
    end
    # Máximo global para escalar as barras de forma comparável entre níveis
    # (mínimo 1 para evitar divisão por zero quando ainda não há atividades)
    bar_max = [counts_by_level.values.flat_map { |d| d[:comps].values }.max.to_i, 1].max
  %>
  <div style="background:var(--surface); border:1px solid var(--line); border-radius:16px; padding:28px; margin-bottom:1.5rem;">

    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:1.5rem;">
      <div>
        <h2 style="font-family:'Raleway',sans-serif; font-size:1.1rem; font-weight:700; color:var(--ink); margin:0 0 4px;">Atividades por Nível</h2>
        <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; color:var(--ink-faint); margin:0;">Distribuição de competências por nível</p>
      </div>
      <%= link_to "Ver todas →", activities_path,
            style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.8rem; color:var(--action); font-weight:600; text-decoration:none; flex-shrink:0;" %>
    </div>

    <div style="display:flex; flex-direction:column; gap:0; border:1px solid var(--line-soft); border-radius:12px; overflow:hidden;">

      <%# Cabeçalho %>
      <div style="display:grid; grid-template-columns:52px 1fr 44px; gap:0; background:var(--paper); padding:8px 16px; border-bottom:1px solid var(--paper-2);">
        <div></div>
        <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:12px;">
          <% ApplicationHelper::COMPETENCY_META.each do |key, cm| %>
            <div style="font-family:'DM Mono',monospace; font-size:0.65rem; font-weight:800; color:<%= cm[:color] %>; letter-spacing:0.06em; text-transform:uppercase;">
              <%= cm[:icon] %> <%= cm[:abbr] %>
            </div>
          <% end %>
        </div>
        <div style="font-family:'DM Mono',monospace; font-size:0.65rem; color:var(--ink-faint); letter-spacing:0.06em; text-transform:uppercase; text-align:right;">Total</div>
      </div>

      <% ['A1','A2','B1','B2','C1'].each_with_index do |lvl, i| %>
        <% data  = counts_by_level[lvl] %>
        <% total = data[:total] %>
        <% c     = cefr_colors(lvl) %>
        <% last  = i == 4 %>

        <div style="display:grid; grid-template-columns:52px 1fr 44px; gap:0; align-items:center; padding:14px 16px; background:var(--surface); <%= last ? '' : 'border-bottom:1px solid var(--paper);' %>">

          <%# Badge nível %>
          <div>
            <span style="font-family:'DM Mono',monospace; font-size:0.72rem; font-weight:700;
                         background:<%= c[:bg] %>; color:<%= c[:text] %>; border:1.5px solid <%= c[:border] %>;
                         padding:3px 8px; border-radius:20px; display:inline-block; text-align:center;">
              <%= lvl %>
            </span>
          </div>

          <%# Barras de competência %>
          <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:12px; align-items:center;">
            <% ApplicationHelper::COMPETENCY_META.each do |key, cm| %>
              <% n   = data[:comps][key] %>
              <% pct = (n.to_f / bar_max * 100).round %>
              <%= link_to activities_path(level: lvl, competencia: key),
                    style: "text-decoration:none; display:flex; flex-direction:column; gap:4px;" do %>
                <div style="display:flex; align-items:center; gap:6px;">
                  <div style="flex:1; background:var(--line-soft); border-radius:99px; height:7px; overflow:hidden;">
                    <div style="width:<%= n > 0 ? [pct, 4].max : 0 %>%; height:100%; border-radius:99px; background:<%= cm[:bar] %>; transition:width 0.4s ease;"></div>
                  </div>
                  <span style="font-family:'DM Mono',monospace; font-size:0.75rem; font-weight:700; color:<%= n > 0 ? cm[:color] : 'var(--ink-faint)' %>; min-width:18px; text-align:right; flex-shrink:0;">
                    <%= n %>
                  </span>
                </div>
              <% end %>
            <% end %>
          </div>

          <%# Total %>
          <div style="text-align:right;">
            <span style="font-family:'DM Mono',monospace; font-size:0.9rem; font-weight:800; color:<%= total > 0 ? 'var(--ink)' : 'var(--line)' %>;">
              <%= total %>
            </span>
          </div>

        </div>
      <% end %>

    </div>
  </div>



  <%# ── Meus Alunos ── %>
  <div id="tour-teacher-students" style="background:var(--surface); border:1px solid var(--line); border-radius:16px; padding:28px; margin-bottom:1.5rem;">
    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:1.25rem;">
      <h2 style="font-family:'Raleway',sans-serif; font-size:1.1rem; font-weight:700; color:var(--ink);">
        Meus Alunos
      </h2>
      <%= link_to "Ver todos →", teacher_students_path,
            style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.8rem; color:var(--brand); font-weight:600; text-decoration:none;" %>
    </div>

    <% if recent_students.empty? %>
      <div style="text-align:center; padding:24px 20px; color:var(--ink-faint);">
        <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.88rem;">Nenhum aluno convidado ainda.</div>
      </div>
    <% else %>
      <div style="display:flex; flex-direction:column; gap:10px;">
        <% recent_students.each do |student| %>
          <%= link_to teacher_student_profile_path(student),
                style: "display:flex; align-items:center; gap:12px; padding:12px 14px; border:1px solid var(--line-soft); border-radius:10px; text-decoration:none; background:var(--surface-2);"  do %>
            <div style="width:34px; height:34px; border-radius:50%; background:var(--brand); display:flex; align-items:center; justify-content:center;
                        font-family:'Raleway',sans-serif; font-size:0.88rem; font-weight:800; color:var(--surface); flex-shrink:0;">
              <%= student.display_name[0].upcase %>
            </div>
            <div style="flex:1; min-width:0;">
              <div style="display:flex; align-items:center; gap:6px; flex-wrap:wrap;">
                <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.88rem; font-weight:700; color:var(--ink);
                            white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                  <%= student.display_name %>
                </span>
                <%= professional_badge_html(student) %>
              </div>
              <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.75rem; color:var(--ink-faint);">
                <% if student.last_active %>
                  ativo <%= time_ago_in_words(student.last_active) %> atrás
                <% else %>
                  sem tentativas ainda
                <% end %>
              </div>
            </div>
            <% if student.avg_score.present? %>
              <span style="font-family:'DM Mono',monospace; font-size:0.82rem; font-weight:800; color:var(--ink-soft); flex-shrink:0;">
                <%= student.avg_score.to_i %>%
              </span>
            <% end %>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# ── Avaliações recentes ── %>
  <% if recent_ratings.any? %>
  <%
    total_ratings = ActivityRating
      .joins(:activity)
      .where(activities: { teacher_id: current_user.id })
      .where.not(comment: [nil, ''])
      .count
  %>
  <div style="background:var(--info-tint); border:1px solid var(--sky-border); border-radius:16px; padding:28px; margin-bottom:1.5rem;">
    <div style="display:flex; align-items:center; gap:8px; margin-bottom:1.25rem;">
      <h2 style="font-family:'Raleway',sans-serif; font-size:1.1rem; font-weight:700; color:var(--sky); margin:0;">
        ⭐ Avaliações dos alunos
      </h2>
      <span style="font-family:'DM Mono',monospace; font-size:0.75rem; font-weight:700;
                   background:var(--sky-border); color:var(--sky); padding:2px 8px; border-radius:20px;">
        <%= total_ratings %>
      </span>
    </div>
    <div id="ratings-list" style="display:flex; flex-direction:column; gap:8px;">
      <% recent_ratings.each do |rating| %>
        <%= render 'teachers/rating_card', rating: rating %>
      <% end %>
    </div>
    <% if total_ratings > 3 %>
    <div style="text-align:center; margin-top:14px;">
      <button id="load-more-ratings"
              data-offset="3"
              data-url="<%= teacher_more_ratings_path %>"
              style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:600; color:var(--sky);
                     background:var(--sky-tint); border:1px solid var(--sky-border); border-radius:8px; padding:8px 20px;
                     cursor:pointer;">
        Ver mais avaliações
      </button>
    </div>
    <% end %>
  </div>
  <% end %>

  <script>
    (function() {
      var btn  = document.getElementById('load-more-ratings');
      if (!btn) return;
      var list         = document.getElementById('ratings-list');
      var initialCount = list.children.length;
      var expanded     = false;

      btn.addEventListener('click', function() {
        if (expanded) {
          while (list.children.length > initialCount) {
            list.removeChild(list.lastChild);
          }
          btn.dataset.offset = String(initialCount);
          btn.textContent = 'Ver mais avaliações';
          btn.style.color      = 'var(--sky)';
          btn.style.background = 'var(--sky-tint)';
          expanded = false;
          return;
        }

        var offset = parseInt(btn.dataset.offset);
        btn.disabled = true;
        btn.textContent = 'Carregando...';
        fetch(btn.dataset.url + '?offset=' + offset, {
          headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          list.insertAdjacentHTML('beforeend', data.html);
          btn.dataset.offset = data.next_offset;
          btn.disabled = false;
          if (data.has_more) {
            btn.textContent = 'Ver mais avaliações';
          } else {
            btn.textContent = 'Ver menos';
            btn.style.color      = 'var(--sky)';
            btn.style.background = 'var(--sky-border)';
            expanded = true;
          }
        })
        .catch(function() {
          btn.disabled = false;
          btn.textContent = 'Ver mais avaliações';
        });
      });
    })();
  </script>

  <%# ── Aguardando Revisão ── %>
  <% if pending_review.any? %>
  <div style="background:var(--action-tint); border:1px solid var(--action-soft); border-radius:16px; padding:28px; margin-bottom:1.5rem;">
    <div style="display:flex; align-items:center; gap:8px; margin-bottom:1.25rem;">
      <h2 style="font-family:'Raleway',sans-serif; font-size:1.1rem; font-weight:700; color:var(--action-ink); margin:0;">
        ✍️ Aguardando seu feedback
      </h2>
      <span style="font-family:'DM Mono',monospace; font-size:0.75rem; font-weight:700;
                   background:var(--action-soft); color:var(--action-ink); padding:2px 8px; border-radius:20px;">
        <%= pending_review.size %>
      </span>
    </div>
    <div style="display:flex; flex-direction:column; gap:8px;">
      <% pending_review.each do |attempt| %>
        <%= link_to teacher_student_profile_path(attempt.user_id, anchor: "attempt-#{attempt.id}"),
              style: "display:flex; align-items:center; justify-content:space-between; padding:11px 14px; background:var(--surface); border:1px solid var(--action-soft); border-radius:10px; text-decoration:none;" do %>
          <div>
            <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.88rem; font-weight:700; color:var(--ink);">
              <%= attempt.user&.display_name || "Aluno" %>
            </div>
            <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.75rem; color:var(--ink-faint); margin-top:2px;">
              <%= attempt.activity.title %> · <%= attempt.submitted_at.strftime("%d/%m") %>
            </div>
          </div>
          <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.75rem; font-weight:600; color:var(--action);">
            Ver →
          </span>
        <% end %>
      <% end %>
    </div>
  </div>
  <% end %>

  <%# ── Sugestões de vídeo do dia ── %>
  <% pending_suggestions = VideoSuggestion.for_teacher(current_user).today.pending %>
  <% if pending_suggestions.any? %>
    <div style="margin-bottom:2rem;">
      <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:12px; flex-wrap:wrap; gap:8px;">
        <div style="font-family:'Raleway',sans-serif; font-size:1rem; font-weight:700; color:var(--ink); display:flex; align-items:center; gap:8px;">
          🎬 Sugestões de hoje
          <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.75rem; font-weight:600; background:var(--warning-tint); color:var(--warning-ink); border:1.5px solid var(--warning-border); border-radius:20px; padding:2px 10px;">
            <%= pending_suggestions.count %> pendente<%= pending_suggestions.count > 1 ? 's' : '' %>
          </span>
        </div>
        <%= link_to video_suggestions_path,
              style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.8rem; font-weight:600; color:var(--brand); text-decoration:none;" do %>
          Ver todas →
        <% end %>
      </div>
      <div style="display:flex; flex-direction:column; gap:10px;">
        <% pending_suggestions.each do |s| %>
          <%= render 'video_suggestions/suggestion_card', suggestion: s %>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# ── CTA Footer ── %>
  <div style="display:flex; justify-content:center; gap:12px; flex-wrap:wrap; padding-bottom:2rem;">
    <%= link_to activities_path,
          style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; font-weight:700;
                  background:var(--brand); color:var(--surface); padding:13px 32px; border-radius:12px;
                  text-decoration:none; display:inline-flex; align-items:center; gap:8px;" do %>
      Ver Todas as Atividades →
    <% end %>
    <%= link_to generate_with_ai_activities_path,
          style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; font-weight:700;
                  background:var(--brand-deep); color:var(--surface); padding:13px 28px; border-radius:12px;
                  text-decoration:none; display:inline-flex; align-items:center; gap:8px;" do %>
      ✨ Gerar com IA
    <% end %>
  </div>

</div>
