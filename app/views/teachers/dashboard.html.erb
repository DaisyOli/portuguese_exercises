<% content_for :head do %>
  <title>Dashboard · Practice-BR</title>
<% end %>

<%
  user_activities     = Activity.where(teacher_id: current_user.id)
  activities_by_level = user_activities.group(:level).count
  total_activities    = user_activities.count
  unique_students     = QuizAttempt.joins(:activity).where(activities: { teacher_id: current_user.id }).distinct.count('user_id')
  total_attempts      = QuizAttempt.joins(:activity).where(activities: { teacher_id: current_user.id }).count
  recent_activities   = user_activities.order(created_at: :desc).limit(5)
  max_count           = activities_by_level.values.max || 1

  # cefr_colors(level) available from ApplicationHelper::CEFR_COLORS

  type_labels = {
    'multiple_choice'  => 'Múltipla escolha',
    'fill_in_blank'    => 'Completar lacunas',
    'sentence_ordering'=> 'Ordenar frases',
    'paragraph_ordering'=> 'Ordenar parágrafos',
    'column_matching'  => 'Associar colunas',
  }
%>

<div class="dash-outer" style="max-width:1100px; margin:0 auto;">

  <%# ── Saudação ── %>
  <div style="margin-bottom:2rem;">
    <h1 style="font-family:'Raleway',sans-serif; font-size:1.75rem; font-weight:700; color:#1C1917; margin-bottom:4px;">
      Olá, <%= current_user.display_name %> 👋
    </h1>
    <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.95rem; color:#5C5853;">
      Aqui está o resumo das suas atividades.
    </p>
  </div>

  <%# ── 4 Cards de Métricas ── %>
  <div class="dash-metrics-grid" style="margin-bottom:2rem;">

    <div style="background:#fff; border:1px solid #DDD9D2; border-radius:14px; padding:20px 22px;">
      <div style="font-family:'DM Mono',monospace; font-size:0.68rem; color:#9C9892; letter-spacing:0.08em; margin-bottom:8px; text-transform:uppercase;">Atividades</div>
      <div style="font-family:'Raleway',sans-serif; font-size:2rem; font-weight:800; color:#0F3826; line-height:1;"><%= total_activities %></div>
      <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; color:#5C5853; margin-top:6px;">criadas por você</div>
    </div>

    <div style="background:#fff; border:1px solid #DDD9D2; border-radius:14px; padding:20px 22px;">
      <div style="font-family:'DM Mono',monospace; font-size:0.68rem; color:#9C9892; letter-spacing:0.08em; margin-bottom:8px; text-transform:uppercase;">Estudantes</div>
      <div style="font-family:'Raleway',sans-serif; font-size:2rem; font-weight:800; color:#2563EB; line-height:1;"><%= unique_students %></div>
      <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; color:#5C5853; margin-top:6px;">únicos participantes</div>
    </div>

    <div style="background:#fff; border:1px solid #DDD9D2; border-radius:14px; padding:20px 22px;">
      <div style="font-family:'DM Mono',monospace; font-size:0.68rem; color:#9C9892; letter-spacing:0.08em; margin-bottom:8px; text-transform:uppercase;">Tentativas</div>
      <div style="font-family:'Raleway',sans-serif; font-size:2rem; font-weight:800; color:#C9952A; line-height:1;"><%= total_attempts %></div>
      <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; color:#5C5853; margin-top:6px;">respostas enviadas</div>
    </div>

    <div style="background:#fff; border:1.5px dashed #DDD9D2; border-radius:14px; padding:20px 22px; display:flex; flex-direction:column; justify-content:center;">
      <div style="font-family:'DM Mono',monospace; font-size:0.68rem; color:#9C9892; letter-spacing:0.08em; margin-bottom:8px; text-transform:uppercase;">Avaliações</div>
      <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.88rem; font-weight:600; color:#5C5853; margin-bottom:4px;">Feedback dos alunos</div>
      <div style="font-family:'DM Mono',monospace; font-size:0.72rem; color:#9C9892;">em breve...</div>
    </div>

  </div>

  <%# ── Atividades por Nível ── %>
  <div style="background:#fff; border:1px solid #DDD9D2; border-radius:16px; padding:28px; margin-bottom:1.5rem;">

    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:1.5rem;">
      <h2 style="font-family:'Raleway',sans-serif; font-size:1.1rem; font-weight:700; color:#1C1917;">Atividades por Nível</h2>
      <%= link_to "Ver todas →", activities_path,
            style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.8rem; color:#C9952A; font-weight:600; text-decoration:none;" %>
    </div>

    <div style="display:flex; flex-direction:column; gap:12px;">
      <% ['A1', 'A2', 'B1', 'B2', 'C1'].each do |lvl| %>
        <% count = activities_by_level[lvl] || 0 %>
        <% width = (count.to_f / max_count * 100).round %>
        <% c = cefr_colors(lvl) %>
        <div style="display:flex; align-items:center; gap:16px;">
          <span style="font-family:'DM Mono',monospace; font-size:0.72rem; font-weight:700;
                       background:<%= c[:bg] %>; color:<%= c[:text] %>; border:1.5px solid <%= c[:border] %>;
                       padding:3px 10px; border-radius:20px; min-width:38px; text-align:center; flex-shrink:0;">
            <%= lvl %>
          </span>
          <div style="flex:1; background:#F7F5F0; border-radius:99px; height:8px; overflow:hidden;">
            <div style="width:<%= count > 0 ? [width, 4].max : 0 %>%; height:100%; border-radius:99px; background:<%= c[:bar] %>; transition:width 0.4s ease;"></div>
          </div>
          <span style="font-family:'DM Mono',monospace; font-size:0.8rem; color:<%= count > 0 ? '#5C5853' : '#9C9892' %>; min-width:24px; text-align:right;">
            <%= count %>
          </span>
        </div>
      <% end %>
    </div>
  </div>

  <%# ── Atividades Recentes ── %>
  <div style="background:#fff; border:1px solid #DDD9D2; border-radius:16px; padding:28px; margin-bottom:2rem;">

    <h2 style="font-family:'Raleway',sans-serif; font-size:1.1rem; font-weight:700; color:#1C1917; margin-bottom:1.5rem;">
      Atividades Recentes
    </h2>

    <% if recent_activities.empty? %>
      <div style="text-align:center; padding:40px 20px; color:#9C9892;">
        <div style="font-size:2.5rem; margin-bottom:12px;">📝</div>
        <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; font-weight:600; color:#5C5853; margin-bottom:6px;">Nenhuma atividade ainda</div>
        <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem;">Clique em "+ Nova Atividade" para começar.</div>
      </div>
    <% else %>
      <% recent_activities.each_with_index do |activity, i| %>
        <% c = cefr_colors(activity.level) %>
        <div class="dash-activity-row" style="padding:14px 0; <%= i < recent_activities.size - 1 ? 'border-bottom:1px solid #F0EDE8;' : '' %>">
          <span style="font-family:'DM Mono',monospace; font-size:0.72rem; font-weight:700;
                       background:<%= c[:bg] %>; color:<%= c[:text] %>; border:1.5px solid <%= c[:border] %>;
                       padding:3px 10px; border-radius:20px; flex-shrink:0;">
            <%= activity.level %>
          </span>
          <div style="flex:1; min-width:0;">
            <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; font-weight:600; color:#1C1917; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
              <%= activity.title %>
            </div>
            <% if activity.content_type.present? %>
              <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; color:#9C9892; margin-top:2px;">
                <%= type_labels[activity.content_type] || activity.content_type.humanize %>
              </div>
            <% end %>
          </div>
          <div class="dash-row-buttons" style="display:flex; align-items:center; gap:8px; flex-shrink:0;">
            <%= link_to "Ver", activity_path(activity),
                  style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; font-weight:600;
                          color:#2563EB; padding:5px 12px; border:1.5px solid #BFDBFE; border-radius:8px;
                          text-decoration:none; background:#EBF2FC;" %>
            <%= link_to "Editar", edit_activity_path(activity),
                  style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; font-weight:500;
                          color:#5C5853; padding:5px 12px; border:1.5px solid #DDD9D2; border-radius:8px;
                          text-decoration:none;" %>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>

  <%# ── CTA Footer ── %>
  <div style="display:flex; justify-content:center; gap:12px; flex-wrap:wrap; padding-bottom:2rem;">
    <%= link_to activities_path,
          style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; font-weight:700;
                  background:#1A6B4A; color:#fff; padding:13px 32px; border-radius:12px;
                  text-decoration:none; display:inline-flex; align-items:center; gap:8px;" do %>
      Ver Todas as Atividades →
    <% end %>
    <%= link_to generate_with_ai_activities_path,
          style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; font-weight:700;
                  background:#0F3826; color:#fff; padding:13px 28px; border-radius:12px;
                  text-decoration:none; display:inline-flex; align-items:center; gap:8px;" do %>
      ✨ Gerar com IA
    <% end %>
  </div>

</div>
