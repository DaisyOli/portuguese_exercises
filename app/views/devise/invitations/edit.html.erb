<% content_for :head do %>
  <title>Criar conta · Practice-BR</title>
  <style>
    .auth-input:focus { border-color:var(--brand-bright) !important; box-shadow:0 0 0 3px var(--brand-glow) !important; outline:none !important; }
  </style>
<% end %>

<div style="min-height:100vh; display:flex; align-items:center; justify-content:center; padding:24px 16px;">
  <div style="background:var(--surface); border:1px solid var(--line); border-radius:20px; padding:40px 36px; width:100%; max-width:400px; box-shadow:0 4px 32px rgba(0,0,0,0.07);">

    <%# Cabeçalho de boas-vindas %>
    <div style="text-align:center; margin-bottom:28px;">
      <div style="width:52px; height:52px; background:var(--brand-tint); border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 14px; font-size:1.6rem;">🎉</div>
      <h1 style="font-family:'Raleway',sans-serif; font-size:1.3rem; font-weight:700; color:var(--ink); margin-bottom:6px;">
        Bem-vindo ao Practice-BR!
      </h1>
      <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; color:var(--ink-soft); margin:0;">
        Crie sua senha para acessar a plataforma.
      </p>
    </div>

    <%= form_for(resource, as: resource_name, url: invitation_path(resource_name), html: { method: :put }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
      <%= f.hidden_field :invitation_token, value: resource.invitation_token %>

      <div style="margin-bottom:16px;">
        <%= f.label :name, "Seu nome",
              style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:600; color:var(--ink); display:block; margin-bottom:6px;" %>
        <%= f.text_field :name,
              placeholder: "Como você quer ser chamado?",
              class: "auth-input",
              style: "width:100%; padding:11px 14px; border:1.5px solid var(--line); border-radius:10px; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; color:var(--ink); background:var(--surface); box-sizing:border-box;" %>
      </div>

      <% if f.object.class.require_password_on_accepting %>
        <div style="margin-bottom:16px;">
          <%= f.label :password, "Nova senha",
                style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:600; color:var(--ink); display:block; margin-bottom:6px;" %>
          <%= f.password_field :password, autocomplete: "new-password",
                placeholder: "Mínimo 6 caracteres",
                class: "auth-input",
                style: "width:100%; padding:11px 14px; border:1.5px solid var(--line); border-radius:10px; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; color:var(--ink); background:var(--surface); box-sizing:border-box;" %>
          <% if @minimum_password_length %>
            <div style="font-family:'DM Mono',monospace; font-size:0.68rem; color:var(--ink-faint); margin-top:4px;">
              mínimo <%= @minimum_password_length %> caracteres
            </div>
          <% end %>
        </div>

        <div style="margin-bottom:28px;">
          <%= f.label :password_confirmation, "Confirmar senha",
                style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:600; color:var(--ink); display:block; margin-bottom:6px;" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password",
                placeholder: "Repita a senha",
                class: "auth-input",
                style: "width:100%; padding:11px 14px; border:1.5px solid var(--line); border-radius:10px; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; color:var(--ink); background:var(--surface); box-sizing:border-box;" %>
        </div>
      <% end %>

      <%# Toggle lembrete semanal %>
      <div style="background:var(--paper); border-radius:12px; padding:14px 16px; margin-bottom:20px; display:flex; align-items:flex-start; gap:12px;">
        <%= f.check_box :weekly_reminder_email,
              style: "margin-top:3px; accent-color:var(--brand); width:16px; height:16px; flex-shrink:0; cursor:pointer;",
              id: "weekly_reminder_checkbox" %>
        <label for="weekly_reminder_checkbox" style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; color:var(--ink); cursor:pointer; line-height:1.4;">
          <span style="font-weight:700;" id="wr-label">Lembrete semanal por email</span><br>
          <span style="color:var(--ink-faint);" id="wr-desc">Receba toda segunda os exercícios disponíveis no seu nível</span>
        </label>
      </div>

      <script>
      (function() {
        var lang = navigator.language || 'pt';
        var d = lang.startsWith('fr')
          ? { label: "Rappel hebdomadaire par email", desc: "Recevez chaque lundi vos exercices disponibles · sem pressão" }
          : lang.startsWith('en')
          ? { label: "Weekly email reminder", desc: "Get your available exercises every Monday · sem pressão" }
          : { label: "Lembrete semanal por email", desc: "Receba toda segunda os exercícios disponíveis no seu nível" };
        var l = document.getElementById('wr-label');
        var d2 = document.getElementById('wr-desc');
        if (l) l.textContent = d.label;
        if (d2) d2.textContent = d.desc;
      })();
      </script>

      <%= f.submit "Criar minha conta",
            style: "width:100%; background:var(--brand-deep); color:var(--surface); font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; font-weight:700; padding:12px; border:none; border-radius:12px; cursor:pointer; display:block;" %>
    <% end %>

  </div>
</div>
