<% content_for :head do %>
  <title>Convidar usuário · Practice-BR</title>
  <style>
    .auth-input:focus { border-color:var(--brand-bright) !important; box-shadow:0 0 0 3px var(--brand-glow) !important; outline:none !important; }
  </style>
<% end %>

<div style="max-width:520px; margin:2rem auto; padding:0 1.5rem 2rem;">
  <div style="background:var(--surface); border:1px solid var(--line); border-radius:20px; padding:36px; box-shadow:0 4px 32px rgba(0,0,0,0.07);">

    <h1 style="font-family:'Raleway',sans-serif; font-size:1.25rem; font-weight:700; color:var(--ink); margin-bottom:6px;">
      <%= current_user.admin? ? "Convidar novo usuário" : "Convidar Estudante" %>
    </h1>
    <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; color:var(--ink-soft); margin-bottom:28px;">
      O usuário receberá um email para criar sua conta.
    </p>

    <%= form_for(resource, as: resource_name, url: invitation_path(resource_name), html: { method: :post }) do |f| %>

      <% if resource.errors.any? %>
        <div style="background:var(--error-tint); border:1.5px solid var(--error-border); border-radius:10px; padding:14px 16px; margin-bottom:20px;">
          <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:600; color:var(--error-deep); margin-bottom:6px;">
            Corrija os erros abaixo:
          </div>
          <ul style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; color:var(--error); margin:0; padding-left:18px;">
            <% resource.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <% resource.class.invite_key_fields.each do |field| %>
        <div style="margin-bottom:18px;">
          <%= f.label field, "Email do usuário",
                style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:600; color:var(--ink); display:block; margin-bottom:6px;" %>
          <%= f.email_field field,
                placeholder: "exemplo@email.com",
                required: true,
                class: "auth-input",
                style: "width:100%; padding:11px 14px; border:1.5px solid var(--line); border-radius:10px; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; color:var(--ink); background:var(--surface); box-sizing:border-box;" %>
        </div>
      <% end %>

      <% if current_user.admin? %>
        <div style="margin-bottom:18px;">
          <%= f.label :role, "Tipo de usuário",
                style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:600; color:var(--ink); display:block; margin-bottom:6px;" %>
          <%= f.select :role,
                [['Estudante', 'trial'], ['Professor(a)', 'teacher']],
                { include_blank: 'Selecione o tipo...' },
                id: "invite-role-select",
                style: "width:100%; padding:11px 14px; border:1.5px solid var(--line); border-radius:10px; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; color:var(--ink); background:var(--surface); box-sizing:border-box; cursor:pointer;",
                class: "auth-input",
                required: true %>
        </div>
      <% else %>
        <%= f.hidden_field :role, value: "trial" %>
      <% end %>

      <%# ── Perfil Profissional — só para alunos ── %>
      <div id="professional-type-field" style="margin-bottom:18px;">
        <%= f.label :professional_type, "Perfil profissional",
              style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:600; color:var(--ink); display:block; margin-bottom:6px;" %>
        <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; color:var(--ink-faint); margin:0 0 8px;">
          Opcional. Para alunos em percurso de formação profissional.
        </p>
        <%= f.select :professional_type,
              [['OPCO', 'OPCO'], ['eCPF', 'eCPF']],
              { include_blank: 'Nenhum (acesso padrão)' },
              style: "width:100%; padding:11px 14px; border:1.5px solid var(--line); border-radius:10px; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; color:var(--ink); background:var(--surface); box-sizing:border-box; cursor:pointer;",
              class: "auth-input" %>
      </div>

      <%# ── Nível CEFR — sempre visível para professora, condicional para admin ── %>
      <div id="level-field" style="display:<%= current_user.admin? ? 'none' : 'block' %>; margin-bottom:28px;">
        <%= f.label :level, "Nível do aluno",
              style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:600; color:var(--ink); display:block; margin-bottom:8px;" %>
        <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; color:var(--ink-faint); margin:0 0 10px;">
          Define quais atividades o aluno pode acessar. C1 = acesso total.
        </p>
        <div style="display:flex; gap:8px; flex-wrap:wrap;">
          <% User::CEFR_LEVELS.each do |lvl| %>
            <% lc = cefr_colors(lvl) %>
            <label style="cursor:pointer;">
              <%= f.radio_button :level, lvl, style: "display:none;",
                    id: "level_#{lvl}",
                    onchange: "updateLevelButtons()" %>
              <span id="level-btn-<%= lvl %>"
                    onclick="document.getElementById('level_<%= lvl %>').checked = true; updateLevelButtons();"
                    style="display:inline-block; font-family:'DM Mono',monospace; font-size:0.78rem; font-weight:700;
                           padding:7px 16px; border-radius:20px; cursor:pointer; user-select:none;
                           border:1.5px solid var(--line); background:var(--surface); color:var(--ink-faint);
                           transition:all 0.1s;">
                <%= lvl %>
              </span>
            </label>
          <% end %>
        </div>
      </div>

      <%= f.submit "Enviar Convite",
            style: "width:100%; background:var(--action); color:var(--surface); font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; font-weight:700; padding:12px; border:none; border-radius:12px; cursor:pointer; margin-bottom:16px; display:block;" %>

    <% end %>

    <div style="text-align:center;">
      <%= link_to "← Voltar", (current_user.admin? ? admin_root_path : teacher_dashboard_path),
            style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; color:var(--ink-faint); text-decoration:none;" %>
    </div>

  </div>
</div>

<script>
  var cefrColors = {
    A1: { bg: 'var(--info-tint)', text: 'var(--info)', border: 'var(--info-border)' },
    A2: { bg: 'var(--success-tint)', text: 'var(--success)', border: 'var(--success-border)' },
    B1: { bg: 'var(--warning-tint)', text: 'var(--warning)', border: 'var(--warning-border)' },
    B2: { bg: 'var(--violet-tint)', text: 'var(--violet)', border: 'var(--violet-border)' },
    C1: { bg: 'var(--error-tint)', text: 'var(--error)', border: 'var(--error-border)' }
  };

  function toggleLevelField() {
    var select   = document.getElementById('invite-role-select');
    var level    = document.getElementById('level-field');
    var profType = document.getElementById('professional-type-field');
    if (!select) return;
    var isStudent = select.value === 'trial';
    if (level)    level.style.display    = isStudent ? 'block' : 'none';
    if (profType) profType.style.display = isStudent ? 'block' : 'none';
  }

  function updateLevelButtons() {
    var radios = document.querySelectorAll('input[name="user[level]"]');
    radios.forEach(function(radio) {
      var btn = document.getElementById('level-btn-' + radio.value);
      if (!btn) return;
      if (radio.checked) {
        var c = cefrColors[radio.value] || {};
        btn.style.background  = c.bg    || 'var(--brand-tint)';
        btn.style.color       = c.text  || 'var(--brand-deep)';
        btn.style.borderColor = c.border || 'var(--brand)';
      } else {
        btn.style.background  = 'var(--surface)';
        btn.style.color       = 'var(--ink-faint)';
        btn.style.borderColor = 'var(--line)';
      }
    });
  }

  // Dispara tanto no carregamento inicial (Turbo ou não) quanto na mudança
  document.addEventListener('DOMContentLoaded', function() {
    toggleLevelField();
    var select = document.getElementById('invite-role-select');
    if (select) select.addEventListener('change', toggleLevelField);
  });
  document.addEventListener('turbo:load', function() {
    toggleLevelField();
    var select = document.getElementById('invite-role-select');
    if (select) select.addEventListener('change', toggleLevelField);
  });
</script>
