<% content_for :head do %>
  <title>Convidar usuário · Practice-BR</title>
  <style>
    .auth-input:focus { border-color:#2A9B6F !important; box-shadow:0 0 0 3px rgba(42,155,111,0.12) !important; outline:none !important; }
  </style>
<% end %>

<div style="max-width:520px; margin:2rem auto; padding:0 1.5rem 2rem;">
  <div style="background:#fff; border:1px solid #DDD9D2; border-radius:20px; padding:36px; box-shadow:0 4px 32px rgba(0,0,0,0.07);">

    <h1 style="font-family:'Raleway',sans-serif; font-size:1.25rem; font-weight:700; color:#1C1917; margin-bottom:6px;">
      <%= current_user.admin? ? "Convidar novo usuário" : "Convidar aluno" %>
    </h1>
    <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; color:#5C5853; margin-bottom:28px;">
      O usuário receberá um email para criar sua conta.
    </p>

    <%= form_for(resource, as: resource_name, url: invitation_path(resource_name), html: { method: :post }) do |f| %>

      <% if resource.errors.any? %>
        <div style="background:#FEF2F2; border:1.5px solid #FCA5A5; border-radius:10px; padding:14px 16px; margin-bottom:20px;">
          <div style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:600; color:#991B1B; margin-bottom:6px;">
            Corrija os erros abaixo:
          </div>
          <ul style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; color:#B91C1C; margin:0; padding-left:18px;">
            <% resource.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <% resource.class.invite_key_fields.each do |field| %>
        <div style="margin-bottom:18px;">
          <%= f.label field, "Email do usuário",
                style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:600; color:#1C1917; display:block; margin-bottom:6px;" %>
          <%= f.email_field field,
                placeholder: "exemplo@email.com",
                required: true,
                class: "auth-input",
                style: "width:100%; padding:11px 14px; border:1.5px solid #DDD9D2; border-radius:10px; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; color:#1C1917; background:#fff; box-sizing:border-box;" %>
        </div>
      <% end %>

      <% if current_user.admin? %>
        <div style="margin-bottom:18px;">
          <%= f.label :role, "Tipo de usuário",
                style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:600; color:#1C1917; display:block; margin-bottom:6px;" %>
          <%= f.select :role,
                [['Estudante', 'student'], ['Professor(a)', 'teacher']],
                { include_blank: 'Selecione o tipo...' },
                id: "invite-role-select",
                style: "width:100%; padding:11px 14px; border:1.5px solid #DDD9D2; border-radius:10px; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; color:#1C1917; background:#fff; box-sizing:border-box; cursor:pointer;",
                class: "auth-input",
                required: true %>
        </div>
      <% else %>
        <%= f.hidden_field :role, value: "student" %>
      <% end %>

      <%# ── Nível CEFR — sempre visível para professora, condicional para admin ── %>
      <div id="level-field" style="display:<%= current_user.admin? ? 'none' : 'block' %>; margin-bottom:28px;">
        <%= f.label :level, "Nível do aluno",
              style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:600; color:#1C1917; display:block; margin-bottom:8px;" %>
        <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.78rem; color:#9C9892; margin:0 0 10px;">
          Define quais atividades o aluno pode acessar. C1 = acesso total.
        </p>
        <div style="display:flex; gap:8px; flex-wrap:wrap;">
          <% User::CEFR_LEVELS.each do |lvl| %>
            <% lc = cefr_colors(lvl) %>
            <label style="cursor:pointer;">
              <%= f.radio_button :level, lvl, style: "display:none;",
                    id: "level_#{lvl}",
                    onchange: "updateLevelButtons()" %>
              <span id="level-btn-<%= lvl %>"
                    onclick="document.getElementById('level_<%= lvl %>').checked = true; updateLevelButtons();"
                    style="display:inline-block; font-family:'DM Mono',monospace; font-size:0.78rem; font-weight:700;
                           padding:7px 16px; border-radius:20px; cursor:pointer; user-select:none;
                           border:1.5px solid #DDD9D2; background:#fff; color:#9C9892;
                           transition:all 0.1s;">
                <%= lvl %>
              </span>
            </label>
          <% end %>
        </div>
      </div>

      <%= f.submit "Enviar Convite",
            style: "width:100%; background:#C9952A; color:#fff; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; font-weight:700; padding:12px; border:none; border-radius:12px; cursor:pointer; margin-bottom:16px; display:block;" %>

    <% end %>

    <div style="text-align:center;">
      <%= link_to "← Voltar", (current_user.admin? ? admin_root_path : teacher_dashboard_path),
            style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; color:#9C9892; text-decoration:none;" %>
    </div>

  </div>
</div>

<script>
  var cefrColors = {
    A1: { bg: '#EFF6FF', text: '#1D4ED8', border: '#BFDBFE' },
    A2: { bg: '#F0FDF4', text: '#15803D', border: '#86EFAC' },
    B1: { bg: '#FFF7ED', text: '#C2410C', border: '#FDBA74' },
    B2: { bg: '#FDF4FF', text: '#7E22CE', border: '#E9D5FF' },
    C1: { bg: '#FFF1F2', text: '#BE123C', border: '#FECDD3' }
  };

  function toggleLevelField() {
    var select = document.getElementById('invite-role-select');
    var field  = document.getElementById('level-field');
    if (!select || !field) return;
    field.style.display = select.value === 'student' ? 'block' : 'none';
  }

  function updateLevelButtons() {
    var radios = document.querySelectorAll('input[name="user[level]"]');
    radios.forEach(function(radio) {
      var btn = document.getElementById('level-btn-' + radio.value);
      if (!btn) return;
      if (radio.checked) {
        var c = cefrColors[radio.value] || {};
        btn.style.background  = c.bg    || '#E8F5EE';
        btn.style.color       = c.text  || '#0F3826';
        btn.style.borderColor = c.border || '#1A6B4A';
      } else {
        btn.style.background  = '#fff';
        btn.style.color       = '#9C9892';
        btn.style.borderColor = '#DDD9D2';
      }
    });
  }

  // Dispara tanto no carregamento inicial (Turbo ou não) quanto na mudança
  document.addEventListener('DOMContentLoaded', function() {
    toggleLevelField();
    var select = document.getElementById('invite-role-select');
    if (select) select.addEventListener('change', toggleLevelField);
  });
  document.addEventListener('turbo:load', function() {
    toggleLevelField();
    var select = document.getElementById('invite-role-select');
    if (select) select.addEventListener('change', toggleLevelField);
  });
</script>
