<% content_for :head do %>
  <title>Nova senha · Practice-BR</title>
  <style>
    .auth-input:focus { border-color:var(--brand-bright) !important; box-shadow:0 0 0 3px var(--brand-glow) !important; outline:none !important; }
  </style>
<% end %>

<div style="min-height:100vh; display:flex; align-items:center; justify-content:center; padding:24px 16px;">
  <div style="background:var(--surface); border:1px solid var(--line); border-radius:20px; padding:40px 36px; width:100%; max-width:400px; box-shadow:0 4px 32px rgba(0,0,0,0.07);">

    <div style="text-align:center; margin-bottom:28px;">
      <div style="width:48px; height:48px; background:var(--brand-tint); border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 14px; font-size:1.4rem;">🔒</div>
      <h1 style="font-family:'Raleway',sans-serif; font-size:1.2rem; font-weight:700; color:var(--ink); margin-bottom:6px;">
        Criar nova senha
      </h1>
      <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; color:var(--ink-soft); margin:0;">
        Escolha uma senha segura para sua conta.
      </p>
    </div>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
      <%= f.hidden_field :reset_password_token %>

      <div style="margin-bottom:16px;">
        <%= f.label :password, "Nova senha",
              style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:600; color:var(--ink); display:block; margin-bottom:6px;" %>
        <%= f.password_field :password, autofocus: true, autocomplete: "new-password",
              placeholder: "Mínimo 6 caracteres",
              class: "auth-input",
              style: "width:100%; padding:11px 14px; border:1.5px solid var(--line); border-radius:10px; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; color:var(--ink); background:var(--surface); box-sizing:border-box;" %>
        <% if @minimum_password_length %>
          <div style="font-family:'DM Mono',monospace; font-size:0.68rem; color:var(--ink-faint); margin-top:4px;">
            mínimo <%= @minimum_password_length %> caracteres
          </div>
        <% end %>
      </div>

      <div style="margin-bottom:28px;">
        <%= f.label :password_confirmation, "Confirmar nova senha",
              style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; font-weight:600; color:var(--ink); display:block; margin-bottom:6px;" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password",
              placeholder: "Repita a senha",
              class: "auth-input",
              style: "width:100%; padding:11px 14px; border:1.5px solid var(--line); border-radius:10px; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; color:var(--ink); background:var(--surface); box-sizing:border-box;" %>
      </div>

      <%= f.submit "Salvar nova senha",
            style: "width:100%; background:var(--action); color:var(--surface); font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; font-weight:700; padding:12px; border:none; border-radius:12px; cursor:pointer; display:block;" %>
    <% end %>

  </div>
</div>
