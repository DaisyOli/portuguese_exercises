<!DOCTYPE html>
<html>
<head>
  <meta content="text/html; charset=UTF-8" http-equiv="Content-Type" />
</head>
<body style="margin:0; padding:0; background:#F7F5F0; font-family:'Helvetica Neue',Arial,sans-serif;">

  <table width="100%" cellpadding="0" cellspacing="0" style="background:#F7F5F0; padding:40px 16px;">
    <tr>
      <td align="center">
        <table width="560" cellpadding="0" cellspacing="0" style="background:#fff; border-radius:16px; border:1px solid #DDD9D2; overflow:hidden;">

          <%# ── Cabeçalho ── %>
          <tr>
            <td style="background:#0F3826; padding:28px 36px;">
              <div style="font-family:'Helvetica Neue',Arial,sans-serif; font-size:1.3rem; font-weight:800; color:#fff; letter-spacing:-0.02em;">
                Practice-BR
              </div>
              <div style="font-family:'Helvetica Neue',Arial,sans-serif; font-size:0.8rem; color:#6EBD96; margin-top:4px;">
                Plataforma de Português para Estrangeiros
              </div>
            </td>
          </tr>

          <%# ── Corpo ── %>
          <tr>
            <td style="padding:36px 36px 28px;">
              <div style="font-size:2rem; margin-bottom:16px;">🎉</div>
              <h1 style="font-family:'Helvetica Neue',Arial,sans-serif; font-size:1.2rem; font-weight:700; color:#1C1917; margin:0 0 12px;">
                Você foi convidado!
              </h1>
              <p style="font-family:'Helvetica Neue',Arial,sans-serif; font-size:0.9rem; color:#5C5853; line-height:1.6; margin:0 0 24px;">
                <%= t("devise.mailer.invitation_instructions.someone_invited_you") %>
              </p>

              <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom:28px;">
                <tr>
                  <td align="center">
                    <a href="<%= accept_invitation_url(@resource, invitation_token: @token) %>"
                       style="display:inline-block; background:#1A6B4A; color:#fff;
                              font-family:'Helvetica Neue',Arial,sans-serif; font-size:0.92rem; font-weight:700;
                              padding:14px 36px; border-radius:10px; text-decoration:none;">
                      <%= t("devise.mailer.invitation_instructions.accept") %> →
                    </a>
                  </td>
                </tr>
              </table>

              <% if @resource.invitation_due_at %>
                <p style="font-family:'Helvetica Neue',Arial,sans-serif; font-size:0.8rem; color:#9C9892; margin:0 0 16px;">
                  <%= t("devise.mailer.invitation_instructions.accept_until", due_date: l(@resource.invitation_due_at, format: :long)) %>
                </p>
              <% end %>

              <p style="font-family:'Helvetica Neue',Arial,sans-serif; font-size:0.8rem; color:#9C9892; line-height:1.55; margin:0;">
                <%= t("devise.mailer.invitation_instructions.ignore") %>
              </p>
            </td>
          </tr>

          <%# ── Rodapé ── %>
          <tr>
            <td style="background:#F7F5F0; border-top:1px solid #EAE7E2; padding:18px 36px; text-align:center;">
              <p style="font-family:'Helvetica Neue',Arial,sans-serif; font-size:0.75rem; color:#9C9892; margin:0;">
                © Practice-BR · Este é um email automático, por favor não responda.
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>

</body>
</html>
