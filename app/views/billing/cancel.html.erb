<% content_for :head do %>
  <title>Pagamento cancelado · Practice-BR</title>
<% end %>

<div style="min-height:100vh; display:flex; align-items:center; justify-content:center; background:var(--paper); padding:2rem 1rem;">
  <div style="max-width:420px; width:100%; text-align:center;">

    <div style="font-size:4rem; margin-bottom:1rem;">😕</div>

    <h1 style="font-family:'Raleway',sans-serif; font-size:1.6rem; font-weight:800; color:var(--ink); margin-bottom:12px;">
      Pagamento cancelado
    </h1>

    <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.95rem; color:var(--ink-soft); line-height:1.6; margin-bottom:2rem;">
      Nenhuma cobrança foi feita. Você pode tentar novamente quando quiser.
    </p>

    <%= link_to billing_new_path,
          style: "display:inline-block; background:var(--brand); color:var(--surface); font-family:'Plus Jakarta Sans',sans-serif; font-size:0.95rem; font-weight:700; padding:14px 36px; border-radius:12px; text-decoration:none; margin-bottom:12px;" do %>
      Tentar novamente
    <% end %>

    <br>

    <%= link_to "← Sair", destroy_user_session_path, data: { turbo: false },
          style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.82rem; color:var(--ink-faint); text-decoration:none;" %>

  </div>
</div>
