<% content_for :head do %>
  <title>Practice-BR</title>
<% end %>

<div style="min-height:100vh; display:flex; align-items:center; justify-content:center; padding:24px 16px;">
  <div style="background:var(--surface); border:1px solid var(--line); border-radius:20px; padding:40px 36px; width:100%; max-width:400px; box-shadow:0 4px 32px rgba(0,0,0,0.07); text-align:center;">

    <%# Logo %>
    <div style="display:inline-flex; align-items:center; gap:10px; margin-bottom:28px;">
      <%= image_tag "practice-br-logo-mark-color.svg", alt:"Practice-BR", style:"height:38px;" %>
      <div style="text-align:left;">
        <div style="font-family:'Raleway',sans-serif; font-size:1.2rem; font-weight:800; color:var(--brand-deep); line-height:1.1;">Practice-BR</div>
        <div style="font-family:'DM Mono',monospace; font-size:0.58rem; color:var(--ink-faint); letter-spacing:0.06em;">PORTUGUÊS PARA ESTRANGEIROS</div>
      </div>
    </div>

    <% if user_signed_in? %>
      <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.88rem; color:var(--ink-soft); margin:0 0 6px 0;">
        <%= t('home.logged_in_as') %>
      </p>
      <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.95rem; font-weight:700; color:var(--ink); margin:0 0 28px 0;">
        <%= current_user.email %>
      </p>

      <% if current_user.teacher? %>
        <%= link_to t('home.go_to_teacher_dashboard'), teacher_dashboard_path,
              style: "display:block; width:100%; background:var(--brand); color:var(--surface); font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; font-weight:700; padding:12px; border:none; border-radius:12px; cursor:pointer; text-decoration:none; margin-bottom:12px; box-sizing:border-box;" %>
      <% elsif current_user.student? %>
        <%= link_to t('home.go_to_student_dashboard'), student_dashboard_path,
              style: "display:block; width:100%; background:var(--brand); color:var(--surface); font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; font-weight:700; padding:12px; border:none; border-radius:12px; cursor:pointer; text-decoration:none; margin-bottom:12px; box-sizing:border-box;" %>
      <% end %>

      <%= link_to t('auth.sign_out'), destroy_user_session_path,
            data: { turbo: false },
            style: "display:block; width:100%; background:var(--error-tint); color:var(--error); font-family:'Plus Jakarta Sans',sans-serif; font-size:0.88rem; font-weight:600; padding:10px; border:1.5px solid var(--error-border); border-radius:12px; cursor:pointer; box-sizing:border-box; text-align:center; text-decoration:none;" %>

    <% else %>
      <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.88rem; color:var(--ink-soft); margin:0 0 28px 0;">
        <%= t('home.login_prompt') %>
      </p>
      <%= link_to t('devise.sessions.sign_in'), new_user_session_path,
            style: "display:block; width:100%; background:var(--action); color:var(--surface); font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; font-weight:700; padding:12px; border:none; border-radius:12px; cursor:pointer; text-decoration:none; margin-bottom:12px; box-sizing:border-box;" %>
    <% end %>

  </div>
</div>
