<nav id="main-navbar"
     data-turbo-permanent
     class="navbar px-4"
     style="position:fixed; top:0; left:0; right:0; z-index:100; background:var(--brand-deep); min-height:56px;">

  <%# Logo — leva ao dashboard correspondente %>
  <div class="navbar-start">
    <%= link_to (current_user.teacher? ? teacher_dashboard_path : student_dashboard_path) do %>
      <%= image_tag "practice-br-logo-horizontal-mono-light.svg",
            alt: "Practice-BR",
            class: "hidden sm:block",
            style: "height:28px;" %>
      <%= image_tag "practice-br-logo-mark-mono-light.svg",
            alt: "Practice-BR",
            class: "block sm:hidden",
            style: "height:28px;" %>
    <% end %>
  </div>

  <%# Ações — lado direito %>
  <div class="navbar-end gap-2 sm:gap-4">

    <%# Botões da professora — visíveis só em desktop %>
    <% if current_user.teacher? %>
      <%= link_to "+ Nova Atividade", new_activity_path,
            id: "tour-nova-atividade",
            class: "hidden sm:inline-flex items-center whitespace-nowrap px-4 py-1.5 rounded-lg text-sm font-semibold text-white no-underline",
            style: "background:var(--brand-bright); font-family:'Plus Jakarta Sans',sans-serif; text-decoration:none;" %>

      <%= link_to new_user_invitation_path,
            id: "tour-convidar",
            class: "hidden sm:inline-flex items-center whitespace-nowrap px-4 py-1.5 rounded-lg text-sm font-semibold text-white no-underline",
            style: "background:var(--action); font-family:'Plus Jakarta Sans',sans-serif; text-decoration:none; gap:6px;" do %>
        ✉️ Convidar
      <% end %>
    <% end %>

    <%# Streak pill — sempre visível para alunos, só se > 0 para professoras %>
    <% streak = session[:current_streak].to_i %>
    <% if current_user.student? || streak > 0 %>
      <div class="hidden sm:flex items-center gap-1 px-3 py-1 rounded-full"
           style="background:rgba(255,255,255,0.12); border:1px solid rgba(255,255,255,0.2); font-family:'DM Mono',monospace; font-size:0.8rem; color:var(--action-bright);">
        🔥 <%= streak %>
      </div>
    <% end %>

    <%# Avatar + dropdown %>
    <div class="dropdown dropdown-end" id="tour-avatar">
      <label tabindex="0" class="btn btn-ghost btn-circle" style="width:36px; height:36px; min-height:0; padding:0;">
        <div class="rounded-full flex items-center justify-center text-sm font-bold"
             style="width:32px; height:32px;
                    background: linear-gradient(135deg, <%= current_user.teacher? ? 'var(--action), var(--action-bright)' : 'var(--info), var(--info-deep)' %>);
                    color:var(--surface); font-family:'Plus Jakarta Sans',sans-serif;">
          <%= current_user.display_name.first.upcase %>
        </div>
      </label>

      <ul tabindex="0"
          class="dropdown-content menu menu-sm shadow-lg z-50 mt-2 p-2 rounded-xl"
          style="background:var(--surface); border:1px solid var(--line); min-width:210px;">

        <%# Cabeçalho do dropdown %>
        <li class="px-3 pt-1 pb-0 pointer-events-none">
          <span style="font-family:'DM Mono',monospace; font-size:0.68rem; color:var(--ink-faint); letter-spacing:0.08em;">
            <%= current_user.admin? ? 'ADMIN' : (current_user.teacher? ? 'PROFESSORA' : 'ALUNO') %>
          </span>
        </li>
        <li class="px-3 pb-2 pointer-events-none">
          <span style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.875rem; font-weight:600; color:var(--ink);">
            <%= current_user.display_name %>
          </span>
        </li>
        <div style="height:1px; background:var(--line); margin:2px 8px 6px;"></div>

        <%# Links da professora — só aparecem no mobile %>
        <% if current_user.teacher? %>
          <li class="sm:hidden">
            <%= link_to new_activity_path,
                  style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.875rem; font-weight:600; color:var(--brand);" do %>
              + Nova Atividade
            <% end %>
          </li>
          <li class="sm:hidden">
            <%= link_to new_user_invitation_path,
                  style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.875rem; font-weight:600; color:var(--action);" do %>
              ✉️ Convidar aluno
            <% end %>
          </li>
          <div class="sm:hidden" style="height:1px; background:var(--line); margin:6px 8px;"></div>
        <% end %>

        <%# Link para painel admin — só para admins %>
        <% if current_user.admin? %>
          <div style="height:1px; background:var(--line); margin:6px 8px;"></div>
          <li>
            <%= link_to admin_root_path,
                  style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.875rem; font-weight:600; color:var(--brand-deep);" do %>
              ⚙️ Painel Admin
            <% end %>
          </li>
        <% end %>

        <%# Sair %>
        <li>
          <%= link_to t('auth.sign_out'), destroy_user_session_path,
                data: { turbo: false },
                style: "font-family:'Plus Jakarta Sans',sans-serif; font-size:0.875rem; color:var(--error); background:none; border:none; padding:0; cursor:pointer; text-decoration:none;" %>
        </li>
      </ul>
    </div>
  </div>
</nav>
