#!/bin/bash
set -e

MAX_RETRIES=5
RETRY_DELAY=8

for i in $(seq 1 $MAX_RETRIES); do
  echo "db:migrate attempt $i/$MAX_RETRIES..."
  bundle exec rails db:migrate && echo "Migration succeeded." && exit 0
  echo "Attempt $i failed. Retrying in ${RETRY_DELAY}s..."
  sleep $RETRY_DELAY
done

echo "ERROR: db:migrate failed after $MAX_RETRIES attempts."
exit 1
